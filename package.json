{
  "name": "dockercart-theme-tailwind",
  "version": "1.0.6",
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/typography": "^0.5.9",
    "autoprefixer": "^10.4.14",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "postcss": "^8.4.27",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^3.4.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./tools/tailwind/tailwind-input.css -o ./upload/catalog/view/theme/dockercart/stylesheet/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./tools/tailwind/tailwind-input.css -o ./upload/catalog/view/theme/dockercart/stylesheet/tailwind.css --watch",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose"
  },
  "dependencies": {
    "lucide": "^0.577.0"
  }
}
