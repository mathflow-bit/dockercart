check-multicurrency.sh

# SSL / certificate artifacts (self-signed and Let's Encrypt)
# Ignore generated self-signed certificates and private keys
/docker/ssl/
/docker/ssl/**
# Ignore Let's Encrypt/ACME storage
/docker/acme/
/docker/acme/**
# Ensure acme.json (contains private keys) is not committed
/docker/acme/acme.json

# Ignore Let's Encrypt runtime data (contains private keys and account data)
/docker/letsencrypt/accounts/
/docker/letsencrypt/archive/
/docker/letsencrypt/live/*
/docker/letsencrypt/renewal/
/docker/letsencrypt/renewal-hooks/
/docker/letsencrypt/www/
/docker/letsencrypt/*.log
/docker/letsencrypt/*.lock


/__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore custom local Dockercart prefixed artifacts
**/dockercart_custom_*

*.lock
backups/
sitemap.xml