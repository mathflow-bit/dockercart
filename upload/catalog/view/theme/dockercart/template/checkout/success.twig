{{ header }}
<main id="checkout-success" class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      {{ content_top }}

      <div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm text-center">
        <div class="w-16 h-16 rounded-2xl bg-blue-50 text-blue-600 border border-blue-100 flex items-center justify-center mx-auto mb-4">
          <i data-lucide="badge-check" class="w-8 h-8"></i>
        </div>

        <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-4">{{ heading_title }}</h2>

        <div class="text-sm sm:text-base text-gray-600 leading-7">
          {{ text_message }}
        </div>

        <div class="mt-8">
          <a href="{{ continue }}" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-7 py-3 rounded-xl transition-colors">
            {{ button_continue }}
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
