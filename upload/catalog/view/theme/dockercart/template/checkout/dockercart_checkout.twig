  <!-- Expandable Order Details -->
  <div id="mobile-order-details" class="mb-3">
    <div class="space-y-2 mb-4 pb-4 border-b border-gray-200">
      {% if products %}
        {% for product in products %}
        <div class="flex justify-between text-sm">
          <span class="text-text-secondary">{{ product.quantity }}x {{ product.name }}</span>
          <span class="text-text-primary font-medium">{{ product.total }}</span>
        </div>
        {% endfor %}
      {% endif %}
