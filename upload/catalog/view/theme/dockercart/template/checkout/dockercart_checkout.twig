    <div class="space-y-2">
      {% if totals %}
        {% for total in totals %}
        <div class="flex justify-between text-sm {% if total.title == 'Total' %}font-semibold text-base pt-2 border-t border-gray-200{% endif %}">
          <span class="{% if total.title == 'Total' %}text-text-primary{% else %}text-text-secondary{% endif %}">{{ total.title }}</span>
          <span class="{% if total.title == 'Total' %}text-primary text-lg{% else %}text-text-primary{% endif %}">{{ total.text }}</span>
