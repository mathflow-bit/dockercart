<script>
const CONFIG = {
  urls: {
    cart: '{{ ajax_cart }}',
    customer: '{{ ajax_customer }}',
    shipping_address: '{{ ajax_shipping_address }}',
    payment_address: '{{ ajax_payment_address }}',
    shipping_method: '{{ ajax_shipping_method }}',
    payment_method: '{{ ajax_payment_method }}',
    payment_extension: '{{ ajax_payment_extension }}',
    coupon: '{{ ajax_coupon }}',
    voucher: '{{ ajax_voucher }}',
    reward: '{{ ajax_reward }}',
    country: '{{ ajax_country }}',
    confirm: '{{ ajax_confirm }}'
  },
  shippingRequired: {{ shipping_required ? 'true' : 'false' }},
  debug: {{ debug ? 'true' : 'false' }}
};

// Saved addresses (for logged-in customers)
const SAVED_ADDRESSES = {{ addresses ? addresses|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw : '{}' }};
const DEFAULT_ADDRESS_ID = {{ default_address_id|default(0) }};
const SELECTED_SHIPPING_ADDRESS_ID = {{ shipping_address_id|default(0) }};
const TEXT_SELECT_PLACEHOLDER = '{{ text_select|e('js') }}';
const TEXT_NEW_ADDRESS = '{{ text_new_address|e('js') }}';
const TEXT_SAVED_ADDRESSES = '{{ text_saved_addresses|e('js') }}';
const TEXT_DEFAULT_ADDRESS = '{{ text_default_address|e('js') }}';

// Export localized strings for use in inline JS
window.dcLang = window.dcLang || {};
Object.assign(window.dcLang, {
  success_word: '{{ text_success|default('Success')|e('js') }}',
  please_fix_following: '{{ text_please_fix_following|default('Please fix the following')|e('js') }}',
  complete_address_first: '{{ text_complete_address_first|default('Please complete your address first')|e('js') }}',
  error_updating_address: '{{ error_updating_address|default('Error updating address. Please try again.')|e('js') }}',
  error_loading_regions: '{{ error_loading_regions|default('Error loading regions. Please try again.')|e('js') }}',
  no_shipping_methods_for_address: '{{ text_no_shipping_for_address|default('No shipping methods available for this address. Please check your shipping settings or contact support.')|e('js') }}',
  fill_and_save_shipping_to_enable_payment: '{{ text_fill_and_save_shipping_to_enable_payment|default('Please fill in and save your shipping address to enable payment methods.')|e('js') }}',
  text_loading: '{{ text_loading|e('js') }}',
  enter_coupon_code: '{{ text_enter_coupon_code|default('Please enter a coupon code')|e('js') }}',
  error_select_shipping_method: '{{ error_shipping_method|e('js') }}',
  error_select_payment_method: '{{ error_payment_method|e('js') }}',
  please_fix_errors: '{{ text_please_fix_errors|default('Please fix the following errors:')|e('js') }}',
  order_unclear_response: '{{ text_order_unclear_response|default('Order placed but response unclear. Please check your account.')|e('js') }}'
});

// Initialize autosave control flag
window._allowShippingAutosave = true;

// Shipping method field visibility config (populated from server response)
window._shippingFields = null;

// Compatibility alias for legacy code
const ajaxUrls = CONFIG.urls;

const log = (msg, data = '') => {
  if (!CONFIG.debug) return;
  if (typeof console !== 'undefined') {
    console.log(`[DockerCart] ${msg}`, data);
  }
};

const $ = selector => document.querySelector(selector);
const $$ = selector => document.querySelectorAll(selector);

const DEFAULT_SHIPPING_COUNTRY_ID = '{{ country_id|default('')|e('js') }}';
const DEFAULT_SHIPPING_ZONE_ID = '{{ zone_id|default('')|e('js') }}';
const DEFAULT_PAYMENT_COUNTRY_ID = '{{ payment_country_id|default(country_id|default(''))|e('js') }}';
const DEFAULT_PAYMENT_ZONE_ID = '{{ payment_zone_id|default(zone_id|default(''))|e('js') }}';

const getFieldValue = (selector, fallback = '') => {
  const el = $(selector);

  if (!el) {
    return fallback || '';
  }

  const value = (el.value ?? '').toString();
  return value !== '' ? value : (fallback || '');
};

const getShippingCountryId = () => getFieldValue('#input-country', DEFAULT_SHIPPING_COUNTRY_ID);
const getShippingZoneId = () => getFieldValue('#input-zone', DEFAULT_SHIPPING_ZONE_ID);
const getPaymentCountryId = () => getFieldValue('#input-payment-country', DEFAULT_PAYMENT_COUNTRY_ID);
const getPaymentZoneId = () => getFieldValue('#input-payment-zone', DEFAULT_PAYMENT_ZONE_ID);

const throttle = (func, delay) => {
  let lastCall = 0;
  return (...args) => {
    const now = Date.now();
    if (now - lastCall >= delay) {
      lastCall = now;
      func(...args);
    }
  };
};

const ajax = (url, options = {}) => {
  const config = {
    method: 'GET',
    headers: { 'Content-Type': 'application/json' },
    ...options
  };

  if (config.data) {
    config.body = JSON.stringify(config.data);
    delete config.data;
  }

  if (!config.signal && options.abortController) {
    config.signal = options.abortController.signal;
  }

  return fetch(url, config)
    .then(response => {
      if (response.ok) {
        return response.json();
      }

      // Try to read response body for better error messages (could be JSON or plain text)
      return response.text().then(text => {
        let body = text;
        try {
          body = JSON.parse(text);
        } catch (e) {
          // not JSON
        }

        const err = new Error(`HTTP ${response.status}`);
        err.status = response.status;
        err.body = body;
        throw err;
      });
    })
    .catch(error => {
      if (error.name === 'AbortError') return Promise.reject({ aborted: true });
      throw error;
    });
};

const showNotification = (messages, type = 'error', autoHide = true) => {
  const msgs = Array.isArray(messages) ? messages : [String(messages)];
  const colorMap = { success: 'green', warn: 'orange', error: 'red' };
  const color = colorMap[type] || 'red';

  let box = $('#validation-errors');
  if (!box) {
    box = document.createElement('div');
    box.id = 'validation-errors';
    box.className = `fixed top-4 left-1/2 -translate-x-1/2 bg-${color}-50 border-2 border-${color}-500 text-${color}-800 px-6 py-4 rounded-xl shadow-lg z-50 max-w-md`;
    document.body.append(box);
  }

  const title = type === 'success' ? (window.dcLang?.success_word || 'Success') : (window.dcLang?.please_fix_following || 'Please fix the following');
  box.innerHTML = `
    <div class="flex items-start gap-3">
      <svg class="w-6 h-6 text-${color}-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div class="flex-1">
        <h3 class="font-semibold mb-2">${title}:</h3>
        <ul class="list-disc list-inside space-y-1 text-sm">
          ${msgs.map(m => `<li>${m}</li>`).join('')}
        </ul>
      </div>
      <button class="close-btn text-${color}-600 hover:text-${color}-800 ml-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  `;

  box.querySelector('.close-btn')?.addEventListener('click', () => box.remove(), { once: true });
  if (autoHide) setTimeout(() => box.remove(), 8000);
  window.scrollTo({ top: 0, behavior: 'smooth' });
};

const FIELD_MAP = {
  firstname: '#input-firstname',
  lastname: '#input-lastname',
  address_1: '#input-address-1',
  address_2: '#input-address-2',
  city: '#input-city',
  postcode: '#input-postcode',
  country: '#input-country',
  country_id: '#input-country',
  zone: '#input-zone',
  zone_id: '#input-zone',
  email: '#input-email',
  telephone: '#input-telephone',
  payment_address_1: '#input-payment-address-1',
  payment_address_2: '#input-payment-address-2',
  payment_city: '#input-payment-city',
  payment_postcode: '#input-payment-postcode',
  payment_country_id: '#input-payment-country',
  payment_zone_id: '#input-payment-zone'
};

const showFieldErrors = (errorObj) => {
  if (!errorObj) return;
  const messages = [];

  Object.entries(errorObj).forEach(([key, msg]) => {
    const selector = FIELD_MAP[key];
    let label = key;

    if (selector) {
      const el = $(selector);
      if (el) {
        el.classList.add('border-error');
        const labelEl = el.closest('div')?.querySelector('label');
        if (labelEl?.textContent) {
          label = labelEl.textContent.trim();
          label = label.replace(/\(Optional\)|\s*\(Optional\)/gi, '').trim();
        }
      }
    }
    messages.push(`${label}: ${msg}`);
  });

  showNotification(messages, 'error');
};

// Saved address helpers
const SHIPPING_FIELD_MAP_FULL = {
  firstname: '#input-firstname',
  lastname: '#input-lastname',
  company: '#input-company',
  address_1: '#input-address-1',
  address_2: '#input-address-2',
  city: '#input-city',
  postcode: '#input-postcode',
  country_id: '#input-country',
  zone_id: '#input-zone'
};

const ensureSavedAddressesState = (addresses) => {
  if (addresses && typeof addresses === 'object') {
    window._savedAddresses = addresses;
  }
};

const formatAddressForLabel = (addr) => {
  if (!addr || typeof addr !== 'object') return '';
  const parts = [];
  if (addr.firstname || addr.lastname) {
    parts.push([addr.firstname, addr.lastname].filter(Boolean).join(' ').trim());
  }
  ['address_1', 'address_2', 'city', 'zone', 'country'].forEach(key => {
    if (addr[key]) parts.push(addr[key]);
  });
  return parts.filter(Boolean).join(', ');
};

const refreshSavedAddressSelect = (selectEl, addresses, selectedId) => {
  if (!selectEl) return;
  const list = addresses && typeof addresses === 'object' ? Object.values(addresses) : [];
  if (!list.length) return;

  selectEl.innerHTML = '';

  list.forEach(addr => {
    const option = document.createElement('option');
    const addrId = addr.address_id || addr.addressId || addr.addressid;
    option.value = String(addrId);
    option.dataset.address = JSON.stringify(addr);
    let label = formatAddressForLabel(addr) || TEXT_SAVED_ADDRESSES;
    if (DEFAULT_ADDRESS_ID && Number(DEFAULT_ADDRESS_ID) === Number(addrId)) {
      label += ` (${TEXT_DEFAULT_ADDRESS})`;
    }
    option.textContent = label;
    selectEl.appendChild(option);
  });

  const newOpt = document.createElement('option');
  newOpt.value = 'new';
  newOpt.textContent = TEXT_NEW_ADDRESS;
  selectEl.appendChild(newOpt);

  const desired = selectedId || SELECTED_SHIPPING_ADDRESS_ID || DEFAULT_ADDRESS_ID;
  if (desired && selectEl.querySelector(`option[value="${desired}"]`)) {
    selectEl.value = String(desired);
  }
};

const applyAddressToShippingFields = (address) => {
  if (!address) return;
  Object.entries(SHIPPING_FIELD_MAP_FULL).forEach(([key, selector]) => {
    const el = $(selector);
    if (el && Object.prototype.hasOwnProperty.call(address, key)) {
      el.value = address[key] ?? '';
    }
  });
};

const loadZonesForAddress = (countryId, zoneId, zoneSelect, countrySelect) => {
  if (countrySelect) {
    countrySelect.value = countryId || '';
  }

  if (!zoneSelect) return Promise.resolve();

  if (!countryId) {
    zoneSelect.innerHTML = `<option value="">${TEXT_SELECT_PLACEHOLDER}</option>`;
    return Promise.resolve();
  }

  zoneSelect.innerHTML = '<option value="">Loading...</option>';
  return ajax(`${CONFIG.urls.country}&country_id=${countryId}`)
    .then(json => {
      let html = `<option value="">${TEXT_SELECT_PLACEHOLDER}</option>`;
      if (json.zone && Array.isArray(json.zone)) {
        json.zone.forEach(z => {
          html += `<option value="${z.zone_id}">${z.name}</option>`;
        });
      }
      zoneSelect.innerHTML = html;
      if (zoneId) {
        zoneSelect.value = String(zoneId);
      }
    })
    .catch(() => {
      zoneSelect.innerHTML = `<option value="">${TEXT_SELECT_PLACEHOLDER}</option>`;
    });
};

const setShippingFieldsEditable = (editable = true) => {
  const block = document.querySelector('[data-block-id="shipping_address"]');
  if (!block) return;
  const inputs = Array.from(block.querySelectorAll('input, select, textarea'));
  inputs.forEach(el => {
    if (el.matches('[data-prefilled-hidden]')) return;
    // Always keep the saved-address dropdown editable so user can switch addresses
    if (el.id === 'saved-shipping-address') {
      el.disabled = false;
      return;
    }

    if (el.tagName === 'SELECT') {
      el.disabled = !editable ? true : false;
    } else {
      el.readOnly = !editable ? true : false;
    }
  });
};

/**
 * Set up click handler for payment button in hidden extension container.
 * This handler parses inline scripts from legacy payment extensions and
 * executes their AJAX calls when the button is clicked or triggered programmatically.
 */
const setupPaymentButtonHandler = (container) => {
  try {
    // Replace global alert with friendly notification for legacy payment scripts
    if (!window._dc_alert_overridden) {
      window._dc_old_alert = window.alert;
      window.alert = function(msg) {
        try { showNotification(String(msg), 'error'); } catch (e) { console.error(e); }
      };
      window._dc_alert_overridden = true;
    }

    // Find and parse inline scripts in the payment extension HTML
    const scripts = Array.from(container.querySelectorAll('script'));
    const parsedCalls = [];

    scripts.forEach(s => {
      const code = s.innerText || s.textContent || s.innerHTML || '';
      // Remove script tag from DOM to avoid duplicate execution
      try { s.parentNode && s.parentNode.removeChild(s); } catch (e) {}
      if (!code.trim()) return;

      // Look for $.ajax({ url: '...', type: 'GET'|'POST', dataType: 'json' }) pattern
      const urlMatch = code.match(/url\s*:\s*['"]([^'"]+)['"]/i);
      const typeMatch = code.match(/type\s*:\s*['"]([^'"]+)['"]/i);
      const dataMatch = code.match(/data\s*:\s*(\{[\s\S]*?\})/i);

      if (urlMatch) {
        const url = urlMatch[1];
        const method = typeMatch ? typeMatch[1].toUpperCase() : (dataMatch ? 'POST' : 'GET');
        parsedCalls.push({ url, method, raw: code });
        log('Parsed payment extension AJAX call', { url, method });
      }
    });

    // Wire click handler to the payment button
    if (parsedCalls.length && parsedCalls[0]) {
      const call = parsedCalls[0];
      const btn = container.querySelector('#button-confirm');
      if (btn) {
        btn.addEventListener('click', function paymentHandler(e) {
          e.preventDefault();

          // Manage loading state
          const isInput = btn.tagName === 'INPUT' || btn.tagName === 'BUTTON';
          const origText = isInput ? (btn.value || btn.innerText) : btn.innerText;
          const loadingText = btn.getAttribute('data-loading-text');
          if (loadingText) {
            try { if (btn.tagName === 'INPUT') btn.value = loadingText; else btn.innerText = loadingText; } catch (e) {}
          }
          btn.disabled = true;

          // Perform the request using our ajax helper
          ajax(call.url, { method: call.method })
            .then(json => {
              try {
                if (json && json.redirect) {
                  window.location = json.redirect;
                  return;
                }
                if (json && json.success) {
                  if (json.redirect) window.location = json.redirect;
                }
              } catch (err) {
                console.error('Payment handler success error', err);
              }
            })
            .catch(err => {
              log('Payment handler error', err);
              let msg = 'Payment processing error';
              try {
                if (err && err.message) msg = err.message;
              } catch (e) {}
              showNotification(msg, 'error');
            })
            .finally(() => {
              // Reset button state
              btn.disabled = false;
              if (loadingText) {
                try { if (btn.tagName === 'INPUT') btn.value = origText; else btn.innerText = origText; } catch (e) {}
              }
            });
        });
        log('Payment button handler set up successfully');
      }
    }
  } catch (e) {
    console.error('Error setting up payment button handler', e);
  }
};

document.addEventListener('DOMContentLoaded', () => {
  log('Checkout initialized', ajaxUrls);

  // Saved addresses dropdown (logged-in users)
  window._savedAddresses = (SAVED_ADDRESSES && typeof SAVED_ADDRESSES === 'object') ? SAVED_ADDRESSES : {};
  const savedShippingSelect = $('#saved-shipping-address');
  if (savedShippingSelect) {
    refreshSavedAddressSelect(savedShippingSelect, window._savedAddresses, DEFAULT_ADDRESS_ID);
    savedShippingSelect.addEventListener('change', () => handleSavedShippingSelection(savedShippingSelect));
  }

  // Radio card selection - use event delegation on checkout form container instead of entire document
  // This prevents unnecessary event processing for all document clicks
  const checkoutForm = $('.max-w-7xl');
  if (checkoutForm) {
    checkoutForm.addEventListener('click', (e) => {
      const radioCard = e.target.closest('.radio-card');
      if (!radioCard) return;

      const radio = radioCard.querySelector('input[type="radio"]');
      if (!radio) return;

      const radioGroup = radio.name;
      Array.from(document.getElementsByName(radioGroup)).forEach(input => {
        input.closest('.radio-card')?.classList.remove('selected');
      });

      radioCard.classList.add('selected');

      const clickedInput = e.target.closest('input[type="radio"]');
      if (clickedInput) {
        return;
      }

      try {
        radio.click();
      } catch (err) {
        radio.checked = true;
        radio.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  }

  // Mobile summary toggle - expand/collapse order summary and hide when scrolled to bottom
  const toggleSummaryBtn = $('#toggle-summary');
  if (toggleSummaryBtn) {
    const summary = $('#mobile-summary');
    const orderSummaryContent = summary?.querySelector('#mobile-order-details');

    // Track if user manually expanded/collapsed to preserve state during scroll
    let userManuallyToggled = false;
    let isUserExpanded = false;

    // Initially collapsed - only show toggle button
    if (orderSummaryContent) {
      orderSummaryContent.style.maxHeight = '0';
      orderSummaryContent.style.overflow = 'hidden';
      orderSummaryContent.style.transition = 'max-height 0.3s ease';
    }

    toggleSummaryBtn.addEventListener('click', () => {
      const arrow = $('#summary-arrow');
      const text = $('#summary-text');

      if (orderSummaryContent) {
        const isExpanded = orderSummaryContent.style.maxHeight !== '0px';

        if (isExpanded) {
          // Collapse
          orderSummaryContent.style.maxHeight = '0';
          arrow.classList.remove('rotate-180');
          text.textContent = '{{ text_show_summary }}';
          isUserExpanded = false;
        } else {
          // Expand
          orderSummaryContent.style.maxHeight = orderSummaryContent.scrollHeight + 'px';
          arrow.classList.add('rotate-180');
          text.textContent = '{{ text_hide_summary }}';
          isUserExpanded = true;
        }
        // Mark that user manually toggled
        userManuallyToggled = true;
      }
    });

    // Hide mobile summary when user scrolls near bottom of page - THROTTLED to prevent memory leak
    const handleScroll = throttle(() => {
      if (!summary) return;

      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      const windowHeight = window.innerHeight;
      const documentHeight = document.documentElement.scrollHeight;

      // Only auto-hide if user hasn't manually toggled the summary
      if (!userManuallyToggled) {
        // Hide when within 200px of bottom
        if (scrollTop + windowHeight >= documentHeight - 200) {
          summary.style.transform = 'translateY(100%)';
          summary.style.opacity = '0';
          summary.style.pointerEvents = 'none';
        } else {
          summary.style.transform = 'translateY(0)';
          summary.style.opacity = '1';
          summary.style.pointerEvents = 'auto';
        }
      }
    }, 100);

    // Attach scroll listener only once using flag
    if (!window._scrollHandlerAttached) {
      window.addEventListener('scroll', handleScroll);
      window._scrollHandlerAttached = true;
    }
  }

  // Progress tracking helpers
  const getSteps = () => Array.from($$('.progress-step'));

  const setStepCompleted = (index, completed = true) => {
    const steps = getSteps();
    const el = steps[index];
    if (!el) return;
    const circle = el.querySelector('.step-circle');

    log('setStepCompleted: index=', index, 'completed=', completed);

    if (completed) {
      el.classList.add('completed');
      el.classList.remove('active');
      if (circle) {
        circle.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';
      }
    } else {
      el.classList.remove('completed');
      if (circle) circle.textContent = (index + 1).toString();
    }
  };

  const setStepActive = (index) => {
    const steps = getSteps();
    log('setStepActive: index=', index);
    steps.forEach((el, i) => {
      if (i === index) {
        el.classList.add('active');
        el.classList.remove('completed');
      } else {
        el.classList.remove('active');
      }
    });
  };
  // Helper: validate a block by its `data-block-id` using admin-configured required fields
  const isBlockComplete = (blockSelector) => {
    const block = $(blockSelector);
    if (!block) return false;

    // Check both `data-required` and the HTML5 `required` attribute.
    // `toggleAddressFieldsByShippingMethod` sets both, but we check both
    // to be robust against any order/timing issues.
    const requiredInputs = block.querySelectorAll(
      'input[data-required="1"], select[data-required="1"], textarea[data-required="1"], ' +
      'input[required]:not([data-required="0"]), select[required]:not([data-required="0"]), textarea[required]:not([data-required="0"])'
    );

    // If there are no required inputs defined for this block, do NOT assume it's complete.
    // Previously we returned true here which caused blocks like payment_method (which
    // often have no required inputs) to be treated as complete before methods were loaded.
    // Instead, return false and let callers consider method-selection or rendered options.
    if (!requiredInputs || requiredInputs.length === 0) {
      return false;
    }

    for (const input of requiredInputs) {
      // Skip hidden fields — they cannot be filled by the user and their
      // values come from module defaults or are sent via hidden inputs.
      if (input.type === 'hidden') continue;
      const container = input.closest('[style*="display: none"]');
      if (container) continue;

      const value = input.type === 'checkbox' ? input.checked : input.value;
      if (!value || (typeof value === 'string' && value.trim() === '')) {
        return false;
      }
      if (input.type === 'email' && value && !/\S+@\S+\.\S+/.test(value)) {
        return false;
      }
    }

    return true;
  };

  // Intelligently update progress based on which blocks are actually filled
  const updateProgressIntelligent = () => {
    // Step 1: use isStep1Valid() which already respects admin `data-required` flags
    const step1Done = (typeof isStep1Valid === 'function') ? !!isStep1Valid() : isBlockComplete('[data-block-id="customer_details"]');

    // Step 2: shipping address block must have ALL its required fields filled.
    // This includes after-shipping fields (address_1, city, etc.) that become
    // required dynamically when a shipping method is selected. Simply having a
    // shipping method checked does NOT mean step 2 is complete — the required
    // address fields for that method must also be filled.
    const shippingBlockComplete = isBlockComplete('[data-block-id="shipping_address"]');
    const step2Done = shippingBlockComplete;

    // Step 3: payment block required fields (if admin created one) OR presence of selected payment method
    const paymentBlockComplete = isBlockComplete('[data-block-id="payment_address"]') || isBlockComplete('[data-block-id="payment_method"]');
    const paymentMethodSelected = !!$('input[name="payment_method"]:checked');
    // Consider Step 3 complete if either the payment block is complete
    // (required payment-address fields filled) or a payment method is selected.
    const step3Done = paymentBlockComplete || paymentMethodSelected;

    log('updateProgressIntelligent: step1Done=', step1Done, 'step2Done=', step2Done, 'step3Done=', step3Done);

    // Mark each step completed independently
    setStepCompleted(0, !!step1Done);
    setStepCompleted(1, !!step2Done);
    setStepCompleted(2, !!step3Done);

    // Choose active step: first incomplete step (lowest index). If all complete,
    // keep the last step active.
    let activeIndex = -1;
    if (!step1Done) activeIndex = 0;
    else if (!step2Done) activeIndex = 1;
    else if (!step3Done) activeIndex = 2;

    setStepActive(activeIndex);
  };

  const updateProgress = (step) => {
    updateProgressIntelligent();
  };

  const loadShippingMethods = () => {
    log('Loading shipping methods...');
    const container = $('#shipping-methods');
    if (!container) return;

    container.innerHTML = '<div class="text-sm text-text-secondary py-4">{{ text_loading }}</div>';

    const data = {
      firstname: $('#input-firstname')?.value || '',
      lastname: $('#input-lastname')?.value || '',
      address_1: $('#input-address-1')?.value || '',
      address_2: $('#input-address-2')?.value || '',
      city: $('#input-city')?.value || '',
      postcode: $('#input-postcode')?.value || '',
      country_id: getShippingCountryId(),
      zone_id: getShippingZoneId()
    };

    log('Loading shipping methods with data:', data);

    ajax(ajaxUrls.shipping_address, { method: 'POST', data })
      .then(json => {
        if (json?.shipping_methods) {
          // Store field visibility config globally
          if (json.shipping_fields) {
            window._shippingFields = json.shipping_fields;
          }
          renderShippingMethods(json.shipping_methods);
        } else if (json?.error) {
          const errHtml = typeof json.error === 'object'
            ? Object.values(json.error).map(v => `<div>• ${v}</div>`).join('')
            : String(json.error);
          container.innerHTML = `<div class="text-sm text-red-600 py-4">${errHtml}</div>`;
        } else {
          container.innerHTML = `<div class="text-sm text-text-secondary py-4">${window.dcLang?.complete_address_first || 'Please complete your address first'}</div>`;
        }
      })
      .catch(error => {
        log('Shipping error', error);
        container.innerHTML = '<div class="text-sm text-red-600 py-4">Error loading shipping methods</div>';
      });
  };

  // Toggle address field visibility based on selected shipping method's field config.
  // Controls visibility of the after-shipping container and individual fields within it.
  const toggleAddressFieldsByShippingMethod = (methodValue) => {
    if (!methodValue || !window._shippingFields) {
      log('toggleAddressFields: skip — no methodValue or _shippingFields');
      return;
    }

    // Use full method code (e.g., flat.flat) as primary key in _shippingFields
    // Fall back to carrier code (module part) for backward compatibility
    let fields = window._shippingFields[methodValue];
    if (!fields && methodValue.includes('.')) {
      const carrierCode = methodValue.split('.')[0];
      fields = window._shippingFields[carrierCode];
    }
    if (!fields) {
      log('toggleAddressFields: no config for', methodValue);
      return;
    }

    log('toggleAddressFields:', methodValue, JSON.stringify(fields));

    // Helper: extract config from a field entry (supports both new and legacy formats)
    const getFieldConfig = (entry) => {
      if (typeof entry === 'object' && entry !== null && 'visible' in entry) {
        // New format: { visible: 0/1, required: 0/1 }
        return { visible: entry.visible == 1, required: entry.required == 1 };
      }
      // Legacy format: scalar 0/1 (visibility only, not required)
      return { visible: entry == 1, required: false };
    };

    // Determine if ANY of the after-shipping fields should be visible
    const afterFields = ['company', 'address_1', 'address_2', 'city', 'postcode'];
    const hasVisibleField = afterFields.some(f => {
      if (!(f in fields)) return false;
      return getFieldConfig(fields[f]).visible;
    });

    // Show/hide the after-shipping container based on whether any field is visible
    const afterShippingContainer = $('#after-shipping-fields');
    if (afterShippingContainer) {
      if (hasVisibleField) {
        afterShippingContainer.style.display = '';
        log('toggleAddressFields: showing after-shipping container');
      } else {
        afterShippingContainer.style.display = 'none';
        log('toggleAddressFields: hiding after-shipping container');
      }
    }

    // Search within the shipping_address block only (avoid payment fields)
    const shippingBlock = document.querySelector('[data-block-id="shipping_address"]');
    if (!shippingBlock) {
      log('toggleAddressFields: shipping_address block not found');
      return;
    }

    // Toggle individual fields based on the shipping method config.
    // This affects the display of each field's wrapper div inside the after-shipping container.
    afterFields.forEach((fieldKey) => {
      if (!(fieldKey in fields)) return;
      const config = getFieldConfig(fields[fieldKey]);

      // Find the input/select by data-dc-field attribute within the shipping block
      const input = shippingBlock.querySelector('[data-dc-field="' + fieldKey + '"]');
      if (!input) {
        log('toggleAddressFields: not found in DOM:', fieldKey);
        return;
      }

      // Walk up to the wrapper div (input is directly inside a <div>)
      let fieldContainer = input.parentElement;
      if (!fieldContainer || fieldContainer.tagName !== 'DIV') {
        fieldContainer = fieldContainer ? fieldContainer.parentElement : null;
      }
      if (!fieldContainer) return;

      // Walk up to the grid row (grid container that wraps field wrappers)
      const gridRow = fieldContainer.parentElement;

      log('toggleAddressFields:', fieldKey,
          'visible:', config.visible,
          'required:', config.required);

      if (config.visible) {
        fieldContainer.style.display = '';
        input.required = config.required;
        input.dataset.required = config.required ? '1' : '0';
        // Add/remove required visual indicator
        fieldContainer.classList.toggle('field-required', config.required);
        // Toggle (Optional) label
        const optionalSpan = fieldContainer.querySelector('[data-dc-optional]');
        if (optionalSpan) {
          optionalSpan.style.display = config.required ? 'none' : '';
        }
        // Show the grid row
        if (gridRow && gridRow.classList.contains('grid')) {
          gridRow.style.display = '';
        }
      } else {
        fieldContainer.style.display = 'none';
        input.required = false;
        fieldContainer.classList.remove('field-required');

        // Hide the grid row if ALL its direct child wrappers are hidden
        if (gridRow && gridRow.classList.contains('grid')) {
          const allHidden = Array.from(gridRow.children).every(child => {
            return child.style.display === 'none';
          });
          if (allHidden) {
            gridRow.style.display = 'none';
          }
        }
      }
    });

    // Attach auto-save listeners to after-shipping fields when they become visible
    if (hasVisibleField && afterShippingContainer) {
      attachAfterShippingListeners();
    }

    // Trigger address complete check to handle fields that may now need saving
    setTimeout(checkAddressComplete, 100);
  };

  // Attach auto-save event listeners to after-shipping address fields
  const attachAfterShippingListeners = () => {
    if (window._afterShippingListenersAttached) return;

    const afterFieldSelectors = [
      '#input-company',
      '#input-address-1',
      '#input-address-2',
      '#input-city',
      '#input-postcode'
    ];

    afterFieldSelectors.forEach(selector => {
      const input = $(selector);
      if (input) {
        // Remove any previously attached listeners by cloning
        if (input.dataset.dcListenerAttached) return;
        input.addEventListener('blur', scheduleSaveShippingAddress);
        input.addEventListener('change', scheduleSaveShippingAddress);
        input.dataset.dcListenerAttached = '1';
        log('Attached auto-save listener to', selector);
      }
    });

    window._afterShippingListenersAttached = true;
  };


  // Render shipping methods from server-provided object
  const renderShippingMethods = (shipping_methods) => {
    log('renderShippingMethods: processing', Object.keys(shipping_methods));
    const container = $('#shipping-methods');
    if (!container) {
      log('ERROR: #shipping-methods container not found');
      return;
    }

    const fragment = document.createDocumentFragment();
    let first = true;

    Object.entries(shipping_methods).forEach(([key, method]) => {
      if (!method.quote) {
        return;
      }

      Object.entries(method.quote).forEach(([code, quote]) => {
        const label = document.createElement('label');
        label.className = `radio-card flex items-center justify-between ${first ? 'selected' : ''}`;

        const left = document.createElement('div');
        left.className = 'flex items-center gap-3';

        const input = document.createElement('input');
        input.type = 'radio';
        input.name = 'shipping_method';
        input.value = `${key}.${code}`;
        if (first) input.checked = true;

        const titleWrap = document.createElement('div');
        let titleHtml = `<div class="font-medium text-text-primary">${quote.title}</div>`;

        // Add description if available
        if (quote.description) {
          titleHtml += `<div class="text-sm text-text-secondary mt-1">${quote.description}</div>`;
        }

        titleWrap.innerHTML = titleHtml;

        left.appendChild(input);
        left.appendChild(titleWrap);

        const price = document.createElement('span');
        price.className = 'font-semibold text-text-primary';
        price.textContent = quote.text;

        label.appendChild(left);
        label.appendChild(price);

        fragment.appendChild(label);

        first = false;
      });
    });

    log('Fragment built with', fragment.children.length, 'methods');
    if (fragment.children.length) {
      // Clear container first to remove old DOM nodes and their event listeners
      container.innerHTML = '';
      container.appendChild(fragment);
      log('Shipping methods DOM updated');

      // Attach change listeners to shipping method inputs.
      // Use guards to avoid duplicate or concurrent POSTs.
      window._savingShippingMethod = window._savingShippingMethod || false;
      window._lastSentShippingMethod = window._lastSentShippingMethod || null;

      // Clone and replace nodes to remove old listeners from previous renders (prevent memory leak)
      const shippingInputs = Array.from(document.getElementsByName('shipping_method'));
      shippingInputs.forEach(input => {
        const newInput = input.cloneNode(true);
        if (input.parentNode) {
          input.parentNode.replaceChild(newInput, input);
        }

        newInput.addEventListener('change', (e) => {
          const value = e.target.value;
          log('Shipping method changed', value);

          // Toggle address field visibility based on selected shipping method
          toggleAddressFieldsByShippingMethod(value);

          // Keep the visual selection in sync when change fires (keyboard, programmatic or click)
            try {
            const radioGroup = e.target.name;
            Array.from(document.getElementsByName(radioGroup)).forEach(i => i.closest('.radio-card')?.classList.remove('selected'));
            e.target.closest('.radio-card')?.classList.add('selected');
          } catch (err) {
            // ignore visual sync errors
          }

          // Skip if already sending or value unchanged
          if (window._savingShippingMethod) {
            log('Skipping shipping_method change: request already in progress');
            return;
          }

          if (window._lastSentShippingMethod && window._lastSentShippingMethod === value) {
            log('Skipping shipping_method change: same method already sent');
            return;
          }

          window._savingShippingMethod = true;

          ajax(ajaxUrls.shipping_method, { method: 'POST', data: { shipping_method: value } })
            .then(json => {
              log('Shipping method saved', json);
              if (json.error) {
                if (typeof json.error === 'object') showFieldErrors(json.error);
                else showNotification(json.error, 'error');
                return;
              }
              if (json.totals) {
                updateTotals(json.totals);
              }
              // Remember last successfully sent method
              window._lastSentShippingMethod = value;

              updateProgressIntelligent();
              // After shipping method saved, save payment address (same as shipping),
              // then load payment methods. This ensures payment_address is in session.
              const paymentSameCheckbox = $('#payment-same-as-shipping');
              if (paymentSameCheckbox && paymentSameCheckbox.checked) {
                savePaymentAddressSameAsShipping();
              } else {
                loadPaymentMethods();
              }
            })
            .catch(error => {
              log('Error saving shipping method', error);
            })
            .finally(() => {
              window._savingShippingMethod = false;
            });
        });
      });

      // Trigger change on the selected input to update totals immediately (if not already sent)
      const selected = $('input[name="shipping_method"]:checked');

      // Auto-trigger field visibility toggle for the initially selected method
      // This MUST run before updateProgressIntelligent so that after-shipping
      // fields have their correct data-required attributes set before we check
      // whether the shipping address block is complete.
      if (selected) {
        toggleAddressFieldsByShippingMethod(selected.value);
      }

      // Update progress now that shipping methods are rendered and selected
      updateProgressIntelligent();

      if (selected) {
        // Only trigger if we haven't already sent this method
        if (!window._lastSentShippingMethod || window._lastSentShippingMethod !== selected.value) {
          selected.dispatchEvent(new Event('change', { bubbles: true }));
        } else {
          log('Selected shipping method already sent previously, not re-triggering change');
        }
      }
    } else {
      log('ERROR: No methods rendered in fragment');
      container.innerHTML = '<div class="text-sm text-text-secondary py-4">No shipping methods available</div>';
    }
  };

  // Handle saved address selection from dropdown
  const handleSavedShippingSelection = (selectEl) => {
    if (!selectEl) return;
    const value = selectEl.value;
    if (!value) return;

    // Reset debounced guard to allow saving new edits
    window._lastSavedShipping = null;

    if (value === 'new') {
      setShippingFieldsEditable(true);

      // Clear all address fields first
      Object.values(SHIPPING_FIELD_MAP_FULL).forEach(sel => {
        const el = $(sel);
        if (el) el.value = '';
      });

      // Make firstname/lastname in customer_details editable (they get
      // cleared because SHIPPING_FIELD_MAP_FULL targets #input-firstname
      // and #input-lastname, but they remain readonly for logged-in users).
      const customerBlock = document.querySelector('[data-block-id="customer_details"]');
      if (customerBlock) {
        ['#input-firstname', '#input-lastname'].forEach(sel => {
          const el = customerBlock.querySelector(sel);
          if (el) {
            el.removeAttribute('readonly');
            el.removeAttribute('data-prefilled');
          }
        });
        // Also remove the edit/save controls that initPrefilledBlocks created
        const controls = customerBlock.querySelector('.flex.items-center.gap-2.justify-end');
        if (controls) controls.remove();
      }

      // Fill country and zone from module defaults
      const countrySelect = $('#input-country');
      const zoneSelect = $('#input-zone');

      if (countrySelect && DEFAULT_SHIPPING_COUNTRY_ID) {
        countrySelect.value = DEFAULT_SHIPPING_COUNTRY_ID;

        // Load zones for the default country
        zoneSelect.innerHTML = `<option value="">${TEXT_SELECT_PLACEHOLDER}</option>`;

        ajax(`${CONFIG.urls.country}&country_id=${DEFAULT_SHIPPING_COUNTRY_ID}`)
          .then(json => {
            let html = `<option value="">${TEXT_SELECT_PLACEHOLDER}</option>`;
            if (json.zone && Array.isArray(json.zone)) {
              json.zone.forEach(z => {
                html += `<option value="${z.zone_id}">${z.name}</option>`;
              });
            }
            zoneSelect.innerHTML = html;

            if (DEFAULT_SHIPPING_ZONE_ID) {
              zoneSelect.value = String(DEFAULT_SHIPPING_ZONE_ID);
            }

            // Trigger address completion check with defaults
            setTimeout(checkAddressComplete, 50);
          })
          .catch(() => {
            zoneSelect.innerHTML = `<option value="">${TEXT_SELECT_PLACEHOLDER}</option>`;
          });
      } else if (zoneSelect) {
        zoneSelect.innerHTML = `<option value="">${TEXT_SELECT_PLACEHOLDER}</option>`;
      }

      return;
    }

    const opt = selectEl.selectedOptions && selectEl.selectedOptions[0];
    let addr = null;
    if (opt && opt.dataset.address) {
      try { addr = JSON.parse(opt.dataset.address); } catch (e) { addr = null; }
    }
    if (!addr && window._savedAddresses && window._savedAddresses[value]) {
      addr = window._savedAddresses[value];
    }
    if (!addr) return;

    // Disable autosave while we're updating form fields from dropdown
    // to prevent race condition where autosave sends form data before address_id is confirmed
    if (window._saveShippingTimer) {
      clearTimeout(window._saveShippingTimer);
      window._saveShippingTimer = null;
    }
    window._allowShippingAutosave = false;

    applyAddressToShippingFields(addr);

    const countrySelect = $('#input-country');
    const zoneSelect = $('#input-zone');
    loadZonesForAddress(addr.country_id, addr.zone_id, zoneSelect, countrySelect)
      .then(() => {
        // When user explicitly selects a saved address, make AJAX call with address_id
        // to inform backend which saved address is selected
        const addressId = parseInt(value, 10);
        if (!isNaN(addressId)) {
          log('Confirming address selection with backend. Address ID:', addressId);
          ajax(ajaxUrls.shipping_address, {
            method: 'POST',
            data: { address_id: addressId }
          })
          .then(json => {
            if (json.error) {
              const errMsg = typeof json.error === 'object' ? Object.values(json.error).join('\n') : String(json.error);
              showNotification(errMsg, 'error');
              window._allowShippingAutosave = true; // Re-enable autosave on error
              return;
            }

            log('Address selection confirmed by backend. Response:', json);

            // Update shipping methods if server returned them
            if (json.shipping_methods) {
              // Store field visibility config globally
              if (json.shipping_fields) {
                window._shippingFields = json.shipping_fields;
              }
              renderShippingMethods(json.shipping_methods);
            }

            // Update address dropdown if server returned updated list
            if (json.addresses) {
              ensureSavedAddressesState(json.addresses);
              refreshSavedAddressSelect(selectEl, json.addresses, value);
            }

            // Handle payment address if checkbox is checked
            const paymentSameCheckbox = $('#payment-same-as-shipping');
            if (paymentSameCheckbox && paymentSameCheckbox.checked && typeof savePaymentAddressSameAsShipping === 'function') {
              setTimeout(() => savePaymentAddressSameAsShipping(), 300);
            }

            updateProgressIntelligent();

            // Re-enable autosave after address is confirmed on backend
            window._allowShippingAutosave = true;
          })
          .catch(error => {
            log('Error confirming address selection:', error);
            // Prefer structured server message when available
            let message = window.dcLang?.error_updating_address || 'Error updating address. Please try again.';
            if (error && error.body) {
              if (typeof error.body === 'string') {
                message = error.body;
              } else if (typeof error.body === 'object') {
                // If backend returned structured { error: 'msg' } or similar
                if (error.body.error) message = error.body.error;
                else message = JSON.stringify(error.body);
              }
            } else if (error && error.message) {
              message = error.message;
            }

            showNotification(message, 'error');
            window._allowShippingAutosave = true; // Re-enable autosave on network error
          });
        } else {
          log('Invalid address ID:', value);
        }
      });
  };

  const loadPaymentMethods = () => {
    log('Loading payment methods...');
    const container = $('#payment-methods');
    if (!container) return;

    // Prevent concurrent loads
    if (window._loadingPaymentMethods) {
      log('Payment methods already loading, skipping');
      return;
    }
    window._loadingPaymentMethods = true;

    container.innerHTML = '<div class="text-sm text-text-secondary py-4">{{ text_loading }}</div>';

    ajax(CONFIG.urls.payment_method, { method: 'GET' })
      .then(json => {
        log('Payment methods response', json);

        if (json.error) {
          const errHtml = typeof json.error === 'object'
            ? Object.values(json.error).map(v => `<div>• ${v}</div>`).join('')
            : String(json.error);
          container.innerHTML = `<div class="text-sm text-red-600 py-4">${errHtml}</div>`;
          return;
        }

        if (!json.payment_methods) {
          container.innerHTML = '<div class="text-sm text-text-secondary py-4">Complete previous steps first</div>';
          return;
        }

        const fragment = document.createDocumentFragment();
        let first = true;

        Object.entries(json.payment_methods).forEach(([code, method]) => {
          const label = document.createElement('label');
          label.className = `radio-card flex items-center justify-between ${first ? 'selected' : ''}`;

          const left = document.createElement('div');
          left.className = 'flex items-center gap-3';

          const input = document.createElement('input');
          input.type = 'radio';
          input.name = 'payment_method';
          input.value = code;
          if (first) input.checked = true;

          const titleWrap = document.createElement('div');
          let titleHtml = `<div class="font-medium text-text-primary">${method.title}</div>`;

          // Add description if available
          if (method.description) {
            titleHtml += `<div class="text-sm text-text-secondary mt-1">${method.description}</div>`;
          }

          titleWrap.innerHTML = titleHtml;

          left.appendChild(input);
          left.appendChild(titleWrap);

          label.appendChild(left);
          fragment.appendChild(label);

          first = false;
        });

        if (fragment.children.length) {
          container.innerHTML = '';
          container.appendChild(fragment);

          // Attach change listeners to payment method inputs
          // Clone and replace nodes to remove old listeners from previous renders
          const paymentInputs = Array.from(document.getElementsByName('payment_method'));
          paymentInputs.forEach(input => {
            const newInput = input.cloneNode(true);
            if (input.parentNode) {
              input.parentNode.replaceChild(newInput, input);
            }

            newInput.addEventListener('change', (e) => {
              const value = e.target.value;
              log('Payment method changed', value);

              // Keep the visual selection in sync when change fires (keyboard, programmatic or click)
                try {
                const radioGroup = e.target.name;
                Array.from(document.getElementsByName(radioGroup)).forEach(i => i.closest('.radio-card')?.classList.remove('selected'));
                e.target.closest('.radio-card')?.classList.add('selected');
              } catch (err) {
                // ignore visual sync errors
              }

              // Step 1: Save payment method selection
              ajax(ajaxUrls.payment_method, { method: 'POST', data: { payment_method: value } })
                .then(json => {
                  log('Payment method saved', json);
                  if (json.error) {
                    if (typeof json.error === 'object') showFieldErrors(json.error);
                    else showNotification(json.error, 'error');
                    return;
                  }

                  // Step 2: Load payment extension form/instructions into hidden container
                  log('Loading payment extension...');
                  return ajax(ajaxUrls.payment_extension, { method: 'GET' });
                })
                .then(json => {
                  log('Payment extension response', json);
                  if (json && json.payment) {
                    const extContainer = $('#payment-extension-container');
                    if (extContainer) {
                      extContainer.innerHTML = json.payment;
                      // Don't show it yet - it stays hidden until confirm is clicked
                      log('Payment extension loaded into hidden container');

                      // Set up click handler for the payment button in the hidden form
                      // This handler will execute when the button is clicked OR triggered programmatically
                      setupPaymentButtonHandler(extContainer);
                    }
                  }
                  updateProgressIntelligent();
                })
                .catch(error => {
                  log('Error loading payment extension', error);
                });
            });
          });

          // Do NOT auto-trigger change on first payment method to avoid premature progress mark.
          // User will explicitly interact with payment methods when ready.

          // However, if the first payment method is already checked (by default),
          // update progress to reflect that Step 3 may already be ready
          const checkedMethod = $('input[name="payment_method"]:checked');
          if (checkedMethod) {
            log('Payment method pre-selected, updating progress');
            updateProgressIntelligent();
          }
        } else {
          container.innerHTML = '<div class="text-sm text-text-secondary py-4">No payment methods available</div>';
        }
      })
      .catch(error => {
        log('Payment error', error);
        container.innerHTML = '<div class="text-sm text-red-600 py-4">Error loading payment methods</div>';
      })
      .finally(() => {
        window._loadingPaymentMethods = false;
      });
  };

  // Country change - load zones
  const countrySelect = $('#input-country');
  const zoneSelect = $('#input-zone');

  if (countrySelect && zoneSelect) {
    countrySelect.addEventListener('change', () => {
      const country_id = countrySelect.value;
      log('Country changed', country_id);

      if (country_id) {
        zoneSelect.innerHTML = '<option value="">Loading...</option>';

        ajax(`${CONFIG.urls.country}&country_id=${country_id}`)
          .then(json => {
            log('Zones loaded', json);

            let html = '<option value="">{{ text_select }}</option>';

            if (json.zone && json.zone.length > 0) {
              json.zone.forEach(zone => {
                html += `<option value="${zone.zone_id}">${zone.name}</option>`;
              });
            }

            zoneSelect.innerHTML = html;

            // If the server provided a preselected zone_id (e.g. for logged-in users), select it
            try {
              const initialZoneId = '{{ zone_id|default('') }}';
              if (initialZoneId) {
                zoneSelect.value = initialZoneId;
              }
            } catch (e) { /* ignore template injection errors */ }

            // After zones are loaded and value set, trigger address completion
            // check so shipping methods load (needed when country/zone are
            // hidden in admin but have default values).
            setTimeout(checkAddressComplete, 50);

            // Activate step 2 only if Step 1 is valid
            if (isStep1Valid()) {
              setStepCompleted(0, true);
              setStepActive(1);
            } else {
              setStepCompleted(0, false);
              setStepActive(0);
            }
          })
          .catch(error => {
            log('Zone loading error', error);
            zoneSelect.innerHTML = '<option value="">{{ text_select }}</option>';
            showNotification(window.dcLang?.error_loading_regions || 'Error loading regions. Please try again.', 'error');
          });
      } else {
        zoneSelect.innerHTML = '<option value="">{{ text_select }}</option>';
      }
    });

    // Add listener to zone change to trigger address save and reload methods
    zoneSelect.addEventListener('change', () => {
      const zone_id = zoneSelect.value;
      if (zone_id) {
        log('Zone changed, triggering address save to load shipping/payment methods');
        checkAddressComplete();
      }
    });
  }

  // Activate step 1 when basic info is filled (based on admin required config)
  const checkStep1 = () => {
    if (isStep1Valid()) {
      log('Step 1 completed');
      setStepCompleted(0, true);
      setStepActive(1);
      updateProgressIntelligent();
    } else {
      setStepCompleted(0, false);
      updateProgressIntelligent();
    }
  };

  // Trigger initial check on page load
  setTimeout(() => checkStep1(), 500);

  // Check if Step 1 is valid (used by other flow triggers)
  // Now checks dynamically based on which fields are marked as required in admin
  const isStep1Valid = () => {
    // Get all required fields in customer details block (typically step 1)
    const customerDetailsBlock = $('[data-block-id="customer_details"]');
    if (!customerDetailsBlock) return true; // If no customer details block, consider valid

    const requiredInputs = customerDetailsBlock.querySelectorAll('input[data-required="1"], select[data-required="1"], textarea[data-required="1"]');

    for (const input of requiredInputs) {
      const value = input.type === 'checkbox' ? input.checked : input.value;
      if (!value || (typeof value === 'string' && value.trim() === '')) {
        return false;
      }

      // Special email validation
      if (input.type === 'email' && value && !/\S+@\S+\.\S+/.test(value)) {
        return false;
      }
    }

    return true;
  };

  // Attach checkStep1 to all inputs in customer_details block (only once via flag to avoid memory leak)
  const attachStep1Listeners = () => {
    if (window._step1ListenersAttached) return;
    const customerDetailsBlock = $('[data-block-id="customer_details"]');
    if (!customerDetailsBlock) return false;

    Array.from(customerDetailsBlock.querySelectorAll('input, select, textarea')).forEach(input => {
      input.addEventListener('input', checkStep1);
      input.addEventListener('change', checkStep1);
    });

    // Mark attached only after successfully adding listeners
    window._step1ListenersAttached = true;
    log('Attached Step 1 listeners');
    return true;
  };

  // Try to attach immediately, otherwise watch for DOM changes and attach when block appears
  if (!attachStep1Listeners()) {
    let observer = new MutationObserver((mutations, obs) => {
      if (attachStep1Listeners()) {
        obs.disconnect();
        observer = null; // Clear reference for garbage collection
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });

    // Safety cleanup: disconnect observer after 5 seconds if still running
    setTimeout(() => {
      if (observer) {
        observer.disconnect();
        observer = null;
      }
    }, 5000);
  }

  // Trigger country change on load if a country is selected (only for guest users or empty zone)
  // For logged-in users with prefilled data, zones are already loaded from server
  if (countrySelect && countrySelect.value) {
    const hasPrefilledZone = zoneSelect?.hasAttribute('data-prefilled') ||
                             (zoneSelect?.options && zoneSelect.options.length > 1);
    if (!hasPrefilledZone) {
      countrySelect.dispatchEvent(new Event('change'));
    }
  }

  // Country selector can be hidden while region selector stays visible.
  // In this case, load regions using default country from backend.
  if (!countrySelect && zoneSelect && DEFAULT_SHIPPING_COUNTRY_ID) {
    zoneSelect.innerHTML = '<option value="">Loading...</option>';

    ajax(`${CONFIG.urls.country}&country_id=${DEFAULT_SHIPPING_COUNTRY_ID}`)
      .then(json => {
        let html = '<option value="">{{ text_select }}</option>';

        if (json.zone && json.zone.length > 0) {
          json.zone.forEach(zone => {
            html += `<option value="${zone.zone_id}">${zone.name}</option>`;
          });
        }

        zoneSelect.innerHTML = html;

        const initialZoneId = getShippingZoneId();
        if (initialZoneId) {
          zoneSelect.value = String(initialZoneId);
        }

        // Trigger address check to load shipping methods now that
        // zones are available with default values.
        setTimeout(checkAddressComplete, 50);
      })
      .catch(error => {
        log('Zone loading error (hidden country)', error);
        zoneSelect.innerHTML = '<option value="">{{ text_select }}</option>';
      });
  }

  // Payment methods will be loaded after user selects a shipping method

  // Monitor address fields to auto-save and load shipping
  const checkAddressComplete = () => {
    const country = getShippingCountryId();
    const zone = getShippingZoneId();

    // Check if after-shipping fields (address_1, city, postcode) exist in DOM
    const address1 = $('#input-address-1')?.value;
    const city = $('#input-city')?.value;
    const postcodeEl = $('#input-postcode');
    const postcode = postcodeEl?.value;
    const postcodeRequired = postcodeEl ? (postcodeEl.getAttribute('data-required') === '1' || postcodeEl.hasAttribute('required')) : false;

    // Determine if after-shipping fields are visible in the DOM
    const afterShippingContainer = $('#after-shipping-fields');
    const afterShippingVisible = afterShippingContainer && afterShippingContainer.style.display !== 'none';

    log('checkAddressComplete: afterShippingVisible=', afterShippingVisible, 'address1=', !!address1, 'city=', !!city, 'country=', !!country, 'zone=', !!zone, 'postcodeRequired=', postcodeRequired, 'postcodeFilled=', !!postcode);

    if (!afterShippingVisible) {
      // After-shipping fields are hidden (no shipping method selected yet).
      // Save with just country + zone to load available shipping methods.
      if (country && zone) {
        log('After-shipping fields hidden but country+zone set, loading shipping methods...');
        saveShippingAddress();
      } else {
        log('Country/zone incomplete, not saving yet');
      }
    } else {
      // After-shipping fields are visible (shipping method selected).
      // Allow address save only when core address fields are present.
      if (address1 && city && country && zone && (!postcodeRequired || (postcodeRequired && postcode && postcode.trim() !== ''))) {
        log('Full address complete, triggering save...');
        saveShippingAddress();
      } else {
        log('Full address incomplete, not saving yet');
      }
    }
  };

  // Debounced auto-save scheduler to avoid rapid/concurrent saves
  const scheduleSaveShippingAddress = () => {
    // Don't schedule save if autosave is disabled (e.g., during dropdown selection)
    if (window._allowShippingAutosave === false) {
      log('Autosave disabled, skipping schedule');
      return;
    }

    if (window._saveShippingTimer) {
      clearTimeout(window._saveShippingTimer);
      window._saveShippingTimer = null;
    }
    window._saveShippingTimer = setTimeout(() => {
      window._saveShippingTimer = null;
      checkAddressComplete();
      // Always update progress after a blur/change, even if the address
      // save was skipped (payload unchanged). This ensures the progress
      // reflects the current state of all required fields.
      updateProgressIntelligent();
    }, 500);
  };

  // Attach listeners only once (prevent memory leak from re-attaching)
  if (!window._shippingAddressListenersAttached) {
    ['#input-address-1', '#input-city', '#input-postcode', '#input-zone'].forEach(selector => {
      const input = $(selector);
      if (input) {
        input.addEventListener('blur', scheduleSaveShippingAddress);
        input.addEventListener('change', scheduleSaveShippingAddress);
      }
    });

    // Also listen to Step 1 fields and trigger address save when both Step 1 and address are complete
    ['#input-email', '#input-firstname', '#input-lastname'].forEach(selector => {
      const input = $(selector);
      if (input) {
        input.addEventListener('blur', () => {
          log('Step 1 field changed, checking if we should save address');
          setTimeout(checkAddressComplete, 200);
        });
        input.addEventListener('change', () => {
          log('Step 1 field changed, checking if we should save address');
          setTimeout(checkAddressComplete, 200);
        });
      }
    });
    window._shippingAddressListenersAttached = true;
  }

  // Auto-trigger shipping address save for logged-in users with prefilled data
  // This ensures shipping methods are loaded immediately on page load
  {% if logged %}
  setTimeout(() => {
    const hasPrefilledAddress = $('#input-address-1')?.hasAttribute('data-prefilled') ||
                                 $('#input-address-1')?.hasAttribute('readonly');

    if (hasPrefilledAddress) {
      log('Logged-in user with prefilled address detected, auto-loading shipping methods');
      checkAddressComplete();
    }
  }, 500);
  {% endif %}

  // Auto-load shipping methods when country and zone are pre-filled (e.g., from default config).
  // This applies to ALL users (guests and logged-in) so shipping methods appear immediately
  // as soon as country/zone are known, without waiting for the full address.
  setTimeout(() => {
    const countryId = getShippingCountryId();
    const zoneId = getShippingZoneId();
    log('Auto-load check: countryId=', countryId, 'zoneId=', zoneId);
    if (countryId && zoneId) {
      log('Country and zone are pre-filled, auto-loading shipping methods immediately');
      loadShippingMethods();
    } else if (countryId && !zoneId) {
      // Country set but zone not - still try (some shipping methods only need country)
      log('Country is pre-filled (no zone), attempting to load shipping methods');
      loadShippingMethods();
    }
  }, 300);

  // Save shipping address
  const saveShippingAddress = () => {
    // Prevent duplicate/concurrent saves
    if (window._savingShipping) {
      log('Save already in progress, skipping');
      return;
    }

    // Gather address data — include firstname/lastname from Step 1 if available
    const data = {
      firstname: $('#input-firstname')?.value || '',
      lastname: $('#input-lastname')?.value || '',
      address_1: $('#input-address-1')?.value || '',
      address_2: $('#input-address-2')?.value || '',
      city: $('#input-city')?.value || '',
      postcode: $('#input-postcode')?.value || '',
      country_id: getShippingCountryId(),
      zone_id: getShippingZoneId()
      // Note: address_id is NOT sent here - when user edits form fields,
      // we treat it as a new address (or update to unsaved version)
      // address_id is only sent when explicitly selecting from dropdown
    };

    // Avoid re-saving the same address repeatedly
    const payloadKey = JSON.stringify(data);
    log('Prepared shipping payload', payloadKey, 'lastSaved=', window._lastSavedShipping);
    if (window._lastSavedShipping === payloadKey) {
      log('Address unchanged since last save, skipping');
      return;
    }

    log('Saving shipping address', data);

    window._savingShipping = true;

    ajax(ajaxUrls.shipping_address, { method: 'POST', data })
      .then(json => {
        log('Shipping address response JSON:', JSON.stringify(json));

        // Clear previous field error markers
        ['#input-firstname','#input-lastname','#input-address-1','#input-city','#input-postcode','#input-country','#input-zone'].forEach(sel => {
          const el = $(sel);
          if (el) el.classList.remove('border-error');
        });

        if (json.error) {
          // Mark fields returned by server as invalid
          if (typeof json.error === 'object') {
            Object.keys(json.error).forEach(key => {
              const mapping = {
                firstname: '#input-firstname',
                lastname: '#input-lastname',
                address_1: '#input-address-1',
                city: '#input-city',
                postcode: '#input-postcode',
                country: '#input-country',
                zone: '#input-zone'
              };
              const sel = mapping[key];
              const el = $(sel);
              if (el) el.classList.add('border-error');
            });
            // Show combined error message in notification
            const errorList = Object.entries(json.error).map(([k,v]) => v);
            log('Validation errors:', errorList);
            // Only show notification if this is the first error (not a loop)
            if (!window._lastShippingError || window._lastShippingError !== errorList.join('')) {
              window._lastShippingError = errorList.join('');
              let errorBox = $('#validation-errors');
              if (!errorBox) {
                errorBox = document.createElement('div');
                errorBox.id = 'validation-errors';
                errorBox.className = 'fixed top-4 left-1/2 transform -translate-x-1/2 bg-red-50 border-2 border-red-500 text-red-800 px-6 py-4 rounded-xl shadow-lg z-50 max-w-md';
                document.body.appendChild(errorBox);
              }
              errorBox.innerHTML = `
                <div class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <div class="flex-1">
                    <h3 class="font-semibold mb-2">${window.dcLang?.please_fix_following || 'Please fix the following'}</h3>
                    <ul class="list-disc list-inside space-y-1 text-sm">
                      ${errorList.map(err => `<li>${err}</li>`).join('')}
                    </ul>
                  </div>
                  <button class="close-error-btn text-red-600 hover:text-red-800 ml-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                  </button>
                </div>
              `;
              // Add close button listener
              const closeBtn = errorBox.querySelector('.close-error-btn');
              if (closeBtn) {
                closeBtn.addEventListener('click', () => errorBox.remove(), { once: true });
              }
              setTimeout(() => errorBox.remove(), 8000);
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          } else {
            showNotification(json.error, 'error');
          }
        } else {
          // Success: address saved, clear error tracking
          window._lastShippingError = null;

          // Remember last saved payload to prevent loops
          window._lastSavedShipping = payloadKey;

          // Render shipping methods returned in response
          // updateProgressIntelligent() will be called after shipping methods are rendered
          log('Checking for shipping_methods in response. Has shipping_methods:', !!json.shipping_methods);
          if (json.shipping_methods && Object.keys(json.shipping_methods).length > 0) {
            log('Server returned shipping_methods, rendering:', Object.keys(json.shipping_methods));
            // Store field visibility config globally
            if (json.shipping_fields) {
              window._shippingFields = json.shipping_fields;
            }
            renderShippingMethods(json.shipping_methods);
          } else {
            log('No shipping_methods in response. Response keys:', Object.keys(json));
            // Show message that no shipping methods are available
            const container = $('#shipping-methods');
            if (container) {
              container.innerHTML = `<div class="text-sm text-orange-600 py-4">${window.dcLang?.no_shipping_methods_for_address || 'No shipping methods available for this address. Please check your shipping settings or contact support.'}</div>`;
            }
          }

          // Refresh saved-address dropdown if server returned updated address book
          if (json.addresses) {
            ensureSavedAddressesState(json.addresses);
            const select = $('#saved-shipping-address');
            if (select) {
              refreshSavedAddressSelect(select, json.addresses, json.address_id || select.value);
            }
          }

          // After shipping address saved, auto-save payment address if checkbox is checked
          const paymentSameCheckbox = $('#payment-same-as-shipping');
          if (paymentSameCheckbox && paymentSameCheckbox.checked) {
            log('Payment address same as shipping is checked, saving payment address...');
            // savePaymentAddressSameAsShipping will call loadPaymentMethods when done
            setTimeout(() => savePaymentAddressSameAsShipping(), 200);
          } else {
            log('Payment address NOT same as shipping, user must fill payment address separately');
          }
        }
      })
      .catch(error => {
        log('Error saving address', error);
      })
      .finally(() => {
        window._savingShipping = false;
      });
  };

  // Create Account Checkbox
  const createAccountCheckbox = $('#create-account-checkbox');
  const createAccountFields = $('#create-account-fields');

  if (createAccountCheckbox && createAccountFields) {
    createAccountCheckbox.addEventListener('change', () => {
      if (createAccountCheckbox.checked) {
        createAccountFields.style.display = 'block';
      } else {
        createAccountFields.style.display = 'none';
        // Clear password fields
        const passwordInput = $('#input-password');
        const confirmPasswordInput = $('#input-confirm-password');
        if (passwordInput) passwordInput.value = '';
        if (confirmPasswordInput) confirmPasswordInput.value = '';
      }
    });
  }

  // Payment Address Same as Shipping Checkbox
  const paymentSameCheckbox = $('#payment-same-as-shipping');
  const paymentAddressSection = $('#payment-address-section');

  if (paymentSameCheckbox && paymentAddressSection) {
    // Handle checkbox toggle
    paymentSameCheckbox.addEventListener('change', () => {
      if (paymentSameCheckbox.checked) {
        // Hide payment address fields
        paymentAddressSection.style.display = 'none';

        // Only auto-save payment address as same as shipping if shipping address
        // has been saved at least once to avoid loading payment methods prematurely.
        if (window._lastSavedShipping) {
          savePaymentAddressSameAsShipping();
        } else {
          // Provide user guidance in the payment methods area
          const pmContainer = $('#payment-methods');
          if (pmContainer) {
            pmContainer.innerHTML = `<div class="text-sm text-text-secondary py-4">${window.dcLang?.fill_and_save_shipping_to_enable_payment || 'Please fill in and save your shipping address to enable payment methods.'}</div>`;
          }
        }
      } else {
        // Show payment address fields
        paymentAddressSection.style.display = 'block';

        // Ensure zones for payment country are loaded when the payment address
        // section becomes visible. If the zone select is empty, trigger the
        // payment country change handler to populate regions.
        try {
          const payCountry = $('#input-payment-country');
          const payZone = $('#input-payment-zone');
          if (payCountry && payZone) {
            // If the zone select has no meaningful options, trigger change to load
            if (!payZone.options || payZone.options.length <= 1 || payZone.innerHTML.trim() === '') {
              // Trigger the existing change listener which performs an AJAX load
              payCountry.dispatchEvent(new Event('change', { bubbles: true }));
            }
          }
        } catch (e) {
          console.error('Error triggering payment country change', e);
        }
      }
    });

    // On page load, if checked (default), save payment address same as shipping after shipping is saved
    // This will be triggered after shipping address save completes
  }

  // Save payment address as same as shipping
  const savePaymentAddressSameAsShipping = () => {
    log('Saving payment address same as shipping');
    ajax(ajaxUrls.payment_address, { method: 'POST', data: { same_as_shipping: true } })
      .then(json => {
        log('Payment address saved (same as shipping)', json);
        if (json.error) {
          let errHtml = '';
          if (typeof json.error === 'object') {
            errHtml = Object.values(json.error).join('\n');
          } else {
            errHtml = String(json.error);
          }
          log('Error saving payment address:', errHtml);
          // Don't alert, just log — payment methods will show error if needed
        } else {
          // Payment address saved successfully, now load payment methods
          loadPaymentMethods();
        }
      })
      .catch(error => {
        log('Error saving payment address', error);
      });
  };

  // Save separate payment address when user fills fields
  const savePaymentAddress = () => {
    // Prefer payment-specific name fields if present, otherwise fall back to main customer fields.
    const data = {
      firstname: $('#input-payment-firstname')?.value || $('#input-firstname')?.value || '',
      lastname: $('#input-payment-lastname')?.value || $('#input-lastname')?.value || '',
      address_1: $('#input-payment-address-1')?.value || '',
      address_2: $('#input-payment-address-2')?.value || '',
      city: $('#input-payment-city')?.value || '',
      postcode: $('#input-payment-postcode')?.value || '',
      country_id: getPaymentCountryId(),
      zone_id: getPaymentZoneId()
    };

    log('Saving separate payment address', data);
    ajax(ajaxUrls.payment_address, { method: 'POST', data })
      .then(json => {
        log('Payment address saved', json);
        if (json.error) {
          if (typeof json.error === 'object') {
            showFieldErrors(json.error);
          } else {
            showNotification(String(json.error), 'error');
          }
        } else {
          // Payment address saved successfully
          log('Payment address saved successfully');
          // Load payment methods (which will call updateProgressIntelligent when ready)
          loadPaymentMethods();
        }
      })
      .catch(error => {
        log('Error saving payment address', error);
      });
  };

  // Payment country change - load zones
  const paymentCountrySelect = $('#input-payment-country');
  const paymentZoneSelect = $('#input-payment-zone');

  if (paymentCountrySelect && paymentZoneSelect) {
    paymentCountrySelect.addEventListener('change', () => {
      const country_id = paymentCountrySelect.value;
      log('Payment country changed', country_id);

      if (country_id) {
        paymentZoneSelect.innerHTML = '<option value="">Loading...</option>';

        ajax(`${CONFIG.urls.country}&country_id=${country_id}`)
          .then(json => {
            log('Payment zones loaded', json);

            let html = '<option value="">{{ text_select }}</option>';

            if (json.zone && json.zone.length > 0) {
              json.zone.forEach(zone => {
                html += `<option value="${zone.zone_id}">${zone.name}</option>`;
              });
            }

            paymentZoneSelect.innerHTML = html;

            // If server provided a payment_zone_id, attempt to select it
            try {
              const initialPaymentZoneId = '{{ payment_zone_id|default('') }}';
              if (initialPaymentZoneId) {
                paymentZoneSelect.value = initialPaymentZoneId;
              }
            } catch (e) { /* ignore */ }
          })
          .catch(error => {
            log('Payment zone loading error', error);
            paymentZoneSelect.innerHTML = '<option value="">{{ text_select }}</option>';
          });
      } else {
        paymentZoneSelect.innerHTML = '<option value="">{{ text_select }}</option>';
      }
    });

    // Add listener to payment zone change to trigger auto-save
    paymentZoneSelect.addEventListener('change', () => {
      const zone_id = paymentZoneSelect.value;
      if (zone_id) {
        log('Payment zone changed, triggering payment address save');
        // Check if all required payment fields are filled and save
        const addr1 = $('#input-payment-address-1')?.value;
        const city = $('#input-payment-city')?.value;
        const country = getPaymentCountryId();
        const postcodeEl = $('#input-payment-postcode');
        const postcode = postcodeEl?.value;
        const postcodeRequired = postcodeEl ? (postcodeEl.getAttribute('data-required') === '1' || postcodeEl.hasAttribute('required')) : false;

        if (addr1 && city && country && zone_id && (!postcodeRequired || (postcodeRequired && postcode && postcode.trim() !== ''))) {
          savePaymentAddress();
        }
      }
    });
  }

  if (!paymentCountrySelect && paymentZoneSelect && DEFAULT_PAYMENT_COUNTRY_ID) {
    paymentZoneSelect.innerHTML = '<option value="">Loading...</option>';

    ajax(`${CONFIG.urls.country}&country_id=${DEFAULT_PAYMENT_COUNTRY_ID}`)
      .then(json => {
        let html = '<option value="">{{ text_select }}</option>';

        if (json.zone && json.zone.length > 0) {
          json.zone.forEach(zone => {
            html += `<option value="${zone.zone_id}">${zone.name}</option>`;
          });
        }

        paymentZoneSelect.innerHTML = html;

        const initialPaymentZoneId = getPaymentZoneId();
        if (initialPaymentZoneId) {
          paymentZoneSelect.value = String(initialPaymentZoneId);
        }
      })
      .catch(error => {
        log('Payment zone loading error (hidden country)', error);
        paymentZoneSelect.innerHTML = '<option value="">{{ text_select }}</option>';
      });
  }

  // Prefilled (readonly) block edit handling for logged-in users
  const initPrefilledBlocks = () => {
    // Find all blocks that contain prefilled inputs
    const blocks = Array.from(document.querySelectorAll('[data-block-id]'));

    blocks.forEach(block => {
      const prefixed = block.querySelector('[data-prefilled="1"]');
      if (!prefixed) return;

      // Build control UI
      const controls = document.createElement('div');
      controls.className = 'flex items-center gap-2 justify-end mb-3';
      controls.style.gap = '8px';

      const editBtn = document.createElement('button');
      editBtn.type = 'button';
      editBtn.className = 'px-3 py-2 border border-gray-200 rounded-md text-sm text-primary';
      editBtn.textContent = '{{ button_edit|e('js') }}';

      const saveBtn = document.createElement('button');
      saveBtn.type = 'button';
      saveBtn.className = 'px-3 py-2 bg-primary text-white rounded-md text-sm';
      saveBtn.textContent = '{{ button_save|e('js') }}';
      saveBtn.style.display = 'none';

      const cancelBtn = document.createElement('button');
      cancelBtn.type = 'button';
      cancelBtn.className = 'px-3 py-2 border border-gray-200 rounded-md text-sm';
      cancelBtn.textContent = '{{ button_cancel|e('js') }}';
      cancelBtn.style.display = 'none';

      // Save to account checkbox (only for logged-in users)
      const saveLabel = document.createElement('label');
      saveLabel.className = 'inline-flex items-center gap-2 text-sm';
      saveLabel.style.display = 'none';
      const saveCheckbox = document.createElement('input');
      saveCheckbox.type = 'checkbox';
      saveCheckbox.className = 'h-4 w-4';
      saveCheckbox.id = `save-to-account-${block.getAttribute('data-block-id')}`;
      const saveText = document.createElement('span');
      saveText.textContent = '{{ text_save_to_account|e('js') }}';
      saveLabel.appendChild(saveCheckbox);
      saveLabel.appendChild(saveText);

      controls.appendChild(saveLabel);
      controls.appendChild(cancelBtn);
      controls.appendChild(saveBtn);
      controls.appendChild(editBtn);

      // Insert controls at top of block (if block has heading area, try to place before it)
      const heading = block.querySelector('h3, h2, .block-title');
      if (heading && heading.parentNode) {
        heading.parentNode.insertBefore(controls, heading.nextSibling);
      } else {
        block.insertBefore(controls, block.firstChild);
      }

      // Snapshot original values (for selects also save selectedIndex and options HTML;
      // for checkboxes/radios save checked state). This allows rollback to fully
      // restore the block exactly as it was before editing (prevents zone/state
      // losing when cancel is pressed).
      const inputs = Array.from(block.querySelectorAll('input, select, textarea'));
      const original = {};
      inputs.forEach(i => {
        const key = i.id || i.name || Math.random();
        if (i.tagName === 'SELECT') {
          original[key] = {
            value: i.value,
            selectedIndex: i.selectedIndex,
            optionsHTML: i.innerHTML
          };
        } else if (i.type === 'checkbox' || i.type === 'radio') {
          original[key] = { checked: i.checked };
        } else {
          original[key] = i.value;
        }
      });

      const enableEditing = () => {
        inputs.forEach(i => {
          if (i.matches('[data-prefilled-hidden]')) return; // skip hidden helper
          if (i.tagName === 'SELECT') {
            i.disabled = false;
          } else if (i.type === 'checkbox' || i.type === 'radio') {
            i.disabled = false;
          } else {
            i.readOnly = false;
          }
        });
        editBtn.style.display = 'none';
        saveBtn.style.display = '';
        cancelBtn.style.display = '';
        saveLabel.style.display = '';
        // Focus first input
        const firstInput = inputs.find(i => !i.matches('[data-prefilled-hidden]'));
        if (firstInput) firstInput.focus();
      };

      const disableEditing = () => {
        inputs.forEach(i => {
          if (i.matches('[data-prefilled-hidden]')) return;
          // Keep saved-address dropdown editable even when block is disabled
          if (i.id === 'saved-shipping-address') {
            i.disabled = false;
            return;
          }

          if (i.tagName === 'SELECT') {
            i.disabled = true;
          } else if (i.type === 'checkbox' || i.type === 'radio') {
            i.disabled = true;
          } else {
            i.readOnly = true;
          }
        });
        editBtn.style.display = '';
        saveBtn.style.display = 'none';
        cancelBtn.style.display = 'none';
        saveLabel.style.display = 'none';
      };

      const rollback = () => {
        inputs.forEach(i => {
          if (i.matches('[data-prefilled-hidden]')) return;
          const key = i.id || i.name || null;
          if (key && original[key] !== undefined) {
            // Restore selects including their original option list so selected
            // value/index survive (this prevents state/zone from being reset when
            // the options were dynamically reloaded during edit).
            if (i.tagName === 'SELECT' && typeof original[key] === 'object') {
              try {
                // If options were changed during edit (e.g. country change triggered
                // zone load), replace options with the original snapshot
                if (original[key].optionsHTML !== undefined) {
                  i.innerHTML = original[key].optionsHTML;
                }

                // Restore value first; if that option doesn't exist, fall back to saved index
                i.value = original[key].value;
                if (i.value !== original[key].value && typeof original[key].selectedIndex === 'number') {
                  i.selectedIndex = Math.min(original[key].selectedIndex, i.options.length - 1);
                }
              } catch (e) {
                // Fallback: try to restore selectedIndex only
                if (typeof original[key].selectedIndex === 'number') {
                  i.selectedIndex = Math.min(original[key].selectedIndex, i.options.length - 1);
                }
              }
            } else if (i.type === 'checkbox' || i.type === 'radio') {
              i.checked = !!original[key].checked;
            } else {
              i.value = original[key];
            }
          }
        });
      };

      editBtn.addEventListener('click', enableEditing);
      cancelBtn.addEventListener('click', () => {
        rollback();
        disableEditing();

        // Dispatch change on any selects in the block so dependent listeners
        // (e.g. zone -> load shipping methods) react to restored values.
        try {
          const selects = Array.from(block.querySelectorAll('select'));
          selects.forEach(s => s.dispatchEvent(new Event('change', { bubbles: true })));
        } catch (e) {
          console.error('Error dispatching change events after rollback', e);
        }

        // If this is the shipping address block, ensure address completeness
        // check runs to reload shipping/payment methods if needed.
        const bid = block.getAttribute('data-block-id');
        if (typeof checkAddressComplete === 'function' && bid === 'shipping_address') {
          setTimeout(() => checkAddressComplete(), 80);
        }
      });

      saveBtn.addEventListener('click', () => {
        // Collect values only from non-hidden inputs
        const payload = {};
        inputs.forEach(i => {
          if (i.matches('[data-prefilled-hidden]')) return;
          if (!i.name) return;
          if (i.type === 'checkbox') payload[i.name] = i.checked ? 1 : 0;
          else payload[i.name] = i.value;
        });
        // Note: save_to_account is no longer sent from frontend
        // Address will be saved automatically on order confirmation

        // Determine endpoint based on block id
        const blockId = block.getAttribute('data-block-id');
        let url = null;
        if (blockId === 'shipping_address') url = ajaxUrls.shipping_address;
        else if (blockId === 'payment_address') url = ajaxUrls.payment_address;
        else {
          // Unknown block, just disable editing
          disableEditing();
          return;
        }

        // Send AJAX request
        ajax(url, { method: 'POST', data: payload })
          .then(json => {
            if (json.error) {
              showFieldErrors(json.error);
            } else {
              // Update hidden helper inputs to reflect new values
              inputs.forEach(i => {
                if (i.matches('[data-prefilled-hidden]')) {
                  const name = i.getAttribute('name');
                  const source = block.querySelector(`[name="${CSS.escape(name)}"]`);
                  if (source && !source.matches('[data-prefilled-hidden]')) i.value = source.value;
                }
              });
              // Update original snapshot (including selectedIndex for selects)
              inputs.forEach(i => {
                if (!i.matches('[data-prefilled-hidden]')) {
                  const key = i.id || i.name || Math.random();
                  if (i.tagName === 'SELECT') {
                    original[key] = { value: i.value, selectedIndex: i.selectedIndex };
                  } else {
                    original[key] = i.value;
                  }
                }
              });
              disableEditing();
            }
          })
          .catch(err => { console.error('Save error', err); });
      });

      // Initially disable editing (inputs already have readonly/disabled from template)
      disableEditing();
    });
  };

  // Initialize prefilled block handlers after DOM ready
  try { initPrefilledBlocks(); } catch (e) { console.error('prefilled blocks init failed', e); }

  // Monitor payment address fields and auto-save when complete (only attach once)
  if (!window._paymentAddressListenersAttached) {
    ['#input-payment-address-1', '#input-payment-city', '#input-payment-postcode', '#input-payment-zone'].forEach(selector => {
      const input = $(selector);
      if (input) {
        input.addEventListener('blur', () => {
          // Check if all required payment fields are filled
          const addr1 = $('#input-payment-address-1')?.value;
          const city = $('#input-payment-city')?.value;
          const country = getPaymentCountryId();
          const zone = getPaymentZoneId();
          const postcodeEl = $('#input-payment-postcode');
          const postcode = postcodeEl?.value;
          const postcodeRequired = postcodeEl ? (postcodeEl.getAttribute('data-required') === '1' || postcodeEl.hasAttribute('required')) : false;

          // Only save if postcode is not required OR postcode is required and filled.
          if (addr1 && city && country && zone && (!postcodeRequired || (postcodeRequired && postcode && postcode.trim() !== ''))) {
            savePaymentAddress();
          }
        });
      }
    });
    window._paymentAddressListenersAttached = true;
  }

  // Terms & Conditions Modal
  const termsModal = $('#terms-modal');
  const showTermsBtn = $('#show-terms-modal');
  const closeTermsBtn = $('#close-terms-modal');
  const acceptTermsBtn = $('#accept-terms');
  const declineTermsBtn = $('#decline-terms');
  const agreeCheckbox = $('#agree');

  if (showTermsBtn && termsModal) {
    showTermsBtn.addEventListener('click', (e) => {
      e.preventDefault();

      // Load terms content
      const termsContent = $('#terms-content');
      termsContent.innerHTML = `<div class="text-sm text-text-secondary">${window.dcLang?.text_loading || 'Loading terms...'}</div>`;

      // Fetch terms via AJAX with robust fallback
      const termsUrl = '{{ agree_link }}';
      fetch(termsUrl, { credentials: 'same-origin' })
        .then(response => {
          if (!response.ok) throw new Error('Network response was not ok: ' + response.status);
          return response.text();
        })
        .then(html => {
          // Extract meaningful content if possible
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const content = doc.querySelector('.content, .description, main, article, #content');

          if (content && content.innerHTML.trim()) {
            termsContent.innerHTML = content.innerHTML;
            return;
          }

          // If the page includes a 404 message or we couldn't find content, show a friendly fallback link
          if (html.includes('The page you requested cannot be found') || html.includes('not found') || !html.trim()) {
            termsContent.innerHTML = '<div class="text-sm text-text-secondary">Terms page is not available inside the modal. <a href="' + termsUrl + '" target="_blank" rel="noopener" class="text-primary hover:underline">Open terms in a new tab</a></div>';
          } else {
            termsContent.innerHTML = html;
          }
        })
        .catch(error => {
          log('Error loading terms', error);
          termsContent.innerHTML = '<div class="text-sm text-red-600">Terms unavailable. <a href="' + termsUrl + '" target="_blank" rel="noopener" class="text-primary hover:underline">Open terms in a new tab</a></div>';
        });

      // Show modal (content will update when fetch completes)
      termsModal.style.display = 'flex';
    });

    closeTermsBtn?.addEventListener('click', () => {
      termsModal.style.display = 'none';
    });

    declineTermsBtn?.addEventListener('click', () => {
      agreeCheckbox.checked = false;
      termsModal.style.display = 'none';
    });

    acceptTermsBtn?.addEventListener('click', () => {
      agreeCheckbox.checked = true;
      termsModal.style.display = 'none';
    });

    // Close modal on backdrop click
    termsModal.addEventListener('click', (e) => {
      if (e.target === termsModal) {
        termsModal.style.display = 'none';
      }
    });
  }

  // Coupon code
  const applyCouponBtn = $('#apply-coupon');
  if (applyCouponBtn) {
    applyCouponBtn.addEventListener('click', () => {
      const code = $('#coupon-code')?.value?.trim();

      // Don't send request if coupon code is empty
      if (!code) {
        let errorBox = $('#validation-errors');
        if (!errorBox) {
          errorBox = document.createElement('div');
          errorBox.id = 'validation-errors';
          errorBox.className = 'fixed top-4 left-1/2 transform -translate-x-1/2 bg-orange-50 border-2 border-orange-500 text-orange-800 px-6 py-4 rounded-xl shadow-lg z-50 max-w-md';
          document.body.appendChild(errorBox);
        }
        errorBox.innerHTML = `
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-orange-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            <div class="flex-1">
              <p class="text-sm">${window.dcLang?.enter_coupon_code || 'Please enter a coupon code'}</p>
            </div>
            <button class="close-notification-btn text-orange-600 hover:text-orange-800 ml-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        `;
        const closeBtn = errorBox.querySelector('.close-notification-btn');
        if (closeBtn) closeBtn.addEventListener('click', () => errorBox?.remove(), { once: true });
        setTimeout(() => errorBox?.remove(), 4000);
        return;
      }

      ajax(ajaxUrls.coupon, { method: 'POST', data: { coupon: code } })
        .then(json => {
          let notificationBox = $('#validation-errors');
          if (json.success) {
            // Show success notification
            if (!notificationBox) {
              notificationBox = document.createElement('div');
              notificationBox.id = 'validation-errors';
              notificationBox.className = 'fixed top-4 left-1/2 transform -translate-x-1/2 bg-green-50 border-2 border-green-500 text-green-800 px-6 py-4 rounded-xl shadow-lg z-50 max-w-md';
              document.body.appendChild(notificationBox);
            }
            notificationBox.innerHTML = `
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div class="flex-1">
                  <p class="text-sm">${json.success}</p>
                </div>
                <button class="close-notification-btn text-green-600 hover:text-green-800 ml-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </button>
              </div>
            `;
            const closeSuccessBtn = notificationBox.querySelector('.close-notification-btn');
            if (closeSuccessBtn) closeSuccessBtn.addEventListener('click', () => notificationBox?.remove(), { once: true });
            setTimeout(() => notificationBox?.remove(), 4000);
            // Clear coupon input
            const couponInput = $('#coupon-code');
            if (couponInput) couponInput.value = '';
          }
          if (json.error) {
            // Show error notification
            if (!notificationBox) {
              notificationBox = document.createElement('div');
              notificationBox.id = 'validation-errors';
              notificationBox.className = 'fixed top-4 left-1/2 transform -translate-x-1/2 bg-red-50 border-2 border-red-500 text-red-800 px-6 py-4 rounded-xl shadow-lg z-50 max-w-md';
              document.body.appendChild(notificationBox);
            }
            notificationBox.innerHTML = `
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div class="flex-1">
                  <p class="text-sm">${json.error}</p>
                </div>
                <button class="close-notification-btn text-red-600 hover:text-red-800 ml-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </button>
              </div>
            `;
            const closeErrorBtn = notificationBox.querySelector('.close-notification-btn');
            if (closeErrorBtn) closeErrorBtn.addEventListener('click', () => notificationBox?.remove(), { once: true });
            setTimeout(() => notificationBox?.remove(), 4000);
          }
          if (json.totals) {
            updateTotals(json.totals);
          }
        })
        .catch(error => {
          log('Coupon error', error);
        });
    });
  }

  // Update totals display
  const updateTotals = (totals) => {
    const cartTotals = $('#cart-totals');
    const mobileTotal = $('#mobile-total');
    if (!cartTotals) return;

    cartTotals.innerHTML = '';
    let totalValue = '';

    totals.forEach(total => {
      const isTotal = total.title === 'Total';

      const row = document.createElement('div');
      row.className = `flex justify-between text-sm ${isTotal ? 'text-base font-semibold border-t border-gray-200 pt-3' : ''}`;

      const title = document.createElement('span');
      title.className = isTotal ? 'text-text-primary' : 'text-text-secondary';
      title.textContent = total.title;

      const value = document.createElement('span');
      value.className = `font-medium ${isTotal ? 'text-xl text-primary' : 'text-text-primary'}`;
      value.textContent = total.text;

      row.appendChild(title);
      row.appendChild(value);

      cartTotals.appendChild(row);

      if (isTotal) totalValue = total.text;
    });

    if (mobileTotal) mobileTotal.textContent = totalValue;
  };

  // Confirm order button
  const handleConfirmOrder = (e) => {
    e.preventDefault();

    const btn = e.currentTarget;
    log('Confirm button clicked');

    // Reset errors
    Array.from($$('input, select, textarea')).forEach(el => el.classList.remove('border-error'));

    // Validate dynamically based on data-required attribute from admin config
    const errors = [];

    // Check if create-account is checked - if yes, email is required even if not marked as required
    const createAccountChecked = $('#create-account-checkbox')?.checked;
    const emailInput = $('#input-email');
    if (createAccountChecked && emailInput) {
      const emailValue = emailInput.value?.trim();
      if (!emailValue) {
        emailInput.classList.add('border-error');
        errors.push('{{ text_email_required_create_account|e('js') }}');
      } else if (!/\S+@\S+\.\S+/.test(emailValue)) {
        emailInput.classList.add('border-error');
        errors.push('{{ text_email_invalid|e('js') }}');
      }
    }
    // Validate password fields if user requested account creation
    if (createAccountChecked) {
      const pwdInput = $('#input-password');
      const confirmInput = $('#input-confirm-password');
      const pwdVal = pwdInput?.value || '';
      const confirmVal = confirmInput?.value || '';

      if (!pwdVal) {
        if (pwdInput) pwdInput.classList.add('border-error');
        errors.push('{{ text_password_required_create_account|e('js') }}');
      } else if (pwdVal.length < 4) {
        if (pwdInput) pwdInput.classList.add('border-error');
        errors.push('{{ text_password_minlength|e('js') }}'.replace('%s', '4'));
      }

      if (pwdVal !== confirmVal) {
        if (confirmInput) confirmInput.classList.add('border-error');
        errors.push('{{ text_passwords_do_not_match|e('js') }}');
      }
    }

    // Check all inputs with data-required="1" or required attribute
    Array.from($$('input[data-required="1"], select[data-required="1"], textarea[data-required="1"], input[required], select[required], textarea[required]')).forEach(input => {
      // Skip payment address fields if "payment same as shipping" is checked
      const paymentSameChecked = $('#payment-same-as-shipping')?.checked;
      if (paymentSameChecked && input.closest('#payment-address-section')) {
        return; // Skip validation for payment address fields
      }

      const value = input.type === 'checkbox' ? input.checked : input.value;
      const fieldName = input.name || input.id || 'Field';
      // Get label text without (Optional) suffix for cleaner error messages
      let label = input.closest('div')?.querySelector('label')?.textContent?.trim() || fieldName;
      label = label.replace(/\(Optional\)|\s*\(Optional\)/gi, '').trim();

      if (!value || (typeof value === 'string' && value.trim() === '')) {
        input.classList.add('border-error');
        // Localized required message with placeholder
        errors.push(`{{ text_required_field|e('js') }}`.replace('%s', label));
      }

      // Email validation (skip if already validated above for create-account)
      if (input.type === 'email' && value && !/\S+@\S+\.\S+/.test(value) && input !== emailInput) {
        input.classList.add('border-error');
        errors.push(`{{ text_field_invalid_email|e('js') }}`.replace('%s', label));
      }

      // Phone validation (flexible for international formats)
      if (input.type === 'tel' || input.name === 'telephone') {
        const phoneValue = value.toString().replace(/[\s\-\(\)]/g, '');
        // Require at least 7 digits (allows +, spaces, dashes, parentheses)
        if (value && phoneValue.length < 7) {
          input.classList.add('border-error');
          errors.push(`${label} must contain at least 7 digits`);
        }
        // Check if contains at least some digits
        if (value && !/\d{7,}/.test(phoneValue)) {
          input.classList.add('border-error');
          errors.push(`${label} must be a valid phone number`);
        }
      }
    });

    // Check shipping method (only if shipping is required)
    if ({{ shipping_required ? 'true' : 'false' }} && !$('input[name="shipping_method"]:checked')) {
      errors.push(window.dcLang?.error_select_shipping_method || 'Please select a shipping method');
    }

    // Check payment method
    if (!$('input[name="payment_method"]:checked')) {
      errors.push(window.dcLang?.error_select_payment_method || 'Please select a payment method');
    }

    // Check terms agreement
    const agreeCheckbox = $('#agree');
    if (agreeCheckbox && !agreeCheckbox.checked) {
      errors.push('{{ error_agree|e('js') }}');
    }

    if (errors.length > 0) {
      log('Validation errors', errors);
      // Show errors in a notification div instead of alert
      let errorBox = $('#validation-errors');
      if (!errorBox) {
        errorBox = document.createElement('div');
        errorBox.id = 'validation-errors';
        errorBox.className = 'fixed top-4 left-1/2 transform -translate-x-1/2 bg-red-50 border-2 border-red-500 text-red-800 px-6 py-4 rounded-xl shadow-lg z-50 max-w-md';
        document.body.appendChild(errorBox);
      }
      errorBox.innerHTML = `
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div class="flex-1">
            <h3 class="font-semibold mb-2">${window.dcLang?.please_fix_errors || 'Please fix the following errors:'}</h3>
            <ul class="list-disc list-inside space-y-1 text-sm">
              ${errors.map(err => `<li>${err}</li>`).join('')}
            </ul>
          </div>
          <button class="close-error-btn text-red-600 hover:text-red-800 ml-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      `;
      const closeValidationBtn = errorBox.querySelector('.close-error-btn');
      if (closeValidationBtn) closeValidationBtn.addEventListener('click', () => errorBox.remove(), { once: true });
      // Auto-remove after 8 seconds
      setTimeout(() => errorBox.remove(), 8000);
      // Scroll to top to show error
      window.scrollTo({ top: 0, behavior: 'smooth' });
      return false;
    }

    // Disable button
    btn.disabled = true;
    btn.innerHTML = '{{ text_processing }}';

    log('Starting order confirmation...');

    // Helper to reset button
    const resetButton = () => {
      btn.disabled = false;
      btn.innerHTML = '{{ button_confirm }}';
    };

    // Step 1: Save guest customer
    const guestData = {
      firstname: $('#input-firstname')?.value || '',
      lastname: $('#input-lastname')?.value || '',
      email: $('#input-email')?.value || '',
      telephone: $('#input-telephone')?.value || ''
    };

    // If user requested account creation, include password and flag for server
    if (createAccountChecked) {
      const pwd = $('#input-password')?.value || '';
      const confirmPwd = $('#input-confirm-password')?.value || '';
      guestData.create_account = true;
      guestData.password = pwd;
      // include confirm if present (server may use it in validation)
      if ($('#input-confirm-password')) guestData.confirm = confirmPwd;
    }

    log('Saving guest data', guestData);

    const doCustomerSave = () => {
      // Call the customer endpoint only when admin-configured required customer
      // fields are present and valid, or when account creation is requested.
      // This avoids sending guest payloads just because optional fields (like
      // telephone) are filled.
      const customerDetailsBlock = $('[data-block-id="customer_details"]');
      const requiredInputs = customerDetailsBlock ? customerDetailsBlock.querySelectorAll('[data-required="1"]') : [];
      const hasRequired = requiredInputs && requiredInputs.length > 0;

      // Only save if account creation is requested OR one of the following is true:
      //  - admin-configured required customer fields exist and are all valid
      //  - there are no admin-required customer fields and the user has provided
      //    at least one identifying value (firstname/lastname/email/telephone)
      // This keeps behavior configurable via admin while still saving user-entered
      // optional identifiers like telephone when no required fields block the save.
      const anyIdentifyingFilled = (guestData.firstname && guestData.firstname.trim() !== '')
        || (guestData.lastname && guestData.lastname.trim() !== '')
        || (guestData.email && guestData.email.trim() !== '')
        || (guestData.telephone && guestData.telephone.trim() !== '');

      const isLogged = {{ logged ? 'true' : 'false' }};

      // For logged-in users we should attempt to persist changes to their
      // customer details so the final order uses the edited values. If the
      // admin requires specific fields, respect that validation flow; otherwise
      // fall back to saving when any identifying field is present.
      const shouldSave = createAccountChecked
        || (hasRequired && isStep1Valid())
        || (!hasRequired && anyIdentifyingFilled)
        || (isLogged && anyIdentifyingFilled);

      if (shouldSave) {
        // Check if "Save to account" is checked in customer details block (for logged-in users)
        if (isLogged) {
          const saveToAccountCheckbox = customerDetailsBlock
            ? customerDetailsBlock.querySelector('input[type="checkbox"][id*="save-to-account"]')
            : null;
          if (saveToAccountCheckbox && saveToAccountCheckbox.checked) {
            guestData.save_to_account = true;
          }
        }

        // Avoid sending duplicate customer payloads when nothing changed
        try {
          const payloadKey = JSON.stringify(guestData);
          window._lastSavedCustomer = window._lastSavedCustomer || null;
          if (window._lastSavedCustomer === payloadKey) {
            log('Customer data unchanged since last save, skipping AJAX');
            return Promise.resolve({ skipped: true });
          }

          window._lastSavedCustomer = payloadKey;
        } catch (e) {
          // If serialization fails, fall back to sending the request
          log('Could not compute customer payloadKey', e);
        }

        return ajax(ajaxUrls.customer, { method: 'POST', data: guestData })
          .then(json => {
            log('Guest saved', json);
            if (json.error) {
              // If server returned structured field errors, surface them in the inline notification
              if (typeof json.error === 'object') {
                showFieldErrors(json.error);
              } else {
                showNotification(json.error, 'error');
              }
              resetButton();
              return Promise.reject('Guest data error');
            }
            return json;
          });
      }

      log('Skipping guest save - no admin-required customer fields and account creation not requested');
      return Promise.resolve({});
    };

    doCustomerSave()
      .then(() => {
        // Step 2: Save payment address
        // Determine whether payment address should be the same as shipping
        const paymentSameChecked = $('#payment-same-as-shipping')?.checked;

        if (paymentSameChecked) {
          log('Payment address is marked same as shipping - instruct server to copy shipping address');
          // Server understands same_as_shipping flag for convenience
          return ajax(ajaxUrls.payment_address, { method: 'POST', data: { same_as_shipping: true } });
        } else {
          // Use payment-specific fields if present, otherwise fall back to main customer fields
          const addressData = {
            firstname: $('#input-payment-firstname')?.value || $('#input-firstname')?.value || '',
            lastname: $('#input-payment-lastname')?.value || $('#input-lastname')?.value || '',
            address_1: $('#input-payment-address-1')?.value || '',
            address_2: $('#input-payment-address-2')?.value || '',
            city: $('#input-payment-city')?.value || '',
            postcode: $('#input-payment-postcode')?.value || '',
            country_id: getPaymentCountryId(),
            zone_id: getPaymentZoneId()
          };

          log('Saving payment address (separate)', addressData);
          return ajax(ajaxUrls.payment_address, { method: 'POST', data: addressData });
        }
      })
      .then(json => {
        log('Payment address saved', json);
        if (json.error) {
          if (typeof json.error === 'object') showFieldErrors(json.error);
          else showNotification(json.error, 'error');
          resetButton();
          return Promise.reject('Payment address error');
        }

        // Step 3: Save shipping method
        const shippingMethod = $('input[name="shipping_method"]:checked')?.value;
        log('Saving shipping method', shippingMethod);
        return ajax(ajaxUrls.shipping_method, { method: 'POST', data: { shipping_method: shippingMethod } });
      })
      .then(json => {
        log('Shipping method saved', json);
        if (json.error) {
          if (typeof json.error === 'object') showFieldErrors(json.error);
          else showNotification(json.error, 'error');
          resetButton();
          return Promise.reject('Shipping method error');
        }

        // Step 4: Save payment method
        const paymentMethod = $('input[name="payment_method"]:checked')?.value;
        log('Saving payment method', paymentMethod);
        return ajax(ajaxUrls.payment_method, { method: 'POST', data: { payment_method: paymentMethod } });
      })
      .then(json => {
        log('Payment method saved', json);
        if (json.error) {
          if (typeof json.error === 'object') showFieldErrors(json.error);
          else showNotification(json.error, 'error');
          resetButton();
          return Promise.reject('Payment method error');
        }

        // Step 5: Confirm order
        log('Confirming order...');
        const orderComment = $('#input-comment')?.value || '';
        return ajax(ajaxUrls.confirm, { method: 'POST', data: { agree: 1, comment: orderComment } });
      })
      .then(json => {
        log('Order confirmed', json);

        if (json.redirect) {
          // Most common case: order created, redirect to success or payment gateway
          // If payment form was loaded, check if it has a button and trigger it
          const extContainer = $('#payment-extension-container');
          if (extContainer && extContainer.innerHTML.trim()) {
            // Payment form is loaded but not visible
            // Try to find and trigger the payment button
            const paymentBtn = extContainer.querySelector('#button-confirm');
            if (paymentBtn) {
              log('Triggering hidden payment button programmatically');
              paymentBtn.click();
              return; // Let the payment button handler manage navigation
            }
          }

          // No payment form or no button found, redirect directly
          window.location.href = json.redirect;
        } else if (json.error) {
          if (typeof json.error === 'object') showFieldErrors(json.error);
          else showNotification(json.error, 'error');
          resetButton();
        } else {
          log('Unknown response', json);
          showNotification(window.dcLang?.order_unclear_response || 'Order placed but response unclear. Please check your account.', 'warn');
        }
      })
      .catch(error => {
        log('Order confirmation error', error);
        if (typeof error === 'object' && error.message) {
          showNotification('Error: ' + error.message, 'error');
        }
        resetButton();
      });

    return false;
  };

  // Attach confirm handlers
  const confirmBtn = $('#button-confirm');
  const mobileConfirmBtn = $('#mobile-button-confirm');

  if (confirmBtn) confirmBtn.addEventListener('click', handleConfirmOrder);
  if (mobileConfirmBtn) mobileConfirmBtn.addEventListener('click', handleConfirmOrder);

  // Remove error state on input
  Array.from($$('input, select')).forEach(input => {
    input.addEventListener('input', (e) => {
      e.target.classList.remove('border-error');
    });
    input.addEventListener('change', (e) => {
      e.target.classList.remove('border-error');
    });
  });

  // Smooth scroll on mobile when focusing inputs
  if (window.innerWidth < 1024) {
    Array.from($$('input, select')).forEach(input => {
      input.addEventListener('focus', function() {
        setTimeout(() => {
          this.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 300);
      });
    });
  }
});
</script>

</body>
</html>
