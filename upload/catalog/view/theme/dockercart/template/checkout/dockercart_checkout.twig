<!DOCTYPE html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>{{ heading_title }}</title>
<base href="{{ base }}" />
{% if description %}<meta name="description" content="{{ description }}" />{% endif %}
{% if keywords %}<meta name="keywords" content="{{ keywords }}" />{% endif %}
{% for favicon in favicon_links %}
<link rel="{{ favicon.rel }}" type="{{ favicon.type }}" sizes="{{ favicon.sizes }}" href="{{ favicon.href }}" />
{% endfor %}
{% for link in links %}
{% if link.hreflang is defined %}
<link href="{{ link.href }}" rel="{{ link.rel }}" hreflang="{{ link.hreflang }}" />
{% else %}
<link href="{{ link.href }}" rel="{{ link.rel }}" />
{% endif %}
{% endfor %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<!-- Local Tailwind browser bundle (downloaded into theme assets) -->
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
<script>
(() => {
  const config = {
    theme: {
      extend: {
        colors: {
          primary: '#635BFF',
          'primary-dark': '#4F46E5',
          'text-primary': '#111',
          'text-secondary': '#475467',
          'bg-light': '#F8FAFC',
          error: '#EF4444'
        },
        fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] }
      }
    }
  };

  if (typeof tailwind !== 'undefined') {
    tailwind.config = config;
    return;
  }

  window.__tailwind_pending = config;
  let attempts = 0;
  const maxAttempts = 30;

  const interval = setInterval(() => {
    if (typeof tailwind !== 'undefined') {
      tailwind.config = window.__tailwind_pending;
      clearInterval(interval);
    } else if (++attempts >= maxAttempts) {
      clearInterval(interval);
    }
  }, 100);
})();
</script>
<style>
:root {
  --bg-primary: #F8FAFC;
  --bg-secondary: #FFF;
  --text-primary: #111;
  --text-secondary: #475467;
  --border-color: #E5E7EB;
  --primary-color: #635BFF;
  --primary-hover: #4F46E5;
  --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

{% if theme == 'dark' %}
:root {
  --bg-primary: #0F172A;
  --bg-secondary: #1E293B;
  --text-primary: #F1F5F9;
  --text-secondary: #94A3B8;
  --border-color: #334155;
  --primary-color: #818CF8;
  --primary-hover: #6366F1;
}
{% endif %}

*, *::before, *::after { font-family: 'Inter', system-ui, sans-serif; }
body { background: var(--bg-primary); color: var(--text-primary); margin: 0; padding: 0; }
.bg-white { background-color: var(--bg-secondary) !important; }
.text-text-primary { color: var(--text-primary) !important; }
.text-text-secondary { color: var(--text-secondary) !important; }
.border-gray-200, .border-gray-300 { border-color: var(--border-color) !important; }
input, select, textarea {
  background-color: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
  border-color: var(--border-color) !important;
}
/* Custom select caret using currentColor so it adapts to light/dark themes */
select {
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20' fill='none' stroke='currentColor' stroke-width='1.5'><path d='M6 8l4 4 4-4'/></svg>");
  background-repeat: no-repeat;
  background-position: right 12px center;
  padding-right: 40px;
}

/* Trust badges: in dark theme show as simple inline text (not buttons) */
{% if theme == 'dark' %}
.trust-badge {
  background: transparent !important;
  padding: 0 !important;
  border-radius: 0 !important;
  color: var(--text-primary) !important;
  gap: 8px;
}
/* Ensure SVG icons inherit the light text color in dark theme */
.trust-badge svg,
.trust-badge svg * {
  color: var(--text-primary) !important;
  fill: currentColor !important;
  stroke: currentColor !important;
}
.trust-badge span { font-size: 13px; margin-left: 6px; color: var(--text-primary) !important; }

/* Promo apply button: ensure contrast in dark theme */
#apply-coupon {
  background: transparent;
  color: var(--text-primary);
  border: 1px solid var(--border-color);
  padding: 0 1rem;
}
/* Ensure select caret is visible (white) in dark theme */
select {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20' fill='none' stroke='%23FFFFFF' stroke-width='1.5'><path d='M6 8l4 4 4-4'/></svg>") !important;
}
/* Inputs in dark theme: lighter border and clearer focus outline */
input, select, textarea {
  border-color: rgba(255,255,255,0.12) !important;
  background-color: var(--bg-secondary) !important;
  color: var(--text-primary) !important;
}
input:focus, select:focus, textarea:focus {
  border-color: var(--primary-color) !important;
  box-shadow: 0 0 0 6px rgba(99,91,255,0.10) !important;
  outline: none !important;
}
{% else %}
/* Light theme: ensure promo button has visible border & text */
#apply-coupon {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border: 1px solid var(--border-color);
}
{% endif %}
button { cursor: pointer; }
.border-error {
  border: 2px solid #EF4444 !important;
  background-color: rgb(239 68 68 / 3%) !important;
  box-shadow: 0 0 0 6px rgb(239 68 68 / 12%) !important;
}

.border-error:focus {
  border: 2px solid #EF4444 !important;
  box-shadow: 0 0 0 8px rgb(239 68 68 / 16%) !important;
}

.gradient-primary { background: linear-gradient(135deg, #635BFF, #4F46E5); }

.input-focus:focus {
  border-color: #635BFF;
  box-shadow: 0 0 0 4px rgb(99 91 255 / 10%);
  outline: none;
}

/* Required field indicator for shipping-method-dependent fields */
.field-required label .text-sm {
  position: relative;
}
.field-required label .text-sm::after {
  content: ' *';
  color: #EF4444;
  font-weight: bold;
}

.btn-hover:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 24px rgb(99 91 255 / 25%);
}

.btn-active:active { transform: translateY(0); }
@media (max-width: 1023px) {
  .mobile-order-summary {
    position: fixed;
    inset: auto 0 0;
    background: #fff;
    border-top: 1px solid #E5E7EB;
    box-shadow: 0 -4px 20px rgb(0 0 0 / 8%);
    z-index: 50;
    transition: transform 0.3s ease;
  }
  .mobile-order-summary.hidden-mobile { transform: translateY(100%); }
}

/* Fix: allow flex children (e.g. coupon input with .flex-1) to shrink on small screens
   so input + button fit within the viewport without overflowing. */
@media (max-width: 640px) {
  .flex > .flex-1 { min-width: 0; }
  input.flex-1 { min-width: 0; }
}

.progress-step { position: relative; }

.progress-step::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 2px;
  background: #E5E7EB;
  z-index: -1;
}

.progress-step.active .step-circle {
  background: #635BFF !important;
  color: #fff;
  border-color: #635BFF !important;
}

.progress-step.completed .step-circle {
  background: #10B981 !important;
  color: #fff;
  border-color: #10B981 !important;
}
.trust-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  background: #F9FAFB;
  border-radius: 8px;
  font-size: 13px;
  color: #475467;
}
.apple-pay-btn {
  background: #000;
  color: #fff;
  border: none;
  border-radius: 12px;
  height: 56px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}
.apple-pay-btn:hover {
  background: #1a1a1a;
  transform: translateY(-1px);
}
.order-item {
  display: flex;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid #F3F4F6;
}
.order-item:last-child {
  border-bottom: none;
}
.sticky-summary {
  position: sticky;
  top: 32px;
  max-height: calc(100vh - 64px);
  overflow-y: auto;
}
input[type="radio"] {
  width: 20px;
  height: 20px;
  accent-color: #635BFF;
  cursor: pointer;
}
.radio-card {
  border: 2px solid #E5E7EB;
  border-radius: 12px;
  padding: 16px;
  cursor: pointer;
  transition: all 0.2s;
}
.radio-card:hover {
  border-color: #635BFF;
  background: #F9FAFB;
}
.radio-card.selected {
  border-color: #635BFF;
  background: rgba(99, 91, 255, 0.03);
}
/* Readonly and disabled fields styling - gray background for visual distinction */
input[readonly]:not([type="checkbox"]):not([type="radio"]),
textarea[readonly],
select[disabled] {
  background-color: #f3f4f6 !important;
  cursor: not-allowed;
  opacity: 0.9;
}
</style>
{{ google_analytics }}
{% if analytics is defined %}
{% for analytic in analytics %}
{{ analytic }}
{% endfor %}
{% endif %}
</head>
<body class="bg-bg-light">

<!-- Header -->
<header class="bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="flex items-center justify-between">
      <a href="{{ home }}" class="flex items-center">
        {% if logo %}
        <img src="{{ logo }}" alt="{{ name }}" class="max-w-36 sm:max-w-44 object-contain">
        {% else %}
        <span class="text-xl sm:text-2xl font-bold text-primary">{{ name }}</span>
        {% endif %}
      </a>
      <a href="{{ shopping_cart }}" class="text-sm text-text-secondary hover:text-primary transition">
        <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
        {{ text_cart }}
      </a>
    </div>
  </div>
</header>

<!-- Progress Bar -->
{% if show_progress %}
<div class="bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex items-center justify-between max-w-2xl mx-auto">
      <div class="progress-step active flex-1 flex flex-col items-center">
        <div class="step-circle w-10 h-10 rounded-full border-2 border-gray-300 bg-white flex items-center justify-center font-semibold text-sm mb-2">1</div>
        <span class="text-xs sm:text-sm font-medium text-text-primary text-center">{{ text_checkout_account }}</span>
      </div>
      <div class="flex-1 h-0.5 bg-gray-200 mx-2"></div>
      <div class="progress-step flex-1 flex flex-col items-center">
        <div class="step-circle w-10 h-10 rounded-full border-2 border-gray-300 bg-white flex items-center justify-center font-semibold text-sm mb-2">2</div>
        <span class="text-xs sm:text-sm font-medium text-gray-400 text-center">{{ text_checkout_shipping }}</span>
      </div>
      <div class="flex-1 h-0.5 bg-gray-200 mx-2"></div>
      <div class="progress-step flex-1 flex flex-col items-center">
        <div class="step-circle w-10 h-10 rounded-full border-2 border-gray-300 bg-white flex items-center justify-center font-semibold text-sm mb-2">3</div>
        <span class="text-xs sm:text-sm font-medium text-gray-400 text-center">{{ text_checkout_payment }}</span>
      </div>
    </div>
  </div>
</div>
{% endif %}

<!-- Main Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">

    <!-- Left Column - Checkout Form (60%) -->
    <div class="lg:col-span-7 space-y-6">

      {% set step_counter = 1 %}
      {% set total_steps = 3 %}

      {% for block in blocks %}
        {% if block.enabled %}
          {% if block.id == 'terms' %}
            <!-- Terms & Conditions Block -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8" data-block-id="terms">
              <div class="flex items-center">
                <label class="flex items-center gap-3 cursor-pointer">
                  <!-- The agree checkbox is validated explicitly in JS; remove generic 'required' markers to avoid duplicate errors -->
                  <input type="checkbox" id="agree" class="w-5 h-5 accent-primary cursor-pointer">
                  <span class="text-sm text-text-secondary">
                    {% if agree_id %}
                      {{ text_agree_read|default('I have read and agree to the') }} <button type="button" id="show-terms-modal" class="text-primary hover:underline font-medium">{{ text_terms }}</button>
                    {% else %}
                      {{ text_agree_simple|default('I agree to the Terms and Conditions') }}
                    {% endif %}
                  </span>
                </label>
              </div>
            </div>
          {% elseif block.rows is defined and block.rows|length > 0 %}
            <!-- Block: {{ block.name }} (with rows) -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8"
                 data-block-id="{{ block.id }}"
                 {% if block.id == 'payment_address' %}style="display: none;" id="payment-address-section"{% endif %}>
              <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-semibold text-text-primary">{{ block.name }}</h2>
                {% if block.id in ['customer_details', 'shipping_address', 'payment_method'] %}
                  <span class="text-sm text-text-secondary">{{ text_step }} {{ step_counter }}/{{ total_steps }}</span>
                  {% set step_counter = step_counter + 1 %}
                {% endif %}
              </div>

            {# Saved address selector for logged-in customers #}
            {% if block.id == 'shipping_address' and logged and addresses and addresses|length > 0 %}
              <div class="space-y-2 mb-2">
                <label class="block text-sm font-medium text-text-primary">{{ text_saved_addresses }}</label>
                <select id="saved-shipping-address" class="w-full h-12 px-4 bg-white border-2 border-gray-300 rounded-xl text-base text-text-primary input-focus transition appearance-none bg-no-repeat bg-right" style="background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27currentColor%27 stroke-width=%272%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3e%3cpolyline points=%276 9 12 15 18 9%27%3e%3c/polyline%3e%3c/svg%3e'); background-position: right 1rem center; background-size: 1.5em 1.5em;">
                  {% for address_id, address in addresses %}
                    {% set addrId = address.address_id|default(address_id) %}
                    {% set formatted = (address.firstname ~ ' ' ~ address.lastname ~ ', ' ~ address.address_1 ~ (address.address_2 ? ', ' ~ address.address_2 : '') ~ (address.city ? ', ' ~ address.city : '') ~ (address.zone ? ', ' ~ address.zone : '') ~ (address.country ? ', ' ~ address.country : ''))|trim(', ') %}
                    <option value="{{ addrId }}" data-address='{{ address|json_encode(constant('JSON_UNESCAPED_UNICODE'))|e('html_attr') }}' {% if shipping_address_id and shipping_address_id == addrId %}selected{% elseif not shipping_address_id and default_address_id and default_address_id == addrId %}selected{% endif %}>
                      {{ formatted }}{% if default_address_id and default_address_id == addrId %} ({{ text_default_address }}){% endif %}
                    </option>
                  {% endfor %}
                  <option value="new">{{ text_new_address }}</option>
                </select>
                <p class="text-xs text-text-secondary">{{ text_select_address }}</p>
              </div>
            {% endif %}

            {# Helper macro: render a single row of fields.
               `ctx` is the parent template context passed via _context.
               Inside a macro, top-level variables like `logged`, `countries`
               are NOT visible — we must access them through ctx. #}
            {% macro renderRow(row, ctx) %}
              {% set columns = row.columns|default(1) %}
              {% if row.fields|length > 0 %}
                {% if columns == 2 %}
                  {% set grid_class = 'grid grid-cols-1 md:grid-cols-2 gap-4' %}
                {% elseif columns == 3 %}
                  {% set grid_class = 'grid grid-cols-1 md:grid-cols-3 gap-4' %}
                {% else %}
                  {% set grid_class = 'grid grid-cols-1 gap-4' %}
                {% endif %}
                <div class="{{ grid_class }}">
                {% for field in row.fields %}
                  {% if field.id is defined and field.id|slice(-3) == '_id' %}
                    {% set base = field.id|slice(0, -3) %}
                  {% else %}
                    {% set base = field.id %}
                  {% endif %}
                  {% set field_id = 'input-' ~ (base|replace({'_':'-'})) %}
                  {% set is_required = field.required == 1 %}
                  {% set ctx_logged = attribute(ctx, 'logged')|default(false) %}
                  {% set ctx_countries = attribute(ctx, 'countries')|default([]) %}
                  {% set ctx_country_id = attribute(ctx, 'country_id')|default('') %}

                  {% if field.type == 'text' or field.type == 'email' or field.type == 'tel' %}
                    <div{% if field.hidden %} style="display: none;"{% endif %}>
                      <label class="block text-sm font-medium text-text-primary mb-2">
                        {{ field.label|default(field.name|default(field.id)) }}
                        {% if not is_required %}<span class="text-gray-400 font-normal" data-dc-optional="1">({% if attribute(ctx, 'text_optional') is defined %}{{ attribute(ctx, 'text_optional') }}{% else %}Optional{% endif %})</span>{% endif %}
                        {% if field.type == 'tel' %}<span class="text-xs text-gray-500">{% if attribute(ctx, 'text_telephone_hint') is defined %}{{ attribute(ctx, 'text_telephone_hint') }}{% endif %}</span>{% endif %}
                      </label>
                      <input
                        type="{{ field.type }}"
                        id="{{ field_id }}"
                        name="{{ field.id }}"
                        data-dc-field="{{ field.id }}"
                        placeholder="{{ field.placeholder }}"
                        value="{{ attribute(ctx, field.id)|default('') }}"
                        {% if ctx_logged and attribute(ctx, field.id) is defined and attribute(ctx, field.id) != '' %}readonly data-prefilled="1"{% endif %}
                        {% if is_required %}required{% endif %}
                        data-required="{{ is_required ? '1' : '0' }}"
                        class="w-full h-14 px-4 bg-white border-2 border-gray-300 rounded-xl text-base text-text-primary placeholder-gray-400 input-focus transition">
                    </div>

                  {% elseif field.type == 'textarea' %}
                    <div{% if field.hidden %} style="display: none;"{% endif %}>
                      <label class="block text-sm font-medium text-text-primary mb-2">
                        {{ field.label|default(field.name|default(field.id)) }}
                        {% if not is_required %}<span class="text-gray-400 font-normal" data-dc-optional="1">({% if attribute(ctx, 'text_optional') is defined %}{{ attribute(ctx, 'text_optional') }}{% else %}Optional{% endif %})</span>{% endif %}
                      </label>
                      <textarea
                        id="{{ field_id }}"
                        name="{{ field.id }}"
                        data-dc-field="{{ field.id }}"
                        rows="4"
                        placeholder="{{ field.placeholder }}"
                        {% if is_required %}required{% endif %}
                        data-required="{{ is_required ? '1' : '0' }}"
                        {% if ctx_logged and attribute(ctx, field.id) is defined and attribute(ctx, field.id) != '' %}readonly data-prefilled="1"{% endif %}
                        class="w-full px-4 py-3 bg-white border-2 border-gray-300 rounded-xl text-base text-text-primary placeholder-gray-400 input-focus transition">{{ attribute(ctx, field.id)|default('') }}</textarea>
                    </div>

                  {% elseif field.type == 'select' %}
                    <div{% if field.hidden %} style="display: none;"{% endif %}>
                      <label class="block text-sm font-medium text-text-primary mb-2">
                        {{ field.label|default(field.name|default(field.id)) }}
                        {% if not is_required %}<span class="text-gray-400 font-normal" data-dc-optional="1">({% if attribute(ctx, 'text_optional') is defined %}{{ attribute(ctx, 'text_optional') }}{% else %}Optional{% endif %})</span>{% endif %}
                      </label>
                      <select
                        id="{{ field_id }}"
                        name="{{ field.id }}"
                        data-dc-field="{{ field.id }}"
                        {% if is_required %}required{% endif %}
                        data-required="{{ is_required ? '1' : '0' }}"
                        class="w-full h-14 px-4 bg-white border-2 border-gray-300 rounded-xl text-base text-text-primary input-focus transition appearance-none bg-no-repeat bg-right"
                        style="background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27currentColor%27 stroke-width=%272%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3e%3cpolyline points=%276 9 12 15 18 9%27%3e%3c/polyline%3e%3c/svg%3e'); background-position: right 1rem center; background-size: 1.5em 1.5em;">
                        <option value="">{{ field.placeholder }}</option>
                        {% if field.id == 'country_id' or field.id == 'payment_country_id' %}
                          {% for country in ctx_countries %}
                            {% set selected_country = attribute(ctx, field.id) is defined and attribute(ctx, field.id) ? attribute(ctx, field.id) : (ctx_country_id) %}
                            <option value="{{ country.country_id }}" {% if country.country_id == selected_country %}selected{% endif %}>{{ country.name }}</option>
                          {% endfor %}
                          {% if ctx_logged and attribute(ctx, field.id) is defined and attribute(ctx, field.id) != '' %}
                            <input type="hidden" name="{{ field.id }}" value="{{ attribute(ctx, field.id)|default('') }}" data-prefilled-hidden>
                          {% endif %}
                        {% endif %}
                      </select>
                    </div>

                  {% elseif field.type == 'checkbox' %}
                    <div class="pt-4"{% if field.hidden %} style="display: none;"{% endif %}>
                      <label class="flex items-center gap-3 cursor-pointer">
                        <input
                          type="checkbox"
                          id="{{ field_id }}"
                          name="{{ field.id }}"
                          data-dc-field="{{ field.id }}"
                          {% if is_required %}required{% endif %}
                          data-required="{{ is_required ? '1' : '0' }}"
                          class="w-5 h-5 accent-primary cursor-pointer"
                          {% if attribute(ctx, field.id) %}checked{% endif %}
                          {% if ctx_logged and attribute(ctx, field.id) is defined and attribute(ctx, field.id) %}disabled data-prefilled="1"{% endif %}>
                          {% if ctx_logged and attribute(ctx, field.id) is defined and attribute(ctx, field.id) %}
                            <input type="hidden" name="{{ field.id }}" value="1" data-prefilled-hidden>
                          {% endif %}
                        <span class="text-sm font-medium text-text-primary">{{ field.label|default(field.name|default(field.id)) }}</span>
                      </label>
                    </div>
                  {% endif %}
                {% endfor %}
                </div>{# end grid #}
              {% endif %}
            {% endmacro %}

            <div class="space-y-4" id="shipping-address-fields">
              {% if block.rows is defined and block.rows|length > 0 %}
                {# Part 1: Render rows BEFORE shipping methods (country + zone) #}
                {% for row in block.rows %}
                  {% if not row.after_shipping is defined or not row.after_shipping %}
                    {{ _self.renderRow(row, _context) }}
                  {% endif %}
                {% endfor %}
              {% endif %}

              {# Special handling for shipping/payment methods based on block ID #}
              {% if block.id == 'shipping_address' %}
                <div class="pt-4">
                  <label class="block text-sm font-medium text-text-primary mb-3">{{ text_shipping_method }}</label>
                  <div class="space-y-3" id="shipping-methods">
                    <div class="text-sm text-text-secondary py-4">
                        {{ text_fill_address_to_see_shipping|default('Please fill in your address and select a region to see available shipping methods.') }}
                      </div>
                  </div>
                </div>

                {# Part 2: Render rows AFTER shipping methods (company, address, city, postcode) #}
                {# These fields are hidden initially and revealed when a shipping method is selected #}
                <div class="after-shipping-fields space-y-4 pt-4" id="after-shipping-fields">
                {% if block.rows is defined and block.rows|length > 0 %}
                  {% for row in block.rows %}
                    {% if row.after_shipping is defined and row.after_shipping %}
                      {{ _self.renderRow(row, _context) }}
                    {% endif %}
                  {% endfor %}
                {% endif %}
                </div>
              {% endif %}

              {# Payment Address Same as Shipping checkbox #}
              {% if block.id == 'shipping_address' %}
                <div class="pt-4 border-t border-gray-200 mt-4">
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" id="payment-same-as-shipping" checked class="w-5 h-5 accent-primary cursor-pointer">
                    <span class="text-sm font-medium text-text-primary">{{ text_payment_same_as_shipping|default('Payment address is the same as shipping address') }}</span>
                  </label>
                </div>
              {% endif %}

              {# Guest Create Account - Checkbox and Password fields #}
              {% if block.id == 'customer_details' and guest_create_account and not logged %}
                <div class="pt-4 border-t border-gray-200 mt-4">
                  <label class="flex items-center gap-3 cursor-pointer mb-4">
                    <input type="checkbox" id="create-account-checkbox" class="w-5 h-5 accent-primary cursor-pointer">
                    <span class="text-sm font-medium text-text-primary">{{ text_create_account }}</span>
                  </label>

                  <div id="create-account-fields" class="space-y-4" style="display: none;">
                    <div>
                      <label class="block text-sm font-medium text-text-primary mb-2">
                        {{ entry_password }}
                      </label>
                      <input
                        type="password"
                        id="input-password"
                        name="password"
                        placeholder="{{ placeholder_password|default('Enter password') }}"
                        class="w-full h-14 px-4 bg-white border-2 border-gray-300 rounded-xl text-base text-text-primary placeholder-gray-400 input-focus transition">
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-text-primary mb-2">
                        {{ entry_confirm }}
                      </label>
                      <input
                        type="password"
                        id="input-confirm-password"
                        name="confirm_password"
                        placeholder="{{ placeholder_confirm_password|default('Re-enter password') }}"
                        class="w-full h-14 px-4 bg-white border-2 border-gray-300 rounded-xl text-base text-text-primary placeholder-gray-400 input-focus transition">
                    </div>
                    <p class="text-xs text-gray-500">
                      <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      {{ text_account_created_after_checkout|default('An account will be created for you after successful checkout.') }}
                    </p>
                  </div>
                </div>
              {% endif %}

              {% if block.id == 'payment_method' %}
                <div class="space-y-3" id="payment-methods">
                  <div class="text-sm text-text-secondary py-4">
                    {{ text_fill_shipping_to_see_payment|default('Please select a shipping method to see available payment methods.') }}
                  </div>
                </div>
                <!-- Hidden container for payment extension form (loaded via AJAX) -->
                <div id="payment-extension-container" style="display: none;"></div>
              {% endif %}
            </div>
          </div>
          {% endif %}
        {% endif %}
      {% endfor %}

      <!-- Trust Badges -->
      <div class="flex flex-wrap gap-3 justify-center pb-8 lg:pb-0">
        <div class="trust-badge">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
          <span>{{ text_secure }}</span>
        </div>
        <div class="trust-badge">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          <span>{{ text_return }}</span>
        </div>
        <div class="trust-badge">
          <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
          </svg>
          <span>{{ text_payment_secure }}</span>
        </div>
      </div>
    </div>

    <!-- Right Column - Order Summary (40%) -->
    <div class="lg:col-span-5">
      <div class="sticky-summary bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
        <h2 class="text-xl font-semibold text-text-primary mb-6">{{ text_order_summary }}</h2>

        <!-- Order Items -->
        <div class="border-b border-gray-200 pb-4 mb-4">
          <div class="space-y-0" id="cart-items">
            {% if cart_products %}
              {% for product in cart_products %}
              <div class="order-item">
                <div class="w-16 h-16 bg-gray-100 rounded-lg overflow-hidden flex-shrink-0">
                  <img src="{{ product.thumb }}" alt="{{ product.name }}" class="w-full h-full object-cover">
                </div>
                <div class="flex-1 min-w-0">
                  <h4 class="font-medium text-text-primary text-sm mb-1 truncate">{{ product.name }}</h4>
                  <p class="text-sm text-text-secondary">{{ text_quantity }}: {{ product.quantity }}</p>
                  {% if product.option %}
                    {% for option in product.option %}
                    <p class="text-xs text-text-secondary">{{ option.name }}: {{ option.value }}</p>
                    {% endfor %}
                  {% endif %}
                </div>
                <div class="text-right">
                  <p class="font-semibold text-text-primary">{{ product.total }}</p>
                </div>
              </div>
              {% endfor %}
            {% else %}
              <div class="text-center py-8">
                <p class="text-text-secondary">{{ text_empty_cart }}</p>
              </div>
            {% endif %}
          </div>
        </div>

        <!-- Promo Code -->
        <div class="mb-4">
          <div class="flex gap-2 items-stretch">
            <input type="text" id="coupon-code" placeholder="{{ text_coupon }}"
              class="flex-1 h-12 px-4 bg-gray-50 border border-gray-300 rounded-lg text-sm text-text-primary placeholder-gray-400 focus:border-primary focus:bg-white transition">
            <button type="button" id="apply-coupon" class="px-4 sm:px-6 h-12 bg-gray-100 hover:bg-gray-200 text-text-primary font-medium rounded-lg transition text-sm whitespace-nowrap flex-shrink-0">
              {{ button_coupon }}
            </button>
          </div>
        </div>

        <!-- Totals -->
        <div class="space-y-3 border-t border-gray-200 pt-4 mb-6" id="cart-totals">
          {% if totals %}
            {% for total in totals %}
            <div class="flex justify-between text-sm {% if total.title == 'Total' %}text-base font-semibold border-t border-gray-200 pt-3{% endif %}">
              <span class="{% if total.title == 'Total' %}text-text-primary{% else %}text-text-secondary{% endif %}">{{ total.title }}</span>
              <span class="font-medium {% if total.title == 'Total' %}text-xl text-primary{% else %}text-text-primary{% endif %}">{{ total.text }}</span>
            </div>
            {% endfor %}
          {% else %}
            <div class="flex justify-between text-base font-semibold">
              <span class="text-text-primary">{{ text_total }}</span>
              <span class="text-xl text-primary">$0.00</span>
            </div>
          {% endif %}
        </div>

        <!-- Place Order Button -->
        <button type="button" id="button-confirm" class="gradient-primary w-full h-14 rounded-xl text-white font-semibold text-base btn-hover btn-active transition-all">
          {{ button_confirm }}
        </button>

        <p class="text-xs text-center text-text-secondary mt-4">
          {{ text_checkout_notice }}
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Terms & Conditions Modal -->
<div id="terms-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4" style="display: none;">
  <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] flex flex-col">
    <div class="flex items-center justify-between p-6 border-b border-gray-200">
      <h3 class="text-xl font-semibold text-text-primary">{{ text_terms }}</h3>
      <button type="button" id="close-terms-modal" class="text-gray-400 hover:text-gray-600 transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
