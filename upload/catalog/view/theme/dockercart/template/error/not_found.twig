{{ header }}

<main class="py-10 sm:py-12 px-4 sm:px-6 lg:px-8 bg-white min-h-screen">
  <div class="max-w-5xl mx-auto">
    {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
      breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-400 mb-5',
      breadcrumbs_link_class: 'hover:text-blue-600 transition',
      breadcrumbs_last_class: 'text-gray-600 font-semibold'
    } %}

    {{ content_top }}

    <section class="bg-white border border-gray-100 rounded-3xl shadow-sm p-8 sm:p-10 text-center">
      <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-red-50 text-red-500 mb-4">
        <i data-lucide="file-warning" class="w-7 h-7"></i>
      </span>

      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-2">{{ heading_title|default('Page not found') }}</h1>
      <p class="text-gray-500 max-w-xl mx-auto">{{ text_error|default('The page you requested could not be found. Please check the URL or return to the homepage.') }}</p>

      <a href="{{ continue|default('/') }}" class="mt-6 inline-flex items-center justify-center px-5 py-2.5 rounded-xl bg-blue-600 text-white text-sm font-semibold hover:bg-blue-700 transition">
        {{ button_continue|default('Continue') }}
      </a>
    </section>

    {{ content_bottom }}
  </div>
</main>

{{ footer }}
