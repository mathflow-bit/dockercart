{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      {{ content_top }}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        {# ── Categories ── #}
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6">
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-5">{{ text_category }}</p>
          <ul class="space-y-2">
            {% for category_1 in categories %}
            <li>
              <a href="{{ category_1.href }}" class="text-sm font-semibold text-gray-800 hover:text-blue-600 transition flex items-center gap-2">
                <i data-lucide="folder" class="w-4 h-4 text-gray-300 flex-shrink-0"></i>
                {{ category_1.name }}
              </a>
              {% if category_1.children %}
              <ul class="mt-1.5 ml-6 space-y-1">
                {% for category_2 in category_1.children %}
                <li>
                  <a href="{{ category_2.href }}" class="text-sm text-gray-600 hover:text-blue-600 transition flex items-center gap-2">
                    <i data-lucide="folder-open" class="w-3.5 h-3.5 text-gray-300 flex-shrink-0"></i>
                    {{ category_2.name }}
                  </a>
                  {% if category_2.children %}
                  <ul class="mt-1 ml-5 space-y-1">
                    {% for category_3 in category_2.children %}
                    <li>
                      <a href="{{ category_3.href }}" class="text-xs text-gray-500 hover:text-blue-600 transition flex items-center gap-1.5">
                        <i data-lucide="chevron-right" class="w-3 h-3 text-gray-300 flex-shrink-0"></i>
                        {{ category_3.name }}
                      </a>
                    </li>
                    {% endfor %}
                  </ul>
                  {% endif %}
                </li>
                {% endfor %}
              </ul>
              {% endif %}
            </li>
            {% endfor %}
          </ul>
        </div>

        {# ── Account & Site links ── #}
        <div class="space-y-4">

          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-5">{{ text_account }}</p>
            <ul class="space-y-2 text-sm">
              <li><a href="{{ account }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="user" class="w-4 h-4 text-gray-300"></i> {{ text_account }}</a></li>
              <li><a href="{{ edit }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="settings" class="w-4 h-4 text-gray-300"></i> {{ text_edit }}</a></li>
              <li><a href="{{ password }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="lock" class="w-4 h-4 text-gray-300"></i> {{ text_password }}</a></li>
              <li><a href="{{ address }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="map-pin" class="w-4 h-4 text-gray-300"></i> {{ text_address }}</a></li>
              <li><a href="{{ history }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="shopping-bag" class="w-4 h-4 text-gray-300"></i> {{ text_history }}</a></li>
              <li><a href="{{ download }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="download" class="w-4 h-4 text-gray-300"></i> {{ text_download }}</a></li>
            </ul>
          </div>

          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-5">{{ text_shopping }}</p>
            <ul class="space-y-2 text-sm">
              {% if special %}
              <li><a href="{{ special }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="tag" class="w-4 h-4 text-gray-300"></i> {{ text_special }}</a></li>
              {% endif %}
              <li><a href="{{ history }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="shopping-cart" class="w-4 h-4 text-gray-300"></i> {{ text_cart }}</a></li>
              <li><a href="{{ checkout }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="credit-card" class="w-4 h-4 text-gray-300"></i> {{ text_checkout }}</a></li>
              <li><a href="{{ search }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="search" class="w-4 h-4 text-gray-300"></i> {{ text_search }}</a></li>
            </ul>
          </div>

          {% if informations %}
          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6">
            <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-5">{{ text_information }}</p>
            <ul class="space-y-2 text-sm">
              {% for information in informations %}
              <li><a href="{{ information.href }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="file-text" class="w-4 h-4 text-gray-300"></i> {{ information.title }}</a></li>
              {% endfor %}
              <li><a href="{{ contact }}" class="flex items-center gap-2 text-gray-700 hover:text-blue-600 transition"><i data-lucide="mail" class="w-4 h-4 text-gray-300"></i> {{ text_contact }}</a></li>
            </ul>
          </div>
          {% endif %}

        </div>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
