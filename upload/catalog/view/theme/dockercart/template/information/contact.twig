{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      {{ content_top }}

      {# ── Main location ── #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8 mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-5">{{ text_location }}</p>
        <div class="flex flex-col sm:flex-row gap-6">
          {% if image %}
          <div class="flex-shrink-0">
            <img src="{{ image }}" alt="{{ store }}" class="w-24 h-24 object-cover rounded-2xl border border-gray-100" />
          </div>
          {% endif %}
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 flex-1 text-sm">
            <div>
              <p class="font-bold text-gray-900 mb-1">{{ store }}</p>
              <address class="not-italic text-gray-500 leading-relaxed">{{ address }}</address>
              {% if geocode %}
              <a href="https://maps.google.com/maps?q={{ geocode|url_encode }}&hl={{ geocode_hl }}&t=m&z=15" target="_blank"
                class="inline-flex items-center gap-1.5 mt-3 text-blue-600 hover:text-blue-700 text-xs font-medium border border-blue-200 hover:border-blue-300 px-3 py-1.5 rounded-lg transition">
                <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
                {{ button_map }}
              </a>
              {% endif %}
            </div>
            <div>
              <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1">{{ text_telephone }}</p>
              <p class="text-gray-800">{{ telephone }}</p>
              {% if fax %}
              <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1 mt-3">{{ text_fax }}</p>
              <p class="text-gray-800">{{ fax }}</p>
              {% endif %}
            </div>
            <div>
              {% if open %}
              <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1">{{ text_open }}</p>
              <p class="text-gray-800 leading-relaxed">{{ open }}</p>
              {% endif %}
              {% if comment %}
              <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1 mt-3">{{ text_comment }}</p>
              <p class="text-gray-800 leading-relaxed">{{ comment }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      </div>

      {# ── Additional locations ── #}
      {% if locations %}
      <div class="mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-3 px-1">{{ text_store }}</p>
        <div class="space-y-3" id="accordion-locations">
          {% for location in locations %}
          <details class="bg-white rounded-2xl border border-gray-100 shadow-sm group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-semibold text-gray-800 text-sm">
              {{ location.name }}
              <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180"></i>
            </summary>
            <div class="px-5 pb-5 border-t border-gray-50">
              <div class="flex flex-col sm:flex-row gap-6 pt-4">
                {% if location.image %}
                <div class="flex-shrink-0">
                  <img src="{{ location.image }}" alt="{{ location.name }}" class="w-20 h-20 object-cover rounded-xl border border-gray-100" />
                </div>
                {% endif %}
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 flex-1 text-sm">
                  <div>
                    <p class="font-bold text-gray-900 mb-1">{{ location.name }}</p>
                    <address class="not-italic text-gray-500 leading-relaxed">{{ location.address }}</address>
                    {% if location.geocode %}
                    <a href="https://maps.google.com/maps?q={{ location.geocode|url_encode }}&hl={{ geocode_hl }}&t=m&z=15" target="_blank"
                      class="inline-flex items-center gap-1.5 mt-3 text-blue-600 hover:text-blue-700 text-xs font-medium border border-blue-200 hover:border-blue-300 px-3 py-1.5 rounded-lg transition">
                      <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
                      {{ button_map }}
                    </a>
                    {% endif %}
                  </div>
                  <div>
                    <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1">{{ text_telephone }}</p>
                    <p class="text-gray-800">{{ location.telephone }}</p>
                    {% if location.fax %}
                    <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1 mt-3">{{ text_fax }}</p>
                    <p class="text-gray-800">{{ location.fax }}</p>
                    {% endif %}
                  </div>
                  <div>
                    {% if location.open %}
                    <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1">{{ text_open }}</p>
                    <p class="text-gray-800 leading-relaxed">{{ location.open }}</p>
                    {% endif %}
                    {% if location.comment %}
                    <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1 mt-3">{{ text_comment }}</p>
                    <p class="text-gray-800 leading-relaxed">{{ location.comment }}</p>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          </details>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {# ── Contact form ── #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-6">{{ text_contact }}</p>
        <form action="{{ action }}" method="post" enctype="multipart/form-data">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-name">{{ entry_name }}</label>
              <input type="text" name="name" value="{{ name }}" id="input-name"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_name %}<p class="text-sm text-red-500 mt-1">{{ error_name }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-email">{{ entry_email }}</label>
              <input type="email" name="email" value="{{ email }}" id="input-email"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_email %}<p class="text-sm text-red-500 mt-1">{{ error_email }}</p>{% endif %}
            </div>
          </div>
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-enquiry">{{ entry_enquiry }}</label>
            <textarea name="enquiry" rows="6" id="input-enquiry"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white resize-y">{{ enquiry }}</textarea>
            {% if error_enquiry %}<p class="text-sm text-red-500 mt-1">{{ error_enquiry }}</p>{% endif %}
          </div>
          {% if captcha %}
          <div class="mb-5">{{ captcha }}</div>
          {% endif %}
          <div class="flex justify-end">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-xl transition-colors text-sm flex items-center gap-2">
              <i data-lucide="send" class="w-4 h-4"></i>
              {{ button_submit }}
            </button>
          </div>
        </form>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
