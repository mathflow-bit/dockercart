{{ header }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
<style>
  .dc-gal-wrap {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .dc-gal-row {
    display: flex;
    gap: .75rem;
  }

  /* Fixed height for multi-photo rows; single photo uses natural height */
  .dc-gal-row--2 { min-height: 20rem; }
  .dc-gal-row--3,
  .dc-gal-row--4 { min-height: 26rem; }

  .dc-gal-item {
    flex: 1;
    border: 0;
    background: transparent;
    padding: 0;
    overflow: hidden;
    border-radius: 1rem;
    cursor: zoom-in;
    position: relative;
    min-height: 14rem;
    transition: transform .3s cubic-bezier(.22, 1, .36, 1), box-shadow .3s cubic-bezier(.22, 1, .36, 1);
  }

  /* Primary slot gets extra flex-weight in split rows */
  .dc-gal-item--big { flex: 1.3; }

  .dc-gal-item:hover {
    transform: scale(1.012);
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.13);
    z-index: 1;
  }

  /* Default: crop-fill for square/portrait images */
  .dc-gal-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform .6s cubic-bezier(.22, 1, .36, 1);
  }

  .dc-gal-item:hover img { transform: scale(1.06); }

  /* Wide/panoramic: show full image without cropping */
  .dc-gal-item.dc-ratio-wide {
    background: #f8fafc;
  }
  .dc-gal-item.dc-ratio-wide img {
    object-fit: contain;
  }

  /* Single photo: natural proportions, no forced tall slot */
  .dc-gal-row--1 .dc-gal-item {
    min-height: 0;
  }
  .dc-gal-row--1 .dc-gal-item img {
    height: auto;
    max-height: min(68vh, 34rem);
    object-fit: contain;
  }

  .dc-gal-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .dc-gal-col .dc-gal-item {
    flex: 1;
    min-height: 0;
  }

  @media (max-width: 639px) {
    .dc-gal-row { flex-direction: column; }
    .dc-gal-col { flex-direction: column; }
    .dc-gal-row--2, .dc-gal-row--3, .dc-gal-row--4 { min-height: auto; }
    .dc-gal-item { min-height: 16rem; }
    .dc-gal-col .dc-gal-item { min-height: 14rem; }
    .dc-gal-row--1 .dc-gal-item img { max-height: 22rem; }
  }

  .zoom-hint { opacity: 0; transform: translateY(6px); transition: all .25s ease; }
  .dc-gal-item:hover .zoom-hint { opacity: 1; transform: translateY(0); }

  .dc-messenger-fab-panel {
    transition: opacity .2s ease, transform .2s ease;
  }
</style>
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      {{ content_top }}

      {# ── Main location ── #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8 mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-5">{{ text_location }}</p>
        <div class="flex flex-col sm:flex-row gap-6">
          <div class="flex-shrink-0">
            <span class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-blue-50 text-blue-600 border border-blue-100 inline-flex items-center justify-center shadow-sm">
              <i data-lucide="map-pin" class="w-8 h-8 sm:w-10 sm:h-10"></i>
            </span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 flex-1 text-sm">
            <div>
              <p class="font-bold text-gray-900 mb-1">{{ store }}</p>
              <address class="not-italic text-gray-500 leading-relaxed">{{ address }}</address>
              {% if geocode_url %}
              <a href="{{ geocode_url }}" target="_blank"
                class="inline-flex items-center gap-1.5 mt-3 text-blue-600 hover:text-blue-700 text-xs font-medium border border-blue-200 hover:border-blue-300 px-3 py-1.5 rounded-lg transition">
                <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
                {{ button_map }}
              </a>
              {% endif %}
            </div>
            <div>
              <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1">{{ text_telephone }}</p>
              <div class="flex flex-col items-start gap-2">
                <a href="tel:{{ telephone }}" class="text-gray-800 hover:text-blue-700 transition block">{{ telephone }}</a>
              {% if fax %}
                <a href="tel:{{ fax }}" class="text-gray-800 hover:text-blue-700 transition block">{{ fax }}</a>
              {% endif %}
              </div>

              {% if social_links %}
              <div class="flex flex-wrap items-center gap-2.5 mt-4">
                {% for social in social_links %}
                <a href="{{ social.link }}" target="_blank" rel="noopener nofollow"
                  class="w-9 h-9 inline-flex items-center justify-center rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition"
                  aria-label="Messenger link {{ loop.index }}">
                  <img src="{{ social.image }}" alt="" class="w-6 h-6 object-contain" />
                </a>
                {% endfor %}
              </div>
              {% endif %}
            </div>
            <div>
              {% if open %}
              <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1">{{ text_open }}</p>
              <p class="text-gray-800 leading-relaxed">{{ open }}</p>
              {% endif %}
              {% if comment %}
              <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1 mt-3">{{ text_comment }}</p>
              <p class="text-gray-800 leading-relaxed">{{ comment }}</p>
              {% endif %}
            </div>
          </div>
        </div>

      </div>

      {% if store_images %}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8 mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-5">{{ text_store_gallery }}</p>
        {% set total = store_images|length %}
        {% set i0 = store_images[0] is defined ? store_images[0] : null %}
        {% set i1 = store_images[1] is defined ? store_images[1] : null %}
        {% set i2 = store_images[2] is defined ? store_images[2] : null %}
        {% set i3 = store_images[3] is defined ? store_images[3] : null %}
        {% set i4 = store_images[4] is defined ? store_images[4] : null %}
        <div class="dc-gal-wrap">

          {% if total == 1 %}
          {# ── 1 фото: натуральные пропорции ── #}
          <div class="dc-gal-row dc-gal-row--1">
            <button type="button" class="dc-gal-item {{ i0.ratio_class }}" data-gallery-index="0">
              <img src="{{ i0.preview }}" data-popup="{{ i0.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
          </div>

          {% elseif total == 2 %}
          {# ── 2 фото: равные колонки ── #}
          <div class="dc-gal-row dc-gal-row--2">
            <button type="button" class="dc-gal-item {{ i0.ratio_class }}" data-gallery-index="0">
              <img src="{{ i0.preview }}" data-popup="{{ i0.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
            <button type="button" class="dc-gal-item {{ i1.ratio_class }}" data-gallery-index="1">
              <img src="{{ i1.preview }}" data-popup="{{ i1.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
          </div>

          {% elseif total == 3 %}
          {# ── 3 фото: [большое | 2 сложенных] ── #}
          <div class="dc-gal-row dc-gal-row--3">
            <button type="button" class="dc-gal-item dc-gal-item--big {{ i0.ratio_class }}" data-gallery-index="0">
              <img src="{{ i0.preview }}" data-popup="{{ i0.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
            <div class="dc-gal-col">
              <button type="button" class="dc-gal-item {{ i1.ratio_class }}" data-gallery-index="1">
                <img src="{{ i1.preview }}" data-popup="{{ i1.popup }}" alt="{{ store }}" />
                <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
              </button>
              <button type="button" class="dc-gal-item {{ i2.ratio_class }}" data-gallery-index="2">
                <img src="{{ i2.preview }}" data-popup="{{ i2.popup }}" alt="{{ store }}" />
                <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
              </button>
            </div>
          </div>

          {% elseif total == 4 %}
          {# ── 4 фото: ряд1 [большое|маленькое], ряд2 [маленькое|большое] ── #}
          <div class="dc-gal-row dc-gal-row--4">
            <button type="button" class="dc-gal-item dc-gal-item--big {{ i0.ratio_class }}" data-gallery-index="0">
              <img src="{{ i0.preview }}" data-popup="{{ i0.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
            <button type="button" class="dc-gal-item {{ i1.ratio_class }}" data-gallery-index="1">
              <img src="{{ i1.preview }}" data-popup="{{ i1.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
          </div>
          <div class="dc-gal-row dc-gal-row--4">
            <button type="button" class="dc-gal-item {{ i2.ratio_class }}" data-gallery-index="2">
              <img src="{{ i2.preview }}" data-popup="{{ i2.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
            <button type="button" class="dc-gal-item dc-gal-item--big {{ i3.ratio_class }}" data-gallery-index="3">
              <img src="{{ i3.preview }}" data-popup="{{ i3.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
          </div>

          {% else %}
          {# ── 5 фото: [большое | 2 сложенных] + [равные | равные] ── #}
          <div class="dc-gal-row dc-gal-row--3">
            <button type="button" class="dc-gal-item dc-gal-item--big {{ i0.ratio_class }}" data-gallery-index="0">
              <img src="{{ i0.preview }}" data-popup="{{ i0.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
            <div class="dc-gal-col">
              <button type="button" class="dc-gal-item {{ i1.ratio_class }}" data-gallery-index="1">
                <img src="{{ i1.preview }}" data-popup="{{ i1.popup }}" alt="{{ store }}" />
                <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
              </button>
              <button type="button" class="dc-gal-item {{ i2.ratio_class }}" data-gallery-index="2">
                <img src="{{ i2.preview }}" data-popup="{{ i2.popup }}" alt="{{ store }}" />
                <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
              </button>
            </div>
          </div>
          <div class="dc-gal-row dc-gal-row--2">
            <button type="button" class="dc-gal-item {{ i3.ratio_class }}" data-gallery-index="3">
              <img src="{{ i3.preview }}" data-popup="{{ i3.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
            <button type="button" class="dc-gal-item {{ i4.ratio_class }}" data-gallery-index="4">
              <img src="{{ i4.preview }}" data-popup="{{ i4.popup }}" alt="{{ store }}" />
              <span class="zoom-hint absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 bg-gray-900/75 text-white text-[11px] font-semibold px-2 py-1 rounded-lg backdrop-blur-sm"><i data-lucide="zoom-in" class="w-3 h-3"></i></span>
            </button>
          </div>
          {% endif %}

        </div>
      </div>
      {% endif %}

      {# ── Additional locations ── #}
      {% if locations %}
      <div class="mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-3 px-1">{{ text_store }}</p>
        <div class="space-y-3" id="accordion-locations">
          {% for location in locations %}
          <details class="bg-white rounded-2xl border border-gray-100 shadow-sm group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-semibold text-gray-800 text-sm">
              {{ location.name }}
              <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180"></i>
            </summary>
            <div class="px-5 pb-5 border-t border-gray-50">
              <div class="flex flex-col sm:flex-row gap-6 pt-4">
                {% if location.image %}
                <div class="flex-shrink-0">
                  <img src="{{ location.image }}" alt="{{ location.name }}" class="w-20 h-20 object-cover rounded-xl border border-gray-100" />
                </div>
                {% endif %}
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 flex-1 text-sm">
                  <div>
                    <p class="font-bold text-gray-900 mb-1">{{ location.name }}</p>
                    <address class="not-italic text-gray-500 leading-relaxed">{{ location.address }}</address>
                    {% if location.geocode_url %}
                    <a href="{{ location.geocode_url }}" target="_blank"
                      class="inline-flex items-center gap-1.5 mt-3 text-blue-600 hover:text-blue-700 text-xs font-medium border border-blue-200 hover:border-blue-300 px-3 py-1.5 rounded-lg transition">
                      <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
                      {{ button_map }}
                    </a>
                    {% endif %}
                  </div>
                  <div>
                    <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1">{{ text_telephone }}</p>
                    <p class="text-gray-800">{{ location.telephone }}</p>
                    {% if location.fax %}
                    <p class="text-gray-800 mt-3">{{ location.fax }}</p>
                    {% endif %}
                  </div>
                  <div>
                    {% if location.open %}
                    <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1">{{ text_open }}</p>
                    <p class="text-gray-800 leading-relaxed">{{ location.open }}</p>
                    {% endif %}
                    {% if location.comment %}
                    <p class="font-semibold text-gray-500 text-xs uppercase tracking-widest mb-1 mt-3">{{ text_comment }}</p>
                    <p class="text-gray-800 leading-relaxed">{{ location.comment }}</p>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          </details>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {# ── Contact form ── #}
      {% if contact_form_status %}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-6">{{ text_contact }}</p>
        <form action="{{ action }}" method="post" enctype="multipart/form-data">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-name">{{ entry_name }}</label>
              <input type="text" name="name" value="{{ name }}" id="input-name"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_name %}<p class="text-sm text-red-500 mt-1">{{ error_name }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-email">{{ entry_email }}</label>
              <input type="email" name="email" value="{{ email }}" id="input-email"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_email %}<p class="text-sm text-red-500 mt-1">{{ error_email }}</p>{% endif %}
            </div>
          </div>
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-enquiry">{{ entry_enquiry }}</label>
            <textarea name="enquiry" rows="6" id="input-enquiry"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white resize-y">{{ enquiry }}</textarea>
            {% if error_enquiry %}<p class="text-sm text-red-500 mt-1">{{ error_enquiry }}</p>{% endif %}
          </div>
          {% if captcha %}
          <div class="mb-5">{{ captcha }}</div>
          {% endif %}
          <div class="flex justify-end">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-xl transition-colors text-sm flex items-center gap-2">
              <i data-lucide="send" class="w-4 h-4"></i>
              {{ button_submit }}
            </button>
          </div>
        </form>
      </div>
      {% endif %}

      {{ content_bottom }}
    </div>
  </section>

</main>



<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var galleryItems = Array.from(document.querySelectorAll('.dc-gal-item[data-gallery-index]'));

  if (galleryItems.length && typeof GLightbox === 'function') {
    galleryItems.sort(function(a, b) {
      return parseInt(a.dataset.galleryIndex || '0', 10) - parseInt(b.dataset.galleryIndex || '0', 10);
    });

    var elements = galleryItems.map(function(item) {
      var img = item.querySelector('img');
      return { href: img ? (img.dataset.popup || img.src) : '', type: 'image' };
    }).filter(function(e) { return e.href; });

    if (elements.length) {
      var lightbox = GLightbox({
        elements: elements,
        loop: true,
        touchNavigation: true,
        zoomable: true,
        openEffect: 'zoom',
        closeEffect: 'fade'
      });

      galleryItems.forEach(function(item) {
        item.addEventListener('click', function() {
          lightbox.openAt(parseInt(item.dataset.galleryIndex || '0', 10));
        });
      });
    }
  }

  if (typeof lucide !== 'undefined') {
    lucide.createIcons();
  }
});
</script>
{{ footer }}
