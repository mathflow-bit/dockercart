{% macro render_children(nodes) %}
  {% import _self as tree %}

  {% if nodes %}
    <ul class="space-y-1.5 border-l border-gray-200 pl-3">
      {% for child in nodes %}
        <li>
          <a href="{{ child.href }}" class="flex items-center justify-between gap-2 text-sm text-gray-600 hover:text-blue-600 transition py-0.5">
            <span>{{ child.name }}</span>
            <span class="text-[11px] text-gray-400">{{ child.total }}</span>
          </a>

          {% if child.children %}
            <div class="mt-1">
              {{ tree.render_children(child.children) }}
            </div>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}

{% import _self as tree %}

{{ header }}

<section class="py-10 sm:py-12 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
      breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-400 mb-4',
      breadcrumbs_link_class: 'hover:text-blue-600 transition',
      breadcrumbs_last_class: 'text-gray-600'
    } %}

    <div class="mb-8">
      <p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-1">{{ text_browse_by }}</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{{ heading_title }}</h1>
      <p class="text-sm text-gray-500 mt-2">{{ text_intro }}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
      <aside class="lg:col-span-4 xl:col-span-3">
        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-4 sm:p-5 lg:sticky lg:top-[152px]">
          <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest mb-4">{{ text_show }}</h2>

          {% if categories_tree %}
          <div class="space-y-2 dc-cats-tree">
            {% for category in categories_tree %}
              <details class="group border border-gray-100 rounded-xl">
                <summary class="list-none cursor-pointer select-none px-3 py-2.5 flex items-center justify-between gap-2 hover:bg-blue-50/50 transition">
                  <span class="text-sm font-semibold text-gray-800">{{ category.name }}</span>
                  <span class="text-xs text-gray-400">{{ category.total }}</span>
                </summary>

                <div class="px-3 pb-3">
                  <a href="{{ category.href }}" class="inline-flex items-center gap-1 text-xs font-semibold text-blue-600 hover:text-blue-700 mb-2">→ {{ text_items }}</a>

                  {{ tree.render_children(category.children) }}
                </div>
              </details>
            {% endfor %}
          </div>
          {% else %}
          <p class="text-sm text-gray-500">{{ text_empty }}</p>
          {% endif %}
        </div>
      </aside>

      <div class="lg:col-span-8 xl:col-span-9">
        {% if popular_categories %}
        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-5">
          {% for category in popular_categories %}
            <a href="{{ category.href }}" class="group relative rounded-2xl overflow-hidden h-44 sm:h-52 block border border-gray-100 shadow-sm hover:shadow-xl transition">
              <img src="{{ category.image }}" alt="{{ category.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-transparent"></div>
                <div class="absolute left-3 right-3 bottom-3">
                <h3 class="text-white text-sm font-bold leading-tight">{{ category.name }}</h3>
                <p class="text-white/80 text-xs mt-0.5">{{ text_items_count|format(category.total) }}</p>
              </div>
            </a>
          {% endfor %}
        </div>
        {% else %}
        <div class="text-center py-12">
          <i data-lucide="folder-x" class="w-16 h-16 text-gray-300 mx-auto mb-4"></i>
          <h2 class="text-xl font-semibold text-gray-600 mb-2">{{ text_empty }}</h2>
          <p class="text-gray-500">{{ text_intro }}</p>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{{ footer }}
