{% if reviews %}
  {% for review in reviews %}
    <div class="dc-review-card bg-white border rounded-xl p-4 mb-4 shadow-sm">
      <div class="dc-review-header flex items-center justify-between mb-2">
        <div class="dc-review-author">
          <strong class="text-sm">{{ review.author }}</strong>
          <div class="text-xs text-muted">{{ review.date_added }}</div>
        </div>
        <div class="dc-review-rating flex items-center gap-2">
          <div class="dc-stars" aria-hidden="true">
            {% for i in 1..5 %}
              {% if review.rating < i %}
                <span class="dc-star" data-val="{{ i }}" aria-label="{{ i }} stars">★</span>
              {% else %}
                <span class="dc-star active" data-val="{{ i }}" aria-label="{{ i }} stars">★</span>
              {% endif %}
            {% endfor %}
          </div>
          <div class="text-sm font-medium">{{ review.rating }}/5</div>
        </div>
      </div>
      <div class="dc-review-body text-sm text-gray-700">{{ review.text|raw }}</div>
    </div>
  {% endfor %}

  <div class="row">
    <div class="col-sm-6 text-left">{{ pagination }}</div>
  </div>
{% else %}
  <p>{{ text_no_reviews }}</p>
{% endif %}
