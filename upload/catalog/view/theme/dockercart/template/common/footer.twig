<!-- ============================================================
     FOOTER
     ============================================================ -->
<footer id="footer" class="bg-gray-950 text-gray-400 px-4 sm:px-6 lg:px-8 pt-16 pb-8">
  <div class="max-w-7xl mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-8 mb-12">

      <!-- Brand column -->
      <div class="col-span-1 lg:col-span-2">
        <div class="mb-5">
        {% if logo_dark %}
            <a href="{{ home }}" class="inline-flex items-center">
              <img src="{{ logo_dark }}" title="{{ name }}" alt="{{ name }}" class="object-contain max-w-[160px] sm:max-w-[220px]" />
            </a>         
        {% endif %}
        </div>

        <!-- Contact info -->
        <ul class="space-y-3 text-sm mb-6">
          {% if store_address %}
          <li class="flex items-start gap-2.5">
            <i data-lucide="map-pin" class="w-4 h-4 text-blue-400 flex-shrink-0 mt-0.5"></i>
            <span>{{ store_address }}</span>
          </li>
          {% endif %}
          <li class="flex items-center gap-2.5">
            <i data-lucide="phone" class="w-4 h-4 text-blue-400 flex-shrink-0"></i>
            <div class="flex flex-col">
              <a href="tel:{{ store_telephone }}" class="hover:text-white transition">{{ store_telephone }}</a>
              {% if store_fax %}
              <a href="tel:{{ store_fax }}" class="hover:text-white transition">{{ store_fax }}</a>
              {% endif %}
            </div>
          </li>
          <li class="flex items-center gap-2.5">
            <i data-lucide="mail" class="w-4 h-4 text-blue-400 flex-shrink-0"></i>
            <a href="mailto:{{ store_email }}" class="hover:text-white transition">{{ store_email }}</a>
          </li>
        </ul>

        <!-- Social icons (configure in admin) -->
        <div class="flex gap-2.5">
          {% if social_links %}
            {% for social in social_links %}
              {% if social.image %}
                <a href="{{ social.link }}" target="_blank" rel="noopener nofollow" class="w-8 h-8 flex items-center justify-center transition" aria-label="Social link">
                  <img src="{{ social.image }}" alt="" class="w-8 h-8 object-contain" />
                </a>
              {% endif %}
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <!-- Information pages -->
      {% if informations %}
      <div>
        <!-- Heading -->
        <h4 class="text-white font-semibold text-sm mb-4">{{ text_information }}</h4>

        <ul id="accordion-information" class="space-y-2.5 text-sm">
          {% for information in informations %}
          <li><a href="{{ information.href }}" class="hover:text-white transition">{{ information.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <!-- Catalog (parent categories) -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4 hidden lg:block">{{ text_catalog }}</h4>
        <button type="button" class="footer-accordion-toggle flex items-center justify-between w-full text-left text-white font-semibold text-sm mb-3 lg:hidden" aria-expanded="false" data-target="accordion-catalog">
          <span>{{ text_catalog }}</span>
          <span class="footer-accordion-arrow inline-flex items-center justify-center"><i data-lucide="chevron-down" class="w-4 h-4"></i></span>
        </button>

        <ul id="accordion-catalog" class="space-y-2.5 text-sm hidden lg:block">
          {# Accent links: New arrivals / Sale #}
          <li><a href="{{ new_arrivals }}" class="hover:text-white transition">{{ text_new_arrivals }}</a></li>
          <li><a href="{{ special }}" class="hover:text-white transition">{{ text_sale }}</a></li>

          {% if show_categories_list %}
            {% for category in categories %}
              <li><a href="{{ category.href }}" class="hover:text-white transition">{{ category.name }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="{{ categories_link }}" class="hover:text-white transition">{{ text_catalog }}</a></li>
            <li><a href="{{ manufacturer }}" class="hover:text-white transition">{{ text_manufacturer }}</a></li>
          {% endif %}
        </ul>
      </div>

      <!-- Service -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4 hidden lg:block">{{ text_service }}</h4>
        <button type="button" class="footer-accordion-toggle flex items-center justify-between w-full text-left text-white font-semibold text-sm mb-3 lg:hidden" aria-expanded="false" data-target="accordion-service">
          <span>{{ text_service }}</span>
          <span class="footer-accordion-arrow inline-flex items-center justify-center"><i data-lucide="chevron-down" class="w-4 h-4"></i></span>
        </button>

        <ul id="accordion-service" class="space-y-2.5 text-sm hidden lg:block">
          <li><a href="{{ contact }}" class="hover:text-white transition">{{ text_contact }}</a></li>
          <li><a href="{{ manufacturer }}" class="hover:text-white transition">{{ text_manufacturer }}</a></li>
          <li><a href="{{ categories_link }}" class="hover:text-white transition">{{ text_catalog }}</a></li>
          <li><a href="{{ return }}" class="hover:text-white transition">{{ text_return }}</a></li>
          <li><a href="{{ sitemap }}" class="hover:text-white transition">{{ text_sitemap }}</a></li>
        </ul>
      </div>

      <!-- My Account -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4 hidden lg:block">{{ text_account }}</h4>
        <button type="button" class="footer-accordion-toggle flex items-center justify-between w-full text-left text-white font-semibold text-sm mb-3 lg:hidden" aria-expanded="false" data-target="accordion-account">
          <span>{{ text_account }}</span>
          <span class="footer-accordion-arrow inline-flex items-center justify-center"><i data-lucide="chevron-down" class="w-4 h-4"></i></span>
        </button>

        <ul id="accordion-account" class="space-y-2.5 text-sm hidden lg:block">
          <li><a href="{{ account }}" class="hover:text-white transition">{{ text_account }}</a></li>
          <li><a href="{{ order }}" class="hover:text-white transition">{{ text_order }}</a></li>
          <li><a href="{{ wishlist }}" class="hover:text-white transition">{{ text_wishlist }}</a></li>
          <li><a href="{{ compare }}" class="hover:text-white transition">{{ text_compare|default('Compare') }}</a></li>
          <li><a href="{{ newsletter }}" class="hover:text-white transition">{{ text_newsletter }}</a></li>
          <li><a href="{{ special }}" class="hover:text-white transition">{{ text_special }}</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <p class="text-gray-500">{{ powered }}</p>
      <!-- Payment method icons -->
      <div class="flex gap-4 items-center opacity-60">
        {% if payment_icons %}
          {% for payment in payment_icons %}
            {% if payment.link %}
            <a href="{{ payment.link }}" target="_blank" rel="noopener nofollow">
              <img src="{{ payment.image }}" alt="Payment" class="h-5 object-contain" />
            </a>
            {% else %}
            <img src="{{ payment.image }}" alt="Payment" class="h-5 object-contain" />
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>

  </div>
</footer>

{% for style in styles %}
<link href="{{ style.href }}" type="text/css" rel="{{ style.rel }}" media="{{ style.media }}" />
{% endfor %}
{% for script in scripts %}
<script src="{{ script }}" type="text/javascript"></script>
{% endfor %}

<!-- Quick View Module -->
<script src="catalog/view/theme/dockercart/javascript/quick-view.js" type="text/javascript"></script>
<script src="catalog/view/theme/dockercart/javascript/load-more.js" type="text/javascript"></script>

