{% if categories %}
{% if menu_type == 'vertical' %}
<div class="hidden lg:block bg-white border-b border-gray-200 h-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-10 flex items-center justify-end">
    <a href="{{ new_arrivals }}" class="flex items-center gap-1 px-3 h-8 text-sm font-bold text-teal-600 hover:text-teal-700 hover:bg-teal-50 transition whitespace-nowrap rounded-sm">
      <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
      {{ text_new_arrivals }}
    </a>
    <a href="{{ special }}" class="flex items-center gap-1 px-3 h-8 text-sm font-bold text-red-500 hover:text-red-600 hover:bg-red-50 transition whitespace-nowrap rounded-sm">
      <i data-lucide="tag" class="w-3.5 h-3.5"></i>
      {{ text_sale }}
    </a>
    {# Information links (bottom = 1) — show when configured; placed here to mirror horizontal "right accent" area #}
    {% if information_links is defined and information_links %}
      {% for info in information_links %}
        <a href="{{ info.href }}" class="flex items-center gap-1 px-3 h-8 text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50 transition whitespace-nowrap rounded-sm">
          {{ info.title }}
        </a>
      {% endfor %}
    {% endif %}
  </div>
</div>

{# ─── Two-panel hamburger (desktop) ──────────────────────────────────── #}
<div id="dc-vertical-menu-panel" class="dc-vertical-menu-panel hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="dc-vm-shell">

      {# LEFT: compact category list #}
      <nav class="dc-vm-left" aria-label="{{ text_catalog }}">
        {% for category in categories %}
        <div class="dc-vm-cat-row" data-vm-cat="{{ loop.index0 }}">
          <a href="{{ category.href }}" class="dc-vm-cat-link{% if category.is_active %} is-active{% endif %}">
            <span>{{ category.name }}</span>
            {% if category.children %}<i data-lucide="chevron-right" class="dc-vm-chevron w-3.5 h-3.5 flex-shrink-0"></i>{% endif %}
          </a>
        </div>
        {% endfor %}
      </nav>

      {# RIGHT: subcategory panel for each top-level category #}
      {# show right panels only if at least one top-level category has children #}
      {% set has_vm_children = false %}
      {% for category in categories %}
        {% if category.children %}
          {% set has_vm_children = true %}
        {% endif %}
      {% endfor %}

      {% if has_vm_children %}
      <div class="dc-vm-right">
        {% for category in categories %}
        <div class="dc-vm-panel" data-vm-panel="{{ loop.index0 }}">
          {% if category.children %}
          <div class="dc-vm-panel-grid" data-cols="{{ category.children|length }}">
            {% for child in category.children %}
            <div class="dc-vm-subcat-group">
              <a href="{{ child.href }}" class="dc-vm-subcat-parent">{{ child.name }}</a>
              {% if child.children %}
              <ul class="dc-vm-subcat-list">
                {% for grandchild in child.children %}
                <li><a href="{{ grandchild.href }}" class="dc-vm-subcat-child">{{ grandchild.name }}</a></li>
                {% endfor %}
              </ul>
              {% endif %}
            </div>
            {% endfor %}
          </div>
          <div class="dc-vm-panel-footer">
            <a href="{{ category.href }}" class="dc-vm-see-all">{{ text_all }} {{ category.name }} →</a>
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% endif %}

    </div>{# /.dc-vm-shell #}
  </div>
</div>

{% else %}
{# ─── Horizontal mega-nav (desktop) — 3 levels inline ──────────────────── #}
<div class="hidden lg:block bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center gap-0.5">

      {% for category in categories %}
        {% if category.children %}

        {# Category with children → mega-dropdown #}
        <div class="dc-cat-item flex-shrink-0 relative">
          <a href="{{ category.href }}" class="flex items-center gap-1 px-3 h-10 text-sm {% if category.is_active %}font-bold text-blue-600 bg-blue-50/80{% else %}font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50/70{% endif %} transition rounded-sm whitespace-nowrap">
            {{ category.name }}
            <i data-lucide="chevron-down" class="w-3 h-3 opacity-50 flex-shrink-0 ml-0.5"></i>
          </a>

          {# Mega-dropdown: L2 as bold group headers, L3 as list below each header #}
          <div class="dc-cat-dropdown bg-white rounded-2xl shadow-2xl border border-gray-100 absolute top-full left-0 z-[200]">
            <div class="dc-cat-mega-inner">
              <p class="dc-cat-mega-heading">{{ category.name }}</p>
              <div class="dc-cat-mega-grid" data-children="{{ category.children|length }}">
                {% for child in category.children %}
                <div class="dc-cat-mega-group">
                  <a href="{{ child.href }}" class="dc-cat-mega-parent">{{ child.name }}</a>
                  {% if child.children %}
                  <ul class="dc-cat-mega-list">
                    {% for grandchild in child.children %}
                    <li><a href="{{ grandchild.href }}" class="dc-cat-mega-child">{{ grandchild.name }}</a></li>
                    {% endfor %}
                  </ul>
                  {% endif %}
                </div>
                {% endfor %}
              </div>
              <div class="dc-cat-mega-footer">
                <a href="{{ category.href }}" class="dc-cat-mega-seeall">{{ text_all }} {{ category.name }} →</a>
              </div>
            </div>
          </div>
        </div>

        {% else %}

        {# Category without children — plain link #}
        <div class="flex-shrink-0">
          <a href="{{ category.href }}" class="flex items-center px-3 h-10 text-sm {% if category.is_active %}font-bold text-blue-600 bg-blue-50/80{% else %}font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50/70{% endif %} transition rounded-sm whitespace-nowrap">
            {{ category.name }}
          </a>
        </div>

        {% endif %}
      {% endfor %}

      {# Right accent links #}
      <div class="ml-auto flex items-center flex-shrink-0">
        <a href="/product-new_arrivals" class="flex items-center gap-1 px-3 h-10 text-sm font-bold text-teal-600 hover:text-teal-700 hover:bg-teal-50 transition whitespace-nowrap rounded-sm">
          <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
          {{ text_new_arrivals }}
        </a>
        <a href="/product-special" class="flex items-center gap-1 px-3 h-10 text-sm font-bold text-red-500 hover:text-red-600 hover:bg-red-50 transition whitespace-nowrap rounded-sm">
          <i data-lucide="tag" class="w-3.5 h-3.5"></i>
          {{ text_sale }}
        </a>
      </div>

    </nav>
  </div>
</div>
{% endif %}
{% endif %}
