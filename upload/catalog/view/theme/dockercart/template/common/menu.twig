{% if categories %}
{% if menu_type == 'vertical' %}
<div class="hidden lg:block bg-white border-b border-gray-200 h-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-10 flex items-center justify-end">
    <a href="/product-new_arrivals" class="flex items-center gap-1 px-3 h-8 text-sm font-bold text-teal-600 hover:text-teal-700 hover:bg-teal-50 transition whitespace-nowrap rounded-sm">
      <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
      {{ text_new_arrivals }}
    </a>
    <a href="/product-special" class="flex items-center gap-1 px-3 h-8 text-sm font-bold text-red-500 hover:text-red-600 hover:bg-red-50 transition whitespace-nowrap rounded-sm">
      <i data-lucide="tag" class="w-3.5 h-3.5"></i>
      {{ text_sale }}
    </a>
  </div>
</div>

<div id="dc-vertical-menu-panel" class="dc-vertical-menu-panel hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="dc-vertical-menu-surface">
      <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-3">{{ text_catalog }}</p>
      <ul class="space-y-1">
        {% for category in categories %}
        <li class="dc-vertical-cat-item">
          <a href="{{ category.href }}" class="dc-vertical-cat-link {% if category.is_active %}is-active{% endif %}">
            <span>{{ category.name }}</span>
            {% if category.children %}<i data-lucide="chevron-right" class="w-3.5 h-3.5 opacity-50"></i>{% endif %}
          </a>

          {% if category.children %}
          <div class="dc-vertical-submenu">
            <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-2">{{ category.name }}</p>
            <ul class="space-y-1">
              {% for child in category.children %}
              <li>
                <a href="{{ child.href }}" class="block text-sm text-gray-700 hover:text-blue-600 py-1.5 px-2 rounded-lg hover:bg-blue-50 transition">{{ child.name }}</a>
              </li>
              {% endfor %}
              <li class="pt-2 border-t border-gray-100 mt-1">
                <a href="{{ category.href }}" class="text-xs font-semibold text-blue-600 hover:text-blue-700 px-2 py-1 block hover:underline">
                  {{ text_all }} {{ category.name }} →
                </a>
              </li>
            </ul>
          </div>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>
{% else %}
<!-- ③ CATEGORY NAV BAR (desktop only) -->
<div class="hidden lg:block bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center gap-0.5">

      {% for category in categories %}
        {% if category.children %}

        <!-- Category with children dropdown -->
        <div class="dc-cat-item flex-shrink-0 relative">
          <a href="{{ category.href }}" class="flex items-center gap-1 px-3 h-10 text-sm {% if category.is_active %}font-bold text-blue-600 bg-blue-50/80{% else %}font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50/70{% endif %} transition rounded-sm whitespace-nowrap">
            {{ category.name }}
            <i data-lucide="chevron-down" class="w-3 h-3 opacity-50 flex-shrink-0 ml-0.5"></i>
          </a>

          <!-- Dropdown panel -->
          <div class="dc-cat-dropdown absolute top-full left-0 bg-white rounded-2xl shadow-2xl border border-gray-100 p-5 z-[100] min-w-[220px]">
            <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-3">{{ category.name }}</p>
            <ul class="space-y-0.5">
              {% for child in category.children %}
                {% if child.children %}
                <li class="dc-cat-sub-item">
                  <a href="{{ child.href }}" class="flex items-center justify-between text-sm text-gray-700 hover:text-blue-600 py-1.5 px-2 rounded-lg hover:bg-blue-50 transition">
                    {{ child.name }}
                    <i data-lucide="chevron-right" class="dc-sub-arrow w-3.5 h-3.5"></i>
                  </a>

                  <div class="dc-cat-sub-dropdown bg-white rounded-2xl shadow-2xl border border-gray-100 p-4 min-w-[210px]">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-2">{{ child.name }}</p>
                    <ul class="space-y-0.5">
                      {% for grandchild in child.children %}
                      <li>
                        <a href="{{ grandchild.href }}" class="block text-sm text-gray-700 hover:text-blue-600 py-1.5 px-2 rounded-lg hover:bg-blue-50 transition">
                          {{ grandchild.name }}
                        </a>
                      </li>
                      {% endfor %}
                    </ul>
                  </div>
                </li>
                {% else %}
                <li>
                  <a href="{{ child.href }}" class="flex items-center text-sm text-gray-700 hover:text-blue-600 py-1.5 px-2 rounded-lg hover:bg-blue-50 transition">
                    {{ child.name }}
                  </a>
                </li>
                {% endif %}
              {% endfor %}
              <li class="pt-2 border-t border-gray-100 mt-1">
                <a href="{{ category.href }}" class="text-xs font-semibold text-blue-600 hover:text-blue-700 px-2 py-1 block hover:underline">
                  {{ text_all }} {{ category.name }} →
                </a>
              </li>
            </ul>
          </div>
        </div>

        {% else %}

        <!-- Category without children — plain link -->
        <div class="flex-shrink-0">
          <a href="{{ category.href }}" class="flex items-center px-3 h-10 text-sm {% if category.is_active %}font-bold text-blue-600 bg-blue-50/80{% else %}font-medium text-gray-700 hover:text-blue-600 hover:bg-blue-50/70{% endif %} transition rounded-sm whitespace-nowrap">
            {{ category.name }}
          </a>
        </div>

        {% endif %}
      {% endfor %}

      <!-- Right accent links -->
      <div class="ml-auto flex items-center flex-shrink-0">
        <a href="/product-new_arrivals" class="flex items-center gap-1 px-3 h-10 text-sm font-bold text-teal-600 hover:text-teal-700 hover:bg-teal-50 transition whitespace-nowrap rounded-sm">
          <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
          {{ text_new_arrivals }}
        </a>
        <a href="/product-special" class="flex items-center gap-1 px-3 h-10 text-sm font-bold text-red-500 hover:text-red-600 hover:bg-red-50 transition whitespace-nowrap rounded-sm">
          <i data-lucide="tag" class="w-3.5 h-3.5"></i>
          {{ text_sale }}
        </a>
      </div>

    </nav>
  </div>
</div>
{% endif %}
{% endif %}
