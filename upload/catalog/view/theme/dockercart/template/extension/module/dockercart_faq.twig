<!-- FAQ Section -->
<section id="faq" class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10">
      <p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-1">{{ heading_subtitle ?: text_heading_subtitle }}</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">{{ heading_title }}</h2>
      {% if heading_description %}
        <p class="text-gray-500 text-sm mt-2 max-w-md mx-auto">{{ heading_description }}</p>
      {% endif %}
    </div>
    <div class="space-y-3" id="faq-list">

      {% for item in items %}
      <div class="faq-item bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm">
        <button class="faq-btn w-full flex items-center justify-between gap-4 p-5 text-left" onclick="toggleFaq(this)">
          <span class="font-semibold text-gray-900 text-sm sm:text-base">{{ item.question }}</span>
          <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-blue-600 flex-shrink-0"></i>
        </button>
        <div class="faq-answer">
          <div class="px-5 pb-5">
            <p class="text-gray-500 text-sm leading-relaxed">{{ item.answer }}</p>
          </div>
        </div>
      </div>
      {% endfor %}

    </div>
  </div>
</section>

<style>
  /* FAQ accordion animations */
  .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.38s ease, padding 0.3s ease; }
  .faq-answer.open { max-height: 400px; }
  .faq-chevron { transition: transform 0.3s ease; }
  .faq-item.open .faq-chevron { transform: rotate(180deg); }
</style>

<script>
  /* FAQ accordion toggle function */
  function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    const answer = item.querySelector('.faq-answer');
    const isOpen = item.classList.contains('open');

    // Close all others
    document.querySelectorAll('.faq-item.open').forEach(other => {
      if (other !== item) {
        other.classList.remove('open');
        other.querySelector('.faq-answer').classList.remove('open');
      }
    });

    // Toggle current
    item.classList.toggle('open', !isOpen);
    answer.classList.toggle('open', !isOpen);
  }
</script>

{% if json_ld %}
<script type="application/ld+json">{{ json_ld }}</script>
{% endif %}
