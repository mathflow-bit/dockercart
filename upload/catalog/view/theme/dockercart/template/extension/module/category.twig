{% if categories %}
<section id="categories" class="py-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <style>
    .dc-cats-scroll::-webkit-scrollbar{height:4px}
    .dc-cat-card img{transition:transform .45s ease}
    .dc-cat-card:hover img{transform:scale(1.08)}
  </style>

  <div class="flex items-end justify-between mb-8">
    <div>
      <p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-1">{{ text_browse_by }}</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">{{ text_popular_categories }}</h2>
    </div>
    <a href="{{ all_categories_href }}" class="text-sm font-medium text-blue-600 hover:underline hidden sm:block">{{ text_view_all }}</a>
  </div>

  <div class="dc-cats-scroll flex gap-3 overflow-x-auto pb-2 sm:grid sm:grid-cols-4 lg:grid-cols-8 sm:overflow-visible">
    {% for category in categories|slice(0, 8) %}
      <a href="{{ category.href }}" class="dc-cat-card flex-shrink-0 group relative rounded-2xl overflow-hidden w-32 h-44 sm:w-auto sm:h-48 block cursor-pointer">
        <img src="{{ category.image }}" alt="{{ category.name_raw|default(category.name) }}" class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <span class="absolute bottom-3 left-0 right-0 text-center text-white text-xs font-bold tracking-wide px-1">{{ category.name_raw|default(category.name) }}</span>
      </a>
    {% endfor %}
  </div>
</section>
{% endif %}
