{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-lg mx-auto">
      {{ content_top }}

      {% if success %}
      <div class="mb-6 bg-green-50 border border-green-200 text-green-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ success }}</span>
      </div>
      {% endif %}

      <div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
        <form action="{{ action }}" method="post" enctype="multipart/form-data">
          <p class="text-sm text-gray-500 mb-6">{{ text_newsletter }}</p>
          <div class="flex items-center gap-6 mb-6">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="newsletter" value="1" {% if newsletter %}checked="checked"{% endif %}
                class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500" />
              <span class="text-sm font-medium text-gray-700">{{ text_yes }}</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="newsletter" value="0" {% if not newsletter %}checked="checked"{% endif %}
                class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500" />
              <span class="text-sm font-medium text-gray-700">{{ text_no }}</span>
            </label>
          </div>
          <div class="flex items-center justify-between gap-4">
            <a href="{{ back }}" class="border border-gray-200 hover:border-gray-300 bg-white text-gray-700 font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
              {{ button_back }}
            </a>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
              {{ button_continue }}
            </button>
          </div>
        </form>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
