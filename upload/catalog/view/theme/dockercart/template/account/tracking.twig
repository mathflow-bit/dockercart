{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      {{ content_top }}

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        {# Tracking Code #}
        <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm">
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ entry_code }}</p>
          <p class="text-sm text-gray-500 mb-4">{{ text_description }}</p>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-code">{{ entry_code }}</label>
              <textarea id="input-code" rows="5" placeholder="{{ entry_code }}"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white font-mono">{{ code }}</textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-generator">{{ entry_generator }}</label>
              <input type="text" name="product" value="" placeholder="{{ entry_generator }}" id="input-generator"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-link">{{ entry_link }}</label>
              <textarea name="link" rows="4" placeholder="{{ entry_link }}" id="input-link"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white font-mono"></textarea>
            </div>
          </form>
        </div>

        {# Info Card #}
        <div class="bg-blue-50 border border-blue-100 rounded-3xl p-6">
          <div class="flex items-start gap-4">
            <i data-lucide="link" class="w-8 h-8 text-blue-500 flex-shrink-0 mt-1"></i>
            <div>
              <p class="font-semibold text-blue-900 mb-2">{{ text_description }}</p>
              <p class="text-sm text-blue-700 leading-relaxed">{{ help_generator }}</p>
            </div>
          </div>
        </div>

      </div>

      <div class="mt-6 flex justify-end">
        <a href="{{ continue }}" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
          {{ button_continue }}
        </a>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
<script type="text/javascript"><!--
$('input[name=\'product\']').autocomplete({
  'source': function(request, response) {
    $.ajax({
      url: 'index.php?route=account/tracking/autocomplete&filter_name=' + encodeURIComponent(request) + '&tracking=' + encodeURIComponent($('#input-code').val()),
      dataType: 'json',
      success: function(json) {
        response($.map(json, function(item) {
          return {
            label: item['name'],
            value: item['link']
          }
        }));
      }
    });
  },
  'select': function(item) {
    $('input[name=\'product\']').val(item['label']);
    $('textarea[name=\'link\']').val(item['value']);
  }
});
//--></script>
{{ footer }}
