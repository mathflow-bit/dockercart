{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      {{ content_top }}

      {% if error_warning %}
      <div class="mb-6 bg-red-50 border border-red-200 text-red-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ error_warning }}</span>
      </div>
      {% endif %}

      <div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
        <p class="text-sm text-gray-500 mb-6">{{ text_description }}</p>
        <form action="{{ action }}" method="post" enctype="multipart/form-data">

          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ text_order }}</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-firstname">{{ entry_firstname }}</label>
              <input type="text" name="firstname" value="{{ firstname }}" placeholder="{{ entry_firstname }}" id="input-firstname"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_firstname %}<p class="text-sm text-red-500 mt-1">{{ error_firstname }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-lastname">{{ entry_lastname }}</label>
              <input type="text" name="lastname" value="{{ lastname }}" placeholder="{{ entry_lastname }}" id="input-lastname"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_lastname %}<p class="text-sm text-red-500 mt-1">{{ error_lastname }}</p>{% endif %}
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-email">{{ entry_email }}</label>
              <input type="email" name="email" value="{{ email }}" placeholder="{{ entry_email }}" id="input-email"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_email %}<p class="text-sm text-red-500 mt-1">{{ error_email }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-telephone">{{ entry_telephone }}</label>
              <input type="tel" name="telephone" value="{{ telephone }}" placeholder="{{ entry_telephone }}" id="input-telephone"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_telephone %}<p class="text-sm text-red-500 mt-1">{{ error_telephone }}</p>{% endif %}
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-order-id">{{ entry_order_id }}</label>
              <input type="text" name="order_id" value="{{ order_id }}" placeholder="{{ entry_order_id }}" id="input-order-id"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_order_id %}<p class="text-sm text-red-500 mt-1">{{ error_order_id }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-date-ordered">{{ entry_date_ordered }}</label>
              <div class="input-group date">
                <input type="text" name="date_ordered" value="{{ date_ordered }}" placeholder="{{ entry_date_ordered }}" data-date-format="YYYY-MM-DD" id="input-date-ordered"
                  class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              </div>
            </div>
          </div>

          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ text_product }}</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-product">{{ entry_product }}</label>
              <input type="text" name="product" value="{{ product }}" placeholder="{{ entry_product }}" id="input-product"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              <input type="hidden" name="product_id" value="{{ product_id }}" />
              {% if error_product %}<p class="text-sm text-red-500 mt-1">{{ error_product }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-model">{{ entry_model }}</label>
              <input type="text" name="model" value="{{ model }}" placeholder="{{ entry_model }}" id="input-model"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_model %}<p class="text-sm text-red-500 mt-1">{{ error_model }}</p>{% endif %}
            </div>
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-quantity">{{ entry_quantity }}</label>
            <input type="text" name="quantity" value="{{ quantity }}" placeholder="{{ entry_quantity }}" id="input-quantity"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">{{ entry_reason }}</label>
            <div class="space-y-2">
              {% for return_reason in return_reasons %}
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="return_reason_id" value="{{ return_reason.return_reason_id }}"
                  {% if return_reason.return_reason_id == return_reason_id %}checked{% endif %}
                  class="w-4 h-4 text-blue-600 border-gray-300" />
                <span class="text-sm text-gray-700">{{ return_reason.name }}</span>
              </label>
              {% endfor %}
            </div>
            {% if error_return_reason %}<p class="text-sm text-red-500 mt-1">{{ error_return_reason }}</p>{% endif %}
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">{{ entry_opened }}</label>
            <div class="flex items-center gap-6">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="opened" value="1" {% if opened %}checked{% endif %}
                  class="w-4 h-4 text-blue-600 border-gray-300" />
                <span class="text-sm text-gray-700">{{ text_yes }}</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="opened" value="0" {% if not opened %}checked{% endif %}
                  class="w-4 h-4 text-blue-600 border-gray-300" />
                <span class="text-sm text-gray-700">{{ text_no }}</span>
              </label>
            </div>
          </div>

          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-comment">{{ entry_comment }}</label>
            <textarea name="comment" rows="5" id="input-comment"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">{{ comment }}</textarea>
          </div>

          <div class="flex items-center justify-between gap-4">
            <a href="{{ back }}" class="border border-gray-200 hover:border-gray-300 bg-white text-gray-700 font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
              {{ button_back }}
            </a>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
              {{ button_continue }}
            </button>
          </div>

        </form>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
<script type="text/javascript"><!--
$('.date').datetimepicker({
  language: '{{ datepicker }}',
  pickTime: false
});
//--></script>
{{ footer }}
