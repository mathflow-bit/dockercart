{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ text_address_book }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      {{ content_top }}

      {% if success %}
      <div class="mb-6 bg-green-50 border border-green-200 text-green-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ success }}</span>
      </div>
      {% endif %}
      {% if error_warning %}
      <div class="mb-6 bg-amber-50 border border-amber-200 text-amber-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="alert-triangle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ error_warning }}</span>
      </div>
      {% endif %}

      {% if addresses %}
      <div class="space-y-3 mb-6">
        {% for result in addresses %}
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex items-center justify-between gap-4">
          <div class="text-sm text-gray-700 leading-relaxed">{{ result.address }}</div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <a href="{{ result.update }}" class="border border-gray-200 hover:border-blue-300 hover:text-blue-600 text-gray-600 font-medium px-4 py-2 rounded-xl transition-colors text-sm">
              {{ button_edit }}
            </a>
            <a href="{{ result.delete }}" onclick="return confirm('{{ text_confirm }}')"
              class="border border-red-100 hover:border-red-300 hover:text-red-600 text-red-400 font-medium px-4 py-2 rounded-xl transition-colors text-sm">
              {{ button_delete }}
            </a>
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 text-center text-gray-400 text-sm mb-6">
        <i data-lucide="map-pin" class="w-8 h-8 mx-auto mb-2 opacity-30"></i>
        <p>{{ text_empty }}</p>
      </div>
      {% endif %}

      <div class="flex items-center justify-between gap-4">
        <a href="{{ back }}" class="border border-gray-200 hover:border-gray-300 bg-white text-gray-700 font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
          {{ button_back }}
        </a>
        <a href="{{ add }}" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm flex items-center gap-2">
          <i data-lucide="plus" class="w-4 h-4"></i>
          {{ button_new_address }}
        </a>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
