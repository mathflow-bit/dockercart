{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      {{ content_top }}

      {# Return Details #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 mb-4">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ text_return_detail }}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <div class="space-y-1.5">
            <p><span class="font-semibold text-gray-500">{{ text_return_id }}</span> <span class="text-gray-800 font-mono">#{{ return_id }}</span></p>
            <p><span class="font-semibold text-gray-500">{{ text_date_added }}</span> <span class="text-gray-800">{{ date_added }}</span></p>
          </div>
          <div class="space-y-1.5">
            <p><span class="font-semibold text-gray-500">{{ text_order_id }}</span> <span class="text-gray-800 font-mono">#{{ order_id }}</span></p>
            <p><span class="font-semibold text-gray-500">{{ text_date_ordered }}</span> <span class="text-gray-800">{{ date_ordered }}</span></p>
          </div>
        </div>
      </div>

      {# Product #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden mb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 bg-gray-50">
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_product }}</th>
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_model }}</th>
                <th class="text-right font-semibold text-gray-500 px-4 py-3">{{ column_quantity }}</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-50">
                <td class="text-left text-gray-800 px-4 py-3">{{ product }}</td>
                <td class="text-left text-gray-600 px-4 py-3">{{ model }}</td>
                <td class="text-right text-gray-700 px-4 py-3">{{ quantity }}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      {# Reason #}
      {% if return_history is defined or opened is defined %}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 mb-4">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ text_reason }}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          {% if return_reason is defined %}
          <p><span class="font-semibold text-gray-500">{{ text_return_reason }}</span> <span class="text-gray-800">{{ return_reason }}</span></p>
          {% endif %}
          {% if opened is defined %}
          <p><span class="font-semibold text-gray-500">{{ text_opened }}</span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {% if opened %}bg-green-100 text-green-700{% else %}bg-gray-100 text-gray-600{% endif %}">
              {{ opened ? text_yes : text_no }}
            </span>
          </p>
          {% endif %}
          {% if comment is defined and comment %}
          <div class="sm:col-span-2">
            <p class="font-semibold text-gray-500 mb-1">{{ text_comment }}</p>
            <p class="text-gray-700">{{ comment }}</p>
          </div>
          {% endif %}
        </div>
      </div>
      {% endif %}

      {# History #}
      {% if return_history is defined and return_history %}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden mb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 bg-gray-50">
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_date_added }}</th>
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_status }}</th>
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_comment }}</th>
              </tr>
            </thead>
            <tbody>
              {% for history in return_history %}
              <tr class="border-b border-gray-50">
                <td class="text-left text-gray-600 px-4 py-3">{{ history.date_added }}</td>
                <td class="text-left px-4 py-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
                    {{ history.status }}
                  </span>
                </td>
                <td class="text-left text-gray-700 px-4 py-3">{{ history.comment }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endif %}

      <div class="flex justify-end">
        <a href="{{ continue }}" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
          {{ button_continue }}
        </a>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
