{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto">
      {{ content_top }}

      {% if error_warning %}
      <div class="mb-6 bg-red-50 border border-red-200 text-red-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ error_warning }}</span>
      </div>
      {% endif %}

      <div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
        <form action="{{ action }}" method="post" enctype="multipart/form-data">

          {# My Affiliate #}
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ text_my_affiliate }}</p>
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-company">{{ entry_company }}</label>
            <input type="text" name="company" value="{{ company }}" placeholder="{{ entry_company }}" id="input-company"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
          </div>
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-website">{{ entry_website }}</label>
            <input type="text" name="website" value="{{ website }}" placeholder="{{ entry_website }}" id="input-website"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
          </div>

          {# Payment #}
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ text_payment }}</p>
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-tax">{{ entry_tax }}</label>
            <input type="text" name="tax" value="{{ tax }}" placeholder="{{ entry_tax }}" id="input-tax"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
          </div>
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">{{ entry_payment }}</label>
            <div class="grid grid-cols-3 gap-2">
              <label class="flex items-center gap-2 cursor-pointer border border-gray-200 rounded-xl p-3 hover:border-blue-300 transition">
                <input type="radio" name="payment" value="cheque" {% if payment == 'cheque' %}checked{% endif %} class="w-4 h-4 text-blue-600 border-gray-300" />
                <span class="text-sm text-gray-700">{{ text_cheque }}</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer border border-gray-200 rounded-xl p-3 hover:border-blue-300 transition">
                <input type="radio" name="payment" value="paypal" {% if payment == 'paypal' %}checked{% endif %} class="w-4 h-4 text-blue-600 border-gray-300" />
                <span class="text-sm text-gray-700">{{ text_paypal }}</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer border border-gray-200 rounded-xl p-3 hover:border-blue-300 transition">
                <input type="radio" name="payment" value="bank" {% if payment == 'bank' %}checked{% endif %} class="w-4 h-4 text-blue-600 border-gray-300" />
                <span class="text-sm text-gray-700">{{ text_bank }}</span>
              </label>
            </div>
          </div>

          {# Cheque #}
          <div id="payment-cheque" class="payment mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-cheque">{{ entry_cheque }}</label>
            <input type="text" name="cheque" value="{{ cheque }}" placeholder="{{ entry_cheque }}" id="input-cheque"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
            {% if error_cheque %}<p class="text-sm text-red-500 mt-1">{{ error_cheque }}</p>{% endif %}
          </div>

          {# PayPal #}
          <div id="payment-paypal" class="payment mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-paypal">{{ entry_paypal }}</label>
            <input type="text" name="paypal" value="{{ paypal }}" placeholder="{{ entry_paypal }}" id="input-paypal"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
            {% if error_paypal %}<p class="text-sm text-red-500 mt-1">{{ error_paypal }}</p>{% endif %}
          </div>

          {# Bank Transfer #}
          <div id="payment-bank" class="payment mb-6 space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-bank-name">{{ entry_bank_name }}</label>
              <input type="text" name="bank_name" value="{{ bank_name }}" placeholder="{{ entry_bank_name }}" id="input-bank-name"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-bank-branch-number">{{ entry_bank_branch_number }}</label>
              <input type="text" name="bank_branch_number" value="{{ bank_branch_number }}" placeholder="{{ entry_bank_branch_number }}" id="input-bank-branch-number"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-bank-swift-code">{{ entry_bank_swift_code }}</label>
              <input type="text" name="bank_swift_code" value="{{ bank_swift_code }}" placeholder="{{ entry_bank_swift_code }}" id="input-bank-swift-code"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-bank-account-name">{{ entry_bank_account_name }}</label>
              <input type="text" name="bank_account_name" value="{{ bank_account_name }}" placeholder="{{ entry_bank_account_name }}" id="input-bank-account-name"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_bank_account_name %}<p class="text-sm text-red-500 mt-1">{{ error_bank_account_name }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-bank-account-number">{{ entry_bank_account_number }}</label>
              <input type="text" name="bank_account_number" value="{{ bank_account_number }}" placeholder="{{ entry_bank_account_number }}" id="input-bank-account-number"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_bank_account_number %}<p class="text-sm text-red-500 mt-1">{{ error_bank_account_number }}</p>{% endif %}
            </div>
          </div>

          <div class="flex items-center justify-end gap-4">
            {% if text_agree %}
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <span>{{ text_agree }}</span>
              <input type="checkbox" name="agree" value="1" {% if agree %}checked{% endif %}
                class="w-4 h-4 text-blue-600 border-gray-300 rounded" />
            </div>
            {% endif %}
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
              {{ button_continue }}
            </button>
          </div>

        </form>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
<script type="text/javascript"><!--
$('input[name=\'payment\']').on('change', function() {
  $('.payment').hide();
  $('#payment-' + this.value).show();
});
$('input[name=\'payment\']:checked').trigger('change');
//--></script>
{{ footer }}
