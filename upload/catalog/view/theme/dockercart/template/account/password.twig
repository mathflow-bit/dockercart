{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-lg mx-auto">
      {{ content_top }}

      <div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-5">{{ text_password }}</p>
        <form action="{{ action }}" method="post" enctype="multipart/form-data">
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-password">{{ entry_password }}</label>
            <input type="password" name="password" value="{{ password }}" placeholder="{{ entry_password }}" id="input-password"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white" />
            {% if error_password %}
            <p class="text-sm text-red-500 mt-1">{{ error_password }}</p>
            {% endif %}
          </div>
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-confirm">{{ entry_confirm }}</label>
            <input type="password" name="confirm" value="{{ confirm }}" placeholder="{{ entry_confirm }}" id="input-confirm"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white" />
            {% if error_confirm %}
            <p class="text-sm text-red-500 mt-1">{{ error_confirm }}</p>
            {% endif %}
          </div>
          <div class="flex items-center justify-between gap-4">
            <a href="{{ back }}" class="border border-gray-200 hover:border-gray-300 bg-white text-gray-700 font-medium px-5 py-2.5 rounded-xl transition-colors text-sm">
              {{ button_back }}
            </a>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
              {{ button_continue }}
            </button>
          </div>
        </form>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
