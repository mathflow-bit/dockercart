{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      {{ content_top }}

      {% if success %}
      <div class="mb-6 bg-green-50 border border-green-200 text-green-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ success }}</span>
      </div>
      {% endif %}
      {% if error_warning %}
      <div class="mb-6 bg-red-50 border border-red-200 text-red-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ error_warning }}</span>
      </div>
      {% endif %}

      {# Order Details #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 mb-4">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ text_order_detail }}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <div class="space-y-1.5">
            {% if invoice_no %}
            <p><span class="font-semibold text-gray-500">{{ text_invoice_no }}</span> <span class="text-gray-800">{{ invoice_no }}</span></p>
            {% endif %}
            <p><span class="font-semibold text-gray-500">{{ text_order_id }}</span> <span class="text-gray-800 font-mono">#{{ order_id }}</span></p>
            <p><span class="font-semibold text-gray-500">{{ text_date_added }}</span> <span class="text-gray-800">{{ date_added }}</span></p>
          </div>
          <div class="space-y-1.5">
            {% if payment_method %}
            <p><span class="font-semibold text-gray-500">{{ text_payment_method }}</span> <span class="text-gray-800">{{ payment_method }}</span></p>
            {% endif %}
            {% if shipping_method %}
            <p><span class="font-semibold text-gray-500">{{ text_shipping_method }}</span> <span class="text-gray-800">{{ shipping_method }}</span></p>
            {% endif %}
          </div>
        </div>
      </div>

      {# Addresses #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 mb-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-2">{{ text_payment_address }}</p>
            <div class="text-gray-700 leading-relaxed">{{ payment_address }}</div>
          </div>
          {% if shipping_address %}
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-2">{{ text_shipping_address }}</p>
            <div class="text-gray-700 leading-relaxed">{{ shipping_address }}</div>
          </div>
          {% endif %}
        </div>
      </div>

      {# Products #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden mb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 bg-gray-50">
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_name }}</th>
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_model }}</th>
                <th class="text-right font-semibold text-gray-500 px-4 py-3">{{ column_quantity }}</th>
                <th class="text-right font-semibold text-gray-500 px-4 py-3">{{ column_price }}</th>
                <th class="text-right font-semibold text-gray-500 px-4 py-3">{{ column_total }}</th>
                {% if products %}
                <th class="px-4 py-3"></th>
                {% endif %}
              </tr>
            </thead>
            <tbody>
              {% for product in products %}
              <tr class="border-b border-gray-50 hover:bg-gray-50/50 transition">
                <td class="text-left text-gray-800 px-4 py-3">
                  {{ product.name }}
                  {% for option in product.option %}
                  <br /><small class="text-gray-400">— {{ option.name }}: {{ option.value }}</small>
                  {% endfor %}
                </td>
                <td class="text-left text-gray-500 px-4 py-3">{{ product.model }}</td>
                <td class="text-right text-gray-700 px-4 py-3">{{ product.quantity }}</td>
                <td class="text-right text-gray-700 px-4 py-3">{{ product.price }}</td>
                <td class="text-right font-semibold text-gray-800 px-4 py-3">{{ product.total }}</td>
                <td class="text-right px-4 py-3 whitespace-nowrap">
                  {% if product.reorder %}
                  <a href="{{ product.reorder }}" class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-700 border border-blue-200 hover:border-blue-300 px-3 py-1.5 rounded-lg transition text-xs mr-1">
                    <i data-lucide="shopping-cart" class="w-3.5 h-3.5"></i>
                  </a>
                  {% endif %}
                  <a href="{{ product.return }}" class="inline-flex items-center gap-1 text-red-500 hover:text-red-600 border border-red-200 hover:border-red-300 px-3 py-1.5 rounded-lg transition text-xs">
                    <i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i>
                  </a>
                </td>
              </tr>
              {% endfor %}
              {% for voucher in vouchers %}
              <tr class="border-b border-gray-50">
                <td class="text-left text-gray-800 px-4 py-3">{{ voucher.description }}</td>
                <td class="px-4 py-3"></td>
                <td class="text-right text-gray-700 px-4 py-3">1</td>
                <td class="text-right text-gray-700 px-4 py-3">{{ voucher.amount }}</td>
                <td class="text-right font-semibold text-gray-800 px-4 py-3">{{ voucher.amount }}</td>
                {% if products %}<td class="px-4 py-3"></td>{% endif %}
              </tr>
              {% endfor %}
            </tbody>
            <tfoot>
              {% for total in totals %}
              <tr class="border-t border-gray-100 bg-gray-50">
                <td colspan="3" class="px-4 py-2"></td>
                <td class="text-right font-semibold text-gray-600 px-4 py-2 text-sm">{{ total.title }}</td>
                <td class="text-right font-bold text-gray-900 px-4 py-2 text-sm">{{ total.text }}</td>
                {% if products %}<td class="px-4 py-2"></td>{% endif %}
              </tr>
              {% endfor %}
            </tfoot>
          </table>
        </div>
      </div>

      {% if comment %}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 mb-4">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-2">{{ text_comment }}</p>
        <p class="text-sm text-gray-700">{{ comment }}</p>
      </div>
      {% endif %}

      {% if histories %}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden mb-4">
        <div class="p-4 border-b border-gray-100 bg-gray-50">
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500">{{ text_history }}</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100">
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_date_added }}</th>
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_status }}</th>
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_comment }}</th>
              </tr>
            </thead>
            <tbody>
              {% for history in histories %}
              <tr class="border-b border-gray-50 hover:bg-gray-50/50 transition">
                <td class="text-left text-gray-600 px-4 py-3">{{ history.date_added }}</td>
                <td class="text-left px-4 py-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
                    {{ history.status }}
                  </span>
                </td>
                <td class="text-left text-gray-700 px-4 py-3">{{ history.comment }}</td>
              </tr>
              {% else %}
              <tr>
                <td colspan="3" class="text-center text-gray-400 px-4 py-4">{{ text_no_results }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endif %}

      <div class="flex justify-end">
        <a href="{{ continue }}" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
          {{ button_continue }}
        </a>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
