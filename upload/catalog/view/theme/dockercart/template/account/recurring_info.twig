{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      {{ content_top }}

      {# Recurring Details #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 mb-4">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-4">{{ text_recurring_detail }}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <div class="space-y-1.5">
            <p><span class="font-semibold text-gray-500">{{ text_order_recurring_id }}</span> <span class="text-gray-800 font-mono">#{{ order_recurring_id }}</span></p>
            <p><span class="font-semibold text-gray-500">{{ text_date_added }}</span> <span class="text-gray-800">{{ date_added }}</span></p>
            <p><span class="font-semibold text-gray-500">{{ text_status }}</span>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700 ml-1">{{ status }}</span>
            </p>
            <p><span class="font-semibold text-gray-500">{{ text_payment_method }}</span> <span class="text-gray-800">{{ payment_method }}</span></p>
          </div>
          <div class="space-y-1.5">
            <p><span class="font-semibold text-gray-500">{{ text_order_id }}</span> <a href="{{ order }}" class="text-blue-600 hover:underline font-mono">#{{ order_id }}</a></p>
            <p><span class="font-semibold text-gray-500">{{ text_product }}</span> <a href="{{ product }}" class="text-blue-600 hover:underline">{{ product_name }}</a></p>
            <p><span class="font-semibold text-gray-500">{{ text_quantity }}</span> <span class="text-gray-800">{{ product_quantity }}</span></p>
          </div>
        </div>
      </div>

      {# Recurring Description #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 mb-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-2">{{ text_description }}</p>
            <p class="text-gray-700">{{ recurring_description }}</p>
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-2">{{ text_reference }}</p>
            <p class="text-gray-700 font-mono break-all">{{ reference }}</p>
          </div>
        </div>
      </div>

      {# Transactions #}
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden mb-4">
        <div class="p-4 border-b border-gray-100 bg-gray-50">
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500">{{ text_transaction }}</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100">
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_date_added }}</th>
                <th class="text-left font-semibold text-gray-500 px-4 py-3">{{ column_type }}</th>
                <th class="text-right font-semibold text-gray-500 px-4 py-3">{{ column_amount }}</th>
              </tr>
            </thead>
            <tbody>
              {% if transactions %}
              {% for transaction in transactions %}
              <tr class="border-b border-gray-50 hover:bg-gray-50/50 transition">
                <td class="text-left text-gray-600 px-4 py-3">{{ transaction.date_added }}</td>
                <td class="text-left text-gray-800 px-4 py-3">{{ transaction.type }}</td>
                <td class="text-right font-semibold text-gray-900 px-4 py-3">{{ transaction.amount }}</td>
              </tr>
              {% endfor %}
              {% else %}
              <tr>
                <td colspan="3" class="text-center text-gray-400 px-4 py-6">{{ text_no_results }}</td>
              </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
      </div>

      {{ recurring }}

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
