{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ heading_title }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto">
      {{ content_top }}

      {% if error_warning %}
      <div class="mb-6 bg-red-50 border border-red-200 text-red-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ error_warning }}</span>
      </div>
      {% endif %}

      <div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
        <p class="text-sm text-gray-500 mb-6">{{ text_description }}</p>
        <form action="{{ action }}" method="post" enctype="multipart/form-data">

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-to-name">{{ entry_to_name }}</label>
              <input type="text" name="to_name" value="{{ to_name }}" id="input-to-name"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_to_name %}<p class="text-sm text-red-500 mt-1">{{ error_to_name }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-to-email">{{ entry_to_email }}</label>
              <input type="email" name="to_email" value="{{ to_email }}" id="input-to-email"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_to_email %}<p class="text-sm text-red-500 mt-1">{{ error_to_email }}</p>{% endif %}
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-from-name">{{ entry_from_name }}</label>
              <input type="text" name="from_name" value="{{ from_name }}" id="input-from-name"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_from_name %}<p class="text-sm text-red-500 mt-1">{{ error_from_name }}</p>{% endif %}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-from-email">{{ entry_from_email }}</label>
              <input type="email" name="from_email" value="{{ from_email }}" id="input-from-email"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
              {% if error_from_email %}<p class="text-sm text-red-500 mt-1">{{ error_from_email }}</p>{% endif %}
            </div>
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">{{ entry_theme }}</label>
            <div class="space-y-2">
              {% for voucher_theme in voucher_themes %}
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="voucher_theme_id" value="{{ voucher_theme.voucher_theme_id }}"
                  {% if voucher_theme.voucher_theme_id == voucher_theme_id %}checked{% endif %}
                  class="w-4 h-4 text-blue-600 border-gray-300" />
                <span class="text-sm text-gray-700">{{ voucher_theme.name }}</span>
              </label>
              {% endfor %}
            </div>
            {% if error_theme %}<p class="text-sm text-red-500 mt-1">{{ error_theme }}</p>{% endif %}
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-message">{{ entry_message }}</label>
            <textarea name="message" rows="4" id="input-message"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">{{ message }}</textarea>
          </div>

          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="input-amount">{{ entry_amount }}</label>
            <input type="text" name="amount" value="{{ amount }}" id="input-amount"
              class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white" />
            {% if error_amount %}<p class="text-sm text-red-500 mt-1">{{ error_amount }}</p>{% endif %}
          </div>

          <div class="flex items-center justify-end gap-4">
            {% if text_agree %}
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <span>{{ text_agree }}</span>
              <input type="checkbox" name="agree" value="1" {% if agree %}checked{% endif %}
                class="w-4 h-4 text-blue-600 border-gray-300 rounded" />
            </div>
            {% endif %}
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors text-sm">
              {{ button_continue }}
            </button>
          </div>

        </form>
      </div>

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
