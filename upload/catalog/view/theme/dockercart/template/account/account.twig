{{ header }}
<main class="bg-gray-50 min-h-screen">

  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-blue-950 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      {% include 'dockercart/template/common/partials/breadcrumbs.twig' with {
        breadcrumbs_class: 'flex flex-wrap items-center gap-2 text-xs text-gray-300 mb-3',
        breadcrumbs_link_class: 'hover:text-white transition',
        breadcrumbs_last_class: 'text-white font-semibold'
      } %}
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">{{ text_my_account }}</h1>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      {{ content_top }}

      {% if success %}
      <div class="mb-6 bg-green-50 border border-green-200 text-green-700 rounded-2xl px-5 py-4 text-sm flex items-center gap-3">
        <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
        <span>{{ success }}</span>
      </div>
      {% endif %}

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

        {# My Account #}
        <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm">
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-3">{{ text_my_account }}</p>
          <ul class="space-y-2">
            <li>
              <a href="{{ edit }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="user" class="w-4 h-4 text-gray-400"></i>
                {{ text_edit }}
              </a>
            </li>
            <li>
              <a href="{{ password }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="lock" class="w-4 h-4 text-gray-400"></i>
                {{ text_password }}
              </a>
            </li>
            <li>
              <a href="{{ address }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="map-pin" class="w-4 h-4 text-gray-400"></i>
                {{ text_address }}
              </a>
            </li>
            <li>
              <a href="{{ wishlist }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="heart" class="w-4 h-4 text-gray-400"></i>
                {{ text_wishlist }}
              </a>
            </li>
          </ul>
        </div>

        {# My Orders #}
        <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm">
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-3">{{ text_my_orders }}</p>
          <ul class="space-y-2">
            <li>
              <a href="{{ order }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="shopping-bag" class="w-4 h-4 text-gray-400"></i>
                {{ text_order }}
              </a>
            </li>
            <li>
              <a href="{{ download }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="download" class="w-4 h-4 text-gray-400"></i>
                {{ text_download }}
              </a>
            </li>
            {% if reward %}
            <li>
              <a href="{{ reward }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="star" class="w-4 h-4 text-gray-400"></i>
                {{ text_reward }}
              </a>
            </li>
            {% endif %}
            <li>
              <a href="{{ return }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="rotate-ccw" class="w-4 h-4 text-gray-400"></i>
                {{ text_return }}
              </a>
            </li>
            <li>
              <a href="{{ transaction }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="receipt" class="w-4 h-4 text-gray-400"></i>
                {{ text_transaction }}
              </a>
            </li>
            <li>
              <a href="{{ recurring }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="refresh-cw" class="w-4 h-4 text-gray-400"></i>
                {{ text_recurring }}
              </a>
            </li>
          </ul>
        </div>

        {# My Affiliate & Newsletter #}
        <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm">
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-3">{{ text_my_affiliate }}</p>
          <ul class="space-y-2 mb-6">
            {% if not tracking %}
            <li>
              <a href="{{ affiliate }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="users" class="w-4 h-4 text-gray-400"></i>
                {{ text_affiliate_add }}
              </a>
            </li>
            {% else %}
            <li>
              <a href="{{ affiliate }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="users" class="w-4 h-4 text-gray-400"></i>
                {{ text_affiliate_edit }}
              </a>
            </li>
            <li>
              <a href="{{ tracking }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="link" class="w-4 h-4 text-gray-400"></i>
                {{ text_tracking }}
              </a>
            </li>
            {% endif %}
          </ul>
          <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-3">{{ text_my_newsletter }}</p>
          <ul class="space-y-2">
            <li>
              <a href="{{ newsletter }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
                <i data-lucide="mail" class="w-4 h-4 text-gray-400"></i>
                {{ text_newsletter }}
              </a>
            </li>
          </ul>
        </div>

      </div>

      {% if credit_cards %}
      <div class="mt-4 bg-white rounded-3xl border border-gray-100 p-6 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-500 mb-3">{{ text_credit_card }}</p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {% for credit_card in credit_cards %}
          <li>
            <a href="{{ credit_card.href }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-blue-600 transition">
              <i data-lucide="credit-card" class="w-4 h-4 text-gray-400"></i>
              {{ credit_card.name }}
            </a>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      {{ content_bottom }}
    </div>
  </section>

</main>
{{ footer }}
