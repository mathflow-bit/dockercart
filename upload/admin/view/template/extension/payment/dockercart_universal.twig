{{ header }}{{ column_left }}
<div id="content">
<link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />

<style>
/* DockerCart Universal Payment module styles */
.dc-payment-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:12px; margin-bottom:16px; }
.dc-payment-card { background:#fff; border:1px solid #e6e9ef; border-radius:10px; padding:12px 14px; display:flex; flex-direction:column; gap:6px; }
.dc-payment-card__k { font-size:11px; text-transform:uppercase; color:#8b96a7; letter-spacing:.04em; }
.dc-payment-card__v { font-size:20px; font-weight:600; line-height:1.2; color:#2a3445; }
.dc-payment-table { width:100%; }
.dc-payment-table thead th { font-size:11px; color:#6f7b8f; text-transform:uppercase; letter-spacing:.04em; font-weight:600; background:#f8fafc; padding:10px 12px; }
.dc-payment-table tbody td { padding:12px; vertical-align:middle; border-bottom:1px solid #f0f3f8; }
.dc-payment-table tbody tr:hover { background:#fafbfe; }
.dc-payment-name { font-weight:600; color:#2f3f59; }
.dc-payment-desc { font-size:12px; color:#8b96a7; margin-top:2px; }
.dc-payment-badge { display:inline-block; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:600; }
.dc-payment-badge--on { background:#e9f7ef; color:#1e7e34; }
.dc-payment-badge--off { background:#fdecee; color:#b02a37; }
.dc-payment-actions { display:flex; gap:6px; justify-content:flex-end; }
.dc-payment-empty { text-align:center; padding:40px 20px; color:#8b96a7; }
.dc-payment-empty i { font-size:48px; display:block; margin-bottom:12px; opacity:0.5; }
@media (max-width: 767px) {
  .dc-payment-grid { grid-template-columns:1fr; }
}
</style>

  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-payment" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary">
          <i class="fa fa-save"></i>
        </button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default">
          <i class="fa fa-reply"></i>
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i class="fa fa-credit-card"></i></div>
          <div>
            <h3 class="dcx-panel-title">{{ heading_title }}</h3>
            <div class="dcx-panel-subtitle">{{ text_module_description }}</div>
          </div>
        </div>
        <div class="dcx-panel-body">

          <ul class="nav nav-tabs dcx-profile-tabs" role="tablist">
            <li class="active"><a href="#tab-methods" data-toggle="tab"><i class="fa fa-list"></i> {{ tab_methods }}</a></li>
            <li><a href="#tab-settings" data-toggle="tab"><i class="fa fa-cog"></i> {{ tab_settings }}</a></li>
          </ul>

          <div class="tab-content" style="margin-top:16px;">
            <div class="tab-pane active" id="tab-methods">

              <div class="dc-payment-grid">
                <div class="dc-payment-card">
                  <div class="dc-payment-card__k">{{ text_total_methods }}</div>
                  <div class="dc-payment-card__v">{{ payment_methods|length }}</div>
                </div>
                <div class="dc-payment-card">
                  <div class="dc-payment-card__k">{{ text_active_methods }}</div>
                  <div class="dc-payment-card__v">{{ payment_methods|filter(m => m.status == 1)|length }}</div>
                </div>
                <div class="dc-payment-card">
                  <div class="dc-payment-card__k">{{ text_geo_zones }}</div>
                  <div class="dc-payment-card__v">{{ geo_zones|length }}</div>
                </div>
              </div>

              <div style="margin-bottom:12px;">
                <a href="{{ add }}" class="btn btn-primary"><i class="fa fa-plus"></i> {{ button_add_method }}</a>
              </div>

              {% if payment_methods %}
              <div class="table-responsive">
                <table class="table dc-payment-table">
                  <thead>
                    <tr>
                      <th>{{ column_name }}</th>
                      <th>{{ column_geo_zone }}</th>
                      <th>{{ column_status }}</th>
                      <th>{{ column_sort_order }}</th>
                      <th style="text-align:right;">{{ column_action }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for method in payment_methods %}
                    <tr id="method-row-{{ method.method_id }}">
                      <td>
                        <div class="dc-payment-name">{{ method.name ? method.name : text_unnamed }}</div>
                        {% if method.description %}
                        <div class="dc-payment-desc">{{ method.description|slice(0, 90) }}{% if method.description|length > 90 %}...{% endif %}</div>
                        {% endif %}
                      </td>
                      <td>
                        {% set geo_zone_name = text_all_zones %}
                        {% for geo_zone in geo_zones %}
                          {% if geo_zone.geo_zone_id == method.geo_zone_id %}
                            {% set geo_zone_name = geo_zone.name %}
                          {% endif %}
                        {% endfor %}
                        {{ geo_zone_name }}
                      </td>
                      <td>
                        {% if method.status %}
                        <span class="dc-payment-badge dc-payment-badge--on">{{ text_enabled }}</span>
                        {% else %}
                        <span class="dc-payment-badge dc-payment-badge--off">{{ text_disabled }}</span>
                        {% endif %}
                      </td>
                      <td>{{ method.sort_order }}</td>
                      <td class="dc-payment-actions">
                        <a href="{{ method.edit }}" class="btn btn-sm btn-primary" data-toggle="tooltip" title="{{ button_edit }}"><i class="fa fa-pencil"></i></a>
                        <button type="button" class="btn btn-sm btn-danger btn-delete" data-method-id="{{ method.method_id }}" data-toggle="tooltip" title="{{ button_delete }}"><i class="fa fa-trash"></i></button>
                      </td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              {% else %}
              <div class="dc-payment-empty">
                <i class="fa fa-credit-card"></i>
                <p>{{ text_no_methods }}</p>
                <a href="{{ add }}" class="btn btn-primary"><i class="fa fa-plus"></i> {{ button_add_method }}</a>
              </div>
              {% endif %}
            </div>

            <div class="tab-pane" id="tab-settings">
              <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-payment" class="dcx-form form-horizontal">

                <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
                  <h4><i class="fa fa-cog"></i> {{ text_general_settings }}</h4>

                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                    <div class="col-sm-10">
                      <select name="payment_dockercart_universal_status" id="input-status" class="form-control" style="max-width:200px;">
                        {% if payment_dockercart_universal_status %}
                        <option value="1" selected>{{ text_enabled }}</option>
                        <option value="0">{{ text_disabled }}</option>
                        {% else %}
                        <option value="1">{{ text_enabled }}</option>
                        <option value="0" selected>{{ text_disabled }}</option>
                        {% endif %}
                      </select>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-order-status">{{ entry_order_status }}</label>
                    <div class="col-sm-10">
                      <select name="payment_dockercart_universal_order_status_id" id="input-order-status" class="form-control" style="max-width:300px;">
                        {% for order_status in order_statuses %}
                        <option value="{{ order_status.order_status_id }}" {% if order_status.order_status_id == payment_dockercart_universal_order_status_id %}selected{% endif %}>{{ order_status.name }}</option>
                        {% endfor %}
                      </select>
                      <div class="help-block">{{ help_order_status }}</div>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
                    <div class="col-sm-10">
                      <input type="text" name="payment_dockercart_universal_sort_order" value="{{ payment_dockercart_universal_sort_order }}" id="input-sort-order" class="form-control" style="max-width:100px;" />
                      <div class="help-block">{{ help_sort_order }}</div>
                    </div>
                  </div>

                </div>
              </form>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
$(function() {
  $('.btn-delete').on('click', function() {
    var methodId = $(this).data('method-id');

    if (confirm('{{ text_confirm_delete }}')) {
      $.ajax({
        url: 'index.php?route=extension/payment/dockercart_universal/delete&user_token={{ user_token }}',
        type: 'POST',
        dataType: 'json',
        data: { method_id: methodId },
        success: function(json) {
          if (json.success) {
            $('#method-row-' + methodId).fadeOut(300, function() {
              $(this).remove();
            });
          } else if (json.error) {
            alert(json.error);
          }
        },
        error: function() {
          alert('{{ error_ajax }}');
        }
      });
    }
  });
});
</script>
{{ footer }}
