    function buildNodes(parentEl, nodes) {
      nodes.forEach(function(node) {
        var li = document.createElement('li');
        li.style.marginBottom = '4px';

        var label = document.createElement('div');
        label.style.cursor = 'pointer';
        label.style.padding = '4px 6px';
        label.style.borderRadius = '3px';
        label.innerHTML = '<span style="font-weight:600">' + escapeHtml(node.name) + '</span> <small class="text-muted">(ID: ' + node.category_id + ')</small>';
        label.addEventListener('click', function(e) {
          e.stopPropagation();
          // select this category for mapping
          mappingCategorySearch.value = node.path + ' (ID: ' + node.category_id + ')';
          mappingCategorySearch.dataset.selectedId = node.category_id;
        });

        li.appendChild(label);

        if (node.children && node.children.length) {
          var toggle = document.createElement('span');
          toggle.innerHTML = ' ▾';
          toggle.style.marginLeft = '6px';
          toggle.style.color = '#888';
          label.appendChild(toggle);

          var childWrap = document.createElement('div');
          childWrap.style.display = 'none';
          childWrap.style.paddingLeft = '12px';
          buildNodes(childWrap, node.children);
          li.appendChild(childWrap);

          label.addEventListener('click', function() {
            childWrap.style.display = childWrap.style.display === 'none' ? 'block' : 'none';
          });
        }

        parentEl.appendChild(li);
      });
    }

      // Render a tree specifically for Exclude Categories with checkboxes
      function renderExcludeTree(container, nodes) {
        container.innerHTML = '';
        var ul = document.createElement('ul');
        ul.style.listStyle = 'none';
        ul.style.paddingLeft = '10px';
        buildNodesForExclude(ul, nodes);
        container.appendChild(ul);
