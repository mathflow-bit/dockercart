    function importCsvMappings(text) {
      var lines = text.split(/\r?\n/);
      var added = 0;
      lines.forEach(function(line) {
        if (!line.trim()) return;
        var parts = line.split(',');
        if (parts.length >= 2) {
          var cid = parseInt(parts[0].trim(),10);
          var google = parts.slice(1).join(',').trim();
          if (!isNaN(cid) && google) {
            addMappingEntry(cid, '', google);
            added++;
          }
        }
      });
      alert('Imported ' + added + ' mappings');
