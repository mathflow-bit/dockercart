    function showGoogleSuggestions(q) {
      var matched = [];
      for (var i=0;i<mappingTaxonomy.length;i++) {
        var entry = mappingTaxonomy[i];
        if (entry.label && entry.label.toLowerCase().indexOf(q) !== -1) matched.push(entry);
        if (matched.length >= 50) break;
      }
      var html = '';
      if (!matched.length) html = '<div style="padding:8px;color:#999;">No suggestions</div>';
      matched.forEach(function(m) {
        var display = (m.id ? (m.id + ' - ') : '') + m.label;
        html += '<a href="#" class="mapping-google-item" data-id="'+(m.id||'')+'" data-label="'+escapeHtml(m.label)+'" style="display:block;padding:8px 12px;border-bottom:1px solid #eee;color:#333;text-decoration:none;">'+escapeHtml(display)+'</a>';
      });
      mappingGoogleResults.innerHTML = html;
      mappingGoogleResults.style.display = 'block';
      mappingGoogleResults.querySelectorAll('.mapping-google-item').forEach(function(item){
        item.addEventListener('click', function(e){
          e.preventDefault();
