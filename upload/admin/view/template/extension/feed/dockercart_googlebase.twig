        nodes.forEach(function(node) {
          var li = document.createElement('li');
          li.style.marginBottom = '4px';

          var row = document.createElement('div');
          row.style.display = 'flex';
          row.style.alignItems = 'center';

          var checkbox = document.createElement('input');
          checkbox.type = 'checkbox';
          checkbox.style.marginRight = '8px';
          checkbox.dataset.id = node.category_id;
          checkbox.checked = excludedCategories.indexOf(node.category_id) > -1;
          checkbox.addEventListener('change', function(e) {
            var id = parseInt(this.dataset.id, 10);
            if (this.checked) {
              addExcludedCategory(id, node.name, node.path);
            } else {
              removeExcludedCategory(id);
            }
          });

          var label = document.createElement('div');
          label.style.cursor = 'pointer';
          label.style.padding = '4px 6px';
          label.style.borderRadius = '3px';
          label.innerHTML = '<span>' + escapeHtml(node.name) + '</span> <small class="text-muted">(ID: ' + node.category_id + ')</small>';

          row.appendChild(checkbox);
          row.appendChild(label);

          li.appendChild(row);

          if (node.children && node.children.length) {
            var toggle = document.createElement('span');
            toggle.innerHTML = ' ▾';
            toggle.style.marginLeft = '6px';
            toggle.style.color = '#888';
            label.appendChild(toggle);

            var childWrap = document.createElement('div');
            childWrap.style.display = 'none';
            childWrap.style.paddingLeft = '12px';
            buildNodesForExclude(childWrap, node.children);
            li.appendChild(childWrap);

            label.addEventListener('click', function() {
