    function parseTaxonomyText(text) {
      mappingTaxonomy = [];
      var lines = text.split(/\r?\n/);
      lines.forEach(function(line) {
        line = line.trim();
        if (!line) return;
        // Accept tab-separated: id\tpath, or id - path, or just path
        var parts = line.split('\t');
        if (parts.length >= 2 && !isNaN(parseInt(parts[0],10))) {
          mappingTaxonomy.push({ id: parts[0].trim(), label: parts.slice(1).join('\t').trim() });
        } else {
          // try split by space after numeric id
          var m = line.match(/^(\d+)\s+(.+)$/);
          if (m) {
            mappingTaxonomy.push({ id: m[1], label: m[2].trim() });
          } else {
            // try format: "id - path"
            var mm = line.match(/^(\d+)\s*-\s*(.+)$/);
            if (mm) {
              mappingTaxonomy.push({ id: mm[1], label: mm[2].trim() });
            } else {
              // no id, use label only
              mappingTaxonomy.push({ id: null, label: line });
            }
          }
        }
      });
    }

