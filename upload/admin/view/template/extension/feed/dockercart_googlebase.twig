{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <style>
    .dc-gb-cards { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:12px; margin-bottom:12px; }
    .dc-gb-card { background:#fff; border:1px solid #e6e9ef; border-radius:10px; padding:12px 14px; }
    .dc-gb-card__k { font-size:11px; text-transform:uppercase; color:#8b96a7; letter-spacing:.04em; }
    .dc-gb-card__v { font-size:22px; font-weight:600; line-height:1.2; color:#2a3445; }
    @media (max-width: 1199px) { .dc-gb-cards { grid-template-columns:repeat(2,minmax(0,1fr)); } }
    @media (max-width: 767px) { .dc-gb-cards { grid-template-columns:1fr; } }
  </style>
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-dockercart-googlebase" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <button type="button" data-toggle="tooltip" title="{{ button_generate|default('Generate Now') }}" class="btn btn-success" id="btn-generate"><i class="fa fa-refresh"></i></button>
        <button type="button" data-toggle="tooltip" title="{{ button_clear_cache|default('Clear Cache') }}" class="btn btn-warning" id="btn-clear-cache"><i class="fa fa-trash"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    
    <div id="alert-container"></div>

    <!-- Nav tabs -->
    <ul class="nav nav-tabs dcx-profile-tabs" id="gb-tabs" role="tablist">
      <li class="active"><a href="#tab-general" class="js-gb-tab" data-tab="tab-general" data-title="General" data-subtitle="Core feed settings, limits and feed overview" data-icon="fa-sliders"><i class="fa fa-sliders"></i> General</a></li>
      <li><a href="#tab-products" class="js-gb-tab" data-tab="tab-products" data-title="{{ tab_products|default('Product Settings') }}" data-subtitle="Product filters, brand source and exclusions" data-icon="fa-cube"><i class="fa fa-cube"></i> {{ tab_products|default('Product Settings') }}</a></li>
      <li><a href="#tab-categories" class="js-gb-tab" data-tab="tab-categories" data-title="{{ tab_categories|default('Category Mapping') }}" data-subtitle="DockerCart to Google category mapping" data-icon="fa-sitemap"><i class="fa fa-sitemap"></i> {{ tab_categories|default('Category Mapping') }}</a></li>
      <li><a href="#tab-shipping" class="js-gb-tab" data-tab="tab-shipping" data-title="{{ tab_shipping|default('Shipping') }}" data-subtitle="Shipping attributes included in feed" data-icon="fa-truck"><i class="fa fa-truck"></i> {{ tab_shipping|default('Shipping') }}</a></li>
      <li><a href="#tab-custom-labels" class="js-gb-tab" data-tab="tab-custom-labels" data-title="{{ tab_custom_labels|default('Custom Labels') }}" data-subtitle="Merchant Center custom labels" data-icon="fa-tags"><i class="fa fa-tags"></i> {{ tab_custom_labels|default('Custom Labels') }}</a></li>
      <li><a href="#tab-license" class="js-gb-tab" data-tab="tab-license" data-title="{{ tab_license|default('License') }}" data-subtitle="License verification and activation status" data-icon="fa-key"><i class="fa fa-key"></i> {{ tab_license|default('License') }}</a></li>
      <li><a href="#tab-about" class="js-gb-tab" data-tab="tab-about" data-title="About" data-subtitle="Module information and support contacts" data-icon="fa-info-circle"><i class="fa fa-info-circle"></i> About</a></li>
    </ul>

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i id="gb-tab-icon" class="fa fa-sliders"></i></div>
          <div>
            <h3 class="dcx-panel-title" id="gb-tab-title">General</h3>
            <div class="dcx-panel-subtitle" id="gb-tab-subtitle">Core feed settings, limits and feed overview</div>
          </div>
        </div>
        <div class="dcx-panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-dockercart-googlebase" class="form-horizontal dcx-form">

          <!-- Tab panes -->
          <div class="tab-content">

            <!-- GENERAL TAB -->
            <div class="dcx-tab-pane active" id="tab-general">
              <div class="dcx-section">
                <h4>{{ text_statistics|default('Feed Statistics') }}</h4>

                <div class="dc-gb-cards">
                  <div class="dc-gb-card">
                    <div class="dc-gb-card__k">{{ text_total_products|default('Total Products') }}</div>
                    <div class="dc-gb-card__v" id="stat-total">{{ feed_stats.total_products }}</div>
                  </div>
                  <div class="dc-gb-card">
                    <div class="dc-gb-card__k">{{ text_enabled_products|default('Enabled Products') }}</div>
                    <div class="dc-gb-card__v" id="stat-enabled">{{ feed_stats.enabled_products }}</div>
                  </div>
                  <div class="dc-gb-card">
                    <div class="dc-gb-card__k">{{ text_in_stock_products|default('In Stock Products') }}</div>
                    <div class="dc-gb-card__v" id="stat-instock">{{ feed_stats.in_stock_products }}</div>
                  </div>
                  <div class="dc-gb-card">
                    <div class="dc-gb-card__k">{{ text_file_size|default('File Size') }}</div>
                    <div class="dc-gb-card__v" id="stat-size">{% if feed_stats.file_exists %}{{ feed_stats.file_size }}{% else %}-{% endif %}</div>
                  </div>
                </div>

                <div class="alert alert-info" style="margin-bottom:0;">
                  <div>
                    <strong>{{ text_feed_url|default('Feed URL') }}:</strong>
                    {% if feed_urls is defined and feed_urls and feed_urls|length > 0 %}
                      <ul style="margin:4px 0 0; padding-left: 18px;">
                        {% for url in feed_urls %}
                          <li><a href="{{ url }}" target="_blank">{{ url }}</a></li>
                        {% endfor %}
                      </ul>
                    {% else %}
                      <a href="{{ feed_url }}" target="_blank">{{ feed_url }}</a>
                    {% endif %}
                  </div>
                  <div style="margin-top:6px;">
                    <strong>{{ text_last_generated|default('Last Generated') }}:</strong>
                    <span id="stat-last-generated">{% if feed_stats.last_generated %}{{ feed_stats.last_generated }}{% else %}{{ text_not_generated|default('Feed not generated yet') }}{% endif %}</span>
                  </div>
                </div>
              </div>

              <div class="dcx-section">
                <h4>Module Settings</h4>

              <!-- Status -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_status" id="input-status" class="form-control">
                    {% if module_dockercart_googlebase_status %}
                    <option value="1" selected="selected">{{ text_enabled }}</option>
                    <option value="0">{{ text_disabled }}</option>
                    {% else %}
                    <option value="1">{{ text_enabled }}</option>
                    <option value="0" selected="selected">{{ text_disabled }}</option>
                    {% endif %}
                  </select>
                  <span class="help-block">{{ help_status|default('Enable or disable the Google Base feed generation') }}</span>
                </div>
              </div>

              <!-- Cache Hours -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-cache-hours">{{ entry_cache_hours|default('Cache Duration (hours)') }}</label>
                <div class="col-sm-10">
                  <input type="number" name="module_dockercart_googlebase_cache_hours" value="{{ module_dockercart_googlebase_cache_hours }}" id="input-cache-hours" class="form-control" min="1" max="168" />
                  <span class="help-block">{{ help_cache_hours|default('How long to cache the feed. Default: 24 hours. Range: 1-168 hours') }}</span>
                </div>
              </div>

              <!-- Max File Size -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-max-file-size">{{ entry_max_file_size|default('Max File Size (MB)') }}</label>
                <div class="col-sm-10">
                  <input type="number" name="module_dockercart_googlebase_max_file_size" value="{{ module_dockercart_googlebase_max_file_size }}" id="input-max-file-size" class="form-control" min="1" max="50" />
                  <span class="help-block">{{ help_max_file_size|default('Maximum file size before splitting into multiple files. Google limit: 50MB') }}</span>
                </div>
              </div>

              <!-- Max Products -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-max-products">{{ entry_max_products|default('Max Products per File') }}</label>
                <div class="col-sm-10">
                  <input type="number" name="module_dockercart_googlebase_max_products" value="{{ module_dockercart_googlebase_max_products }}" id="input-max-products" class="form-control" min="1000" max="1000000" />
                  <span class="help-block">{{ help_max_products|default('Maximum products per file before splitting. Range: 1,000 - 1,000,000') }}</span>
                </div>
              </div>

              <!-- Currency -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-currency">{{ entry_currency|default('Price Currency') }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_currency" id="input-currency" class="form-control">
                    {% for currency in currencies %}
                    <option value="{{ currency.code }}" {% if module_dockercart_googlebase_currency == currency.code %}selected="selected"{% endif %}>{{ currency.title }} ({{ currency.code }})</option>
                    {% endfor %}
                  </select>
                  <span class="help-block">{{ help_currency|default('Select currency for prices in the feed') }}</span>
                </div>
              </div>

              <!-- Image Size -->
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_image_width|default('Image Size') }}</label>
                <div class="col-sm-5">
                  <input type="number" name="module_dockercart_googlebase_image_width" value="{{ module_dockercart_googlebase_image_width }}" id="input-image-width" class="form-control" min="100" max="2000" placeholder="Width" />
                  <span class="help-block">{{ help_image_width|default('Width (px)') }}</span>
                </div>
                <div class="col-sm-5">
                  <input type="number" name="module_dockercart_googlebase_image_height" value="{{ module_dockercart_googlebase_image_height }}" id="input-image-height" class="form-control" min="100" max="2000" placeholder="Height" />
                  <span class="help-block">{{ help_image_height|default('Height (px)') }}</span>
                </div>
              </div>

              <!-- Separate Languages -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-separate-languages">{{ entry_separate_languages|default('Separate Feeds by Language') }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_separate_languages" id="input-separate-languages" class="form-control">
                    <option value="0" {% if module_dockercart_googlebase_separate_languages == '0' %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                    <option value="1" {% if module_dockercart_googlebase_separate_languages == '1' %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                  </select>
                  <span class="help-block">{{ help_separate_languages|default('Generate separate feeds for each language') }}</span>
                </div>
              </div>

              <!-- Separate Stores -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-separate-stores">{{ entry_separate_stores|default('Separate Feeds by Store') }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_separate_stores" id="input-separate-stores" class="form-control">
                    <option value="0" {% if module_dockercart_googlebase_separate_stores == '0' %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                    <option value="1" {% if module_dockercart_googlebase_separate_stores == '1' %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                  </select>
                  <span class="help-block">{{ help_separate_stores|default('Generate separate feeds for each store') }}</span>
                </div>
              </div>

              <!-- Add to Robots removed -->

              <!-- Debug -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-debug">{{ entry_debug|default('Debug Mode') }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_debug" id="input-debug" class="form-control">
                    <option value="0" {% if module_dockercart_googlebase_debug == '0' %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                    <option value="1" {% if module_dockercart_googlebase_debug == '1' %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                  </select>
                  <span class="help-block">{{ help_debug|default('Enable debug logging for troubleshooting') }}</span>
                </div>
              </div>

              <!-- Info -->
              <div class="alert alert-info">
                <i class="fa fa-info-circle"></i> {{ text_info|raw }}
              </div>

              </div>

            </div>

            <!-- PRODUCTS TAB -->
            <div class="dcx-tab-pane" id="tab-products">
              <h4>{{ tab_products|default('Product Settings') }}</h4>

              <!-- Default Condition -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-condition">{{ entry_condition|default('Default Condition') }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_condition" id="input-condition" class="form-control">
                    <option value="new" {% if module_dockercart_googlebase_condition == 'new' %}selected="selected"{% endif %}>{{ text_condition_new|default('New') }}</option>
                    <option value="refurbished" {% if module_dockercart_googlebase_condition == 'refurbished' %}selected="selected"{% endif %}>{{ text_condition_refurbished|default('Refurbished') }}</option>
                    <option value="used" {% if module_dockercart_googlebase_condition == 'used' %}selected="selected"{% endif %}>{{ text_condition_used|default('Used') }}</option>
                  </select>
                  <span class="help-block">{{ help_condition|default('Default product condition') }}</span>
                </div>
              </div>

              <!-- Include Disabled Products -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-include-disabled">{{ entry_include_disabled|default('Include Disabled Products') }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_include_disabled" id="input-include-disabled" class="form-control">
                    <option value="0" {% if module_dockercart_googlebase_include_disabled == '0' %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                    <option value="1" {% if module_dockercart_googlebase_include_disabled == '1' %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                  </select>
                  <span class="help-block">{{ help_include_disabled|default('Include products with status = 0') }}</span>
                </div>
              </div>

              <!-- Include Out of Stock -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-include-out-of-stock">{{ entry_include_out_of_stock|default('Include Out of Stock Products') }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_include_out_of_stock" id="input-include-out-of-stock" class="form-control">
                    <option value="0" {% if module_dockercart_googlebase_include_out_of_stock == '0' %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                    <option value="1" {% if module_dockercart_googlebase_include_out_of_stock == '1' %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                  </select>
                  <span class="help-block">{{ help_include_out_of_stock|default('Include products with quantity = 0') }}</span>
                </div>
              </div>

              <!-- Brand Source -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-brand-source">{{ entry_brand_source|default('Brand Source') }}</label>
                <div class="col-sm-10">
                  <select name="module_dockercart_googlebase_brand_source" id="input-brand-source" class="form-control">
                    <option value="manufacturer" {% if module_dockercart_googlebase_brand_source == 'manufacturer' %}selected="selected"{% endif %}>{{ text_brand_manufacturer|default('From Manufacturer') }}</option>
                    <option value="default" {% if module_dockercart_googlebase_brand_source == 'default' %}selected="selected"{% endif %}>{{ text_brand_default|default('Use Default') }}</option>
                  </select>
                  <span class="help-block">{{ help_brand_source|default('Get brand from manufacturer or use default value') }}</span>
                </div>
              </div>

              <!-- Default Brand -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-brand-default">{{ entry_brand_default|default('Default Brand') }}</label>
                <div class="col-sm-10">
                  <input type="text" name="module_dockercart_googlebase_brand_default" value="{{ module_dockercart_googlebase_brand_default }}" id="input-brand-default" class="form-control" placeholder="" />
                  <span class="help-block">{{ help_brand_default|default('Default brand name if manufacturer is empty') }}</span>
                </div>
              </div>

              <!-- Exclude Products -->
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_exclude_products|default('Exclude Products') }}</label>
                <div class="col-sm-10">
                  <input type="hidden" name="module_dockercart_googlebase_exclude_products" id="input-exclude-products" value="{{ module_dockercart_googlebase_exclude_products }}" />
                  
                  <!-- Search input -->
                  <div class="input-group" style="margin-bottom: 10px; position: relative;">
                    <input type="text" id="product-search" class="form-control" placeholder="{{ text_product_search|default('Type to search products...') }}" autocomplete="off" />
                    <span class="input-group-btn">
                      <button type="button" class="btn btn-default" id="btn-product-search">
                        <i class="fa fa-search"></i>
                      </button>
                    </span>
                    <!-- Search results dropdown (positioned relative to input-group) -->
                    <div id="product-search-results" class="dropdown-menu" style="display: none; position: absolute; top: 100%; left: 0; z-index: 2000; width: 100%; max-height: 300px; overflow-y: auto; background: #fff; border: 1px solid #ddd; box-shadow: 0 6px 12px rgba(0,0,0,.175);"></div>
                  </div>
                  
                  <!-- Selected products list -->
                  <div id="excluded-products-list" class="well" style="min-height: 50px; max-height: 200px; overflow-y: auto;">
                    <div class="text-muted" id="no-products-message">{{ text_no_excluded_products|default('No products excluded') }}</div>
                  </div>
                  <span class="help-block">{{ help_exclude_products|default('Search and select products to exclude from the feed') }}</span>
                </div>
              </div>

              <!-- Exclude Categories -->
              <div class="form-group">
                <label class="col-sm-2 control-label">{{ entry_exclude_categories|default('Exclude Categories') }}</label>
                <div class="col-sm-10">
                  <input type="hidden" name="module_dockercart_googlebase_exclude_categories" id="input-exclude-categories" value="{{ module_dockercart_googlebase_exclude_categories }}" />
                  
                  <!-- Search input -->
                  <div class="input-group" style="margin-bottom: 10px; position: relative;">
                    <input type="text" id="category-search" class="form-control" placeholder="{{ text_category_search|default('Type to search categories...') }}" autocomplete="off" />
                    <span class="input-group-btn">
                      <button type="button" class="btn btn-default" id="btn-category-search">
                        <i class="fa fa-search"></i>
                      </button>
                    </span>
                    <!-- Search results dropdown (positioned relative to input-group) -->
                    <div id="category-search-results" class="dropdown-menu" style="display: none; position: absolute; top: 100%; left: 0; z-index: 2000; width: 100%; max-height: 300px; overflow-y: auto; background: #fff; border: 1px solid #ddd; box-shadow: 0 6px 12px rgba(0,0,0,.175);"></div>
                  </div>
                  
                  <!-- Category tree for easier exclusion -->
                  <div id="exclude-category-tree" style="max-height:320px; overflow:auto; border:1px solid #f0f0f0; padding:8px; background:#fff; margin-bottom:10px;"></div>
                  
                  <!-- Selected categories list -->
                  <div id="excluded-categories-list" class="well" style="min-height: 50px; max-height: 200px; overflow-y: auto;">
                    <div class="text-muted" id="no-categories-message">{{ text_no_excluded_categories|default('No categories excluded') }}</div>
                  </div>
                  <span class="help-block">{{ help_exclude_categories|default('Search and select categories to exclude from the feed') }}</span>
                </div>
              </div>

            </div>

            <!-- CATEGORIES TAB -->
            <div class="dcx-tab-pane" id="tab-categories">
              <h4>{{ tab_categories|default('Category Mapping') }}</h4>

              <div class="alert alert-info">
                <i class="fa fa-info-circle"></i> 
                {{ help_category_mapping|default('Map DockerCart categories to Google Product Categories. Format: category_id = google_category_id (one per line).')|raw }}
              </div>

              <!-- Category Mapping -->
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-category-mapping">{{ entry_category_mapping|default('Google Category Mapping') }}</label>
                <div class="col-sm-10">
                  <div id="mapping-ui">
                    <div style="display:flex; gap:10px; margin-bottom:10px; position:relative; align-items:flex-start;">
                      <div style="flex:1; position:relative; min-width:280px;">
                        <div class="input-group">
                          <input type="text" id="mapping-category-search" class="form-control" placeholder="Search DockerCart categories or type ID" />
                          <span class="input-group-btn"><button id="btn-mapping-category-search" type="button" class="btn btn-default"><i class="fa fa-search"></i></button></span>
                        </div>
                        <div id="mapping-category-results" style="display:none; position: absolute; z-index:9999; left:0; right:0; max-height:220px; overflow:auto; border:1px solid #eee; background:#fff;"></div>
                        <div style="display:flex; gap:10px; margin-top:8px;">
                          <div id="mapping-category-tree" style="flex:1; max-height:420px; overflow:auto; border:1px solid #f0f0f0; padding:8px; background:#fafafa;"></div>
                        </div>
                      </div>
                      <div style="flex:1; min-width:280px;">
                        <input type="text" id="mapping-google-input" class="form-control" placeholder="Google category (ID or path)" />
                        <div style="margin-top:8px;">
                          <div class="panel panel-default" style="padding:8px;">
                            <strong>Taxonomy</strong>
                            <div style="margin-top:8px;">
                              <div id="mapping-google-results-placeholder" style="position:relative;"></div>
                            </div>
                          </div>
                        </div>
                      </div>
                      <div style="width:120px; display:flex; flex-direction:column; gap:8px;">
                        <button type="button" id="btn-add-mapping" class="btn btn-primary" style="width:100%;">Add Mapping</button>
                        <small class="text-muted">Select a category on the left then enter/select a Google taxonomy on the right.</small>
                      </div>
                    </div>

                    <!-- Controls block: Import / Export / Load Taxonomy and status -->
                    <div class="well" style="margin-bottom:12px; display:flex; align-items:center; gap:12px;">
                      <div style="display:flex; gap:8px;">
                        <button type="button" id="btn-import-csv" class="btn btn-default"><i class="fa fa-upload"></i> Import CSV</button>
                        <button type="button" id="btn-export-csv" class="btn btn-default"><i class="fa fa-download"></i> Export CSV</button>
                        <button type="button" id="btn-upload-taxonomy" class="btn btn-default"><i class="fa fa-file"></i> Load Taxonomy</button>
                      </div>
                      <div style="flex:1;">
                        <p class="help-block" style="margin:0;">&nbsp;<span id="mapping-taxonomy-status">Upload Google taxonomy (txt) to enable autocomplete. Import/Export mappings via CSV.</span></p>
                      </div>
                      <div style="min-width:260px; text-align:right;">
                        <input type="file" id="mapping-taxonomy-file" accept=".txt,.csv" style="display:none;" />
                        <input type="file" id="mapping-csv-file" accept=".csv" style="display:none;" />
                      </div>
                    </div>

                    <div style="display:block;">
                      <div id="mapping-list" style="margin-bottom:10px;"></div>
