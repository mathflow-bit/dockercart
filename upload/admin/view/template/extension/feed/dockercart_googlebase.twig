<script type="text/javascript">
function updateGbPanelHeader(tabLink) {
    var $tab = $(tabLink);
    var title = $tab.data('title') || '{{ tab_general|default('General Settings') }}';
    var subtitle = $tab.data('subtitle') || '';
    var icon = String($tab.data('icon') || 'fa-cog').replace(/[^a-z0-9\-]/gi, '');

    $('#gb-tab-title').text(title);
    $('#gb-tab-subtitle').text(subtitle);
    $('#gb-tab-icon').attr('class', 'fa ' + icon);
}

$(document).on('click', '.js-gb-tab', function(e) {
    e.preventDefault();
    var tabId = $(this).data('tab');
    if (!tabId) return;

    $('#gb-tabs > li').removeClass('active');
    $(this).closest('li').addClass('active');

    $('#tab-general, #tab-products, #tab-categories, #tab-shipping, #tab-custom-labels, #tab-license, #tab-about').removeClass('active');
    $('#' + tabId).addClass('active');

    updateGbPanelHeader(this);
});

updateGbPanelHeader($('#gb-tabs > li.active a.js-gb-tab'));

// Generate feed
document.getElementById('btn-generate').addEventListener('click', function() {
    var btn = this;
    var originalHtml = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>';
    
    showAlert('info', 'Generating feed... This may take a while for large catalogs.');
    
    fetch('index.php?route=extension/feed/dockercart_googlebase/generate&user_token={{ user_token }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(function(response) { return response.json(); })
    .then(function(json) {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        
        if (json.success) {
            showAlert('success', json.success);
            if (json.stats) {
                updateStats(json.stats);
            }
        } else if (json.error) {
            showAlert('danger', json.error);
        }
    })
    .catch(function(error) {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        showAlert('danger', 'Error: ' + error.message);
    });
});

// Clear cache
document.getElementById('btn-clear-cache').addEventListener('click', function() {
    var btn = this;
    var originalHtml = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>';
    
    fetch('index.php?route=extension/feed/dockercart_googlebase/clearCache&user_token={{ user_token }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(function(response) { return response.json(); })
    .then(function(json) {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        
        if (json.success) {
            showAlert('success', json.success);
            if (json.stats) {
                updateStats(json.stats);
            }
        } else if (json.error) {
            showAlert('danger', json.error);
        }
    })
    .catch(function(error) {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        showAlert('danger', 'Error: ' + error.message);
    });
});

// License verification
document.getElementById('btn-verify-license').addEventListener('click', function() {
    var btn = this;
    var licenseKey = document.getElementById('input-license-key').value.trim();
    var publicKey = document.getElementById('input-public-key').value.trim();
    var licenseStatus = document.getElementById('license-status');
    var licenseInfo = document.getElementById('license-info');
    var licenseDetails = document.getElementById('license-details');
    
    if (!licenseKey) {
        licenseStatus.innerHTML = '<span class="label label-danger">Please enter license key</span>';
        return;
    }
    
    if (!publicKey) {
        licenseStatus.innerHTML = '<span class="label label-danger">Please enter public key</span>';
        return;
    }
    
    btn.disabled = true;
    var originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Verifying...';
    licenseStatus.innerHTML = '';
    licenseInfo.style.display = 'none';

    // Save keys first (non-blocking)
    fetch('index.php?route=extension/feed/dockercart_googlebase/saveLicenseKeyAjax&user_token={{ user_token }}', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        license_key: licenseKey,
        public_key: publicKey
      })
    }).catch(function(){});
    
    fetch('index.php?route=extension/feed/dockercart_googlebase/verifyLicenseAjax&user_token={{ user_token }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            license_key: licenseKey,
            public_key: publicKey
        })
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        
        if (data.valid) {
            licenseStatus.innerHTML = '<span class="label label-success"><i class="fa fa-check"></i> Valid</span>';
            
            var infoHtml = '<strong>Status:</strong> Active<br>';
            infoHtml += '<strong>Domain:</strong> ' + data.domain + '<br>';
            if (data.expires_formatted) {
                infoHtml += '<strong>Expires:</strong> ' + data.expires_formatted + '<br>';
            } else {
                infoHtml += '<strong>Type:</strong> Lifetime License<br>';
            }
            if (data.license_id) {
                infoHtml += '<strong>License ID:</strong> ' + data.license_id;
            }
            
            licenseDetails.innerHTML = infoHtml;
            licenseInfo.style.display = 'block';
        } else {
            licenseStatus.innerHTML = '<span class="label label-danger"><i class="fa fa-times"></i> Invalid</span>';
            
            if (data.error) {
                licenseDetails.innerHTML = '<strong>Error:</strong> ' + data.error;
                licenseInfo.style.display = 'block';
            }
        }
    })
    .catch(function(error) {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
        licenseStatus.innerHTML = '<span class="label label-danger">Error: ' + error.message + '</span>';
    });
});

// Helper functions
function showAlert(type, message) {
    var alertContainer = document.getElementById('alert-container');
    var alert = document.createElement('div');
    alert.className = 'alert alert-' + type + ' alert-dismissible';
    alert.innerHTML = '<i class="fa fa-' + (type === 'success' ? 'check-circle' : type === 'danger' ? 'exclamation-circle' : 'info-circle') + '"></i> ' + message + 
        ' <button type="button" class="close" data-dismiss="alert">&times;</button>';
    alertContainer.innerHTML = '';
    alertContainer.appendChild(alert);
    
    if (type === 'success') {
        setTimeout(function() {
            alert.style.opacity = '0';
            setTimeout(function() { alert.remove(); }, 300);
        }, 5000);
    }
}

function updateStats(stats) {
    if (stats.file_size) {
        document.getElementById('stat-size').textContent = stats.file_size;
    }
    if (stats.last_generated) {
        document.getElementById('stat-last-generated').textContent = stats.last_generated;
    }
}

// Auto-verify license on page load
document.addEventListener('DOMContentLoaded', function() {
    var licenseKey = document.getElementById('input-license-key').value.trim();
    var publicKey = document.getElementById('input-public-key').value.trim();
    
    if (licenseKey && publicKey) {
        setTimeout(function() {
            document.getElementById('btn-verify-license').click();
        }, 500);
    }
});

// ==========================================
// Exclude Products & Categories Autocomplete
// ==========================================

(function() {
    var excludedProducts = [];
    var excludedCategories = [];
    var searchTimeout = null;
    
    // Parse initial values
    var initialProducts = document.getElementById('input-exclude-products').value.trim();
    var initialCategories = document.getElementById('input-exclude-categories').value.trim();
    
    if (initialProducts) {
        excludedProducts = initialProducts.split(',').map(function(id) {
            return parseInt(id.trim(), 10);
        }).filter(function(id) { return id > 0; });
    }
    
    if (initialCategories) {
        excludedCategories = initialCategories.split(',').map(function(id) {
            return parseInt(id.trim(), 10);
        }).filter(function(id) { return id > 0; });
    }
    
    // Load existing items info on page load
    if (excludedProducts.length > 0) {
        loadProductsInfo(excludedProducts);
    }
    
    if (excludedCategories.length > 0) {
        loadCategoriesInfo(excludedCategories);
    }

    // === CATEGORY MAPPING UI ===
    var mappingEntries = [];
    var mappingHidden = document.getElementById('input-category-mapping');
    var mappingList = document.getElementById('mapping-list');
    var mappingNoItems = document.getElementById('mapping-no-items');
    var mappingCategorySearch = document.getElementById('mapping-category-search');
    var mappingCategoryResults = document.getElementById('mapping-category-results');
    var mappingGoogleInput = document.getElementById('mapping-google-input');
    var btnMappingCategorySearch = document.getElementById('btn-mapping-category-search');
    var btnAddMapping = document.getElementById('btn-add-mapping');

    function parseMappingText(text) {
      var lines = text.split(/\r?\n/);
      var items = [];
      lines.forEach(function(line) {
        line = line.trim();
        if (!line) return;
        var parts = line.split('=');
        if (parts.length >= 2) {
          var left = parts.shift().trim();
          var right = parts.join('=').trim();
          var id = parseInt(left, 10);
          if (!isNaN(id) && right.length) {
            items.push({ category_id: id, google: right });
          }
        }
      });
      return items;
    }

    function serializeMapping(entries) {
      return entries.map(function(e) { return e.category_id + ' = ' + e.google; }).join('\n');
    }

    function renderMappingList() {
      mappingList.innerHTML = '';
      if (!mappingEntries.length) {
        mappingNoItems.style.display = 'block';
        return;
      }
      mappingNoItems.style.display = 'none';
      mappingEntries.forEach(function(item, idx) {
        var row = document.createElement('div');
        row.style.cssText = 'display:flex; align-items:center; padding:6px 8px; margin-bottom:6px; background:#fff; border:1px solid #ddd; border-radius:3px;';
        var left = document.createElement('div');
        left.style.flex = '1';
        left.innerHTML = '<strong>' + escapeHtml(item.path || ('ID: ' + item.category_id)) + '</strong><br><small class="text-muted">DockerCart ID: ' + item.category_id + '</small>';
        var middle = document.createElement('div');
        middle.style.flex = '1';
        middle.innerHTML = '<span>' + escapeHtml(item.google) + '</span>';
        var removeBtn = document.createElement('button');
        removeBtn.className = 'btn btn-danger btn-xs';
        removeBtn.style.marginLeft = '10px';
        removeBtn.innerHTML = '<i class="fa fa-times"></i>';
        removeBtn.addEventListener('click', function() {
          mappingEntries.splice(idx, 1);
          mappingHidden.value = serializeMapping(mappingEntries);
          renderMappingList();
        });
        row.appendChild(left);
        row.appendChild(middle);
        row.appendChild(removeBtn);
        mappingList.appendChild(row);
      });
    }

    // Load existing mappings from hidden textarea
    if (mappingHidden && mappingHidden.value.trim()) {
      mappingEntries = parseMappingText(mappingHidden.value.trim());
      if (mappingEntries.length) {
        // Try to load category paths for entries
        var ids = mappingEntries.map(function(e) { return e.category_id; });
        fetch('index.php?route=extension/feed/dockercart_googlebase/getCategoryInfo&user_token={{ user_token }}&category_ids=' + ids.join(','))
          .then(function(r){ return r.json(); })
          .then(function(data){
            if (data.categories) {
              data.categories.forEach(function(cat) {
                mappingEntries.forEach(function(me) {
                  if (me.category_id == cat.category_id) me.path = cat.path || cat.name;
                });
              });
            }
            renderMappingList();
          }).catch(function(){ renderMappingList(); });
      }
    }

    function addMappingEntry(category_id, category_path, google) {
      category_id = parseInt(category_id, 10);
      if (isNaN(category_id) || !google || !google.trim()) return;
      // prevent duplicates
      for (var i=0;i<mappingEntries.length;i++) {
        if (mappingEntries[i].category_id === category_id) {
          mappingEntries[i].google = google;
          mappingEntries[i].path = category_path || mappingEntries[i].path;
          mappingHidden.value = serializeMapping(mappingEntries);
          renderMappingList();
          return;
        }
      }
      mappingEntries.push({ category_id: category_id, path: category_path, google: google.trim() });
      mappingHidden.value = serializeMapping(mappingEntries);
      renderMappingList();
    }

    // Mapping category search
    var mappingSearchTimeout = null;
    function mappingSearchCategories(query) {
      fetch('index.php?route=extension/feed/dockercart_googlebase/searchCategories&user_token={{ user_token }}&filter=' + encodeURIComponent(query))
        .then(function(response){ return response.json(); })
        .then(function(data){
          var html = '';
          if (data.categories && data.categories.length) {
            data.categories.forEach(function(category){
              html += '<a href="#" class="mapping-category-item" data-id="'+category.category_id+'" data-path="'+escapeHtml(category.path||category.name)+''+'" style="display:block;padding:8px 12px;border-bottom:1px solid #eee;color:#333;text-decoration:none;">'+escapeHtml(category.path||category.name)+'<br><small class="text-muted">ID: '+category.category_id+'</small></a>';
            });
          } else {
            html = '<div style="padding:8px 12px;color:#999;">No categories found</div>';
          }
          mappingCategoryResults.innerHTML = html;
          mappingCategoryResults.style.display = 'block';
          mappingCategoryResults.querySelectorAll('.mapping-category-item').forEach(function(item){
            item.addEventListener('click', function(e){
              e.preventDefault();
              var id = this.getAttribute('data-id');
              var path = this.getAttribute('data-path');
              mappingCategorySearch.value = path + ' (ID: ' + id + ')';
              mappingCategorySearch.dataset.selectedId = id;
              mappingCategoryResults.style.display = 'none';
            });
          });
        }).catch(function(){ mappingCategoryResults.style.display = 'none'; });
    }

    mappingCategorySearch.addEventListener('input', function(){
      clearTimeout(mappingSearchTimeout);
      var q = this.value.trim();
      delete this.dataset.selectedId;
      if (q.length < 2) { mappingCategoryResults.style.display = 'none'; return; }
      mappingSearchTimeout = setTimeout(function(){ mappingSearchCategories(q); }, 250);
    });

    btnMappingCategorySearch.addEventListener('click', function(){
      var q = mappingCategorySearch.value.trim();
      if (q.length >= 1) mappingSearchCategories(q);
    });

    btnAddMapping.addEventListener('click', function(){
      var google = mappingGoogleInput.value.trim();
      var selId = mappingCategorySearch.dataset.selectedId;
      var id = selId ? selId : parseInt(mappingCategorySearch.value.trim(),10);
      if (!id || isNaN(id)) { alert('Please select or enter a valid DockerCart category ID'); return; }
      // Try to get path via getCategoryInfo
      fetch('index.php?route=extension/feed/dockercart_googlebase/getCategoryInfo&user_token={{ user_token }}&category_ids='+id)
        .then(function(r){ return r.json(); })
        .then(function(data){
          var path = '';
          if (data.categories && data.categories.length) path = data.categories[0].path || data.categories[0].name || '';
          addMappingEntry(id, path, google);
          mappingCategorySearch.value = '';
          delete mappingCategorySearch.dataset.selectedId;
          mappingGoogleInput.value = '';
        }).catch(function(){ addMappingEntry(id, '', google); mappingCategorySearch.value = ''; mappingGoogleInput.value = ''; });
    });

    // Ensure hidden textarea is updated on save
    document.getElementById('form-dockercart-googlebase').addEventListener('submit', function() {
      mappingHidden.value = serializeMapping(mappingEntries);
    });

    // --- Category tree + Google taxonomy + CSV import/export ---
    var mappingCategoryTree = document.getElementById('mapping-category-tree');
    var mappingTaxonomy = [];
    var mappingGoogleResults = null;
    var mappingCsvFileInput = document.getElementById('mapping-csv-file');
    var mappingTaxonomyFileInput = document.getElementById('mapping-taxonomy-file');

    function loadCategoryTree() {
