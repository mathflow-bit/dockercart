    // Render a small taxonomy browser inside the Taxonomy panel placeholder
    function renderTaxonomyPanel() {
      var placeholder = document.getElementById('mapping-google-results-placeholder');
      if (!placeholder) return;
      placeholder.innerHTML = '';

      var header = document.createElement('div');
      header.style.marginBottom = '6px';
      header.innerHTML = '<input type="text" id="mapping-taxonomy-search" class="form-control" placeholder="Filter taxonomy...' + '" style="width:100%;" />';
      placeholder.appendChild(header);

      var list = document.createElement('div');
      list.id = 'mapping-taxonomy-list';
      list.style.maxHeight = '320px';
      list.style.overflow = 'auto';
      list.style.border = '1px solid #eee';
      list.style.background = '#fff';
      placeholder.appendChild(list);

      var entries = mappingTaxonomy || [];
      function populate(filter) {
        list.innerHTML = '';
        var f = (filter || '').toLowerCase();
        var count = 0;
        for (var i = 0; i < entries.length; i++) {
          var e = entries[i];
          var label = (e.id ? (e.id + ' - ') : '') + (e.label || '');
          if (f && label.toLowerCase().indexOf(f) === -1) continue;
          var a = document.createElement('a');
          a.href = '#';
          a.style.display = 'block';
          a.style.padding = '6px 8px';
          a.style.borderBottom = '1px solid #f5f5f5';
          a.style.color = '#333';
          a.innerHTML = escapeHtml(label);
          (function(val){
            a.addEventListener('click', function(e){
              e.preventDefault();
              mappingGoogleInput.value = val;
              mappingGoogleInput.focus();
              // hide panel suggestions
              var dd = document.getElementById('mapping-google-results'); if (dd) dd.style.display = 'none';
            });
          })(e.label);
          list.appendChild(a);
          count++;
          if (count >= 200) break; // avoid rendering all thousands by default
        }
        if (count === 0) list.innerHTML = '<div class="text-muted" style="padding:8px;">No taxonomy entries</div>';
      }

      // wire filter
      var filterInput = document.getElementById('mapping-taxonomy-search');
      filterInput.addEventListener('input', function(){ populate(this.value); });

      // initial populate with top entries
      populate('');
    }

    var googleTypTimeout = null;
    mappingGoogleInput.addEventListener('input', function() {
      clearTimeout(googleTypTimeout);
      var q = this.value.trim().toLowerCase();
      if (!q) { mappingGoogleResults.style.display = 'none'; return; }
      googleTypTimeout = setTimeout(function() {
        showGoogleSuggestions(q);
