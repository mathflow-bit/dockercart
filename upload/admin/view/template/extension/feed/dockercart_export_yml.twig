function saveProfile() {
    var formData = {};
    var settings = {};
    var filters = {};
    
    // Get profile_id if editing
    var profileId = $('#form-profile input[name="profile_id"]').val();
    var isEdit = !!profileId;
    if (profileId) {
        formData.profile_id = parseInt(profileId);
    }
    
    $('#form-profile').serializeArray().forEach(function(field) {
        var fieldName = field.name.replace('[]', '');
        
        // Categories and manufacturers go to filters
        if (fieldName === 'categories' || fieldName === 'manufacturers') {
            if (!filters[fieldName.replace('s', '')]) filters[fieldName.replace('s', '')] = [];
            filters[fieldName.replace('s', '')].push(field.value);
        }
        // Price, quantity, weight filters
        else if (['min_price', 'max_price', 'min_quantity', 'min_weight', 'max_weight', 'product_tag'].indexOf(fieldName) > -1) {
            if (!filters[fieldName]) filters[fieldName] = [];
            filters[fieldName].push(field.value);
        }
        // Delivery and additional settings go to settings object
        else if (['delivery_cost', 'delivery_days', 'order_before', 'pickup_enabled', 'sales_notes', 'adult_content'].indexOf(fieldName) > -1) {
            settings[fieldName] = field.value;
        }
        // Everything else goes to top level
        else {
            formData[fieldName] = field.value;
        }
    });
    
    // Handle checkboxes separately (they don't appear in serializeArray if unchecked)
    if ($('#profile-only-special').is(':checked')) {
        filters['only_special'] = ['1'];
    }
    if ($('#profile-pickup-enabled').is(':checked')) {
        settings['pickup_enabled'] = '1';
    }
    if ($('#profile-adult-content').is(':checked')) {
        settings['adult_content'] = '1';
    }
    if ($('#profile-strip-html').is(':checked')) {
        settings['strip_html_tags'] = '1';
    }
    if ($('#profile-split-files').is(':checked')) {
        formData.split_files = 1;
        formData.products_per_file = $('#profile-products-per-file').val() || 10000;
    }
    
    // Add settings and filters to formData
    formData.settings = settings;
    formData.filters = filters;
    
    $.ajax({
        url: '{{ ajax_save_profile }}',
        type: 'post',
        data: JSON.stringify(formData),
        contentType: 'application/json',
        dataType: 'json',
        beforeSend: function() {
            $('.modal-footer .btn-primary').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Saving...');
        },
        success: function(json) {
            if (json.success) {
                $('#profile-modal').modal('hide');
                
                // Show success message
                var message = isEdit ? 'Profile updated successfully!' : 'Profile created successfully!';
                showNotification('success', message);
                
                // Reload profiles table after a short delay
                setTimeout(function() {
                    location.reload();
                }, 1000);
            } else {
                alert('Error: ' + (json.error || 'Failed to save profile'));
                $('.modal-footer .btn-primary').prop('disabled', false).html('<i class="fa fa-save"></i> {{ button_save }}');
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            alert('Error: ' + thrownError);
            $('.modal-footer .btn-primary').prop('disabled', false).html('<i class="fa fa-save"></i> {{ button_save }}');
        }
    });
}

function showNotification(type, message) {
    var alertClass = 'alert-info';
    var icon = 'fa-info-circle';
    
    if (type === 'success') {
        alertClass = 'alert-success';
        icon = 'fa-check-circle';
    } else if (type === 'danger') {
        alertClass = 'alert-danger';
        icon = 'fa-exclamation-circle';
    }
    
    var html = '<div class="alert ' + alertClass + ' alert-dismissible" style="margin-bottom: 20px;">';
    html += '<button type="button" class="close" data-dismiss="alert">&times;</button>';
    html += '<i class="fa ' + icon + '"></i> ' + message;
    html += '</div>';
    
    // Add notification to the top of the profiles section
    $('#module-notice').html(html);
    
    // Auto-dismiss after 5 seconds
    setTimeout(function() {
        $('.alert').fadeOut(function() {
            $(this).remove();
        });
    }, 5000);
}

function generateFeed(profileId, btnEl) {
    if (!confirm('{{ text_confirm_generate }}')) {
        return;
    }
    
  var btn = btnEl || null;
  if (!btn) {
    return;
  }
    var originalHtml = $(btn).html();
    
    $(btn).prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Generating...');
    
    // Show notification
    showNotification('info', 'Generating YML feed... (new tab will open)');
    
    // Open feed URL in new tab with regenerate flag
    var feedUrl = '{{ catalog_url }}' + 'index.php?route=extension/feed/dockercart_export_yml&profile_id=' + profileId + '&lang={{ default_language_code }}&regenerate=1';
    window.open(feedUrl, '_blank');
    
    // Reset button after 2 seconds
    setTimeout(function() {
        $(btn).prop('disabled', false).html(originalHtml);
    }, 2000);
}

function deleteProfile(profileId) {
    if (!confirm('{{ text_confirm_delete }}')) {
        return;
    }
    
    $.ajax({
        url: '{{ ajax_delete_profile }}',
        type: 'post',
        data: JSON.stringify({ profile_id: profileId }),
        contentType: 'application/json',
        dataType: 'json',
        success: function(json) {
            if (json.success) {
                showNotification('success', '{{ text_delete_success }}');
                
                // Remove row from table
                $('tr[data-profile-id=\"' + profileId + '\"]').fadeOut(function() {
                    $(this).remove();
                });
                
                // Reload profiles after a short delay
                setTimeout(function() {
                    location.reload();
                }, 1500);
            } else {
                alert('Error: ' + (json.error || 'Failed to delete profile'));
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            alert('Error: ' + thrownError);
        }
    });
}
