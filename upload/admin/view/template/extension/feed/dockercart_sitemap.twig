{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <style>
    .dcx-sitemap-url { margin-top:6px; font-size:12px; color:#54627a; }
    .dcx-sitemap-url code { display:inline-block; margin-left:6px; }
  </style>
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-dockercart-sitemap" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <button id="button-generate" type="button" data-toggle="tooltip" title="{{ button_generate }}" class="btn btn-success" {% if not license_valid %}disabled{% endif %}><i class="fa fa-refresh"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <ul class="nav nav-tabs dcx-profile-tabs" id="sitemap-tabs" role="tablist">
      <li class="active"><a href="#sitemap-tab-general" class="js-sitemap-tab" data-tab="sitemap-tab-general" data-title="{{ text_tab_general }}" data-subtitle="{{ text_tab_general_subtitle }}" data-icon="fa-sliders"><i class="fa fa-sliders"></i> {{ text_tab_general }}</a></li>
      <li><a href="#sitemap-tab-license" class="js-sitemap-tab" data-tab="sitemap-tab-license" data-title="{{ text_tab_license }}" data-subtitle="{{ text_tab_license_subtitle }}" data-icon="fa-key"><i class="fa fa-key"></i> {{ text_tab_license }}</a></li>
      <li><a href="#sitemap-tab-about" class="js-sitemap-tab" data-tab="sitemap-tab-about" data-title="{{ text_tab_about }}" data-subtitle="{{ text_tab_about_subtitle }}" data-icon="fa-info-circle"><i class="fa fa-info-circle"></i> {{ text_tab_about }}</a></li>
    </ul>

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i id="sitemap-tab-icon" class="fa fa-sliders"></i></div>
          <div>
            <h3 class="dcx-panel-title" id="sitemap-tab-title">{{ text_tab_general }}</h3>
            <div class="dcx-panel-subtitle" id="sitemap-tab-subtitle">{{ text_tab_general_subtitle }}</div>
          </div>
        </div>
        <div class="dcx-panel-body">
          <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-dockercart-sitemap" class="form-horizontal dcx-form">

          <div id="sitemap-tab-general" class="dcx-tab-pane active">
            <div class="dcx-section">
              <h4>{{ text_section_module_settings }}</h4>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-9">
                  <select name="dockercart_sitemap_status" id="input-status" class="form-control">
                    {% if dockercart_sitemap_status %}
                    <option value="1" selected="selected">{{ text_enabled }}</option>
                    <option value="0">{{ text_disabled }}</option>
                    {% else %}
                    <option value="1">{{ text_enabled }}</option>
                    <option value="0" selected="selected">{{ text_disabled }}</option>
                    {% endif %}
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">{{ text_sitemap_url }}</label>
                <div class="col-sm-9">
                  <div class="alert alert-info" style="margin-bottom:0;">
                    <i class="fa fa-info-circle"></i> <a href="{{ sitemap_url }}" target="_blank">{{ sitemap_url }}</a>
                    {% if last_generated %}
                    <div class="dcx-sitemap-url">Last generated: <strong id="sitemap-last-generated">{{ last_generated }}</strong> — <span id="sitemap-file-count">{{ sitemap_file_count }}</span> files</div>
                    {% else %}
                    <div class="dcx-sitemap-url">Last generated: <strong id="sitemap-last-generated">Never</strong></div>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>

            <div class="dcx-section">
