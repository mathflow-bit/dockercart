<script>
function updateSitemapPanelHeader(tabLink) {
  var $tab = $(tabLink);
  var title = $tab.data('title') || '{{ text_tab_general }}';
  var subtitle = $tab.data('subtitle') || '{{ text_tab_general_subtitle }}';
  var icon = String($tab.data('icon') || 'fa-sliders').replace(/[^a-z0-9\-]/gi, '');

  $('#sitemap-tab-title').text(title);
  $('#sitemap-tab-subtitle').text(subtitle);
  $('#sitemap-tab-icon').attr('class', 'fa ' + icon);
}

$(document).on('click', '.js-sitemap-tab', function(e) {
  e.preventDefault();
  var tabId = $(this).data('tab');
  if (!tabId) return;

  $('#sitemap-tabs > li').removeClass('active');
  $(this).closest('li').addClass('active');

  $('#sitemap-tab-general, #sitemap-tab-license, #sitemap-tab-about').removeClass('active');
  $('#' + tabId).addClass('active');

  updateSitemapPanelHeader(this);
});

updateSitemapPanelHeader($('#sitemap-tabs > li.active a.js-sitemap-tab'));
</script>

<script>
/* <![CDATA[ */
(() => {
  const url = '{{ generate_ajax }}';
  const btn = document.getElementById('button-generate');
  if (!btn) return;

  const container = document.querySelector('.container-fluid');
  const lastGeneratedEl = document.getElementById('sitemap-last-generated');
  const fileCountEl = document.getElementById('sitemap-file-count');

  const createAlert = (type, message) => {
    const safe = message || '';
    return `<div class="alert alert-${type} alert-dismissible"><i class="fa ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i> ${safe}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`;
  };

  const setBusy = (isBusy) => {
    btn.disabled = isBusy;
    const icon = btn.querySelector('i');
    if (icon) {
      if (isBusy) {
        icon.classList.add('fa-spin', 'fa-spinner');
      } else {
        icon.classList.remove('fa-spin', 'fa-spinner');
      }
    }
  };

  btn.addEventListener('click', async (ev) => {
    ev.preventDefault();
    setBusy(true);

    try {
      const resp = await fetch(url.replace(/&amp;/g, '&'), {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/json'
        }
      });

      if (!resp.ok) {
        const text = await resp.text();
        const html = createAlert('danger', `Server returned ${resp.status}: ${text}`);
        if (container) container.insertAdjacentHTML('afterbegin', html);
        return;
      }

      const json = await resp.json();

      if (json.error) {
        if (container) container.insertAdjacentHTML('afterbegin', createAlert('danger', json.error));
      } else if (json.success) {
        if (container) container.insertAdjacentHTML('afterbegin', createAlert('success', json.success));
        if (json.last_generated && lastGeneratedEl) lastGeneratedEl.textContent = json.last_generated;
        if (typeof json.file_count !== 'undefined' && fileCountEl) fileCountEl.textContent = json.file_count;
      }
    } catch (err) {
      if (container) container.insertAdjacentHTML('afterbegin', createAlert('danger', 'Unexpected error while generating sitemap.'));
      // Keep the real error in console for debugging
      // eslint-disable-next-line no-console
      console.error('Sitemap generation error', err);
    } finally {
      setBusy(false);
    }
  });
})();
/* ]]> */
</script>

<script>
/* License save + verify (copied from Dockercart Filter behavior) */
document.addEventListener('DOMContentLoaded', function() {
  var btnVerify = document.getElementById('btn-verify-license');
  var licenseInput = document.getElementById('input-license-key');
  var licenseStatus = document.getElementById('license-status');
  var licenseInfo = document.getElementById('license-info');
  var licenseDetails = document.getElementById('license-details');
  var publicKeyInput = document.getElementById('input-public-key');

  function saveLicenseKey(licenseKey) {
    var publicKey = publicKeyInput.value.trim();

    return fetch('{{ license_save_ajax }}'.replace(/&amp;/g, '&'), {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ license_key: licenseKey, public_key: publicKey })
    }).then(function(resp) { return resp.json(); });
  }

  function verifyLicense() {
    var licenseKey = licenseInput.value.trim();
    var publicKey = publicKeyInput.value.trim();

    if (!licenseKey) {
      licenseStatus.innerHTML = '<span class="label label-danger">Please enter license key</span>';
      return;
    }

    if (!publicKey) {
      licenseStatus.innerHTML = '<span class="label label-danger">Please enter public key</span>';
      return;
    }

    btnVerify.disabled = true;
    var originalText = btnVerify.innerHTML;
    btnVerify.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Verifying...';
    licenseStatus.innerHTML = '';
    licenseInfo.style.display = 'none';

    // Save keys first to persist (non-blocking if save fails)
    saveLicenseKey(licenseKey).catch(function(e){ /* ignore save errors here */ });

    fetch('{{ license_verify_ajax }}'.replace(/&amp;/g, '&'), {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ license_key: licenseKey, public_key: publicKey })
    })
    .then(function(resp) { return resp.json(); })
    .then(function(data) {
      btnVerify.disabled = false;
      btnVerify.innerHTML = originalText;

      if (data.valid) {
        licenseStatus.innerHTML = '<span class="label label-success"><i class="fa fa-check"></i> Valid</span>';
        var infoHtml = '<strong>Status:</strong> Active<br>';
        infoHtml += '<strong>Domain:</strong> ' + (data.domain || '{{ license_domain }}') + '<br>';
        if (data.expires_formatted) {
          infoHtml += '<strong>Expires:</strong> ' + data.expires_formatted + '<br>';
        } else {
          infoHtml += '<strong>Type:</strong> Lifetime License<br>';
        }
        if (data.license_id) infoHtml += '<strong>License ID:</strong> ' + data.license_id;
        licenseDetails.innerHTML = infoHtml;
        licenseInfo.style.display = 'block';
      } else {
        licenseStatus.innerHTML = '<span class="label label-danger"><i class="fa fa-times"></i> Invalid</span>';
        licenseDetails.innerHTML = data.error ? ('<strong>Error:</strong> ' + data.error) : '';
        licenseInfo.style.display = 'block';
      }
    })
    .catch(function(err) {
      btnVerify.disabled = false;
      btnVerify.innerHTML = originalText;
      licenseStatus.innerHTML = '<span class="label label-danger">Error: ' + (err.message || err) + '</span>';
    });
  }

  if (btnVerify) {
    licenseInput.addEventListener('input', function() { licenseStatus.innerHTML = ''; licenseInfo.style.display = 'none'; });
    btnVerify.addEventListener('click', function() { verifyLicense(); });

    // Auto-verify when page loads if license exists
    if (licenseInput.value.trim()) {
      setTimeout(function() { verifyLicense(); }, 500);
    }
  }
});
</script>
