{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <style>
    .dc-occ-license-status { margin-left:10px; }
    .dc-occ-lang-tabs { margin-bottom:8px; }
    .dc-occ-lang-tabs > li > a { padding:8px 10px; }
    .dc-occ-check-table input[type="checkbox"] { transform:scale(1.05); }
  </style>

  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-module" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <ul class="nav nav-tabs dcx-profile-tabs" id="occ-tabs" role="tablist">
      <li class="active"><a href="#occ-tab-general" class="js-occ-tab" data-tab="occ-tab-general" data-title="General" data-subtitle="Main behavior, captions and order settings" data-icon="fa-sliders"><i class="fa fa-sliders"></i> General</a></li>
      <li><a href="#occ-tab-fields" class="js-occ-tab" data-tab="occ-tab-fields" data-title="{{ text_field_settings }}" data-subtitle="Configure visible and required form fields" data-icon="fa-list"><i class="fa fa-list"></i> {{ text_field_settings }}</a></li>
      <li><a href="#occ-tab-license" class="js-occ-tab" data-tab="occ-tab-license" data-title="License" data-subtitle="License verification and activation status" data-icon="fa-key"><i class="fa fa-key"></i> License</a></li>
      <li><a href="#occ-tab-about" class="js-occ-tab" data-tab="occ-tab-about" data-title="About" data-subtitle="Module information and support contacts" data-icon="fa-info-circle"><i class="fa fa-info-circle"></i> About</a></li>
    </ul>

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i id="occ-tab-icon" class="fa fa-sliders"></i></div>
          <div>
            <h3 class="dcx-panel-title" id="occ-tab-title">General</h3>
            <div class="dcx-panel-subtitle" id="occ-tab-subtitle">Main behavior, captions and order settings</div>
          </div>
        </div>
        <div class="dcx-panel-body">
          <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-module" class="form-horizontal dcx-form">

            <div id="occ-tab-general" class="dcx-tab-pane active">
              <div class="dcx-section">
                <h4>Module Settings</h4>

                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                  <div class="col-sm-9">
                    <select name="module_dockercart_oneclickcheckout_status" id="input-status" class="form-control">
                      {% if module_dockercart_oneclickcheckout_status %}
                      <option value="1" selected="selected">{{ text_enabled }}</option>
                      <option value="0">{{ text_disabled }}</option>
                      {% else %}
                      <option value="1">{{ text_enabled }}</option>
                      <option value="0" selected="selected">{{ text_disabled }}</option>
                      {% endif %}
                    </select>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-3 control-label">{{ entry_button_text }}</label>
                  <div class="col-sm-9">
                    <ul class="nav nav-tabs dc-occ-lang-tabs" id="language-button">
                      {% for language in languages %}
                      <li{% if loop.first %} class="active"{% endif %}><a href="#language-button{{ language.language_id }}" data-toggle="tab"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }}</a></li>
                      {% endfor %}
                    </ul>
                    <div class="tab-content">
                      {% for language in languages %}
                      <div class="tab-pane{% if loop.first %} active{% endif %}" id="language-button{{ language.language_id }}">
                        <input type="text" name="module_dockercart_oneclickcheckout_button_text[{{ language.language_id }}]" value="{% if module_dockercart_oneclickcheckout_button_text[language.language_id] is defined %}{{ module_dockercart_oneclickcheckout_button_text[language.language_id] }}{% endif %}" placeholder="{{ entry_button_text }}" class="form-control" />
                      </div>
                      {% endfor %}
                    </div>
                    <small class="help-block">{{ help_button_text }}</small>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-3 control-label">{{ entry_modal_title }}</label>
                  <div class="col-sm-9">
                    <ul class="nav nav-tabs dc-occ-lang-tabs" id="language-modal">
                      {% for language in languages %}
                      <li{% if loop.first %} class="active"{% endif %}><a href="#language-modal{{ language.language_id }}" data-toggle="tab"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }}</a></li>
                      {% endfor %}
                    </ul>
                    <div class="tab-content">
                      {% for language in languages %}
                      <div class="tab-pane{% if loop.first %} active{% endif %}" id="language-modal{{ language.language_id }}">
                        <input type="text" name="module_dockercart_oneclickcheckout_modal_title[{{ language.language_id }}]" value="{% if module_dockercart_oneclickcheckout_modal_title[language.language_id] is defined %}{{ module_dockercart_oneclickcheckout_modal_title[language.language_id] }}{% endif %}" placeholder="{{ entry_modal_title }}" class="form-control" />
                      </div>
                      {% endfor %}
                    </div>
                    <small class="help-block">{{ help_modal_title }}</small>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-color-theme">{{ entry_color_theme }}</label>
                  <div class="col-sm-9">
                    <select name="module_dockercart_oneclickcheckout_color_theme" id="input-color-theme" class="form-control">
                      {% for theme_key, theme_name in color_themes %}
                      <option value="{{ theme_key }}"{% if theme_key == module_dockercart_oneclickcheckout_color_theme %} selected="selected"{% endif %}>{{ theme_name }}</option>
                      {% endfor %}
                    </select>
                    <small class="help-block">{{ help_color_theme }}</small>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-order-status">{{ entry_order_status }}</label>
                  <div class="col-sm-9">
                    <select name="module_dockercart_oneclickcheckout_order_status_id" id="input-order-status" class="form-control">
                      {% for order_status in order_statuses %}
                      {% if order_status.order_status_id == module_dockercart_oneclickcheckout_order_status_id %}
                      <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                      {% else %}
                      <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                      {% endif %}
                      {% endfor %}
                    </select>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-3 control-label">{{ entry_use_captcha }}</label>
                  <div class="col-sm-9">
                    <select name="module_dockercart_oneclickcheckout_use_captcha" class="form-control">
                      {% if module_dockercart_oneclickcheckout_use_captcha %}
                      <option value="1" selected="selected">{{ text_yes }}</option>
                      <option value="0">{{ text_no }}</option>
                      {% else %}
                      <option value="1">{{ text_yes }}</option>
                      <option value="0" selected="selected">{{ text_no }}</option>
                      {% endif %}
                    </select>
                    <small class="help-block">{{ help_use_captcha }}</small>
                  </div>
                </div>
              </div>
            </div>

            <div id="occ-tab-fields" class="dcx-tab-pane">
              <div class="dcx-section">
                <h4>{{ text_field_settings }}</h4>

                <div class="table-responsive">
                  <table class="table table-striped table-bordered dcx-table dc-occ-check-table">
                    <thead>
                      <tr>
                        <td>{{ column_field }}</td>
                        <td class="text-center">{{ column_show }}</td>
                        <td class="text-center">{{ column_required }}</td>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>{{ entry_firstname }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_firstname_show" value="1" {% if module_dockercart_oneclickcheckout_field_firstname_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_firstname_required" value="1" {% if module_dockercart_oneclickcheckout_field_firstname_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_lastname }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_lastname_show" value="1" {% if module_dockercart_oneclickcheckout_field_lastname_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_lastname_required" value="1" {% if module_dockercart_oneclickcheckout_field_lastname_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_email }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_email_show" value="1" {% if module_dockercart_oneclickcheckout_field_email_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_email_required" value="1" {% if module_dockercart_oneclickcheckout_field_email_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_telephone }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_telephone_show" value="1" {% if module_dockercart_oneclickcheckout_field_telephone_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_telephone_required" value="1" {% if module_dockercart_oneclickcheckout_field_telephone_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_comment }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_comment_show" value="1" {% if module_dockercart_oneclickcheckout_field_comment_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_comment_required" value="1" {% if module_dockercart_oneclickcheckout_field_comment_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_address }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_address_show" value="1" {% if module_dockercart_oneclickcheckout_field_address_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_address_required" value="1" {% if module_dockercart_oneclickcheckout_field_address_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_city }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_city_show" value="1" {% if module_dockercart_oneclickcheckout_field_city_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_city_required" value="1" {% if module_dockercart_oneclickcheckout_field_city_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_postcode }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_postcode_show" value="1" {% if module_dockercart_oneclickcheckout_field_postcode_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_postcode_required" value="1" {% if module_dockercart_oneclickcheckout_field_postcode_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_country }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_country_show" value="1" {% if module_dockercart_oneclickcheckout_field_country_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_country_required" value="1" {% if module_dockercart_oneclickcheckout_field_country_required %} checked="checked" {% endif %} /></td>
                      </tr>
                      <tr>
                        <td>{{ entry_zone }}</td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_zone_show" value="1" {% if module_dockercart_oneclickcheckout_field_zone_show %} checked="checked" {% endif %} /></td>
                        <td class="text-center"><input type="checkbox" name="module_dockercart_oneclickcheckout_field_zone_required" value="1" {% if module_dockercart_oneclickcheckout_field_zone_required %} checked="checked" {% endif %} /></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <div id="occ-tab-license" class="dcx-tab-pane">
              <div class="dcx-section">
                <h4>License Information</h4>

                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-license-key">{{ entry_license_key }}</label>
                  <div class="col-sm-9">
                    <input type="text" name="module_dockercart_oneclickcheckout_license_key" value="{{ module_dockercart_oneclickcheckout_license_key }}" placeholder="{{ entry_license_key }}" id="input-license-key" class="form-control" />
                    <small class="help-block">{{ help_license_key }}</small>
                    <small class="form-text text-muted" style="margin-top: 5px;">
                      <i class="fa fa-info-circle"></i> License bound to domain: <strong>{{ license_domain|default('localhost') }}</strong>
                    </small>
                    {% if not license_valid and module_dockercart_oneclickcheckout_license_key %}
                    <div class="alert alert-warning" style="margin-top: 10px;">
                      <i class="fa fa-exclamation-triangle"></i> {{ error_license_invalid }}
                    </div>
                    {% endif %}
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-public-key">
                    <span data-toggle="tooltip" title="{{ help_public_key }}">{{ entry_public_key }}</span>
                  </label>
                  <div class="col-sm-9">
                    <textarea name="module_dockercart_oneclickcheckout_public_key" id="input-public-key" rows="8" class="form-control" placeholder="-----BEGIN PUBLIC KEY-----&#10;...&#10;-----END PUBLIC KEY-----">{{ module_dockercart_oneclickcheckout_public_key }}</textarea>
                    <small class="help-block"><i class="fa fa-info-circle"></i> {{ help_public_key }}</small>
                  </div>
                </div>

                <div id="license-info" class="form-group" style="display:none;">
                  <div class="col-sm-offset-3 col-sm-9">
                    <div class="alert alert-info">
                      <h4><i class="fa fa-info-circle"></i> License Information</h4>
                      <p id="license-details"></p>
                    </div>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-3 control-label"></label>
                  <div class="col-sm-9">
                    <button type="button" id="button-verify-license" class="btn btn-info" data-loading-text="{{ text_loading }}">
                      <i class="fa fa-check-circle"></i> {{ button_verify_license }}
                    </button>
                    <span id="license-status" class="dc-occ-license-status"></span>
                  </div>
                </div>
              </div>
            </div>

            <div id="occ-tab-about" class="dcx-tab-pane">
              <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
                <h4>About</h4>
                <table class="table table-bordered dcx-table">
                  <tr>
                    <td style="width:220px;"><strong>Module Version</strong></td>
                    <td>{% if module_version is defined and module_version %}{{ module_version }}{% else %}n/a{% endif %}</td>
                  </tr>
                  <tr>
                    <td><strong>Developer</strong></td>
                    <td>DockerCart Team</td>
                  </tr>
                  <tr>
                    <td><strong>Contact</strong></td>
                    <td><a href="mailto:support@dockercart.net">support@dockercart.net</a></td>
                  </tr>
                </table>
              </div>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}

<script type="text/javascript">
function updateOccPanelHeader(tabLink) {
    var $tab = $(tabLink);
  var title = $tab.data('title') || 'General';
    var subtitle = $tab.data('subtitle') || '';
  var icon = String($tab.data('icon') || 'fa-cog').replace(/[^a-z0-9\-]/gi, '');

    $('#occ-tab-title').text(title);
    $('#occ-tab-subtitle').text(subtitle);
    $('#occ-tab-icon').attr('class', 'fa ' + icon);
}

$(document).on('click', '.js-occ-tab', function(e) {
    e.preventDefault();
    var tabId = $(this).data('tab');
    if (!tabId) return;

    $('#occ-tabs > li').removeClass('active');
    $(this).closest('li').addClass('active');

    $('#occ-tab-general, #occ-tab-fields, #occ-tab-license, #occ-tab-about').removeClass('active');
    $('#' + tabId).addClass('active');

    updateOccPanelHeader(this);
});

updateOccPanelHeader($('#occ-tabs > li.active a.js-occ-tab'));

// Verify license button
$('#button-verify-license').on('click', function() {
    var $btn = $(this);
    var license_key = $('#input-license-key').val();
    var public_key = $('#input-public-key').val();
    var $status = $('#license-status');

    if (!license_key) {
        $status.html('<span class="label label-danger">{{ error_license_invalid }}</span>');
        return;
    }

    if (!public_key) {
        $status.html('<span class="label label-danger">Please enter public key</span>');
        return;
    }

    $btn.button('loading');
    $status.html('<span class="label label-info"><i class="fa fa-spinner fa-spin"></i> Verifying...</span>');
    $('#license-info').hide();

    $.ajax({
        url: 'index.php?route=extension/module/dockercart_oneclickcheckout/verifyLicense&user_token={{ user_token }}',
        type: 'post',
        data: JSON.stringify({
            license_key: license_key,
            public_key: public_key
        }),
        contentType: 'application/json',
        dataType: 'json',
        success: function(json) {
            $btn.button('reset');

            if (json.valid) {
                var message = json.message || '{{ success_license_valid }}';
                $status.html('<span class="label label-success"><i class="fa fa-check"></i> ' + message + '</span>');

                var infoHtml = '<strong>Status:</strong> Active<br>';
                if (json.domain || '{{ license_domain|default('localhost') }}') {
                    infoHtml += '<strong>Domain:</strong> ' + (json.domain || '{{ license_domain|default('localhost') }}') + '<br>';
                }
                if (json.expires_formatted) {
                    infoHtml += '<strong>Expires:</strong> ' + json.expires_formatted + '<br>';
                }
                if (json.license_id) {
                    infoHtml += '<strong>License ID:</strong> ' + json.license_id + '<br>';
                }
                if (json.message && !json.license_id) {
                    infoHtml += '<strong>Message:</strong> ' + json.message;
                }
                $('#license-details').html(infoHtml);
                $('#license-info').show();
            } else {
                var err = json.error || '{{ error_license_invalid }}';
                $status.html('<span class="label label-danger"><i class="fa fa-times"></i> ' + err + '</span>');
                $('#license-details').html('<strong>Error:</strong> ' + err);
                $('#license-info').show();
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            $btn.button('reset');
            $status.html('<span class="label label-danger"><i class="fa fa-times"></i> ' + thrownError + '</span>');
        }
    });
});
</script>
