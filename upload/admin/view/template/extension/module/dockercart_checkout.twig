</div>

<!-- Block Settings Modal (single copy) -->
<div id="block-settings-modal" class="dc-modal-overlay">
  <div class="dc-modal">
    <div class="dc-modal-header">
      <h3><i data-lucide="settings"></i> <span id="modal-block-title">{{ text_block_settings|default('Block Settings') }}</span></h3>
      <button type="button" class="dc-modal-close" onclick="closeBlockSettingsModal()">&times;</button>
    </div>
    <div class="dc-modal-body">
      <div id="modal-block-content">
        <!-- Dynamic content will be loaded here -->
      </div>
    </div>
      <div class="dc-modal-footer">
      <div class="dc-modal-info">
        <i data-lucide="info"></i>
        <span>{{ text_modal_instructions|default('Drag fields to reorder • Toggle switches to show/hide or set as required') }}</span>
      </div>
      <div class="dc-modal-buttons">
        <button type="button" class="btn btn-default" id="btn-modal-close">
          <i data-lucide="x"></i> {{ text_cancel|default('Cancel') }}
        </button>
        <button type="button" class="btn btn-success" id="btn-modal-save">
          <i data-lucide="save"></i> {{ text_save|default('Save') }}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
const DockercartCheckout = (() => {
  const CONFIG = {
    blocksData: [
      {% for block in blocks %}
      { id: '{{ block.id }}', rows: {{ block.rows|json_encode|raw }} }{{ not loop.last ? ',' : '' }}
      {% endfor %}
    ]
  };

  const STATE = {
    blockRowTemplates: {},
    currentBlockIndex: null,
    currentBlockId: null,
    currentBlockRows: [],
    modalObserver: null,
    blocksObserver: null,
    isInitialized: false
  };

  const initTemplates = () => {
    CONFIG.blocksData.forEach(({ id, rows }) => {
      STATE.blockRowTemplates[id] = Array.isArray(rows)
        ? rows.map(row => ({
            columns: row.columns || 1,
            fields: (row.fields || []).map(f => ({
              id: f.id,
              label: f.label || f.name || f.id,
              visible: Boolean(f.visible),
              required: Boolean(f.required),
              type: f.type || 'text',
              placeholder: f.placeholder || ''
            }))
          }))
        : [];
    });
  };

  initTemplates();
  const originalBlockRowTemplates = structuredClone(STATE.blockRowTemplates);
  // Backwards-compatible alias used in several places in the template
  const blockRowTemplates = STATE.blockRowTemplates;
  // Local alias for mutable rows used throughout the modal code
  let currentBlockRows = STATE.currentBlockRows;
  // Local aliases for current block identifiers used across modal functions
  let currentBlockIndex = STATE.currentBlockIndex;
  let currentBlockId = STATE.currentBlockId;
  // Local references for observers and init flag (keep STATE in sync)
  let modalObserver = STATE.modalObserver;
  let blocksObserver = STATE.blocksObserver;
  let isInitialized = STATE.isInitialized;

  const lucideRender = () => {
    try { if (typeof lucide?.createIcons === 'function') lucide.createIcons(); }
    catch { /* ignore */ }
  };

  const parseJSON = (value) => {
    if (!value || typeof value !== 'string') return null;

    // Escape special regex characters in single-char patterns to avoid unterminated
    const escapeForRegex = (s) => String(s).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const countChars = (str, char) => (str.match(new RegExp(escapeForRegex(char), 'g')) || []).length;
    if (countChars(value, '{') !== countChars(value, '}') ||
        countChars(value, '[') !== countChars(value, ']')) {
      console.warn('parseJSON: unbalanced braces/brackets');
      return null;
    }

    try { return JSON.parse(value); } catch { }

    try {
      const textarea = document.createElement('textarea');
      textarea.innerHTML = value;
      const decoded = textarea.value;
      if (decoded !== value) return JSON.parse(decoded);
    } catch { }

    try {
      const normalized = value
        .replace(/\r\n?|\n/g, ' ')
        .replace(/'([^']*)'/g, '"$1"')
        .replace(/([\{,\s])([A-Za-z0-9_\-]+)\s*:/g, '$1"$2":')
        .replace(/,\s*([\}\]])/g, '$1');
      return JSON.parse(normalized);
    } catch (err) {
      console.error('parseJSON: all attempts failed', err);
      return null;
    }
  };

  const openBlockSettingsModal = (blockIndex, blockId) => {
    // update both local aliases and STATE so all code paths see consistent values
    currentBlockIndex = Number(blockIndex);
    currentBlockId = blockId;
    STATE.currentBlockIndex = currentBlockIndex;
    STATE.currentBlockId = currentBlockId;

    const blockItem = document.querySelector(`[data-block-id="${blockId}"]`);
    const modalContent = document.getElementById('modal-block-content');
    const modal = document.getElementById('block-settings-modal');

    if (!blockItem) {
      console.error('Block item not found:', blockId);
      modalContent.innerHTML = '<div class="alert alert-info"><i data-lucide="info"></i> {{ text_block_not_found|default("Block not found.") }}</div>';
      modal.classList.add('active');
      lucideRender();
      return;
    }

    const blockName = blockItem.querySelector('.dc-block-col-name span')?.textContent || blockId;
    const rowsInput = blockItem.querySelector('.block-rows-input');

    // Initialize local rows array for the modal
    currentBlockRows = [];
    if (rowsInput?.value) {
      const parsed = parseJSON(rowsInput.value);
      if (Array.isArray(parsed)) currentBlockRows = parsed;
    }

    // Fallback to template if no rows found
    if (currentBlockRows.length === 0 && blockRowTemplates[blockId]) {
      currentBlockRows = JSON.parse(JSON.stringify(blockRowTemplates[blockId]));
    }

    // Build modal HTML with ROWS
    document.getElementById('modal-block-title').textContent = `${blockName} - {{ text_configure|default("Configure") }}`;

    let content = `<div style="margin-bottom: 15px;">
      <button type="button" class="btn btn-sm btn-success" id="btn-add-row">
        <i data-lucide="plus"></i> {{ button_add_row|default("Add Row") }}
      </button>
    </div>`;
    content += `<h4><i data-lucide="layout"></i> {{ text_rows_configuration|default("Rows Configuration") }}</h4>`;
    content += `<div class="dc-modal-rows-list" data-block-index="${currentBlockIndex}">`;

    if (currentBlockRows && currentBlockRows.length > 0) {
      currentBlockRows.forEach((row, rowIdx) => {
        const columns = row.columns || 1;
        const fields = row.fields || [];

        content += `<div class="dc-modal-row-item" data-row-index="${rowIdx}">
          <div class="dc-modal-row-header">
            <span class="drag-handle" draggable="true" style="cursor: move; margin-right: 10px; user-select: none;">⋮⋮</span>
            <strong>{{ text_row|default("Row") }} ${rowIdx + 1}</strong>
            <span style="margin-left: 15px;">{{ text_columns|default("Columns:") }}</span>
            <select class="row-columns-select" data-row-index="${rowIdx}" style="margin-left: 5px; padding: 2px 5px;">
              <option value="1" ${columns === 1 ? 'selected' : ''}>1</option>
              <option value="2" ${columns === 2 ? 'selected' : ''}>2</option>
              <option value="3" ${columns === 3 ? 'selected' : ''}>3</option>
            </select>
            <button type="button" class="btn btn-xs btn-danger btn-remove-row" data-row-index="${rowIdx}" style="margin-left: 10px;">
              <i data-lucide="trash-2"></i>
            </button>
          </div>
          <div class="dc-modal-row-fields" data-row-index="${rowIdx}">`;
        if (fields.length > 0) {
          fields.forEach((field, fieldIdx) => {
            const label = field.label || field.name || field.id;
            const visibleChecked = field.visible ? 'checked' : '';
            const requiredChecked = field.required ? 'checked' : '';

            content += `<div class="dc-modal-field-item" draggable="true" data-field-index="${fieldIdx}" data-field-id="${field.id}">
              <div class="dc-modal-field-drag"><span class="drag-dots">⋮⋮</span></div>
              <div class="dc-modal-field-name">${label}</div>
              <div class="dc-modal-field-toggles">
                <label class="dc-toggle-sm" title="{{ text_visible|default('Visible') }}">
                  <input type="checkbox" class="field-visible-check" ${visibleChecked}>
                  <span class="dc-toggle-slider-sm"></span>
                  <span class="dc-toggle-label-text">{{ text_visible|default('Visible') }}</span>
                </label>
                <label class="dc-toggle-sm" title="{{ text_required|default('Required') }}">
                  <input type="checkbox" class="field-required-check" ${requiredChecked}>
                  <span class="dc-toggle-slider-sm"></span>
                  <span class="dc-toggle-label-text">{{ text_required|default('Required') }}</span>
                </label>
              </div>
            </div>`;
          });
        } else {
          content += `<div style="padding: 10px; text-align: center; color: #999;">{{ text_no_fields_in_row|default("No fields in this row") }}</div>`;
        }

        content += `</div></div>`;
      });
    } else {
      content += `<div style="padding: 20px; text-align: center; color: #999;">{{ text_no_rows_configured|default('No rows configured. Click "Add Row" to start.') }}</div>`;
    }

    content += `</div>`;
    document.getElementById('modal-block-content').innerHTML = content;
    lucideRender();
    document.getElementById('block-settings-modal').classList.add('active');

    // Initialize dragdrop for modal fields
    initializeModalRowsDragDrop();

    // Setup event handlers for modal buttons and controls (вызываем один раз)
    setupModalEventHandlers();
  };

  const setupModalEventHandlers = () => {
      // Add Row button
      const addRowBtn = document.getElementById('btn-add-row');
      if (addRowBtn) {
        addRowBtn.onclick = function(e) {
          e.preventDefault();
          const newRow = { columns: 1, fields: [] };
          currentBlockRows.push(newRow);
          const rowIdx = currentBlockRows.length - 1;

          const rowsList = document.querySelector('.dc-modal-rows-list');
          if (rowsList) {
            const rowHtml = `<div class="dc-modal-row-item" data-row-index="${rowIdx}">
              <div class="dc-modal-row-header">
                <span class="drag-handle" draggable="true" style="cursor: move; margin-right: 10px; user-select: none;">⋮⋮</span>
                <strong>{{ text_row|default("Row") }} ${rowIdx + 1}</strong>
                <span style="margin-left: 15px;">{{ text_columns|default("Columns:") }}</span>
                <select class="row-columns-select" data-row-index="${rowIdx}" style="margin-left: 5px; padding: 2px 5px;">
                  <option value="1" selected>1</option>
                  <option value="2">2</option>
                  <option value="3">3</option>
                </select>
                <button type="button" class="btn btn-xs btn-danger btn-remove-row" data-row-index="${rowIdx}" style="margin-left: 10px;">
                  <i data-lucide="trash-2"></i>
                </button>
              </div>
              <div class="dc-modal-row-fields" data-row-index="${rowIdx}">
                <div style="padding: 10px; text-align: center; color: #999;">{{ text_no_fields_in_row|default("No fields in this row") }}</div>
              </div>
            </div>`;
            rowsList.insertAdjacentHTML('beforeend', rowHtml);
            lucideRender();

            // Rebind handlers for new row
            setupModalEventHandlers();
            initializeModalRowsDragDrop();
            updateHiddenRowsInput();
          }
          return false;
        };
      }

      // Remove Row buttons
      document.querySelectorAll('.btn-remove-row').forEach(btn => {
        btn.onclick = function(e) {
          e.preventDefault();
          const rowItem = this.closest('.dc-modal-row-item');
          if (!rowItem) return false;
          const rowIndex = parseInt(rowItem.getAttribute('data-row-index'));

          // Check if row is empty
          const fieldsContainer = rowItem.querySelector('.dc-modal-row-fields');
          const fieldItems = fieldsContainer ? fieldsContainer.querySelectorAll('.dc-modal-field-item') : [];
          if (fieldItems.length > 0) {
            alert("{{ error_remove_non_empty_row|default('Cannot remove a non-empty row. Remove all fields first.') }}");
            return false;
          }

          if (!confirm("{{ confirm_are_you_sure|default('Are you sure?') }}")) return false;

          // Remove from state
          currentBlockRows.splice(rowIndex, 1);

          // Remove from DOM
          rowItem.remove();

          // Re-index remaining rows
          const rowsList = document.querySelector('.dc-modal-rows-list');
          if (rowsList) {
            const allRows = rowsList.querySelectorAll('.dc-modal-row-item');
            allRows.forEach((el, idx) => {
              el.setAttribute('data-row-index', idx);
              const headerStrong = el.querySelector('.dc-modal-row-header strong');
              if (headerStrong) headerStrong.textContent = '{{ text_row|default("Row") }}' + ' ' + (idx + 1);
              el.querySelector('.row-columns-select')?.setAttribute('data-row-index', idx);
              el.querySelector('.btn-remove-row')?.setAttribute('data-row-index', idx);
              el.querySelector('.dc-modal-row-fields')?.setAttribute('data-row-index', idx);
            });

            updateHiddenRowsInput();
            updateBadge();
          }
          return false;
        };
      });

      // Columns select
      document.querySelectorAll('.row-columns-select').forEach(select => {
        select.onchange = function(e) {
          const rowIndex = parseInt(this.getAttribute('data-row-index'));
          const newColumns = parseInt(this.value);
          if (currentBlockRows[rowIndex]) {
            currentBlockRows[rowIndex].columns = newColumns;
            updateHiddenRowsInput();
          }
        };
      });

      // Modal footer buttons
      const btnClose = document.getElementById('btn-modal-close');
      if (btnClose) {
        btnClose.onclick = function(e) {
          e.preventDefault();
          console.log('Close button clicked from handler');
          closeBlockSettingsModal();
          return false;
        };
      }

      const btnSave = document.getElementById('btn-modal-save');
      if (btnSave) {
        btnSave.onclick = function(e) {
          e.preventDefault();
          console.log('Save button clicked from handler');
          saveBlockSettings();
          return false;
        };
      }
  };

  const closeBlockSettingsModal = () => {
    document.getElementById('block-settings-modal').classList.remove('active');
    currentBlockIndex = null;
    currentBlockId = null;
    currentBlockRows = [];
    STATE.currentBlockRows = currentBlockRows;
    STATE.currentBlockIndex = null;
    STATE.currentBlockId = null;
  };

  const updateHiddenRowsInput = () => {
    const blockItem = document.querySelector(`[data-block-id="${currentBlockId}"]`) || document.querySelectorAll('.dc-block-item')[currentBlockIndex];
    if (blockItem) {
      let rowsInput = blockItem.querySelector('.block-rows-input');
      if (!rowsInput) {
        rowsInput = document.createElement('input');
        rowsInput.type = 'hidden';
        rowsInput.className = 'block-rows-input';
        const domBlocks = Array.from(document.querySelectorAll('.dc-block-item'));
        const domIndex = domBlocks.indexOf(blockItem);
        rowsInput.name = `module_dockercart_checkout_blocks[${domIndex}][rows]`;
        blockItem.appendChild(rowsInput);
      }
      rowsInput.value = JSON.stringify(currentBlockRows);
    }
  };

  const updateBadge = () => {
    const blockItem = document.querySelector(`[data-block-id="${currentBlockId}"]`) || document.querySelectorAll('.dc-block-item')[currentBlockIndex];
    if (blockItem) {
      const badge = blockItem.querySelector('.dc-block-col-fields .badge');
      if (badge) {
        let enabledCount = 0;
        let totalCount = 0;
        currentBlockRows.forEach(r => {
          if (r.fields) {
            totalCount += r.fields.length;
            enabledCount += r.fields.filter(f => f.visible == 1 || f.visible === true).length;
          }
        });
        badge.textContent = `${enabledCount}/${totalCount}`;
      }
    }
  };

  const saveBlockSettings = () => {
    if (currentBlockIndex === null) return;

    const rowsList = document.querySelector('.dc-modal-rows-list');
    if (!rowsList) return closeBlockSettingsModal();

    // Rebuild currentBlockRows from DOM order to handle deletions/copies/reorders robustly
    // Strategy:
    // 1. Build a map of existing fields by id from currentBlockRows (fallback to empty if none)
    // 2. For each DOM row in order, create a fresh row object with columns and fields built
    //    from the DOM order by looking up field metadata in the map. This ensures saved
    //    state matches exactly what the user sees in the modal regardless of previous indices.
    const fieldMap = {};
    if (Array.isArray(currentBlockRows)) {
      currentBlockRows.forEach(r => {
        (r.fields || []).forEach(f => {
          if (f && typeof f.id !== 'undefined') fieldMap[String(f.id)] = f;
        });
      });
    }

    const newBlockRows = [];
    const rowItems = rowsList.querySelectorAll('.dc-modal-row-item');
    rowItems.forEach((rowItem) => {
      const columnsSelect = rowItem.querySelector('.row-columns-select');
      const columns = columnsSelect ? parseInt(columnsSelect.value) : 1;
      const row = { columns: columns, fields: [] };

      const fieldsContainer = rowItem.querySelector('.dc-modal-row-fields');
      const fieldItems = fieldsContainer ? Array.from(fieldsContainer.querySelectorAll('.dc-modal-field-item')) : [];
      fieldItems.forEach(fieldItem => {
        const fid = fieldItem.getAttribute('data-field-id');
        let field = fid ? fieldMap[String(fid)] : null;
        if (field) {
          // clone to avoid mutating original map object
          field = JSON.parse(JSON.stringify(field));
        } else {
          // minimal fallback object
          field = { id: fid, name: fieldItem.querySelector('.dc-modal-field-name')?.textContent || fid };
        }

        const visibleCheck = fieldItem.querySelector('.field-visible-check');
        const requiredCheck = fieldItem.querySelector('.field-required-check');
        field.visible = visibleCheck && visibleCheck.checked ? 1 : 0;
        field.required = requiredCheck && requiredCheck.checked ? 1 : 0;

        row.fields.push(field);
      });

      newBlockRows.push(row);
    });

    // Replace state with reconstructed rows
    // Defensive merge: ensure we don't accidentally drop known template fields (e.g., address_2)
    try {
      const template = Array.isArray(blockRowTemplates[currentBlockId]) ? blockRowTemplates[currentBlockId] : [];
      // Flatten template field ids
      const templateFieldIds = new Set();
      template.forEach(r => (r.fields || []).forEach(f => { if (f && typeof f.id !== 'undefined') templateFieldIds.add(String(f.id)); }));

      // Collect all ids present in newBlockRows
      const presentIds = new Set();
      newBlockRows.forEach(r => (r.fields || []).forEach(f => { if (f && typeof f.id !== 'undefined') presentIds.add(String(f.id)); }));

      // Determine missing ids
      const missing = [];
      templateFieldIds.forEach(id => { if (!presentIds.has(id)) missing.push(id); });

      if (missing.length > 0) {
        console.warn('saveBlockSettings: missing fields detected compared to template, reattaching as hidden:', missing);
        // Attach missing fields as invisible at the end of the first row (or create a row if none)
        if (newBlockRows.length === 0) newBlockRows.push({ columns: 1, fields: [] });
        const firstRow = newBlockRows[0];
        missing.forEach(mid => {
          // Find metadata in template
          let meta = null;
          for (let tr of template) {
            meta = (tr.fields || []).find(ff => String(ff.id) === String(mid));
            if (meta) break;
          }
          if (!meta) meta = { id: mid, label: mid, visible: false, required: 0 };
          const cloneMeta = JSON.parse(JSON.stringify(meta));
          cloneMeta.visible = cloneMeta.visible ? 1 : 0;
          firstRow.fields.push(cloneMeta);
        });
      }

      currentBlockRows = newBlockRows;
    } catch (e) {
      console.warn('saveBlockSettings: merge fallback error', e);
      currentBlockRows = newBlockRows;
    }
    updateHiddenRowsInput();
    updateBadge();

    // Debugging logs: show reconstructed rows and hidden input value
    try {
      console.debug('saveBlockSettings: reconstructed currentBlockRows for', currentBlockId, JSON.parse(JSON.stringify(currentBlockRows)));
      const bi = document.querySelector(`[data-block-id="${currentBlockId}"]`);
      if (bi) {
        const hid = bi.querySelector('.block-rows-input');
        console.debug('saveBlockSettings: hidden input after rebuild', hid ? hid.value : '(no hidden input)');
      }
    } catch (e) { console.warn('saveBlockSettings: debug log failed', e); }

    // AJAX save without Apply button
    const blockItem = document.querySelector(`[data-block-id="${currentBlockId}"]`) || document.querySelectorAll('.dc-block-item')[currentBlockIndex];
    if (blockItem) {
      const form = blockItem.closest('form') || document.querySelector('form');
      if (form) {
        // Ensure field indices are up-to-date (same as normal form submit)
        document.querySelectorAll('.dc-fields-list').forEach(list => updateFieldIndices(list));

        // Build FormData and include unchecked checkboxes (as '0') so server receives them
        const formData = new FormData(form);
        document.querySelectorAll('.dc-switch input[type="checkbox"], input[type="checkbox"]').forEach(checkbox => {
          const name = checkbox.getAttribute('name');
          if (!name) return;
          if (!checkbox.checked) {
            // Append unchecked checkbox value as '0' for server-side handling
            try { formData.append(name, '0'); } catch (e) { /* ignore */ }
          }
        });

        fetch(form.getAttribute('action') || '', {
          method: 'POST',
          body: formData,
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        })
        .then(response => response.text())
        .then(data => {
          console.debug('saveBlockSettings: AJAX save response', data);
          // Show success feedback and then close modal
          const btn = document.querySelector(`.btn-block-settings[data-block-index="${currentBlockIndex}"]`);
          if (btn) {
            btn.innerHTML = `<i data-lucide="check"></i> Saved`;
            btn.classList.remove('btn-primary');
            btn.classList.add('btn-success');
            lucideRender();
            setTimeout(() => {
              btn.innerHTML = `<i data-lucide="settings"></i> Configure`;
              btn.classList.remove('btn-success');
              btn.classList.add('btn-primary');
              lucideRender();
            }, 1500);
          }

          // Ensure our in-memory template and hidden input reflect the saved state
          try {
            if (typeof currentBlockId !== 'undefined' && currentBlockId) {
              // update template cache used as fallback
              blockRowTemplates[currentBlockId] = JSON.parse(JSON.stringify(currentBlockRows));
              // keep STATE in sync with the in-memory rows
              STATE.currentBlockRows = JSON.parse(JSON.stringify(currentBlockRows));
              // ensure hidden input on the block item is up-to-date
              const savedBlockItem = document.querySelector(`[data-block-id="${currentBlockId}"]`);
              if (savedBlockItem) {
                const hid = savedBlockItem.querySelector('.block-rows-input');
                if (hid) hid.value = JSON.stringify(currentBlockRows);
              }
            }
          } catch (e) { console.warn('Post-save sync failed', e); }

          // Close modal after successful save
          closeBlockSettingsModal();
        })
        .catch(error => {
          console.error('Save error:', error);
          alert('Error saving settings');
        });
      }
    }
  };

  const initializeModalRowsDragDrop = () => {
    const rowsList = document.querySelector('.dc-modal-rows-list');
    if (!rowsList) return;

    let draggedField = null;
    let draggedRow = null;

    // Remove old listeners (by cloning and replacing to clear event listeners)
    const newRowsList = rowsList.cloneNode(true);
    rowsList.parentNode.replaceChild(newRowsList, rowsList);

    // Reattach listeners to new element
    const activeRowsList = document.querySelector('.dc-modal-rows-list');
    if (!activeRowsList) return;

    activeRowsList.addEventListener('dragstart', function (e) {
      const fieldItem = e.target.closest('.dc-modal-field-item');
      const rowItem = e.target.closest('.dc-modal-row-item');

      if (fieldItem && e.target.closest('[draggable]')) {
        draggedField = fieldItem;
        draggedField.classList.add('is-dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/html', fieldItem.innerHTML);
        e.stopPropagation();
      } else if (rowItem && e.target.closest('.drag-handle')) {
        draggedRow = rowItem;
        draggedRow.classList.add('is-dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/html', rowItem.innerHTML);
      }
    });

    activeRowsList.addEventListener('dragend', function (e) {
      if (draggedField) {
        draggedField.classList.remove('is-dragging');
      }
      if (draggedRow) {
        draggedRow.classList.remove('is-dragging');
      }
      draggedField = null;
      draggedRow = null;
    });

    activeRowsList.addEventListener('dragover', function (e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
    });

    activeRowsList.addEventListener('drop', function (e) {
      e.preventDefault();

      // Field drop
      if (draggedField) {
        const targetField = e.target.closest('.dc-modal-field-item');
        const targetRowFields = e.target.closest('.dc-modal-row-fields');

        if (targetField && draggedField !== targetField) {
          const rect = targetField.getBoundingClientRect();
          if (e.clientY < rect.top + rect.height / 2) {
            targetField.parentNode.insertBefore(draggedField, targetField);
          } else {
            targetField.parentNode.insertBefore(draggedField, targetField.nextSibling);
          }
        } else if (targetRowFields && !targetField) {
          targetRowFields.appendChild(draggedField);
        }
      }

      // Row drop
      if (draggedRow) {
        const targetRow = e.target.closest('.dc-modal-row-item');
        if (targetRow && draggedRow !== targetRow) {
          const rect = targetRow.getBoundingClientRect();
          const insertBefore = e.clientY < rect.top + rect.height / 2;

          if (insertBefore) {
            targetRow.parentNode.insertBefore(draggedRow, targetRow);
          } else {
            targetRow.parentNode.insertBefore(draggedRow, targetRow.nextSibling);
          }

          // Синхронизируем currentBlockRows с новым порядком DOM
          const newOrder = [];
          const allRows = activeRowsList.querySelectorAll('.dc-modal-row-item');
          allRows.forEach((el, idx) => {
            const oldIdx = parseInt(el.getAttribute('data-row-index'));
            if (currentBlockRows[oldIdx]) {
              newOrder.push(currentBlockRows[oldIdx]);
            }
            el.setAttribute('data-row-index', idx);
            const headerStrong = el.querySelector('.dc-modal-row-header strong');
            if (headerStrong) headerStrong.textContent = '{{ text_row|default("Row") }}' + ' ' + (idx + 1);
            el.querySelector('.row-columns-select')?.setAttribute('data-row-index', idx);
            el.querySelector('.btn-remove-row')?.setAttribute('data-row-index', idx);
            el.querySelector('.dc-modal-row-fields')?.setAttribute('data-row-index', idx);
          });
          currentBlockRows = newOrder;
          updateHiddenRowsInput();
        }
      }
    });

    // After re-creating the rows list DOM we must rebind modal event handlers
    // so buttons like .btn-remove-row get their click listeners attached.
    // This prevents a race where MutationObserver/drag-drop cloning removes
    // previously attached handlers.
    try { setupModalEventHandlers(); } catch (err) { console.warn('setupModalEventHandlers rebind failed', err); }
  };

  // Generic drag for `.dc-fields-list` containers (used by other codepaths)
  const initFieldsDragDrop = () => {
    const lists = Array.from(document.querySelectorAll('.dc-fields-list'));
    lists.forEach(list => {
      let dragged = null;
      list.addEventListener('dragstart', e => {
        const item = e.target.closest('.dc-field-item');
        if (item) { dragged = item; item.classList.add('dragging'); e.dataTransfer.effectAllowed = 'move'; }
      });
      list.addEventListener('dragend', e => { const item = e.target.closest('.dc-field-item'); if (item) item.classList.remove('dragging'); dragged = null; });
      list.addEventListener('dragover', e => { e.preventDefault(); });
      list.addEventListener('drop', e => {
        e.preventDefault();
        if (!dragged) return;
        const target = e.target.closest('.dc-field-item');
        if (target && target !== dragged && target.parentNode === dragged.parentNode) {
          const rect = target.getBoundingClientRect();
          if (e.clientY < rect.top + rect.height / 2) target.parentNode.insertBefore(dragged, target);
          else target.parentNode.insertBefore(dragged, target.nextSibling);
        }
      });
    });
  };

  const updateFieldIndices = (container) => {
    const fields = container.querySelectorAll('.dc-field-item');
    fields.forEach((field, index) => {
      const sortInput = field.querySelector('.field-sort-order-input'); if (sortInput) sortInput.value = index + 1;
      const inputs = field.querySelectorAll('input[name]');
      inputs.forEach(input => {
        const name = input.getAttribute('name');
        if (name && name.includes('module_dockercart_checkout_blocks')) {
          const newName = name.replace(/\[fields\]\[\d+\]/, `[fields][${index}]`);
          input.setAttribute('name', newName);
        }
      });
    });
  };

  const updateBlocksSortOrder = () => {
    const blocks = document.querySelectorAll('.dc-block-item');
    blocks.forEach((block, idx) => {
      const sortInput = block.querySelector('.sort-order-input'); if (sortInput) sortInput.value = idx + 1;
    });
  };

  // Row management functions
  const addNewRow = () => {
    const newRow = {
      columns: 1,
      fields: []
    };
    currentBlockRows.push(newRow);

    // Re-render modal content
    openBlockSettingsModal(currentBlockIndex, currentBlockId);
  };

  const removeRow = (rowIndex) => {
    if (confirm('Are you sure you want to remove this row?')) {
      currentBlockRows.splice(rowIndex, 1);
      // Re-render modal content
      openBlockSettingsModal(currentBlockIndex, currentBlockId);
    }
  };

  // Public init
  const init = () => {
    if (isInitialized) {
      console.warn('DockercartCheckout already initialized, skipping');
      return;
    }
    console.info('DockercartCheckout init');
    isInitialized = true;
    STATE.isInitialized = true;

    // Use event delegation for buttons (prevents memory leak from multiple listeners)
    const blocksContainer = document.querySelector('.dc-blocks-list');
    if (blocksContainer) {
      blocksContainer.addEventListener('click', (e) => {
        const btn = e.target.closest('.btn-block-settings');
        if (btn) {
          e.preventDefault();
          const blockIndex = btn.getAttribute('data-block-index');
          const blockId = btn.getAttribute('data-block-id');
          openBlockSettingsModal(blockIndex, blockId);
        }
      });
    }

    // Modal observer to initialize inner drag/drop (disconnect old observer first)
    if (modalObserver) {
      modalObserver.disconnect();
      modalObserver = null;
      STATE.modalObserver = null;
    }
    const modalOverlay = document.getElementById('block-settings-modal');
    if (modalOverlay) {
      modalObserver = new MutationObserver(mutations => {
        mutations.forEach(m => {
          if (m.attributeName === 'class' && modalOverlay.classList.contains('active')) {
            // Use RAF instead of setTimeout to prevent buildup
            requestAnimationFrame(() => initializeModalRowsDragDrop());
          }
        });
      });
      modalObserver.observe(modalOverlay, { attributes: true });
      STATE.modalObserver = modalObserver;
    }

    // Close modal on overlay click (single listener)
    const modalEl = document.getElementById('block-settings-modal');
    if (modalEl) {
      const closeHandler = (e) => { if (e.target === modalEl) closeBlockSettingsModal(); };
      modalEl.addEventListener('click', closeHandler);
    }

    // Form submit: update field indices and convert unchecked switches to hidden inputs
    const form = document.getElementById('form-dockercart-checkout');
    if (form) {
      form.addEventListener('submit', () => {
        document.querySelectorAll('.dc-fields-list').forEach(list => updateFieldIndices(list));
        // Convert dc-switch checkboxes
        document.querySelectorAll('.dc-switch input[type="checkbox"]').forEach(checkbox => {
          if (!checkbox.checked) {
            const hidden = document.createElement('input'); hidden.type = 'hidden'; hidden.name = checkbox.name; hidden.value = '0'; form.appendChild(hidden);
          }
        });
      });
    }

    // Blocks sortable observer (updates order if block-level DnD remains elsewhere)
    if (blocksObserver) {
      blocksObserver.disconnect();
      blocksObserver = null;
    }
    const blocksList = document.getElementById('blocks-sortable');
    if (blocksList) {
        blocksObserver = new MutationObserver(() => updateBlocksSortOrder());
        blocksObserver.observe(blocksList, { childList: true });
        STATE.blocksObserver = blocksObserver;
    }
  };

  // Cleanup function to prevent memory leaks
  const cleanup = () => {
    console.info('DockercartCheckout cleanup');
    if (modalObserver) {
      modalObserver.disconnect();
      modalObserver = null;
    }
    if (blocksObserver) {
      blocksObserver.disconnect();
      blocksObserver = null;
    }
    isInitialized = false;
    STATE.isInitialized = false;
    STATE.modalObserver = null;
    STATE.blocksObserver = null;
  };

  // Reveal API
  return {
    init,
    cleanup,
    openBlockSettingsModal,
    closeBlockSettingsModal,
    saveBlockSettings,
    addNewRow,
    removeRow,
    initFieldsDragDrop,
    initializeModalRowsDragDrop,
    updateFieldIndices,
    updateBlocksSortOrder,
    _templates: blockRowTemplates // exposed for debugging
  };
})();

// Expose minimal globals for existing inline handlers
window.openBlockSettingsModal = (idx, id) => DockercartCheckout.openBlockSettingsModal(idx, id);
window.closeBlockSettingsModal = () => DockercartCheckout.closeBlockSettingsModal();
window.saveBlockSettings = () => DockercartCheckout.saveBlockSettings();
// Note: addNewRow and removeRow are now handled via event listeners inside modal

document.addEventListener('DOMContentLoaded', () => {
  DockercartCheckout.init();
});
</script>

