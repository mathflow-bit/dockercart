<script>
// Dynamic zone loading for default country dropdown
document.addEventListener('DOMContentLoaded', function() {
  var defaultCountrySelect = document.getElementById('input-default-country');
  var defaultZoneSelect = document.getElementById('input-default-zone');

  if (defaultCountrySelect && defaultZoneSelect) {
    defaultCountrySelect.addEventListener('change', function() {
      var countryId = this.value;
      var zoneSelect = defaultZoneSelect;

      // Clear current options
      zoneSelect.innerHTML = '<option value="">{{ text_select|default('--- None ---') }}</option>';

      if (!countryId) return;

      // Fetch zones via AJAX
      var xhr = new XMLHttpRequest();
      xhr.open('GET', 'index.php?route=localisation/country/country&country_id=' + countryId + '&user_token={{ user_token }}', true);
      xhr.onload = function() {
        if (xhr.status === 200) {
          try {
            var data = JSON.parse(xhr.responseText);
            if (data.zone) {
              data.zone.forEach(function(zone) {
                var option = document.createElement('option');
                option.value = zone.zone_id;
                option.textContent = zone.name;
                {% if module_dockercart_checkout_default_zone_id %}
                if (zone.zone_id == '{{ module_dockercart_checkout_default_zone_id }}') {
                  option.selected = true;
                }
                {% endif %}
                zoneSelect.appendChild(option);
              });
            }
          } catch(e) {}
        }
      };
      xhr.send();
    });

    // Trigger if country is pre-selected
    if (defaultCountrySelect.value) {
      defaultCountrySelect.dispatchEvent(new Event('change'));
    }
  }
});
</script>

        </form>
