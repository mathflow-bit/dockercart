{{ header }}{{ column_left }}
<div id="content">
<link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

<style>
/* ── DockerCart Theme Settings – module-specific styles ─────────────────── */
.dc-theme-logo-pair {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
@media (max-width: 768px) {
  .dc-theme-logo-pair { grid-template-columns: 1fr; }
}

.dc-logo-card {
  background: #f8fafc;
  border: 1px solid #e2e8f2;
  border-radius: 10px;
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.dc-logo-card__label {
  font-size: 12px;
  font-weight: 700;
  color: #4a5568;
  text-transform: uppercase;
  letter-spacing: .04em;
  display: flex;
  align-items: center;
  gap: 6px;
}
.dc-logo-card__label i { color: #2f65b9; }
.dc-logo-thumb-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 200px;
  height: 80px;
  background: #fff;
  border: 2px dashed #c8d4e3;
  border-radius: 8px;
  cursor: pointer;
  transition: border-color .2s, box-shadow .2s;
  overflow: hidden;
}
.dc-logo-thumb-link:hover {
  border-color: #2f65b9;
  box-shadow: 0 0 0 3px rgba(47,101,185,.1);
}
.dc-logo-thumb-link img {
  max-width: 100%;
  max-height: 72px;
  object-fit: contain;
}
.dc-logo-card__actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ── Social & Payment rows ────────────────────────────────────────────── */
.dc-rows-container {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.dc-row-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
  border: 1px solid #e2e8f2;
  border-radius: 8px;
  padding: 10px 12px;
  transition: box-shadow .2s, border-color .2s;
}
.dc-row-item:hover {
  border-color: #b8c8df;
  box-shadow: 0 2px 8px rgba(26,42,71,.06);
}
.dc-row-item__num {
  min-width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #eaf1ff;
  color: #2f65b9;
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.dc-row-link-input.form-control {
  flex: 1;
  min-width: 0;
  height: 34px;
  font-size: 13px;
  border-radius: 6px;
  padding: 6px 10px;
}
.dc-rows-footer {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}

/* ── Icon picker button ───────────────────────────────────────────────── */
/* removed – social icons now use uploaded images */

/* ── Payment / Social thumbnail ──────────────────────────────────────── */
.dc-payment-thumb-wrap,
.dc-social-thumb-wrap {
  position: relative;
  flex-shrink: 0;
}
.dc-payment-thumb-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100px;
  height: 40px;
  background: #fff;
  border: 2px dashed #c8d4e3;
  border-radius: 6px;
  cursor: pointer;
  overflow: hidden;
  transition: border-color .2s;
}
.dc-payment-thumb-link img {
  max-width: 96px;
  max-height: 36px;
  object-fit: contain;
}
/* Square 40×40 variant for social icons */
.dc-social-thumb-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  background: #fff;
  border: 2px dashed #c8d4e3;
  border-radius: 6px;
  cursor: pointer;
  overflow: hidden;
  transition: border-color .2s;
}
.dc-social-thumb-link img {
  max-width: 36px;
  max-height: 36px;
  object-fit: contain;
}
.dc-payment-thumb-link:hover,
.dc-social-thumb-link:hover { border-color: #2f65b9; }
/* Feature icon picker button – matches social icons style */
.dc-feature-icon-picker-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  background: #fff;
  border: 2px dashed #c8d4e3;
  border-radius: 6px;
  cursor: pointer;
  overflow: hidden;
  transition: border-color .2s;
  padding: 0;
  font-size: 18px;
  color: #333;
}
.dc-feature-icon-picker-btn:hover { border-color: #2f65b9; }
.dc-payment-clear-btn {
  position: absolute;
  top: -6px;
  right: -6px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #ef4444;
  color: #fff;
  border: none;
  cursor: pointer;
  font-size: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  padding: 0;
}
.dc-payment-clear-btn:hover { background: #dc2626; }

/* ── Theme features tables (compact mode) ─────────────────────────────── */
.dc-theme-features-table th,
.dc-theme-features-table td {
  padding: 7px 8px !important;
  vertical-align: top !important;
}
.dc-theme-features-table thead th {
  font-size: 12px;
  font-weight: 700;
  color: #4a5568;
  background: #f8fafc;
}
.dc-theme-features-table .form-control {
  min-height: 30px;
  height: 30px;
  font-size: 12px;
  padding: 4px 8px;
}
.dc-theme-features-table textarea.form-control {
  min-height: 56px;
  height: auto;
  resize: vertical;
}
.dc-feature-tabs {
  margin-bottom: 6px !important;
}
.dc-feature-tabs > li > a {
  padding: 4px 7px;
  font-size: 11px;
  line-height: 1.2;
}
.dc-feature-tabs img {
  width: 14px;
  height: 14px;
}
.dc-feature-label {
  font-size: 11px;
  font-weight: 700;
  color: #667085;
  margin-bottom: 4px;
}
/* Icon picker modal */
.dc-icon-picker-modal { display:none; position:fixed; inset:0; z-index:12000; }
.dc-icon-picker-backdrop { position:absolute; inset:0; background:rgba(0,0,0,0.45); }
.dc-icon-picker-panel { position:relative; max-width:860px; margin:6vh auto; background:#fff; border-radius:10px; padding:16px; box-shadow:0 10px 40px rgba(2,6,23,0.28); }
.dc-icon-picker-header { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px; }
.dc-icon-picker-search { width:100%; max-width:480px; }
.dc-icon-picker-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(56px,1fr)); gap:8px; max-height:56vh; overflow:auto; padding:6px; }
.dc-icon-option { display:flex; align-items:center; justify-content:center; gap:6px; border:1px solid #e6eef8; background:#f8fbff; padding:8px; border-radius:8px; cursor:pointer; }
.dc-icon-option:hover { background:#eaf4ff; border-color:#cfe8ff; }
.dc-icon-option i { width:18px; height:18px; }
.dc-icon-sm { width:14px; height:14px; display:inline-block; }
</style>

  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-dockercart-theme" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary">
          <i class="fa fa-save"></i>
        </button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default">
          <i class="fa fa-reply"></i>
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">

    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i class="fa fa-paint-brush"></i></div>
          <div>
            <h3 class="dcx-panel-title">{{ heading_title }}</h3>
            <div class="dcx-panel-subtitle">{{ text_edit }}</div>
          </div>
        </div>
        <div class="dcx-panel-body">

          <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-dockercart-theme" class="dcx-form">

            {# ─────────────────────── Section: General ────────────────────────── #}
            <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
              <h4><i class="fa fa-cog"></i> {{ text_section_general|default('Настройки модуля') }}</h4>

              <div class="form-group form-horizontal" style="margin-bottom:12px;">
                <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-9">
                  <select name="dockercart_theme_status" id="input-status" class="form-control" style="max-width:200px;">
                    <option value="1" {% if dockercart_theme_status == 1 %}selected="selected"{% endif %}>{{ text_enabled }}</option>
                    <option value="0" {% if dockercart_theme_status == 0 %}selected="selected"{% endif %}>{{ text_disabled }}</option>
                  </select>
                </div>
              </div>

              <div class="form-group form-horizontal" style="margin-bottom:12px;">
                <label class="col-sm-3 control-label" for="input-menu-type">{{ entry_menu_type }}</label>
                <div class="col-sm-9">
                  <select name="dockercart_theme_menu_type" id="input-menu-type" class="form-control" style="max-width:240px;">
                    <option value="horizontal" {% if dockercart_theme_menu_type == 'horizontal' %}selected="selected"{% endif %}>{{ text_menu_horizontal }}</option>
                    <option value="vertical" {% if dockercart_theme_menu_type == 'vertical' %}selected="selected"{% endif %}>{{ text_menu_vertical }}</option>
                  </select>
                  <p class="help-block">{{ help_menu_type }}</p>
                </div>
              </div>
            </div>

            {# ─────────────────────── Section: Logos ─────────────────────────── #}
            <div class="dcx-section">
              <h4><i class="fa fa-picture-o"></i> {{ text_section_logos|default('Логотипы') }}</h4>

              <div class="dc-theme-logo-pair">

                {# Dark logo #}
                <div class="dc-logo-card">
                  <div class="dc-logo-card__label">
                    <i class="fa fa-moon-o"></i> {{ entry_logo_dark }}
                  </div>
                  <div class="dc-logo-card__actions">
                    <div>
                      <a href="" id="thumb-logo-dark" data-toggle="image" class="dc-logo-thumb-link">
                        <img src="{{ logo_dark_thumb }}" data-placeholder="{{ placeholder }}" alt="" />
                      </a>
                      <input type="hidden" name="dockercart_theme_logo_dark" id="input-logo-dark" value="{{ dockercart_theme_logo_dark }}" />
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px;margin-left:8px;">
                      <button type="button" class="btn btn-default btn-sm" id="btn-open-dark">
                        <i class="fa fa-folder-open-o"></i> {{ button_image|default('Выбрать') }}
                      </button>
                      <button type="button" class="btn btn-danger btn-sm js-clear-logo" data-input="input-logo-dark" data-thumb="thumb-logo-dark">
                        <i class="fa fa-times"></i> {{ button_clear|default('Очистить') }}
                      </button>
                    </div>
                  </div>
                  <p class="help-block" style="font-size:12px;color:#8b96a7;margin:0;">{{ help_logo_dark }}</p>
                </div>

                {# Light logo #}
                <div class="dc-logo-card">
                  <div class="dc-logo-card__label">
                    <i class="fa fa-sun-o"></i> {{ entry_logo_light }}
                  </div>
                  <div class="dc-logo-card__actions">
                    <div>
                      <a href="" id="thumb-logo-light" data-toggle="image" class="dc-logo-thumb-link">
                        <img src="{{ logo_light_thumb }}" data-placeholder="{{ placeholder }}" alt="" />
                      </a>
                      <input type="hidden" name="dockercart_theme_logo_light" id="input-logo-light" value="{{ dockercart_theme_logo_light }}" />
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px;margin-left:8px;">
                      <button type="button" class="btn btn-default btn-sm" id="btn-open-light">
                        <i class="fa fa-folder-open-o"></i> {{ button_image|default('Выбрать') }}
                      </button>
                      <button type="button" class="btn btn-danger btn-sm js-clear-logo" data-input="input-logo-light" data-thumb="thumb-logo-light">
                        <i class="fa fa-times"></i> {{ button_clear|default('Очистить') }}
                      </button>
                    </div>
                  </div>
                  <p class="help-block" style="font-size:12px;color:#8b96a7;margin:0;">{{ help_logo_light }}</p>
                </div>

              </div>

              <div class="dc-logo-card" style="margin-top:16px;max-width:460px;">
                <div class="dc-logo-card__label">
                  <i class="fa fa-star"></i> {{ entry_favicon_master }}
                </div>
                <div class="dc-logo-card__actions">
                  <div>
                    <a href="" id="thumb-favicon-master" data-toggle="image" class="dc-logo-thumb-link" style="width:100px;height:100px;">
                      <img src="{{ favicon_master_thumb }}" data-placeholder="{{ placeholder_favicon }}" alt="" style="max-height:92px;" />
                    </a>
                    <input type="hidden" name="dockercart_theme_favicon_master" id="input-favicon-master" value="{{ dockercart_theme_favicon_master }}" />
                  </div>
                  <div style="display:flex;flex-direction:column;gap:6px;margin-left:8px;">
                    <button type="button" class="btn btn-default btn-sm" id="btn-open-favicon-master">
                      <i class="fa fa-folder-open-o"></i> {{ button_image|default('Выбрать') }}
                    </button>
                    <button type="button" class="btn btn-danger btn-sm js-clear-logo" data-input="input-favicon-master" data-thumb="thumb-favicon-master">
                      <i class="fa fa-times"></i> {{ button_clear|default('Очистить') }}
                    </button>
                  </div>
                </div>
                <p class="help-block" style="font-size:12px;color:#8b96a7;margin:0;">{{ help_favicon_master }}</p>
                <p class="help-block" style="font-size:12px;color:#8b96a7;margin:4px 0 0;">{{ help_favicon_master_hint }}</p>
              </div>
            </div>

            {# ─────────────────────── Section: Social icons ───────────────────── #}
            <div class="dcx-section">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                <h4 style="margin:0;"><i class="fa fa-share-alt"></i> {{ entry_social_block }}</h4>
                <button type="button" id="btn-add-social" class="btn btn-primary btn-sm">
                  <i class="fa fa-plus"></i> {{ button_add_social|default('Добавить') }}
                </button>
              </div>

              <div id="social-rows" class="dc-rows-container">
                {% for idx, item in social_items %}
                <div class="dc-row-item dc-social-row" id="social-row-{{ idx }}">
                  <span class="dc-row-item__num">{{ idx + 1 }}</span>
                  <div class="dc-social-thumb-wrap">
                    <a href="" id="thumb-social-row-{{ idx }}" data-toggle="image" class="dc-social-thumb-link">
                      <img src="{{ item.thumb }}" data-placeholder="{{ placeholder_social }}" alt="" />
                    </a>
                    <input type="hidden" name="dockercart_theme_social_image[]" id="input-social-row-{{ idx }}" value="{{ item.image }}" />
                    <button type="button" class="dc-payment-clear-btn js-clear-social-thumb" data-input="input-social-row-{{ idx }}" data-thumb="thumb-social-row-{{ idx }}" title="{{ button_clear|default('Очистить') }}">
                      <i class="fa fa-times"></i>
                    </button>
                  </div>
                  <input type="text" name="dockercart_theme_social_link[]" value="{{ item.link }}" placeholder="https://..." class="form-control dc-row-link-input" />
                  <button type="button" class="btn btn-danger btn-sm js-remove-social-row">
                    <i class="fa fa-times"></i>
                  </button>
                </div>
                {% endfor %}
              </div>

              <p class="help-block" style="margin-top:10px;">{{ help_social_block }}</p>

              {# Messenger FAB toggle #}
              <div style="margin-top:16px;padding-top:14px;border-top:1px solid #e8eaec;display:flex;align-items:center;gap:16px;">
                <label style="font-weight:600;margin:0;white-space:nowrap;">{{ entry_messenger_fab_status }}</label>
                <div class="btn-group" role="group">
                  <label class="btn btn-sm {{ dockercart_theme_messenger_fab_status ? 'btn-primary' : 'btn-default' }}" style="margin:0;">
                    <input type="radio" name="dockercart_theme_messenger_fab_status" value="1" {{ dockercart_theme_messenger_fab_status ? 'checked' : '' }} style="display:none;"> {{ text_enabled }}
                  </label>
                  <label class="btn btn-sm {{ not dockercart_theme_messenger_fab_status ? 'btn-danger' : 'btn-default' }}" style="margin:0;">
                    <input type="radio" name="dockercart_theme_messenger_fab_status" value="0" {{ not dockercart_theme_messenger_fab_status ? 'checked' : '' }} style="display:none;"> {{ text_disabled }}
                  </label>
                </div>
                <span class="help-block" style="margin:0;font-size:12px;color:#8b96a7;">{{ help_messenger_fab_status }}</span>
              </div>
            </div>

            {# ─────────────────────── Section: Payment icons ──────────────────── #}
            <div class="dcx-section">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                <h4 style="margin:0;"><i class="fa fa-credit-card"></i> {{ entry_payment_block }}</h4>
                <button type="button" id="btn-add-payment" class="btn btn-primary btn-sm">
                  <i class="fa fa-plus"></i> {{ button_add_payment|default('Добавить') }}
                </button>
              </div>

              <div id="payment-rows" class="dc-rows-container">
                {% for idx, item in payment_items %}
                <div class="dc-row-item dc-payment-row" id="payment-row-{{ idx }}">
                  <span class="dc-row-item__num">{{ idx + 1 }}</span>
                  <div class="dc-payment-thumb-wrap">
                    <a href="" id="thumb-payment-row-{{ idx }}" data-toggle="image" class="dc-payment-thumb-link">
                      <img src="{{ item.thumb }}" data-placeholder="{{ placeholder_payment }}" alt="" />
                    </a>
                    <input type="hidden" name="dockercart_theme_payment_image[]" id="input-payment-row-{{ idx }}" value="{{ item.image }}" />
                    <button type="button" class="dc-payment-clear-btn js-clear-payment-thumb" data-input="input-payment-row-{{ idx }}" data-thumb="thumb-payment-row-{{ idx }}" title="{{ button_clear|default('Очистить') }}">
                      <i class="fa fa-times"></i>
                    </button>
                  </div>
                  <input type="text" name="dockercart_theme_payment_link[]" value="{{ item.link }}" placeholder="https://... ({{ entry_payment_link }})" class="form-control dc-row-link-input" />
                  <button type="button" class="btn btn-danger btn-sm js-remove-payment-row">
                    <i class="fa fa-times"></i>
                  </button>
                </div>
                {% endfor %}
              </div>

              <p class="help-block" style="margin-top:10px;">{{ help_payment_block }}</p>
            </div>

            {# ─────────────────────── Section: Theme features ─────────────────── #}
            <div class="dcx-section">
              <h4 style="margin-top:0;"><i class="fa fa-magic"></i> {{ text_section_features }}</h4>

              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                <h4 style="margin:0;"><i class="fa fa-magic"></i> {{ entry_features_product }}</h4>
                <button type="button" class="btn btn-primary btn-sm js-add-theme-feature" data-target="product-features-body" data-field="dockercart_theme_product_features" data-prefix="product-feature-row" data-counter="product">
                  <i class="fa fa-plus"></i> {{ button_add_feature }}
                </button>
              </div>
              <div id="product-features-body" class="dc-rows-container">
                {% for idx, feature in dockercart_theme_product_features %}
                <div class="dc-row-item dc-feature-row" id="product-feature-row-{{ idx }}">
                  <span class="dc-row-item__num">{{ idx + 1 }}</span>
                  <div style="flex-shrink:0;">
                    <input type="hidden" name="dockercart_theme_product_features[{{ idx }}][icon]" id="product-feature-icon-{{ idx }}" value="{{ feature.icon|default('truck') }}" />
                    <button type="button" class="dc-feature-icon-picker-btn dc-icon-picker-button" data-target="#product-feature-icon-{{ idx }}" title="{{ text_search_icons|default('Search icons...') }}">
                      <i data-lucide="{{ feature.icon|default('truck') }}" class="dc-icon-sm"></i>
                    </button>
                  </div>
                  <div style="flex:1;min-width:0;">
                    <ul class="nav nav-tabs dc-feature-tabs" role="tablist">
                      {% for language in languages %}
                      <li{% if loop.first %} class="active"{% endif %}><a href="#product-feature-{{ idx }}-lang-{{ language.language_id }}" data-toggle="tab"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }}</a></li>
                      {% endfor %}
                    </ul>
                    <div class="tab-content">
                      {% for language in languages %}
                      <div class="tab-pane{% if loop.first %} active{% endif %}" id="product-feature-{{ idx }}-lang-{{ language.language_id }}">
                        <div class="form-group" style="margin-left:0;margin-right:0;">
                          <label class="control-label dc-feature-label">{{ entry_feature_title }}</label>
                          <input type="text" name="dockercart_theme_product_features[{{ idx }}][title][{{ language.language_id }}]" value="{{ feature.title[language.language_id]|default('') }}" class="form-control" />
                        </div>
                        <div class="form-group" style="margin-left:0;margin-right:0;">
                          <label class="control-label dc-feature-label">{{ entry_feature_text }}</label>
                          <textarea name="dockercart_theme_product_features[{{ idx }}][text][{{ language.language_id }}]" rows="2" class="form-control">{{ feature.text[language.language_id]|default('') }}</textarea>
                        </div>
                        <div class="form-group" style="margin-left:0;margin-right:0;margin-bottom:0;">
                          <label class="control-label dc-feature-label">{{ entry_feature_sort_order }}</label>
                          <input type="number" name="dockercart_theme_product_features[{{ idx }}][sort_order]" value="{{ feature.sort_order|default(loop.index0) }}" class="form-control" style="width:82px;" />
                        </div>
                      </div>
                      {% endfor %}
                    </div>
                  </div>
                  <button type="button" class="btn btn-danger btn-sm js-remove-theme-feature-row" style="flex-shrink:0;">
                    <i class="fa fa-times"></i>
                  </button>
                </div>
                {% endfor %}
              </div>

              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                <h4 style="margin:0;"><i class="fa fa-magic"></i> {{ entry_features_category }}</h4>
                <button type="button" class="btn btn-primary btn-sm js-add-theme-feature" data-target="category-features-body" data-field="dockercart_theme_category_features" data-prefix="category-feature-row" data-counter="category">
                  <i class="fa fa-plus"></i> {{ button_add_feature }}
                </button>
              </div>
              <div id="category-features-body" class="dc-rows-container">
                {% for idx, feature in dockercart_theme_category_features %}
                <div class="dc-row-item dc-feature-row" id="category-feature-row-{{ idx }}">
                  <span class="dc-row-item__num">{{ idx + 1 }}</span>
                  <div style="flex-shrink:0;">
                    <input type="hidden" name="dockercart_theme_category_features[{{ idx }}][icon]" id="category-feature-icon-{{ idx }}" value="{{ feature.icon|default('truck') }}" />
                    <button type="button" class="dc-feature-icon-picker-btn dc-icon-picker-button" data-target="#category-feature-icon-{{ idx }}" title="{{ text_search_icons|default('Search icons...') }}">
                      <i data-lucide="{{ feature.icon|default('truck') }}" class="dc-icon-sm"></i>
                    </button>
                  </div>
                  <div style="flex:1;min-width:0;">
                    <ul class="nav nav-tabs dc-feature-tabs" role="tablist">
                      {% for language in languages %}
                      <li{% if loop.first %} class="active"{% endif %}><a href="#category-feature-{{ idx }}-lang-{{ language.language_id }}" data-toggle="tab"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }}</a></li>
                      {% endfor %}
                    </ul>
                    <div class="tab-content">
                      {% for language in languages %}
                      <div class="tab-pane{% if loop.first %} active{% endif %}" id="category-feature-{{ idx }}-lang-{{ language.language_id }}">
                        <div class="form-group" style="margin-left:0;margin-right:0;">
                          <label class="control-label dc-feature-label">{{ entry_feature_title }}</label>
                          <input type="text" name="dockercart_theme_category_features[{{ idx }}][title][{{ language.language_id }}]" value="{{ feature.title[language.language_id]|default('') }}" class="form-control" />
                        </div>
                        <div class="form-group" style="margin-left:0;margin-right:0;">
                          <label class="control-label dc-feature-label">{{ entry_feature_text }}</label>
                          <textarea name="dockercart_theme_category_features[{{ idx }}][text][{{ language.language_id }}]" rows="2" class="form-control">{{ feature.text[language.language_id]|default('') }}</textarea>
                        </div>
                        <div class="form-group" style="margin-left:0;margin-right:0;margin-bottom:0;">
                          <label class="control-label dc-feature-label">{{ entry_feature_sort_order }}</label>
                          <input type="number" name="dockercart_theme_category_features[{{ idx }}][sort_order]" value="{{ feature.sort_order|default(loop.index0) }}" class="form-control" style="width:82px;" />
                        </div>
                      </div>
                      {% endfor %}
                    </div>
                  </div>
                  <button type="button" class="btn btn-danger btn-sm js-remove-theme-feature-row" style="flex-shrink:0;">
                    <i class="fa fa-times"></i>
                  </button>
                </div>
                {% endfor %}
              </div>

              
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                  <h4 style="margin:0;"><i class="fa fa-magic"></i> {{ entry_features_quickview }}</h4>
                  <button type="button" class="btn btn-primary btn-sm js-add-theme-feature" data-target="quickview-features-body" data-field="dockercart_theme_quickview_features" data-prefix="quickview-feature-row" data-counter="quickview">
                    <i class="fa fa-plus"></i> {{ button_add_feature }}
                  </button>
                </div>
                <div id="quickview-features-body" class="dc-rows-container">
                  {% for idx, feature in dockercart_theme_quickview_features %}
                  <div class="dc-row-item dc-feature-row" id="quickview-feature-row-{{ idx }}">
                    <span class="dc-row-item__num">{{ idx + 1 }}</span>
                    <div style="flex-shrink:0;">
                      <input type="hidden" name="dockercart_theme_quickview_features[{{ idx }}][icon]" id="quickview-feature-icon-{{ idx }}" value="{{ feature.icon|default('truck') }}" />
                      <button type="button" class="dc-feature-icon-picker-btn dc-icon-picker-button" data-target="#quickview-feature-icon-{{ idx }}" title="{{ text_search_icons|default('Search icons...') }}">
                        <i data-lucide="{{ feature.icon|default('truck') }}" class="dc-icon-sm"></i>
                      </button>
                    </div>
                    <div style="flex:1;min-width:0;">
                      <ul class="nav nav-tabs dc-feature-tabs" role="tablist">
                        {% for language in languages %}
                        <li{% if loop.first %} class="active"{% endif %}><a href="#quickview-feature-{{ idx }}-lang-{{ language.language_id }}" data-toggle="tab"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }}</a></li>
                        {% endfor %}
                      </ul>
                      <div class="tab-content">
                        {% for language in languages %}
                        <div class="tab-pane{% if loop.first %} active{% endif %}" id="quickview-feature-{{ idx }}-lang-{{ language.language_id }}">
                          <div class="form-group" style="margin-left:0;margin-right:0;">
                            <label class="control-label dc-feature-label">{{ entry_feature_title }}</label>
                            <input type="text" name="dockercart_theme_quickview_features[{{ idx }}][title][{{ language.language_id }}]" value="{{ feature.title[language.language_id]|default('') }}" class="form-control" />
                          </div>
                          <div class="form-group" style="margin-left:0;margin-right:0;">
                            <label class="control-label dc-feature-label">{{ entry_feature_text }}</label>
                            <textarea name="dockercart_theme_quickview_features[{{ idx }}][text][{{ language.language_id }}]" rows="2" class="form-control">{{ feature.text[language.language_id]|default('') }}</textarea>
                          </div>
                          <div class="form-group" style="margin-left:0;margin-right:0;margin-bottom:0;">
                            <label class="control-label dc-feature-label">{{ entry_feature_sort_order }}</label>
                            <input type="number" name="dockercart_theme_quickview_features[{{ idx }}][sort_order]" value="{{ feature.sort_order|default(loop.index0) }}" class="form-control" style="width:82px;" />
                          </div>
                        </div>
                        {% endfor %}
                      </div>
                    </div>
                    <button type="button" class="btn btn-danger btn-sm js-remove-theme-feature-row" style="flex-shrink:0;">
                      <i class="fa fa-times"></i>
                    </button>
                  </div>
                  {% endfor %}
                </div>
              </div>

              <p class="help-block" style="margin-top:10px;">{{ help_theme_features }}</p>
            </div>

          </form>

        </div>
      </div>
    </div>

  </div>
</div><!-- /#content -->

{{ footer }}

<!-- Icon picker modal -->
<div id="dc-icon-picker-modal" class="dc-icon-picker-modal hidden">
  <div class="dc-icon-picker-backdrop"></div>
  <div class="dc-icon-picker-panel" role="dialog" aria-modal="true" aria-label="{{ text_icon_picker_aria }}">
    <div class="dc-icon-picker-header">
      <div style="display:flex;align-items:center;gap:8px;">
        <strong>{{ text_choose_icon }}</strong>
        <input id="dc-icon-picker-search" class="form-control dc-icon-picker-search" placeholder="{{ text_search_icons|default('Search icons...') }}" />
      </div>
      <div>
        <button id="dc-icon-picker-close" class="btn btn-default">{{ text_close }}</button>
      </div>
    </div>
    <div id="dc-icon-picker-grid" class="dc-icon-picker-grid">
      {% for icon_option in icon_options %}
      <button type="button" class="dc-icon-option" data-icon="{{ icon_option }}">
        <i data-lucide="{{ icon_option }}"></i>
      </button>
      {% endfor %}
    </div>
  </div>
</div>

<script>
(function($) {
  'use strict';

  var placeholder        = '{{ placeholder }}';
  var placeholderPayment = '{{ placeholder_payment }}';
  var placeholderSocial  = '{{ placeholder_social }}';
  var userToken          = '{{ user_token }}';
  var socialRowIndex     = {{ social_items|length }};
  var paymentRowCounter  = {{ payment_items|length }};
  var featureRowCounters = {
    product: {{ dockercart_theme_product_features|length }},
    category: {{ dockercart_theme_category_features|length }},
    quickview: {{ dockercart_theme_quickview_features|length }}
  };

  function renderLucideIcons() {
    if (window.lucide && typeof window.lucide.createIcons === 'function') {
      window.lucide.createIcons();
    }
  }

  function escapeHtml(str) {
    return String(str || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function buildThemeFeatureRow(fieldName, rowIndex, rowPrefix, sortOrder) {
    var html = '';
    {% set default_lang = languages[0] %}
    html += '<div class="dc-row-item dc-feature-row" id="' + rowPrefix + '-' + rowIndex + '">';
    html += '<span class="dc-row-item__num">' + (rowIndex + 1) + '</span>';
    html += '<div style="flex-shrink:0;">';
    html += '<input type="hidden" name="' + fieldName + '[' + rowIndex + '][icon]" id="' + rowPrefix + '-icon-' + rowIndex + '" value="truck" />';
    html += '<button type="button" class="dc-feature-icon-picker-btn dc-icon-picker-button" data-target="#' + rowPrefix + '-icon-' + rowIndex + '" title="{{ text_search_icons|e('html_attr') }}">';
    html += '<i data-lucide="truck" class="dc-icon-sm"></i>';
    html += '</button>';
    html += '</div>';
    html += '<div style="flex:1;min-width:0;">';
    html += '<ul class="nav nav-tabs dc-feature-tabs" role="tablist">';
    {% for language in languages %}
    html += '<li{% if loop.first %} class="active"{% endif %}><a href="#' + rowPrefix + '-' + rowIndex + '-lang-{{ language.language_id }}" data-toggle="tab"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }}</a></li>';
    {% endfor %}
    html += '</ul>';
    html += '<div class="tab-content">';
    {% for language in languages %}
    html += '<div class="tab-pane{% if loop.first %} active{% endif %}" id="' + rowPrefix + '-' + rowIndex + '-lang-{{ language.language_id }}">';
    html += '<div class="form-group" style="margin-left:0;margin-right:0;">';
    html += '<label class="control-label dc-feature-label">{{ entry_feature_title|e('js') }}</label>';
    html += '<input type="text" name="' + fieldName + '[' + rowIndex + '][title][{{ language.language_id }}]" value="" class="form-control" />';
    html += '</div>';
    html += '<div class="form-group" style="margin-left:0;margin-right:0;">';
    html += '<label class="control-label dc-feature-label">{{ entry_feature_text|e('js') }}</label>';
    html += '<textarea name="' + fieldName + '[' + rowIndex + '][text][{{ language.language_id }}]" rows="2" class="form-control"></textarea>';
    html += '</div>';
    html += '<div class="form-group" style="margin-left:0;margin-right:0;margin-bottom:0;">';
    html += '<label class="control-label dc-feature-label">{{ entry_feature_sort_order|e('js') }}</label>';
    html += '<input type="number" name="' + fieldName + '[' + rowIndex + '][sort_order]" value="' + escapeHtml(sortOrder) + '" class="form-control" style="width:82px;" />';
    html += '</div>';
    html += '</div>';
    {% endfor %}
    html += '</div>';
    html += '</div>';
    html += '<button type="button" class="btn btn-danger btn-sm js-remove-theme-feature-row" style="flex-shrink:0;"><i class="fa fa-times"></i></button>';
    html += '</div>';

    return html;
  }

  /* ── Logo clear buttons ───────────────────────────────────────────── */
  $(document).on('click', '.js-clear-logo', function() {
    var inputId = $(this).data('input');
    var thumbId = $(this).data('thumb');
    $('#' + inputId).val('');
    $('#' + thumbId + ' img').attr('src', placeholder);
  });

  /* ── Manual "open" buttons for logos (fallback for older OC builds) ── */
  $('#btn-open-dark').on('click', function() {
    var url = 'index.php?route=common/filemanager&user_token=' + userToken + '&target=input-logo-dark&thumb=thumb-logo-dark';
    window.open(url, 'filemanager', 'width=1200,height=700,scrollbars=yes');
  });
  $('#btn-open-light').on('click', function() {
    var url = 'index.php?route=common/filemanager&user_token=' + userToken + '&target=input-logo-light&thumb=thumb-logo-light';
    window.open(url, 'filemanager', 'width=1200,height=700,scrollbars=yes');
  });
  $('#btn-open-favicon-master').on('click', function() {
    var url = 'index.php?route=common/filemanager&user_token=' + userToken + '&target=input-favicon-master&thumb=thumb-favicon-master';
    window.open(url, 'filemanager', 'width=1200,height=700,scrollbars=yes');
  });

  /* ── Social image clear ─────────────────────────────────────────── */
  $(document).on('click', '.js-clear-social-thumb', function(e) {
    e.stopPropagation();
    var inputId = $(this).data('input');
    var thumbId = $(this).data('thumb');
    $('#' + inputId).val('');
    $('#' + thumbId + ' img').attr('src', placeholderSocial);
  });

  /* ── Payment image clear ─────────────────────────────────────────── */
  $(document).on('click', '.js-clear-payment-thumb', function(e) {
    e.stopPropagation();
    var inputId = $(this).data('input');
    var thumbId = $(this).data('thumb');
    $('#' + inputId).val('');
    $('#' + thumbId + ' img').attr('src', placeholderPayment);
  });

  /* ── Row counter badges ──────────────────────────────────────────── */
  function renumberRows(containerSelector, badgeSelector) {
    $(containerSelector + ' ' + badgeSelector).each(function(i) {
      $(this).text(i + 1);
    });
  }

  /* ── Remove social row ───────────────────────────────────────────── */
  $(document).on('click', '.js-remove-social-row', function() {
    $(this).closest('.dc-social-row').remove();
    renumberRows('#social-rows', '.dc-row-item__num');
  });

  /* ── Add social row ──────────────────────────────────────────────── */
  $('#btn-add-social').on('click', function() {
    var idx = socialRowIndex++;
    var num = $('#social-rows .dc-row-item').length + 1;
    var html = '<div class="dc-row-item dc-social-row" id="social-row-' + idx + '">'
      + '<span class="dc-row-item__num">' + num + '</span>'
      + '<div class="dc-social-thumb-wrap">'
      +   '<a href="" id="thumb-social-row-' + idx + '" data-toggle="image" class="dc-social-thumb-link">'
      +     '<img src="' + placeholderSocial + '" data-placeholder="' + placeholderSocial + '" alt="" />'
      +   '</a>'
      +   '<input type="hidden" name="dockercart_theme_social_image[]" id="input-social-row-' + idx + '" value="" />'
      +   '<button type="button" class="dc-payment-clear-btn js-clear-social-thumb" data-input="input-social-row-' + idx + '" data-thumb="thumb-social-row-' + idx + '" title="Очистить"><i class="fa fa-times"></i></button>'
      + '</div>'
      + '<input type="text" name="dockercart_theme_social_link[]" value="" placeholder="https://..." class="form-control dc-row-link-input" />'
      + '<button type="button" class="btn btn-danger btn-sm js-remove-social-row"><i class="fa fa-times"></i></button>'
      + '</div>';
    $('#social-rows').append(html);
    renumberRows('#social-rows', '.dc-row-item__num');
  });

  /* ── Remove payment row ──────────────────────────────────────────── */
  $(document).on('click', '.js-remove-payment-row', function() {
    $(this).closest('.dc-payment-row').remove();
    renumberRows('#payment-rows', '.dc-row-item__num');
  });

  /* ── Add payment row ─────────────────────────────────────────────── */
  $('#btn-add-payment').on('click', function() {
    var ctr = paymentRowCounter++;
    var numLabel = $('#payment-rows .dc-row-item').length + 1;
    var html = '<div class="dc-row-item dc-payment-row" id="payment-row-' + ctr + '">'
      + '<span class="dc-row-item__num">' + numLabel + '</span>'
      + '<div class="dc-payment-thumb-wrap">'
      +   '<a href="" id="thumb-payment-row-' + ctr + '" data-toggle="image" class="dc-payment-thumb-link">'
      +     '<img src="' + placeholderPayment + '" data-placeholder="' + placeholderPayment + '" alt="" />'
      +   '</a>'
      +   '<input type="hidden" name="dockercart_theme_payment_image[]" id="input-payment-row-' + ctr + '" value="" />'
      +   '<button type="button" class="dc-payment-clear-btn js-clear-payment-thumb" data-input="input-payment-row-' + ctr + '" data-thumb="thumb-payment-row-' + ctr + '" title="Очистить"><i class="fa fa-times"></i></button>'
      + '</div>'
      + '<input type="text" name="dockercart_theme_payment_link[]" value="" placeholder="https://..." class="form-control dc-row-link-input" />'
      + '<button type="button" class="btn btn-danger btn-sm js-remove-payment-row"><i class="fa fa-times"></i></button>'
      + '</div>';
    $('#payment-rows').append(html);
    renumberRows('#payment-rows', '.dc-row-item__num');
  });

  $(document).on('click', '.js-remove-theme-feature-row', function() {
    var $row = $(this).closest('.dc-feature-row');
    var $container = $row.parent();
    $row.remove();
    if ($container && $container.attr('id')) {
      renumberRows('#' + $container.attr('id'), '.dc-row-item__num');
    }
  });

  // Icon picker modal
  var __dc_icon_picker_target = null;
  var __dc_icon_picker_preview = null;

  $(document).on('click', '.dc-icon-picker-button', function(e) {
    e.preventDefault();
    var $btn = $(this);
    var target = $btn.data('target');
    __dc_icon_picker_target = $(target);
    __dc_icon_picker_preview = $btn.find('i[data-lucide]');
    // show modal
    $('#dc-icon-picker-modal').removeClass('hidden').show();
    $('#dc-icon-picker-search').val('');
    $('#dc-icon-picker-grid button').show();
  });

  // Close modal
  $(document).on('click', '#dc-icon-picker-close, #dc-icon-picker-modal .dc-icon-picker-backdrop', function() {
    $('#dc-icon-picker-modal').hide().addClass('hidden');
  });

  // Icon selection
  $(document).on('click', '#dc-icon-picker-grid button.dc-icon-option', function(e) {
    var icon = $(this).data('icon');
    if (__dc_icon_picker_target && __dc_icon_picker_target.length) {
      __dc_icon_picker_target.val(icon);
    }
    if (__dc_icon_picker_preview && __dc_icon_picker_preview.length) {
      __dc_icon_picker_preview.attr('data-lucide', icon);
    }
    // Also update the small button icon if exists (fallback)
    if (__dc_icon_picker_target && __dc_icon_picker_target.attr('id')) {
      var btn = $('[data-target="#' + __dc_icon_picker_target.attr('id') + '"]');
      if (btn.length) {
        btn.find('i[data-lucide]').attr('data-lucide', icon);
      }
    }
    renderLucideIcons();
    $('#dc-icon-picker-modal').hide().addClass('hidden');
  });

  // Search/filter icons in modal
  $(document).on('input', '#dc-icon-picker-search', function() {
    var q = $(this).val().toLowerCase().trim();
    if (q === '') {
      $('#dc-icon-picker-grid button').show();
      return;
    }
    $('#dc-icon-picker-grid button').each(function() {
      var name = $(this).data('icon') || '';
      if (name.indexOf(q) !== -1) $(this).show(); else $(this).hide();
    });
  });

  $(document).on('click', '.js-add-theme-feature', function() {
    var $btn = $(this);
    var targetBodyId = $btn.data('target');
    var fieldName = $btn.data('field');
    var rowPrefix = $btn.data('prefix');
    var counterKey = $btn.data('counter');
    var rowIndex = featureRowCounters[counterKey] || 0;
    var sortOrder = $('#' + targetBodyId + ' .dc-row-item').length;

    $('#' + targetBodyId).append(buildThemeFeatureRow(fieldName, rowIndex, rowPrefix, sortOrder));
    featureRowCounters[counterKey] = rowIndex + 1;
    renderLucideIcons();
    renumberRows('#' + targetBodyId, '.dc-row-item__num');
  });

  renderLucideIcons();

})(jQuery);
</script>
