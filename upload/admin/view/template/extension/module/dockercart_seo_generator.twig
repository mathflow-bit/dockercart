{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-seo-generator" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <ul class="nav nav-tabs dcx-profile-tabs" id="seo-tabs">
      <li class="active"><a href="#tab-general" class="js-seo-tab" data-toggle="tab" data-title="{{ tab_general }}" data-subtitle="{{ text_edit }}" data-icon="fa-sliders"><i class="fa fa-sliders"></i> {{ tab_general }}</a></li>
      <li><a href="#tab-statistics" class="js-seo-tab" data-toggle="tab" data-title="{{ tab_statistics }}" data-subtitle="{{ text_edit }}" data-icon="fa-chart-bar"><i class="fa fa-chart-bar"></i> {{ tab_statistics }}</a></li>
      <li><a href="#tab-products" class="js-seo-tab" data-toggle="tab" data-title="{{ tab_products }}" data-subtitle="{{ text_edit }}" data-icon="fa-cube"><i class="fa fa-cube"></i> {{ tab_products }}</a></li>
      <li><a href="#tab-categories" class="js-seo-tab" data-toggle="tab" data-title="{{ tab_categories }}" data-subtitle="{{ text_edit }}" data-icon="fa-sitemap"><i class="fa fa-sitemap"></i> {{ tab_categories }}</a></li>
      <li><a href="#tab-manufacturers" class="js-seo-tab" data-toggle="tab" data-title="{{ tab_manufacturers }}" data-subtitle="{{ text_edit }}" data-icon="fa-industry"><i class="fa fa-industry"></i> {{ tab_manufacturers }}</a></li>
      <li><a href="#tab-information" class="js-seo-tab" data-toggle="tab" data-title="{{ tab_information }}" data-subtitle="{{ text_edit }}" data-icon="fa-file-text-o"><i class="fa fa-file-text-o"></i> {{ tab_information }}</a></li>
      <li><a href="#tab-controllers" class="js-seo-tab" data-toggle="tab" data-title="{{ tab_controllers }}" data-subtitle="{{ text_edit }}" data-icon="fa-code"><i class="fa fa-code"></i> {{ tab_controllers }}</a></li>
      <li><a href="#tab-license" class="js-seo-tab" data-toggle="tab" data-title="{{ text_tab_license }}" data-subtitle="{{ text_edit }}" data-icon="fa-key"><i class="fa fa-key"></i> {{ text_tab_license }}</a></li>
      <li><a href="#tab-about" class="js-seo-tab" data-toggle="tab" data-title="{{ text_tab_about }}" data-subtitle="{{ heading_title }}" data-icon="fa-info-circle"><i class="fa fa-info-circle"></i> {{ text_tab_about }}</a></li>
    </ul>
    
    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i id="seo-tab-icon" class="fa fa-sliders"></i></div>
          <div>
            <h3 class="dcx-panel-title" id="seo-tab-title">{{ tab_general }}</h3>
            <div class="dcx-panel-subtitle" id="seo-tab-subtitle">{{ text_edit }}</div>
          </div>
        </div>
        <div class="dcx-panel-body">
          <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-seo-generator" class="form-horizontal dcx-form">
          
          <div class="tab-content">
            
            <!-- Общие настройки -->
            <div class="tab-pane active" id="tab-general">
              <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
                <h4>{{ text_module_settings }}</h4>

                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                  <div class="col-sm-9">
                    <select name="module_dockercart_seo_generator_status" id="input-status" class="form-control">
                      {% if module_dockercart_seo_generator_status %}
                      <option value="1" selected="selected">{{ text_enabled }}</option>
                      <option value="0">{{ text_disabled }}</option>
                      {% else %}
                      <option value="1">{{ text_enabled }}</option>
                      <option value="0" selected="selected">{{ text_disabled }}</option>
                      {% endif %}
                    </select>
                    <span class="help-block">{{ help_status }}</span>
                  </div>
                </div>
                
                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-debug">{{ entry_debug }}</label>
                  <div class="col-sm-9">
                    <select name="module_dockercart_seo_generator_debug" id="input-debug" class="form-control">
                      {% if module_dockercart_seo_generator_debug %}
                      <option value="1" selected="selected">{{ text_enabled }}</option>
                      <option value="0">{{ text_disabled }}</option>
                      {% else %}
                      <option value="1">{{ text_enabled }}</option>
                      <option value="0" selected="selected">{{ text_disabled }}</option>
                      {% endif %}
                    </select>
                    <span class="help-block">{{ help_debug }}</span>
                  </div>
                </div>
                
                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-batch-size">{{ entry_batch_size }}</label>
                  <div class="col-sm-9">
                    <input type="text" name="module_dockercart_seo_generator_batch_size" value="{{ module_dockercart_seo_generator_batch_size }}" placeholder="{{ entry_batch_size }}" id="input-batch-size" class="form-control" />
                    <span class="help-block">{{ help_batch_size }}</span>
                  </div>
                </div>
                
                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-disable-prefix">{{ entry_disable_language_prefix|default('Disable Language Prefix') }}</label>
                  <div class="col-sm-9">
                    <select name="module_dockercart_seo_generator_disable_language_prefix" id="input-disable-prefix" class="form-control">
                      {% if module_dockercart_seo_generator_disable_language_prefix %}
                      <option value="1" selected="selected">{{ text_enabled }}</option>
                      <option value="0">{{ text_disabled }}</option>
                      {% else %}
                      <option value="1">{{ text_enabled }}</option>
                      <option value="0" selected="selected">{{ text_disabled }}</option>
                      {% endif %}
                    </select>
                    <span class="help-block">{{ help_disable_language_prefix|default('When enabled, SEO URLs for all languages will be generated without language prefix (e.g. "product-name" instead of "en-gb-product-name").') }}</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="tab-pane" id="tab-license">
              <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
                <h4>{{ text_license }}</h4>

                <div class="form-group required">
                  <label class="col-sm-3 control-label" for="input-license-key">
                    <span data-toggle="tooltip" title="{{ help_license_key|default('Enter your license key purchased from marketplace') }}">
                      {{ entry_license_key|default('License Key') }}
                    </span>
                  </label>
                  <div class="col-sm-6">
                    <input
                      type="text"
                      name="module_dockercart_seo_generator_license_key"
                      value="{{ module_dockercart_seo_generator_license_key }}"
                      placeholder="DCSG-XXXXXXXXXXXXXXXX-YYYYYYYYYYYY"
                      id="input-license-key"
                      class="form-control">
                    <small class="form-text text-muted" style="margin-top: 5px;">
                      <i class="fa fa-info-circle"></i> localhost - {{ text_license_domain|default('License bound to domain') }}
                    </small>
                  </div>
                  <div class="col-sm-3">
                    <button type="button" class="btn btn-info" id="button-verify-license">
                      <i class="fa fa-check-circle"></i> {{ button_verify_license|default('Verify License') }}
                    </button>
                    <span id="license-status" style="margin-left: 10px;"></span>
                  </div>
                </div>

                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-public-key">
                    <span data-toggle="tooltip" title="{{ help_public_key|default('RSA Public Key for license verification. Provided by vendor.') }}">
                      {{ entry_public_key|default('Public Key') }}
                    </span>
                  </label>
                  <div class="col-sm-9">
                    <textarea
                      name="module_dockercart_seo_generator_public_key"
                      id="input-public-key"
                      rows="8"
                      class="form-control"
                      placeholder="-----BEGIN PUBLIC KEY-----&#10;...&#10;-----END PUBLIC KEY-----">{{ module_dockercart_seo_generator_public_key }}</textarea>
                    <small class="form-text text-muted" style="margin-top: 5px;">
                      <i class="fa fa-shield"></i> {{ help_public_key|default('This public key is used to verify license signatures. Get it from your vendor.') }}
                    </small>
                  </div>
                </div>

                <div id="license-info" class="form-group" style="display: none;">
                  <div class="col-sm-offset-3 col-sm-9">
                    <div class="alert alert-info">
                      <h4><i class="fa fa-info-circle"></i> {{ text_license|default('License Information') }}</h4>
                      <p id="license-details"></p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Статистика -->
            <div class="tab-pane" id="tab-statistics">
              <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
                <h4><i class="fa fa-chart-bar"></i> {{ tab_statistics }}</h4>
              </div>
              <div class="row">
                <div class="col-md-6">
                  <div class="panel panel-info">
                    <div class="panel-heading">{{ text_products_stats }}</div>
                    <div class="panel-body">
                      <table class="table">
                        <tr>
                          <td><strong>{{ text_total }}</strong></td>
                          <td class="text-right"><strong>{{ stats.products.total }}</strong></td>
                        </tr>
                        <tr>
                          <td>{{ text_empty_url }}</td>
                          <td class="text-right"><strong class="text-danger">{{ stats.products.empty_url }}</strong></td>
                        </tr>
                        <tr>
                          <td>{{ text_empty_meta }}</td>
                          <td class="text-right"><strong class="text-warning">{{ stats.products.empty_meta }}</strong></td>
                        </tr>
                      </table>
                      
                      <hr>
                      <h5>{{ text_by_languages|default('By Languages:') }}</h5>
                      <table class="table table-condensed">
                        {% for lang_id, lang_stats in stats.products.by_language %}
                        <tr>
                          <td><img src="language/{{ lang_stats.code }}/{{ lang_stats.code }}.png" /> {{ lang_stats.name }}</td>
                          <td class="text-right">
                            <span class="label label-danger">URL: {{ lang_stats.empty_url }}</span>
                            <span class="label label-warning">Meta: {{ lang_stats.empty_meta }}</span>
                          </td>
                        </tr>
                        {% endfor %}
                      </table>
                    </div>
                  </div>
                </div>
                
                <div class="col-md-6">
                  <div class="panel panel-success">
                    <div class="panel-heading">{{ text_categories_stats }}</div>
                    <div class="panel-body">
                      <table class="table">
                        <tr>
                          <td><strong>{{ text_total }}</strong></td>
                          <td class="text-right"><strong>{{ stats.categories.total }}</strong></td>
                        </tr>
                        <tr>
                          <td>{{ text_empty_url }}</td>
                          <td class="text-right"><strong class="text-danger">{{ stats.categories.empty_url }}</strong></td>
                        </tr>
                        <tr>
                          <td>{{ text_empty_meta }}</td>
                          <td class="text-right"><strong class="text-warning">{{ stats.categories.empty_meta }}</strong></td>
                        </tr>
                      </table>
                      
                      <hr>
                      <h5>{{ text_by_languages|default('By Languages:') }}</h5>
                      <table class="table table-condensed">
                        {% for lang_id, lang_stats in stats.categories.by_language %}
                        <tr>
                          <td><img src="language/{{ lang_stats.code }}/{{ lang_stats.code }}.png" /> {{ lang_stats.name }}</td>
                          <td class="text-right">
                            <span class="label label-danger">URL: {{ lang_stats.empty_url }}</span>
                            <span class="label label-warning">Meta: {{ lang_stats.empty_meta }}</span>
                          </td>
                        </tr>
                        {% endfor %}
                      </table>
                    </div>
                  </div>
                </div>
              </div>
              
              <div class="row">
                <div class="col-md-6">
                  <div class="panel panel-warning">
                    <div class="panel-heading">{{ text_manufacturers_stats }}</div>
                    <div class="panel-body">
                      <table class="table">
                        <tr>
                          <td><strong>{{ text_total }}</strong></td>
                          <td class="text-right"><strong>{{ stats.manufacturers.total }}</strong></td>
                        </tr>
                        <tr>
                          <td>{{ text_empty_url }}</td>
                          <td class="text-right"><strong class="text-danger">{{ stats.manufacturers.empty_url }}</strong></td>
                        </tr>
                      </table>
                      
                      <hr>
                      <h5>{{ text_by_languages|default('By Languages:') }}</h5>
                      <table class="table table-condensed">
                        {% for lang_id, lang_stats in stats.manufacturers.by_language %}
                        <tr>
                          <td><img src="language/{{ lang_stats.code }}/{{ lang_stats.code }}.png" /> {{ lang_stats.name }}</td>
                          <td class="text-right">
                            <span class="label label-danger">URL: {{ lang_stats.empty_url }}</span>
                          </td>
                        </tr>
                        {% endfor %}
                      </table>
                    </div>
                  </div>
                </div>
                
                <div class="col-md-6">
                  <div class="panel panel-primary">
                    <div class="panel-heading">{{ text_information_stats }}</div>
                    <div class="panel-body">
                      <table class="table">
                        <tr>
                          <td><strong>{{ text_total }}</strong></td>
                          <td class="text-right"><strong>{{ stats.information.total }}</strong></td>
                        </tr>
                        <tr>
                          <td>{{ text_empty_url }}</td>
                          <td class="text-right"><strong class="text-danger">{{ stats.information.empty_url }}</strong></td>
                        </tr>
                        <tr>
                          <td>{{ text_empty_meta }}</td>
                          <td class="text-right"><strong class="text-warning">{{ stats.information.empty_meta }}</strong></td>
                        </tr>
                      </table>
                      
                      <hr>
                      <h5>{{ text_by_languages|default('By Languages:') }}</h5>
                      <table class="table table-condensed">
                        {% for lang_id, lang_stats in stats.information.by_language %}
                        <tr>
                          <td><img src="language/{{ lang_stats.code }}/{{ lang_stats.code }}.png" /> {{ lang_stats.name }}</td>
                          <td class="text-right">
                            <span class="label label-danger">URL: {{ lang_stats.empty_url }}</span>
                            <span class="label label-warning">Meta: {{ lang_stats.empty_meta }}</span>
                          </td>
                        </tr>
                        {% endfor %}
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Товары -->
            <div class="tab-pane" id="tab-products">
              {{ product_entity_html|raw }}
            </div>
            
            <!-- Категории -->
            <div class="tab-pane" id="tab-categories">
              {{ category_entity_html|raw }}
            </div>
            
            <!-- Производители -->
            <div class="tab-pane" id="tab-manufacturers">
              {{ manufacturer_entity_html|raw }}
            </div>
            
            <!-- Информационные страницы -->
            <div class="tab-pane" id="tab-information">
              {{ information_entity_html|raw }}
            </div>
            
            <!-- Контроллеры -->
            <div class="tab-pane" id="tab-controllers">
              <div class="alert alert-info">
                <i class="fa fa-info-circle"></i> {{ help_controllers }}
              </div>
              
              <div class="well">
                <h4>{{ text_select_controllers }}</h4>
                
                <div class="form-group">
                  <div class="col-sm-12">
                    <button type="button" id="btn-scan-controllers" class="btn btn-primary">
                      <i class="fa fa-search"></i> {{ button_scan_controllers }}
                    </button>
                    <span class="help-block">
                      <i class="fa fa-info-circle"></i> {{ help_controllers }}
                    </span>
                  </div>
                </div>
                
                <div id="found-controllers-list" style="margin-top: 20px; display: none;">
                  <h5>{{ text_found_controllers }}</h5>
                  <p class="text-muted">
                    <i class="fa fa-info-circle"></i> {{ text_controllers_table_help }}
                  </p>
                  
                  <div class="form-group" style="margin-bottom: 15px;">
                    <button type="button" id="btn-generate-selected" class="btn btn-success" disabled>
                      <i class="fa fa-cogs"></i> {{ button_generate_selected }} (<span id="selected-count">0</span>)
                    </button>
                    <button type="button" id="btn-delete-selected" class="btn btn-danger" disabled>
                      <i class="fa fa-trash"></i> {{ button_delete_selected }} (<span id="selected-count-delete">0</span>)
                    </button>
                    <button type="button" id="btn-select-all" class="btn btn-default">
                      <i class="fa fa-check-square-o"></i> Select All
                    </button>
                    <button type="button" id="btn-deselect-all" class="btn btn-default">
                      <i class="fa fa-square-o"></i> Deselect All
                    </button>
                    <label style="margin-left: 20px; display: inline-block;">
                      <input type="checkbox" id="checkbox-overwrite-urls" />
                      {{ text_overwrite_url }}
                    </label>
                    <span class="help-block" style="margin: 5px 0 0 0;">
                      <i class="fa fa-info-circle"></i> {{ text_controllers_mass_help }}
                    </span>
                  </div>
                  
                  <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="controllers-table">
                      <thead>
                        <tr>
                          <th width="30" class="text-center">
                            <input type="checkbox" id="select-all-checkbox" />
                          </th>
                          <th width="200">{{ text_controller_route }}</th>
                          <th width="150">{{ text_controller_title }}</th>
                          {% for language in languages %}
                          <th>
                            <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }} URL
                          </th>
                          {% endfor %}
                          <th width="150">{{ text_actions }}</th>
                        </tr>
                      </thead>
                      <tbody id="controllers-tbody">
                        <!-- Filled by JS -->
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
              
              <div class="alert alert-info">
                <h4><i class="fa fa-lightbulb-o"></i> {{ text_how_to_use }}</h4>
                <ol>
                  <li>{{ text_how_to_use_1 }}</li>
                  <li>{{ text_how_to_use_2 }}</li>
                  <li>{{ text_how_to_use_3 }}</li>
                  <li>{{ text_how_to_use_4 }}</li>
                  <li>{{ text_how_to_use_5 }}</li>
                </ol>
              </div>
            </div>

            <div class="tab-pane" id="tab-about">
              <table class="table table-bordered dcx-table">
                 <tr>
                  <td><strong>{{ text_developer }}</strong></td>
                  <td>{{ text_developer_name }}</td>
                </tr>
                <tr>
                  <td><strong>{{ text_contact }}</strong></td>
                  <td><a href="mailto:support@dockercart.net">support@dockercart.net</a></td>
                </tr>
              </table>
            </div>
            
          </div>
        </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="view/javascript/dockercart_seo_generator.js"></script>
<script>
$(document).ready(function() {
  function updateSeoPanelHeader($tab) {
    var title = $tab.data('title') || '{{ tab_general }}';
    var subtitle = $tab.data('subtitle') || '{{ text_edit }}';
    var icon = String($tab.data('icon') || 'fa-sliders').replace(/[^a-z0-9\-]/gi, '');

    $('#seo-tab-title').text(title);
    $('#seo-tab-subtitle').text(subtitle);
    $('#seo-tab-icon').attr('class', 'fa ' + icon);
  }

  $('.js-seo-tab').on('shown.bs.tab', function() {
    updateSeoPanelHeader($(this));
  });

  updateSeoPanelHeader($('#seo-tabs li.active a.js-seo-tab'));

    DockercartSeoGenerator.init({
        user_token: '{{ user_token }}',
        languages: {{ languages|json_encode|raw }}
    });
});
</script>

{{ footer }}
