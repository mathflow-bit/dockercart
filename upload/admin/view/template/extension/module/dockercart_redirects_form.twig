{{ header }}{{ column_left }}
<div id="content">
  <link rel="stylesheet" href="view/stylesheet/dockercart_dcx_ui.css" />
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-redirect" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="dcx-shell">
      <div class="dcx-panel">
        <div class="dcx-panel-head">
          <div class="dcx-panel-head__icon"><i class="fa fa-pencil"></i></div>
          <div>
            <h3 class="dcx-panel-title">{{ text_form }}</h3>
            <div class="dcx-panel-subtitle">{{ heading_title }}</div>
          </div>
        </div>
        <div class="dcx-panel-body">
          <div class="dcx-section" style="margin-top:0;padding-top:0;border-top:0;">
            <form id="form-redirect" action="{{ action }}" method="post" class="form-horizontal dcx-form">
              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-old">{{ entry_old_url }}</label>
                <div class="col-sm-9">
                  <input type="text" name="old_url" value="{{ old_url }}" placeholder="{{ entry_old_url }}" id="input-old" class="form-control" />
                  {% if error_old_url %}
                  <div class="text-danger">{{ error_old_url }}</div>
                  {% endif %}
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-new">{{ entry_new_url }}</label>
                <div class="col-sm-9">
                  <input type="text" name="new_url" value="{{ new_url }}" placeholder="{{ entry_new_url }}" id="input-new" class="form-control" />
                  {% if error_new_url %}
                  <div class="text-danger">{{ error_new_url }}</div>
                  {% endif %}
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-code">{{ entry_code }}</label>
                <div class="col-sm-9">
                  <select name="code" id="input-code" class="form-control">
                    {% for key, text in redirect_codes %}
                    <option value="{{ key }}" {% if (code ~ '') == (key ~ '') %}selected{% endif %}>{{ text }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
                <div class="col-sm-9">
                  <select name="status" id="input-status" class="form-control">
                    <option value="1" {% if status == '1' or status == 1 %}selected{% endif %}>{{ text_enabled }}</option>
                    <option value="0" {% if status == '0' or status == 0 %}selected{% endif %}>{{ text_disabled }}</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-is-regex">{{ entry_is_regex }}</label>
                <div class="col-sm-9">
                  <select name="is_regex" id="input-is-regex" class="form-control">
                    <option value="1" {% if is_regex %}selected{% endif %}>{{ text_yes }}</option>
                    <option value="0" {% if not is_regex %}selected{% endif %}>{{ text_no }}</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label" for="input-preserve-query">{{ entry_preserve_query }}</label>
                <div class="col-sm-9">
                  <select name="preserve_query" id="input-preserve-query" class="form-control">
                    <option value="1" {% if preserve_query %}selected{% endif %}>{{ text_yes }}</option>
                    <option value="0" {% if not preserve_query %}selected{% endif %}>{{ text_no }}</option>
                  </select>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{{ footer }}
