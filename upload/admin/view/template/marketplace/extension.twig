{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-puzzle-piece"></i> {{ text_list }}</h3>
      </div>
      <div class="panel-body">
        <fieldset>
          <legend>{{ text_type }}</legend>
					<div class="well">
						<div class="row">
							<div class="col-sm-12">
								<div class="btn-group btn-group-sm" role="group" aria-label="Extension types">
									{% for category in categories %}
									<a href="{{ category.href }}" class="btn btn-default extension-type-btn {% if type == category.code %}btn-primary active{% endif %}">{{ category.text }}</a>
									{% endfor %}
								</div>
							</div>
						</div>
					</div>
        </fieldset>
        <div id="extension"></div>
      </div>
    </div>
  </div>
  {% if categories %}
  <script type="text/javascript"><!--
$('.extension-type-btn').on('click', function(e) {
	e.preventDefault();

	var btn = $(this);

	$.ajax({
		url: btn.attr('href'),
		dataType: 'html',
		beforeSend: function() {
			$('.fa-filter').addClass('fa-circle-o-notch fa-spin');
			$('.fa-filter').removeClass('fa-filter');
			$('.extension-type-btn').prop('disabled', true);
		},
		complete: function() {
			$('.fa-circle-o-notch').addClass('fa-filter');
			$('.fa-circle-o-notch').removeClass('fa-circle-o-notch fa-spin');
			$('.extension-type-btn').prop('disabled', false);
		},
		success: function(html) {
			$('#extension').html(html);
			// update active button
			$('.extension-type-btn').removeClass('btn-primary active').addClass('btn-default');
			btn.removeClass('btn-default').addClass('btn-primary active');
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
});

// Trigger initial load: click active button or first button
if ($('.extension-type-btn.active').length) {
	$('.extension-type-btn.active').trigger('click');
} else {
	$('.extension-type-btn:first').trigger('click');
}

$('#extension').on('click', '.btn-success', function(e) {
	e.preventDefault();
	
	var element = this;

	$.ajax({
		url: $(element).attr('href'),
		dataType: 'html',
		beforeSend: function() {
			$(element).button('loading');
		},
		complete: function() {
			$(element).button('reset');
		},
		success: function(html) {
			$('#extension').html(html);
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
});

$('#extension').on('click', '.btn-danger, .btn-warning', function(e) {
	e.preventDefault();
	
	if (confirm('{{ text_confirm }}')) {
		var element = this;
	
		$.ajax({
			url: $(element).attr('href'),
			dataType: 'html',
			beforeSend: function() {
				$(element).button('loading');
			},
			complete: function() {
				$(element).button('reset');
			},
			success: function(html) {
				// refresh menu and extension list
				$.ajax({
					url: 'index.php?route=marketplace/extension/refreshMenu&user_token={{ user_token }}',
					dataType: 'html',
					success: function(html) {
						if (html) {
							$('#column-left').replaceWith(html);
						}
					},
					complete: function() {
						// refresh extension list by reloading the currently active type
						if ($('.extension-type-btn.active').length) {
							$('.extension-type-btn.active').trigger('click');
						} else {
							$('.extension-type-btn:first').trigger('click');
						}
					},
					error: function(xhr, ajaxOptions, thrownError) {
						alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
					}
				});
			},
			error: function(xhr, ajaxOptions, thrownError) {
				alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
			}
		});
	}
});
//--></script>
  {% endif %}
</div>
{{ footer }} 