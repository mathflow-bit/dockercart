  };

  var inlineRecalcTimer = null;
  var inlineDiscountPreviewTimer = null;

  function htmlDecode(value) {
    return $('<textarea/>').html(value || '').text();
  }

  function parseApiError(error) {
    if (typeof error === 'string') {
      return error;
    }

    if (error && typeof error === 'object') {
      if (error.warning) {
        return error.warning;
      }

      var messages = [];

      for (var key in error) {
        if (error.hasOwnProperty(key) && typeof error[key] === 'string') {
          messages.push(error[key]);
        }
      }

      if (messages.length) {
        return messages.join('<br/>');
      }
    }

    return '{{ error_warning|escape('js') }}';
  }

  function quickCountryOptions(selectedId) {
    var html = '<option value="">{{ text_select }}</option>';

    for (var i = 0; i < quickCountries.length; i++) {
      var country = quickCountries[i];
      html += '<option value="' + country.country_id + '"' + (String(country.country_id) === String(selectedId) ? ' selected="selected"' : '') + '>' + country.name + '</option>';
    }

    return html;
  }

  function quickLoadZones(countryId, selectedZoneId) {
    $.ajax({
      url: 'index.php?route=localisation/country/country&user_token={{ user_token }}&country_id=' + countryId,
      dataType: 'json',
      success: function(json) {
        var html = '<option value="">{{ text_select }}</option>';

        if (json['zone'] && json['zone'].length) {
          for (var i = 0; i < json['zone'].length; i++) {
            var zone = json['zone'][i];
            html += '<option value="' + zone.zone_id + '"' + (String(zone.zone_id) === String(selectedZoneId) ? ' selected="selected"' : '') + '>' + zone.name + '</option>';
          }
        } else {
          html += '<option value="0" selected="selected">{{ text_none }}</option>';
        }

        $('#quick-edit-zone').html(html);
      }
    });
  }

  function quickLoadApiMethodOptions(field, selectedCode) {
    $('#quick-edit-method').html('<option value="">{{ text_loading }}</option>');

    if (field === 'payment_method') {
      inlineSyncApiCartFromCurrentTable().then(function() {
        return inlineApiRequest({
        url: '{{ catalog }}index.php?route=api/payment/address&api_token={{ api_token }}&store_id={{ store_id }}',
        type: 'post',
        data: $.param(inlineState.payment)
        });
      }).then(function() {
        return inlineApiRequest({
          url: '{{ catalog }}index.php?route=api/payment/methods&api_token={{ api_token }}&store_id={{ store_id }}'
        });
      }).done(function(json) {
        var html = '<option value="">{{ text_select }}</option>';
        var hasOptions = false;

        if (json.payment_methods) {
          for (var i in json.payment_methods) {
            html += '<option value="' + json.payment_methods[i].code + '"' + (String(json.payment_methods[i].code) === String(selectedCode) ? ' selected="selected"' : '') + '>' + json.payment_methods[i].title + '</option>';
            hasOptions = true;
          }
        }

        if (!hasOptions && selectedCode) {
          html += '<option value="' + selectedCode + '" selected="selected">' + (inlineState.payment_method || selectedCode) + '</option>';
        }

        $('#quick-edit-method').html(html);
      }).fail(function(error) {
        $('#quick-edit-method').html('<option value="">{{ text_select }}</option>');
        showInlineAlert('danger', parseApiError(error));
      });
    }

    if (field === 'shipping_method') {
      inlineSyncApiCartFromCurrentTable().then(function() {
        return inlineApiRequest({
        url: '{{ catalog }}index.php?route=api/shipping/address&api_token={{ api_token }}&store_id={{ store_id }}',
        type: 'post',
        data: $.param(inlineState.shipping)
        });
      }).then(function() {
        return inlineApiRequest({
          url: '{{ catalog }}index.php?route=api/shipping/methods&api_token={{ api_token }}&store_id={{ store_id }}'
        });
      }).done(function(json) {
        var html = '<option value="">{{ text_select }}</option>';
        var hasOptions = false;

        if (json.shipping_methods) {
          for (var i in json.shipping_methods) {
            if (!json.shipping_methods[i].error && json.shipping_methods[i].quote) {
              for (var j in json.shipping_methods[i].quote) {
                var quote = json.shipping_methods[i].quote[j];
                html += '<option value="' + quote.code + '"' + (String(quote.code) === String(selectedCode) ? ' selected="selected"' : '') + '>' + quote.title + ' - ' + quote.text + '</option>';
                hasOptions = true;
              }
            }
          }
        }

        if (!hasOptions && selectedCode) {
          html += '<option value="' + selectedCode + '" selected="selected">' + (inlineState.shipping_method || selectedCode) + '</option>';
        }

        $('#quick-edit-method').html(html);
      }).fail(function(error) {
        $('#quick-edit-method').html('<option value="">{{ text_select }}</option>');
        showInlineAlert('danger', parseApiError(error));
      });
    }
  }

  function inlineApiRequest(options) {
    var deferred = $.Deferred();

    $.ajax($.extend({
      dataType: 'json',
      crossDomain: true,
      type: 'get'
    }, options)).done(function(json) {
      if (json && json['error']) {
        deferred.reject(json['error']);
      } else {
        deferred.resolve(json || {});
      }
    }).fail(function(xhr, ajaxOptions, thrownError) {
      deferred.reject(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
    });

    return deferred.promise();
  }

  function inlineSyncApiCartFromCurrentTable() {
    var cartData = $('#inline-cart input[name^=\'product\'][type=\'text\'], #inline-cart input[name^=\'product\'][type=\'hidden\'], #inline-cart input[name^=\'product\'][type=\'radio\']:checked, #inline-cart input[name^=\'product\'][type=\'checkbox\']:checked, #inline-cart select[name^=\'product\'], #inline-cart textarea[name^=\'product\']').serialize();

    if (!cartData) {
      return $.Deferred().resolve().promise();
    }

    return inlineApiRequest({
      url: '{{ catalog }}index.php?route=api/cart/add&api_token={{ api_token }}&store_id={{ store_id }}',
      type: 'post',
      data: cartData
    });
  }

  function showInlineAlert(type, text) {
