      skipCartReplace: true,
      couponCode: $('#input-inline-coupon').val(),
      applyDiscountPreview: false
    });
  }

  function inlineRenderCartFromApi(json, discounts) {
    discounts = discounts || [];

    var productsHtml = '';

    if (json['products'] && json['products'].length) {
      for (var i = 0; i < json['products'].length; i++) {
        var product = json['products'][i];
        var productHref = 'index.php?route=catalog/product/edit&user_token={{ user_token }}&product_id=' + product['product_id'];
        var productThumb = '';

        if (product['thumb']) {
          productThumb = '<a href="' + productHref + '" class="inline-product-thumb"><img src="' + product['thumb'] + '" alt="" class="img-thumbnail" style="width:40px;height:40px;object-fit:cover;margin-right:8px;vertical-align:middle;" /></a>';
        }

        productsHtml += '<tr>';
        productsHtml += '  <td class="text-left">' + productThumb + '<a href="' + productHref + '">' + product['name'] + '</a><input type="hidden" name="product[' + i + '][product_id]" value="' + product['product_id'] + '" />';

        if (product['option']) {
          for (var j = 0; j < product['option'].length; j++) {
            var option = product['option'][j];
            productsHtml += '<br /><small>- ' + option['name'] + ': ' + option['value'] + '</small>';

            if (option['type'] == 'select' || option['type'] == 'radio' || option['type'] == 'image') {
              productsHtml += '<input type="hidden" name="product[' + i + '][option][' + option['product_option_id'] + ']" value="' + option['product_option_value_id'] + '" />';
            }

            if (option['type'] == 'checkbox') {
              productsHtml += '<input type="hidden" name="product[' + i + '][option][' + option['product_option_id'] + '][]" value="' + option['product_option_value_id'] + '" />';
            }

            if (option['type'] == 'text' || option['type'] == 'textarea' || option['type'] == 'file' || option['type'] == 'date' || option['type'] == 'datetime' || option['type'] == 'time') {
              productsHtml += '<input type="hidden" name="product[' + i + '][option][' + option['product_option_id'] + ']" value="' + option['value'] + '" />';
            }
          }
        }

        productsHtml += '  </td>';
        productsHtml += '  <td class="text-left">' + product['model'] + '</td>';
        productsHtml += '  <td class="text-right" style="max-width: 120px;"><input type="text" name="product[' + i + '][quantity]" value="' + product['quantity'] + '" class="form-control text-right gt-no-translate" data-gt-inline-ignore="1" /></td>';
        productsHtml += '  <td class="text-right" style="max-width: 100px;"><input type="text" name="product[' + i + '][discount]" value="' + (discounts[i] !== undefined ? discounts[i] : 0) + '" class="form-control text-right gt-no-translate" data-gt-inline-ignore="1" /></td>';
        productsHtml += '  <td class="text-right">' + product['price'] + '</td>';
        productsHtml += '  <td class="text-right">' + product['total'] + '</td>';
        productsHtml += '  <td class="text-right"><button type="button" class="btn btn-danger btn-xs button-inline-remove-item"><i class="fa fa-trash"></i></button></td>';
        productsHtml += '</tr>';
      }
    }

    if (json['vouchers'] && json['vouchers'].length) {
      for (var v = 0; v < json['vouchers'].length; v++) {
        var voucher = json['vouchers'][v];
        productsHtml += '<tr>';
        productsHtml += '  <td class="text-left">' + voucher['description'] + '</td>';
        productsHtml += '  <td class="text-left"></td>';
        productsHtml += '  <td class="text-right">1</td>';
        productsHtml += '  <td class="text-right"></td>';
        productsHtml += '  <td class="text-right">' + voucher['price'] + '</td>';
        productsHtml += '  <td class="text-right">' + voucher['price'] + '</td>';
        productsHtml += '  <td class="text-right"></td>';
        productsHtml += '</tr>';
      }
    }

    if (!productsHtml) {
      productsHtml = '<tr class="inline-cart-empty"><td colspan="7" class="text-center">{{ text_no_results }}</td></tr>';
    }

    $('#inline-cart').html(productsHtml);
    inlineReindexCartRows();

    var totalsHtml = '';

    if (json['totals'] && json['totals'].length) {
      for (var t = 0; t < json['totals'].length; t++) {
        totalsHtml += '<tr><td colspan="6" class="text-right">' + json['totals'][t]['title'] + '</td><td class="text-right">' + json['totals'][t]['text'] + '</td></tr>';
      }
    }

    $('#inline-totals').html(totalsHtml);
  }

  function inlineSyncCheckoutContext(couponCode) {
    return inlineApiRequest({
      url: '{{ catalog }}index.php?route=api/payment/address&api_token={{ api_token }}&store_id={{ store_id }}',
      type: 'post',
      data: $.param(inlineState.payment)
    }).then(function() {
      return inlineApiRequest({
        url: '{{ catalog }}index.php?route=api/payment/methods&api_token={{ api_token }}&store_id={{ store_id }}'
      });
    }).then(function() {
      if (inlineState.payment_code) {
        return inlineApiRequest({
          url: '{{ catalog }}index.php?route=api/payment/method&api_token={{ api_token }}&store_id={{ store_id }}',
          type: 'post',
          data: 'payment_method=' + encodeURIComponent(inlineState.payment_code)
        });
      }

      return $.Deferred().resolve().promise();
    }).then(function() {
      if (!inlineState.has_shipping) {
        return $.Deferred().resolve().promise();
      }

      return inlineApiRequest({
        url: '{{ catalog }}index.php?route=api/shipping/address&api_token={{ api_token }}&store_id={{ store_id }}',
        type: 'post',
        data: $.param(inlineState.shipping)
      }).then(function() {
        return inlineApiRequest({
          url: '{{ catalog }}index.php?route=api/shipping/methods&api_token={{ api_token }}&store_id={{ store_id }}'
        });
      }).then(function() {
        if (inlineState.shipping_code) {
          return inlineApiRequest({
            url: '{{ catalog }}index.php?route=api/shipping/method&api_token={{ api_token }}&store_id={{ store_id }}',
            type: 'post',
            data: 'shipping_method=' + encodeURIComponent(inlineState.shipping_code)
          });
        }

        return $.Deferred().resolve().promise();
      });
    }).then(function() {
      if (couponCode) {
        return inlineApiRequest({
          url: '{{ catalog }}index.php?route=api/coupon&api_token={{ api_token }}&store_id={{ store_id }}',
          type: 'post',
          data: 'coupon=' + encodeURIComponent(couponCode)
        });
      }

      return $.Deferred().resolve().promise();
    });
  }

  function inlineRecalculateCartPreview(showSuccess, options) {
    options = options || {};

    var skipCartReplace = options.skipCartReplace ? true : false;
    var applyDiscountPreview = options.applyDiscountPreview ? true : false;
    var couponCode = options.couponCode !== undefined ? options.couponCode : $('#input-inline-coupon').val();
    var discounts = inlineCollectDiscounts();
    var cartData = $('#inline-cart input[name^=\'product\'][type=\'text\'], #inline-cart input[name^=\'product\'][type=\'hidden\'], #inline-cart input[name^=\'product\'][type=\'radio\']:checked, #inline-cart input[name^=\'product\'][type=\'checkbox\']:checked, #inline-cart select[name^=\'product\'], #inline-cart textarea[name^=\'product\']').serialize();

    if (!cartData && !skipCartReplace) {
      $('#inline-totals').html('');
      return $.Deferred().resolve({ products: [], totals: [] }).promise();
    }

    var chain = $.Deferred().resolve().promise();

    if (!skipCartReplace) {
      chain = chain.then(function() {
        return inlineApiRequest({
          url: '{{ catalog }}index.php?route=api/cart/add&api_token={{ api_token }}&store_id={{ store_id }}',
          type: 'post',
          data: cartData
        });
      });
    }

    return chain.then(function() {
      return inlineSyncCheckoutContext(couponCode);
    }).then(function() {
      return inlineApiRequest({
        url: '{{ catalog }}index.php?route=api/cart/products&api_token={{ api_token }}&store_id={{ store_id }}',
        type: 'post',
        data: $.param({ discount: discounts })
      });
    }).done(function(json) {
      if (json.error && (json.error.warning || json.error.minimum || json.error.stock)) {
        showInlineAlert('danger', parseApiError(json.error));
      }

      inlineRenderCartFromApi(json, discounts);

      if (applyDiscountPreview) {
        inlineRequestDiscountPreview();
      }

      if (showSuccess) {
        showInlineAlert('success', '{{ text_success|escape('js') }}');
      }
    });
  }

  function inlinePersistOrderChanges(options) {
    options = options || {};

    var reloadOnSuccess = options.reloadOnSuccess ? true : false;
    var showSuccess = options.showSuccess === undefined ? true : options.showSuccess;
    var coupon = $('#input-inline-coupon').val();
    var discounts = inlineCollectDiscounts();

    return inlineRecalculateCartPreview(false, {
      couponCode: coupon,
      applyDiscountPreview: false
    }).then(function() {
      return inlineApiRequest({
        url: '{{ catalog }}index.php?route=api/customer&api_token={{ api_token }}&store_id={{ store_id }}',
        type: 'post',
        data: $.param(inlineState.customer)
      });
    }).then(function() {
      return inlineSyncCheckoutContext(coupon);
    }).then(function() {
      var orderData = 'comment=' + encodeURIComponent(inlineState.comment) + '&affiliate_id={{ affiliate_id|e('js') }}&skip_history=1';

      if (inlineState.payment_code) {
        orderData += '&payment_method=' + encodeURIComponent(inlineState.payment_code);
      }

      if (inlineState.has_shipping && inlineState.shipping_code) {
        orderData += '&shipping_method=' + encodeURIComponent(inlineState.shipping_code);
      }

      return inlineApiRequest({
        url: '{{ catalog }}index.php?route=api/order/edit&api_token={{ api_token }}&store_id={{ store_id }}&order_id={{ order_id }}',
        type: 'post',
        data: orderData
      });
    }).then(function() {
      return $.ajax({
        url: 'index.php?route=sale/order/applyLineDiscounts&user_token={{ user_token }}&order_id={{ order_id }}',
        type: 'post',
        dataType: 'json',
        data: {
          discount: discounts
        }
      });
    }).then(function() {
      return inlineRequestDiscountPreview();
    }).done(function() {
      if (showSuccess) {
        showInlineAlert('success', '{{ text_success|escape('js') }}');
      }

      if (reloadOnSuccess) {
        location.reload();
      }
    });
  }

