            inlineState.payment_method = payload.title;
            $('.btn-quick-edit[data-field="payment_method"]').data('value', payload.title).data('code', payload.code);
          }

          if (quickEditState.field === 'shipping_method') {
            inlineState.shipping_code = payload.code;
            inlineState.shipping_method = payload.title;
            $('.btn-quick-edit[data-field="shipping_method"]').data('value', payload.title).data('code', payload.code);
          }

          if (quickEditState.field === 'payment_address') {
            inlineState.payment = {
              firstname: payload.firstname,
              lastname: payload.lastname,
              company: payload.company,
              address_1: payload.address_1,
              address_2: payload.address_2,
              city: payload.city,
              postcode: payload.postcode,
              country_id: payload.country_id,
              zone_id: payload.zone_id
            };
          }

          if (quickEditState.field === 'shipping_address') {
            inlineState.shipping = {
              firstname: payload.firstname,
              lastname: payload.lastname,
              company: payload.company,
              address_1: payload.address_1,
