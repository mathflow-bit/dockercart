  function inlineCollectDiscounts() {
    var discounts = [];

    $('#inline-cart tr').not('.inline-cart-empty').each(function() {
      var $row = $(this);
      var $productIdInput = $row.find('input[name$="[product_id]"]');

      if (!$productIdInput.length) {
        return;
      }

      var $discountInput = $row.find('input[name$="[discount]"]');
      var value = parseFloat($discountInput.val());

      if (!$discountInput.length) {
        value = 0;
      }

      if (isNaN(value) || value < 0) {
        value = 0;
      }

      if (value > 100) {
        value = 100;
      }

      if ($discountInput.length) {
        $discountInput.val(value);
      }

      discounts.push(value);
    });

    return discounts;
  }

