    $('#content > .container-fluid').prepend('<div class="alert alert-' + type + ' alert-dismissible"><i class="fa ' + (type === 'danger' ? 'fa-exclamation-circle' : 'fa-check-circle') + '"></i> ' + text + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
  }

  function inlineReindexCartRows() {
    $('#inline-cart tr').not('.inline-cart-empty').each(function(index) {
      $(this).find('input, select, textarea').each(function() {
        var name = $(this).attr('name');

        if (name && name.indexOf('product[') === 0) {
          $(this).attr('name', name.replace(/product\[\d+\]/, 'product[' + index + ']'));
        }
      });
    });
  }

