            inlineState.customer.firstname = payload.firstname;
            inlineState.customer.lastname = payload.lastname;
          }

          if (quickEditState.field === 'email') {
            inlineState.customer.email = payload.value;
            $('.btn-quick-edit[data-field="email"]').data('value', payload.value);
